 Linsen sollten nun fertig gegart sein. Den sirupartigen Balsamico Essig zu den Linsen geben und vorsichtig unterrühren, mit Salz und Pfeffer abschmecken. Sollten die Entenbrust Filets noch nicht fertig sein, so hält man die Linsen in einem Topf im Ofen noch warm. Kurz vor dem Servieren Schnittlauch in feine Röllchen schneiden und unter die Linsen heben"},{s:6,n:"Anrichten",d:"Letztendlich werden zum Anrichten zuerst die Linsen mit einem Löffel auf den Teller gegeben. Die Entenbrustfilet mit groben Meersalz kräftig würzen, schräg in 1 cm breite Stücke schneiden und auf den Linsen servieren. Zu diesem Gericht eignet sich noch der Spargel Erdbeer Salat."}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Geflügel"]}],Ae={Geflügel:{icon:"🐔",color:"#f59e0b",img:"chicken,dish,food"},Fleisch:{icon:"🥩",color:"#ef4444",img:"meat,steak,dish"},"Fisch & Meeresfrüchte":{icon:"🐟",color:"#06b6d4",img:"fish,seafood,plate"},"Pasta & Nudeln":{icon:"🍝",color:"#f97316",img:"pasta,noodles,italian"},"Suppen & Eintöpfe":{icon:"🍲",color:"#84cc16",img:"soup,stew,bowl"},Salate:{icon:"🥗",color:"#22c55e",img:"salad,vegetables,fresh"},Vegetarisch:{icon:"🥦",color:"#10b981",img:"vegetarian,vegetables,healthy"},Asiatisch:{icon:"🥢",color:"#8b5cf6",img:"asian,wok,stirfry"},"Backen & Desserts":{icon:"🎂",color:"#ec4899",img:"cake,dessert,baking"},"Frühstück & Eier":{icon:"🍳",color:"#eab308",img:"breakfast,eggs,morning"},"Sandwiches & Snacks":{icon:"🥪",color:"#64748b",img:"sandwich,snack,food"},"Grillen & Marinaden":{icon:"🔥",color:"#dc2626",img:"grilled,bbq,meat"},Sonstiges:{icon:"🍴",color:"#94a3b8",img:"food,dish,meal"}},Ah=Object.keys(Ae);function ni(e){if(!e)return null;const[n,i]=e.split(":").map(Number);return n>0&&i>0?n+"h "+i+"min":n>0?n+"h":i>0?i+" min":null}function Ns({recipe:e,style:n}){const[i,t]=Z.useState(!1),r=(e.cats||["Sonstiges"])[0],a=Ae[r]||Ae.Sonstiges,l=`https://source.unsplash.com/${e.id%100}/400x260/?${a.img}`;return i?d.jsx("div",{style:{...n,background:a.color+"22",display:"flex",a