    `,document.head.appendChild(n)},[]),null}const $l=[{id:1539,t:"Kirschkuchen",i:[{n:"Butter",u:"g",a:"250"},{n:"Gläser Sauerkirschen",u:"Stk",a:"3"},{n:"Tassen Zucker",u:"Stk",a:"2"},{n:"Tassen Mehl",u:"Stk",a:"4"},{n:"Päckchen Backpulver",u:"Stk",a:"1"},{n:"Salz",u:"Prise",a:"1"},{n:"Zimt",u:"Tl",a:"1"},{n:"Ei",u:"Stk",a:"1"},{n:"Tasse gehackte Mandeln",u:"Stk",a:"1"}],st:[{s:1,n:"Teig zubereiten",d:"Die Butter schmelzen. Sauerkirschen in einem Sieb abtropfen lassen. Zucker, Mehl, Backpulver, Salz und Zimt verrühren. Butter und das Ei zugeben."},{s:2,n:"Streusel kneten",d:"Mit den Knethaken des Handrührers zu Streusel verarbeiten."},{s:3,n:"Backblech vorbereiten und Teig verteilen",d:"Ein Backblech mit Backpapier belegen, die Hälfte des Streusels daraufgeben und andrücken."},{s:4,n:"mit Kirschen belegen",d:"Kirschen darauf verteilen, übrigen Streusel sowie Mandeln darüberstreuen."},{s:5,n:"Ab in den Ofen",d:"Im vorgeheizten Backofen 25 - 35 Minuten backen. (E-Herd: 200 Grad.)"},{s:6,n:"Tipp",d:"Wenn man den Kuchen ca. 1 Tag abgedeckt stehen lässt, dann wird der Teig noch ein wenig feucht und schmeckt danach noch besser. Guten Appetit:-)"}],p:"00:15",c:"00:35",tot:60,srv:"4",cats:["Backen & Desserts"]},{id:1553,t:"Huhnerschnetzeltes Auf Basmatireis",i:[{n:"Hühnerbrustfilet",u:"kg",a:"1"},{n:"Reis",u:"",a:""},{n:"Champignons",u:"g",a:"250"},{n:"Sahne",u:"ml",a:"200"},{n:"Milch",u:"",a:""},{n:"Zitrone",u:"",a:""},{n:"Petersilie",u:"Bd",a:"1"},{n:"Salz/Pfeffer",u:"",a:""},{n:"(Currypulver+ 1Tl Currypaste)",u:"",a:""},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Reiswein",u:"ml",a:"100"}],st:[{s:1,n:"Reis zubereiten",d:"Den Basmatireis in einem Sieb unter klarem Wasser gut abspülen, um den Reis-Staub abzuwaschen. Den Reis nun in einen Topf geben, mit warmem Wasser leicht bedecken und mit Salz würzen. Alles zusammen ca. 15 min. ziehen lassen. Danach Reis zum Kochen bringen. Sobald es kocht und ein Großteil des Wassers verdunstet ist, Herd auf die kleinste Stufe stellen, Butter hinzugeben und nochmals ca. 15 min langsam ziehen lassen."},{s:2,n:"Hühnerbrust vorbereiten und Gemüse putzen",d:"Die Hühnerbrust mit kalten Wasser abwaschen und mit Küchenpapier trocken tupfen. Danach in kleine Stücke schneiden. Die Champignons putzen, vom Stiel das braune Ende abscheiden und den Rest in schmale Scheiben schneiden. Nun die Zwiebel klein schneiden."},{s:3,n:"Curry-Sahnesoße zubereiten",d:"In eine Schüssel mit hohem Rand Sahne, Milch, Currypaste, Currypulver, Salz und Pfeffer hineingeben und verrühren."},{s:4,n:"Fleisch anbraten und würzen",d:"In einer Pfanne oder in einem großem Topf Butter mit Öl erhitzen. Das Fleisch portionsweise hineingeben. Nicht alles mit einem Mal hineinlegen, da sonst zu viel Bratensaft austreten würde und das Fleisch nicht brät, sondern kocht. Während das Fleisch gebraten wird, darf es bereits dezent mit Salz und Pfeffer gewürzt werden. Geschnetzelte herausnehmen und in einer Schüssel zur Seite stellen."},{s:5,n:"Gemüse anbraten",d:"Pilze und Zwiebeln anbraten. Nach ca. 5 min das Fleisch mit dem Bratensaft hinzugegeben und 0,1 ml Reiswein intensiv einkochen."},{s:6,n:"Curry-Sahnesoße hinzufügen",d:'Über das Fleisch und die Pilze etwas Mehl sowie ein wenig Currypulver streuen. Das Ganze verrühren und Wasser sowie später Sahne "“ Milch "“ Soße hinzufügen. Nach Geschmack noch einmal mit Salz und Pfeffer würzen'},{s:7,n:"Gericht verfeinern",d:"Kurz vor dem Schluss etwas Zitronenschale hinein reiben sowie kleingehackte Petersilie untermischen."}],p:"00:15",c:"00:30",tot:60,srv:"4');",cats:["Geflügel"]},{id:1558,t:"Hahnchenschenkel Auf Gemuse In Einer Wurzigen Paprikamarinade",i:[{n:"Hähnchenschenkel",u:"Stk",a:"10"},{n:"Paprika",u:"Stk",a:"1"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"kleine Zucchini",u:"Stk",a:"2"},{n:"kleine Kartoffeln",u:"g",a:"500"},{n:"Meersalz/Pfeffer",u:"",a:""},{n:"Paprika (edelsüss)",u:"Stk",a:"2"},{n:"Rosmarin",u:"Zweige",a:"5"}],st:[{s:1,n:"Hähnchenschenkel vorbereiten",d:"Der Ofen sollte auf 200 Grad vorgeheizt werden. Die Hähnchenschenkel werden gewaschen und mit dem Küchenpapier abgetrocknet. Die Hähnchenschenkel von allen Seiten gut einreiben."},{s:2,n:"Kartoffelecken vorbereiten und würzen",d:"Die kleinen Kartoffeln ordentlich waschen, trocknen und halbieren. In einer kleinen Schüssel wird das Paprikapulver, Salz und der Pfeffer vermischt."},{s:3,n:"Rauf auf´s Backblech",d:"Nun wird ein Backblech mit Backpapier ausgelegt. Grobes Meersalz verteilt und die Kartoffeln darauf. Rosmarin drüber. Man kann nun die Schenkel auf den Kartoffeln verteilen. Ich jedoch bevorzuge eher die Variante, daß ein Gitter über das Blech und die Schenkel darauf gelegt werden. Dies hat den Vorteil, daß die Hähnchenschenkel aufgrund des austretenden Saftes nicht labrig sondern schön knusprig werden. Der Bratensaft tröfpelt zudem noch auf das Gemüse, was noch zusätzlich einen schmackhaften Effekt hat."},{s:4,n:"Gemüse vorbereiten",d:"Währenddessen werden die Kirschtomaten gewaschen und halbiert. Die Paprika und die Zucchini in dünne Streifen geschnitten."},{s:5,n:"Gemüse auf´s Backblech",d:"Nach ca. 30 min. wird das Gemüse auf dem Backblech verteilt und in der Folgezeit immer mal wieder mit dem Bratensaft übergossen. Die Hähnchenschenkel dürfen auch gern gewendet und mit dem Bratensaft beträufelt werden. Nach ca. 45-60 min sollte das Essen fertig sein. (abhänging von Ofen zu Ofen)"}],p:"00:20",c:"1:00",tot:80,srv:"4",cats:["Geflügel","Grillen & Marinaden"]},{id:1570,t:"Gemusesalat Mit Krauterbutterbaguette",i:[{n:"Gurke",u:"Stk",a:"1"},{n:"gr. Tomaten",u:"Stk",a:"4"},{n:"Paprika",u:"Stk",a:"1"},{n:"Mais",u:"Dose",a:"1"},{n:"Radieschen",u:"Bd",a:"1"},{n:"Fetakäse",u:"Pck",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Öl (kein Olivenöl!)",u:"",a:""},{n:"Zitronensaft",u:"",a:""},{n:"Zucker",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""},{n:"Baguette",u:"",a:""},{n:"Kräuterbutter",u:"",a:""}],st:[{s:1,n:"Vinaigrette zubereiten",d:"Zwiebel kleinscheiden. Zusammen mit Öl, Salz, Pfeffer, Zucker und Zitronensaft in einer Schüssel gut vermengen."},{s:2,n:"Gemüse kleinschneiden",d:"Nun wird das Gemüse (Gurke, Tomaten, Paprika und Radieschen) abgewaschen und kleingeschnitten. Die Größe der Stücke kann variieren. Jeder mag es eben anders."},{s:3,n:"Mais unterheben",d:"Eine Dose Mais in ein Sieb gegeben und ggfs. noch mit klarem Wasser in abgespült. Ich haben den Maissaft ungern im Salat. Alles in die Schüssel und schön vermengen."},{s:4,n:"Fetakäse hinzugeben und abschmecken",d:"Den Fetakäse an der schmalen Seite halbieren und beide Hälften in kleine Würfel schneiden. Wer Fetakäse nicht mag, kann diesen auch gern weglassen. Zum Schluss mit Salz Pfeffer und ggfs. Zitrone abschmecken."},{s:5,n:"Kräuterbutter auf Baguette auftragen",d:"Baguette der Länge nach aufschneiden und Kräuterbutter auftragen. Den Ofen auf 180 Grad vorheizen."},{s:6,n:"Baguette in den Ofen geben",d:"Das Kräuterbutterbaguette ca. 5 Minuten im Ofen goldbraun backen."}],p:"00:30",c:"00:10",tot:45,srv:"6",cats:["Salate"]},{id:1572,t:"Knusprige Nudelnester",i:[{n:"Spaghetti",u:"g",a:"300"},{n:"Eiertomaten",u:"g",a:"500"},{n:"Rucola",u:"g",a:"100"},{n:"gekochter Schinken",u:"g",a:"150"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Fontina",u:"g",a:"250"},{n:"Olivenöl",u:"El",a:"1"},{n:"Salz/Pfeffer",u:"",a:""},{n:"rosenscharfes Paprikapulver",u:"Tl",a:"1"},{n:"Butter",u:"",a:""}],st:[{s:1,n:"Spaghetti kochen",d:"Die Spaghetti in kochendem Salzwasser bissfesst garen, abgießen und abtropfen lassen."},{s:2,n:"Tomaten und Rucola vorbereiten",d:"Während die Spaghetti kochen, die Stilansätze der Tomaten entfernen. Die Tomaten kurz mit kochendem Wasser übergießen, häuten und entkernen. Rucola putzen, waschen, trocknen und in ca. 2 cm. große Streifen schneiden."},{s:3,n:"Schinken sowie Gemüse anbraten und würzen",d:"Das Öl erhitzen und den Schinken darin kurz anbraten. Tomaten, Rucola und Knoblauch dazugeben und kurz mitbraten. Hier sollte auch schon mit Salz, Pfeffer und Paprikapulver gewürzt werden."},{s:4,n:"Nester formen und mit Gemüse füllen",d:"Nun eine Auflaufform mit Butter einstreichen und aus den Nudeln kleine Nester bilden und in die Form legen. Dann wird das angebratene Gemüse hineingelegt und Käse darüber gestreut."},{s:5,n:"Im Ofen überbacken",d:"Auf der mittleren Schiene im Ofen überbacken lassen, bis der Käse geschmolzen ist. Danach alles aus dem Ofen nehmen und servieren. Guten Appetit:-)"}],p:"00:20",c:"00:30",tot:60,srv:"4",cats:["Pasta & Nudeln"]},{id:1581,t:"Milchnudeln",i:[{n:"Milch",u:"",a:""},{n:"Nudeln",u:"",a:""},{n:"Zucker",u:"",a:""}],st:[{s:1,n:"Milch aufkochen",d:"Die Milch in einem Topf aufkochen lassen."},{s:2,n:"Nudeln dazugeben",d:"Nudeln rein und gar kochen (immer dabei stehen, damit die Milch nicht überkocht)."},{s:3,n:"Zucker darüber streuen",d:"Auf dem Teller anrichten, Zucker rein, Fertig. Guten Appetit:-)"}],p:"00:00",c:"00:10",tot:15,srv:"3",cats:["Pasta & Nudeln"]},{id:1583,t:"Karpfen",i:[{n:"Karpfen",u:"kg",a:"2"},{n:"Porree",u:"",a:""},{n:"Knollensellerie",u:"",a:""},{n:"Zwiebellauch",u:"",a:""},{n:"Möhre",u:"",a:""},{n:"Butter",u:"",a:""},{n:"Fischgewürz",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Karpfen vorbereiten",d:"Der Karpfen muß frisch im Geschäft gekauft werden und kann dort auch bereits ausgenommen werden. Übrig bleibt alles, bis auf die Innereien. Nun kann man die Flossen und den Kopf abtrennen. Wer es für die Optik dran lassen möchte, kann dies auch tun. Jetzt wird der Karpfen innen und außen gut mit Salz und Pfeffer eingerieben."},{s:2,n:"Suppengrün vorbereiten",d:"Das Suppengrün (Möhren, Porree, Sellerie) werden in grobe Stücke geschnitten und in Bauch des Karpfens gelegt. Den Zwiebellauch und die Knoblauchzehe werden noch hinzugefügt."},{s:3,n:"Karpfen in Alufolie wickeln",d:"Der Ofen wird auf ca. 180 Grad vorgeheizt. Der Karpfen wird auf eine mit Butter eingefettete Alufolie gelegt und dann darin umwickelt."},{s:4,n:"Fisch garen",d:"Jetzt kommt alles in den Ofen (mittlere Schiene) und muß abhängig vom Gewicht zw. 45 Minuten bis 1,5h gebacken werden. Kurz vor dem Ende der Garzeit wird der Fischsud in einen kleinen Topf ein wenig eingekocht"},{s:5,n:"Fisch knusprig braten",d:"Währenddessen wird die Alufolie geöffnet und der Fisch noch einmal kurz mit der Grillfunktion des Ofens schön knusprig gebraten. Zum Schluss kommt alles auf eine große Servierplatte und kann sofort mit dem eingekochten Sud serviert werden. Guten Appetit :-)"}],p:"00:30",c:"1:00",tot:105,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:1585,t:"Tzatziki",i:[{n:"Gurke",u:"Stk",a:"1"},{n:"Magerquark",u:"g",a:"500"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Mayonnaise",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gurke raspeln",d:"Eine Gurke wird in eine Schüssel geraspelt. Sollte diese zu wässrig sein, so kann das austretene Wasser einfach abgegossen werden."},{s:2,n:"Restliche Zutaten vermengen",d:"Anschließend gibt man den Quark, 2 EL Mayonnaise und je nach Bedarf 2-5 Knoblauchzehen dazu."},{s:3,n:"Abschmecken und ziehen lassen",d:"Alles gut verrühren und mit Salz und Pfeffer abschmecken. Der Tzatziki sollte schön cremig sein und nach der Zubereitung ca. 3 Stunden kühl ziehen lassen Dieser Dipp eignet sich für jeden Anlass und findet regelmäßig neue Fans :-) Guten Appetit"}],p:"00:15",c:"00:00",tot:60,srv:"10",cats:["Vegetarisch"]},{id:1592,t:"GemüSe Hackfleisch Auflauf   Herdzeit.De",i:[{n:"Kartoffeln",u:"",a:""},{n:"Hackfleisch",u:"g",a:"300"},{n:"Rosenkohl",u:"",a:""},{n:"Champignons",u:"g",a:"250"},{n:"Brokkoli",u:"",a:""},{n:"Paprikaschote",u:"Stk",a:"1"},{n:"Eier",u:"Stk",a:"3"},{n:"Milch/Sahne",u:"ml",a:"100"},{n:"Salz/Pfeffer/Muskat",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen",d:"Die Kartoffeln werden geschält und vorgekocht."},{s:2,n:"Hackfleisch anbraten",d:"Das Hackfleisch wird in einer Pfanne so lange angebraten, bis es schön krümmelig ist."},{s:3,n:"Rosenkohl und Brokkoli kochen",d:"Der Rosenkohl wird ebenso in einem Topf in leicht gesalzenem Wasser bissfest gegart. Zusätzlich kann auch noch Brokkoli bissfest gekocht werden."},{s:4,n:"Pilze vorbereiten und Auflaufform einfetten",d:"Die Champignons werden geputzt. Nun wird eine Auflaufform eingefettet."},{s:5,n:"Auflauf schichten",d:"Dann wird erst das Hackfleisch, die in Scheiben geschnittenen Kartoffeln, Champignons, der Rosenkohl sowie der Brokkoli nacheinander in der Form aufgeschichtet."},{s:6,n:"Soße über den Auflauf und ab in den Ofen",d:"Jetzt werden 3 Eier und etwas Milch mit Salz, Pfeffer und etwas Muskat vermischt und in die Form gegossen. Zum Schluss wird noch geriebener Käse darüber gestreut und für ca. 20-30 min in den auf 180 Grad vorgeheizten Ofen gestellt. Guten Appetit:-)"}],p:"00:30",c:"00:30",tot:60,srv:"4",cats:["Fleisch","Vegetarisch"]},{id:1595,t:"Gemusesalat",i:[{n:"Salat",u:"",a:""},{n:"Tomaten",u:"Stk",a:"5"},{n:"rote Paprika",u:"Stk",a:"1"},{n:"Apfel",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"2"},{n:"Mais",u:"Dose",a:"1"},{n:"Wallnussöl",u:"",a:""},{n:"Zitronensaft",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Vinaigrette zubereiten",d:"Vinaigrette: Zwiebeln sehr klein schneiden. Walnussöl, Honig, Zitronensaft, Salz und Pfeffer werden zusammen mit den Zwiebeln vermischt."},{s:2,n:"Salat vorbereiten",d:"Die Salatblätter waschen, schleudern und kleinschneiden."},{s:3,n:"Gemüse und Obst vorbereiten",d:"Die Tomaten, die Paprika und der Apfel werden kleingeschnitten. Nun muß die Möhre in dei Schüssel geraspelt werden."},{s:4,n:"Zutaten vermengen und abschmecken",d:"Jetzt wird das geschnittene Gemüse und der abgespülte Mais in die Schüssel gegeben und alles gut miteinander vermengt. Zum Schluss evtl. noch mit Salz und Peffer nachwürzen und kurz durchziehen lassen. Guten Appetit:-)"}],p:"00:20",c:"00:00",tot:30,srv:"8",cats:["Salate"]},{id:1601,t:"Gulasch Mit KartoffelpüRee   Herdzeit.De",i:[{n:"Rindergulasch",u:"g",a:"800"},{n:"Schweinegulasch",u:"g",a:"800"},{n:"gr. Zwiebeln",u:"Stk",a:"5"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Rotwein",u:"l",a:"0.5"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Majoran",u:"EL",a:"2"},{n:"Thymian",u:"EL",a:"1"},{n:"Paprikapulver (edelsüss)",u:"EL",a:"2"},{n:"Chilischote",u:"Stk",a:"0.5"},{n:"Kümmel",u:"TL",a:"0.5"}],st:[{s:1,n:"Fleisch im Ganzen? NEIN kleinschneiden",d:"Die Fleischstücken (Rind / Schwein) mit kaltem Wasser abspülen und mit dem Küchenpapier trockentupfen und in kleine Stücke schneiden."},{s:2,n:"Nicht weinen - ran an die Zwiebeln",d:"Die Zwiebeln schälen und in Ringe schneiden."},{s:3,n:"immer nur ein bisschen - Fleisch portionsweise anbraten",d:"Nun wird ein großer Topf mit Öl erhitzt und das Fleisch wird portionsweise angebraten. Sollte zu viel Bratensaft austreten, gieße ich diesen ab und zu in eine kleine Schüssel. Zum einen, weil das Fleisch gebraten und nicht gekocht werden soll. Zum anderen, weil der überflüssige Bratensaft später wieder dem Gulasch zugeführt wird. Das angebratene Fleisch wird in einer Schüssel kurz daneben gestellt."},{s:4,n:"Zusammen was zusammen gehört",d:"Jetzt die Zwiebeln im gleichen Topf anbraten, das Fleisch hinzugeben und mit Tomatenmark und edelsüßem Paprikapulver würzen und kurz mitbraten."},{s:5,n:"Im Wein liegt die Wahrheit - also rein damit",d:"Als nächstes Rotwein einkochen. Danach kommt heißes Wasser hinzu. Immer nur soviel, dass der Inhalt leicht bedeckt ist. In den nächsten Stunden muss immer wieder mal Wasser hinzugießen und einkochen."},{s:6,n:"Kein Geheimnis - die 7 Gewürze",d:'Nachdem also das erste Mal Wasser aufgegossen wurde, erfolgt die Gewürzzubereitung, sozusagen das Herz des Gulaschgerichtes. Man nehme einen Mörser und füllt folgendes auf: grobes Meersalz, Pfeffer, gerebelter Majoran, Thymian, Kümmel, Knoblauch, getrockneter oder frischer Chili. Alles gründlich "žzermörsern" und mit in den Topf geben.'},{s:7,n:"In der Ruhe liegt der Geschmack",d:"Jetzt kann Gulasch 2-3 Stunden köcheln, bis das Fleisch sich leicht zerdrücken lässt."},{s:8,n:"Kartoffeln kochen",d:"Mehlig kochende Kartoffeln kochen."},{s:9,n:"Milch, Butter unterrühren und würzen",d:"Mit Milch oder Sahne, Butter und Salz würzen."},{s:10,n:"Pürieren und abschmecken",d:"Mit einem Rührgerät pürieren. Abschmecken und fertig."}],p:"00:45",c:"2:00",tot:180,srv:"8",cats:["Fleisch"]},{id:1602,t:"Nudeln Mit Tomatensose",i:[{n:"Nudeln",u:"",a:""},{n:"Jagdwurst",u:"g",a:"250"},{n:"Tomaten aus der Dose",u:"g",a:"600"},{n:"Zucchini",u:"Stk",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"gerebelter Majoran",u:"",a:""},{n:"Thymian",u:"",a:""},{n:"Oregano",u:"",a:"');"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Zucker",u:"",a:""}],st:[{s:1,n:"Jagdwurst und Gemüse würfeln",d:"Die Jagdwurst und die Zucchini in kleine Würfel sowie die Zwiebel kleinschneiden. Knoblauchzehe sehr klein hacken oder in feine Scheiben schneiden."},{s:2,n:"Jagdwurst anbraten",d:"Einen Topf mit Öl erhitzen und die Jagdwurst rundherum anbraten. Danach herausnehmen und in einer Schüssel zur Seite stellen."},{s:3,n:"Gemüse anbraten",d:"Nun das kleingeschnittenen Gemüse im Bratensud anschwitzen. Zuerst die Zucchini und ca. 1-2 Minuten danach die Zwiebel und den Knoblauch hinzufügen."},{s:4,n:"Rest in den Topf",d:"Sobald nach ca. 5 Minuten alles glasig angeschwitzt ist, wird die Jagdwurst wieder in den Topf gegeben. Nun gibt man ca. 1,5 Dosen passierte stückige Tomaten hinzu. Hinweis: Wer Zeit und Muße hat, frische Tomaten zu verarbeiten geht folgendermaßen vor: Tomaten oben kreuzförmig anritzen. Mit heißem Wasser übergießen. Die Tomaten häuten, Strunk entfernen und kleinwürfeln. In der Regel erzielt man aber schon mit den passierten Tomaten gute Geschmackserlebnisse."},{s:5,n:"Tomatensoße einkochen",d:"Gebt nun noch etwas heißes Wasser dazu, würzt das ganze mit gerebeltem Oregano (passt gut zu Tomaten) und lasst es ca. 20 Minuten bei geschlossenem Deckel und reduzierter Hitze köcheln."},{s:6,n:"Abschmecken",d:"Zum Schluss wird die Soße noch mit Salz, Pfeffer, etwas Zucker und einem Teelöffel Butter gewürzt und abgeschmeckt. Der Zucker ist notwendig, da die Soße durch die Tomaten noch etwas säuerlich schmecken kann. Dies rundet zusammen mit der Butter den Geschmack der Soße schön ab."},{s:7,n:"Nudeln kochen",d:"Etwa 10 Minuten vor dem Ende der Kochzeit der Soße, wird ein Topf mit Salzwasser aufgesetzt und die Nudeln bissfest gekocht."},{s:8,n:"Anrichten",d:"Letztendlich alles nett auf einem Teller anrichten, mit Parmesankäse bestreuen und genießen."}],p:"00:20",c:"00:25",tot:60,srv:"4",cats:["Pasta & Nudeln","Vegetarisch"]},{id:1603,t:"Chili Con Carne",i:[{n:"Hackfleisch",u:"g",a:"500"},{n:"Suppengrün",u:"Bd",a:"1"},{n:"eingelegte Tomaten",u:"Dosen",a:"2"},{n:"Kidneybohnen",u:"Dosen",a:"2"},{n:"Mais",u:"Dose",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Paprikapulver",u:"TL",a:"1"},{n:"Majoran",u:"",a:""},{n:"Oregano",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Möhren, Knollensellerie und Porree kleinschneiden."},{s:2,n:"Hackfleisch zubereiten",d:"Öl in einem Topf erhitzen und darin das Hackfleisch krümelig braten. Wenn es fertig gebraten ist, in einer Schüssel zur Seite stellen."},{s:3,n:"Gemüse anbraten, Hackfleisch dazugeben und würzen",d:"Nun wird das kleingeschnittene Gemüse in etwas Öl angebraten. Das Hackfleisch wird wieder hinzugegeben und mit etwas Tomatenmark und Paprikapulver gewürzt."},{s:4,n:"Dosentomaten unterrühren und einkochen lassen",d:"Alles gut unterrühren und später mit den Dosentomaten auffüllen. Noch etwas Wasser rein und schön einkochen lassen."},{s:5,n:"Abschmecken und Mais sowie Kidneybohnen dazugeben",d:"Jetzt wird noch mit Majoran, Oregano, Salz und Pfeffer gewürzt. Ca. 15 Minuten vor dem Ende werden noch der abgespülte Mais und die Kidneybohnen in den Topf gegeben. Nicht vorher, da diese evtl. sonst zu labrig werden."},{s:6,n:"Reis zubereiten",d:"In der kinderfreundlichen Version läßt man die Tabascosauce bzw. den Chili einfach weg. Wer es mag gibt es je nach Geschmack beim würzen dazu. Während alles vorköchelt wird der Reis wie in dem Gericht \\ Hühnergeschnetzeltes auf Basmatireis\\ zubereitet. Guten Appetit:-)"}],p:"00:20",c:"1:30",tot:120,srv:"6",cats:["Fleisch"]},{id:1604,t:"Ungarische Gulaschsuppe",i:[{n:"Rindfleisch",u:"g",a:"600"},{n:"gr. Zwiebel",u:"Stk",a:"1"},{n:"Olivenöl",u:"",a:""},{n:"Kümmel",u:"TL",a:"0.5"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Paprikapulver edelsüss",u:"EL",a:"1"},{n:"Möhre",u:"Stk",a:"1"},{n:"Sellerie",u:"g",a:"100"},{n:"Paprikaschoten",u:"Stk",a:"2"},{n:"Tomaten",u:"Stk",a:"4"},{n:"Kartoffeln",u:"g",a:"400"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch würfeln",d:"Das Fleisch in etwa 1cm große Würfel schneiden."},{s:2,n:"Zwiebel fein hacken und dünsten",d:"Die Zwiebel schälen und sehr fein hacken. Öl in einem Topf erhitzen und die Zwiebel darin glasig andünsten."},{s:3,n:"Fleisch dazugeben und würzen",d:"Kümmel und die zerdrückte Knoblauchzehe unterrühren und kurz mit anbraten. Jetzt wird Paprikapulver und Fleisch dazugegeben und gesalzen. Zugedeckt schmoren lassen und ggfs. Wasser hinzugießen."},{s:4,n:"Gemüse vorbereiten",d:"Die weiteren Zutaten waschen. Die Kartoffeln und das Wurzelgemüse in kleine Würfel schneiden. Paprika in mundgerechte Stücke schneiden sowie die Tomaten vierteln."},{s:5,n:"Gemüse zum Fleisch geben",d:"Wenn das Fleisch halb gar ist, wird das Gemüse hinzugegeben."},{s:6,n:"Das Ganze noch etwas schmoren lassen",d:"Jetzt kann bei Bedarf wieder Wasser hinzugegeben werden und noch weitere 20 min. schmoren lassen. Nach ca. 20 min werden die gewürfelten Kartoffeln hinzugegeben und noch weitere 20 min köcheln lassen. Es darf serviert werden. X deftigX FleischX GemüseX GulaschX KartoffelX SuppeX rindX zwiebelX kümmelX paprikapulver Guten Appetit :-)"}],p:"00:20",c:"1:00",tot:90,srv:"8",cats:["Fleisch","Suppen & Eintöpfe"]},{id:1606,t:"Versunkener Aprikosenkuchen",i:[{n:"Butter",u:"g",a:"100"},{n:"Zucker",u:"g",a:"100"},{n:"Vanillezucker",u:"Pck",a:"1"},{n:"Backöl Zitrone",u:"Fl",a:"0.5"},{n:"Eier",u:"Stk",a:"3"},{n:"Mehl",u:"g",a:"100"},{n:"Backpulver",u:"TL",a:"1"},{n:"Haferflocken",u:"g",a:"100"},{n:"Milch",u:"EL",a:"5"},{n:"Aprikosen aus der Dose",u:"g",a:"500"}],st:[{s:1,n:"Teig zubereiten",d:"Die Butter mit Zucker, Vanillezucker und Backöl Zitrone schaumig rühren. Die Eier werden nach und nach hinzugegeben und solange weitergerührt, bis sich der Zucker aufgelöst hat."},{s:2,n:"Mehl, Backpulver und Haferflocken unterrühren",d:"Das Mehl mit dem Backpulver darübersieben. Haferflocken hinzugeben und zu einem glatten Teig glattrühren und zum Schluss die Milch unterrühren."},{s:3,n:"Ofen vorheizen",d:"Nun wird der Backofen auf ca. 180 Grad Umluft vorgeheizt"},{s:4,n:"Aprikosen vorbereiten",d:"Die Aprikosen in ein Sieb geben und abtropfen lassen. Den Saft auffangen und mit Wasser mischen und selber trinken."},{s:5,n:"Teig in Kuchenform geben",d:"Den Boden und den Rand einer runden Kuchenform mit Backpapier belegen und evtl. den überstehenden Rand abschneiden. Den Teig in die Form geben und gleichmäßig verteilen."},{s:6,n:"Teig mit Aprikosen belegen und ab in den Ofen",d:"Die Aprikosen darauflegen und auf der mittleren Schiene 50 min backen."},{s:7,n:"Tipp",d:"Über den Kuchen kann man nun noch Vanillesauce oder Sahne geben. Guten Appetit:-)"}],p:"00:20",c:"00:50",tot:70,srv:"12",cats:["Backen & Desserts"]},{id:1607,t:"Hahnchenschenkel",i:[{n:"Hähnchenschenkel",u:"Stk",a:"8"},{n:"Hähnchengewürz",u:"",a:""},{n:"Öl",u:"",a:""},{n:"Pommes Frites",u:"",a:""},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Marinade anrühren",d:"Öl und Hähnchengewürzsalz in einer Schüssel verrühren."},{s:2,n:"Hähnchenschenkel vorbereiten und in Marinade schwenken",d:"Hähnchenschenkel mit kaltem Wasser abwaschen und mit Küchenpapier trockentupfen."},{s:3,n:"Im Ofen braten",d:"Alles zusammen auf der mittleren Schiene in den auf 200 Grad vorgeheizten Ofen legen."},{s:4,n:"Bratblech mit Wasser füllen",d:"Das Bratblech kann mit Wasser gefüllt werden. Das hat den Vorteil, daß das runtertropfende Bratfett nicht anbrennt. Weiterhin kann der der enstehende Sud immer mal wieder über die Schenkel gegossen werden. So trocken die Schenkel nicht gleich aus"},{s:5,n:"Tipp",d:"Dazu gibt es Pommes und Ketchup. Dieses Gericht ist wirklich sehr schnell zubereitet und jedes Kind leckt sich die Finger danach. Guten Appetit"}],p:"00:10",c:"1:00",tot:70,srv:"6",cats:["Geflügel"]},{id:1609,t:"Kartoffelsalat   Herdzeit.De",i:[{n:"festkochende Kartoffeln",u:"kg",a:"1.5"},{n:"saure Gurken",u:"Glas",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Apfel",u:"Stk",a:"1"},{n:"Senf",u:"TL",a:"2"},{n:"Essig",u:"EL",a:"4"},{n:"Öl",u:"EL",a:"4"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen und anschließend würfeln",d:"Die Kartoffeln werden mit der Schale gekocht. Nach ca. 25 Minuten nimmt man den Topf vom Herd und ersetzt das heiße Wasser durch kaltes. Die Kartoffeln sollen nun etwas abkühlen, damit man sie später abpellen kann. Sobald das geschehen ist, schneidet man diese in grobe Stücke und gibt alles in eine Schüssel."},{s:2,n:"Gurken, Zwiebel und Apfel kleinschneiden",d:"Die sauren Gurken werden längs geviertelt, in kleine Stücke geschnitten und in die Schüssel gegeben. Die Zwiebel sehr fein schneiden. Den Apfel schälen, den Stiel und das Kerngehäuse entfernen und ebenso in kleine Würfel schneiden. Ab in die Schüssel damit. Die Apfelstücken sorgen für eine natürliche Frische im Salat."},{s:3,n:"Vinaigrette zubereiten",d:"In das Glas mit dem Gurkenwasser gibt man nun 2 TL Dijonsenf, 4 EL Essig, Salz und Pfeffer. Deckel drauf und sehr kräftig schütteln. Beim Abschmecken sollte die Vinaigrette noch etwas essighaltig schmecken. Sobald der Geschmack gefunden wurde, gibt man noch 4 EL Sonnenblumenöl hinzu. Deckel drauf und nochmals gut schütteln. Das Öl sollte man erst zum Schluss hinzugeben, da der Geschmack der Soße in dem Öl \\eingeschlossen\\ wird."},{s:4,n:"Abschmecken und Servieren",d:"Das Gurkenwasser gießt man nun durch ein Sieb in die Schüssel. Alles gut miteinander vermischen und noch kurz durchziehen lassen. Wie gesagt, der Salat eignet sich nicht nur für warme Sommertage, sondern ist zudem noch partytauglich. Guten Appetit"}],p:"00:20",c:"00:20",tot:50,srv:"8",cats:["Salate","Vegetarisch"]},{id:1612,t:"Hahnchenbrustfilet Auf Einem Gemusebett",i:[{n:"Hähnchenbrustfilet am Knochen",u:"g",a:"800"},{n:"Suppengrün",u:"",a:""},{n:"Zucchini",u:"Stk",a:"0.5"},{n:"kleine Champignons",u:"g",a:"200"},{n:"Thymianzweige",u:"",a:""},{n:"Rotwein",u:"ml",a:"300"},{n:"Hühnerfond",u:"ml",a:"250"},{n:"Schalotten",u:"Stk",a:"8"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Das Gemüse vom Suppengrün schälen sowie eine halbe Zucchini in grobe Stücke schneiden. Die kleinen Champignons vom Sand befreien und evtl. vierteln oder halbieren. 8 Schalotten und 3 Knoblauchzehen schälen und vierteln. Alles bis auf die Champignons in eine Schüssel geben und mit Salz, Pfeffer und Thymianzweigen würzen."},{s:2,n:"Fleisch vorbereiten und panieren",d:"Das Hähnchenbrustfilet unter klarem kalten Wasser abwaschen und trocktupfen. Nun wird mit einem großen Messer entlang des Brustknochens geschnitten und somit das Brustfilet entfernt. Die Brustfilethälften werden nun nochmals halbiert und mit Mehl bestäubt."},{s:2,n:"Fleisch vorbereiten und panieren",d:"Das Hähnchenbrustfilet unter klarem kalten Wasser abwaschen und trocktupfen. Nun wird mit einem großen Messer entlang des Brustknochens geschnitten und somit das Brustfilet entfernt. Die Brustfilethälften werden nun nochmals halbiert und mit Mehl bestäubt."},{s:3,n:"Hähnchenbrustfilets anbraten",d:"Jetzt wird eine Pfanne mit Butterschmalz erhitzt und die Brustfilets rundherum schön kross angebraten. Die Pfanne sollte anfänglich sehr heiß sein, sodaß die Poren der Haut geschlossen werden. Evtl. kann danach die Hitze etwas reduziert werden. Zum Schluss kann nun mit Salz gewürzt werden. Achtet darauf, daß die Filets nicht zu lange braten, da das Fleisch sonst zu trocken werden könnte."},{s:3,n:"Hähnchenbrustfilets anbraten",d:"Jetzt wird eine Pfanne mit Butterschmalz erhitzt und die Brustfilets rundherum schön kross angebraten. Die Pfanne sollte anfänglich sehr heiß sein, sodaß die Poren der Haut geschlossen werden. Evtl. kann danach die Hitze etwas reduziert werden. Zum Schluss kann nun mit Salz gewürzt werden. Achtet darauf, daß die Filets nicht zu lange braten, da das Fleisch sonst zu trocken werden könnte."},{s:4,n:"Gemüse anbraten und Soße anrühren",d:"Nun wird das Fleisch zur Seite gestellt und das grob geschnittene Gemüse sowie die Champignons in der gleichen Pfanne scharf angebraten. Tomatenmark hinzufügen und drunterrühren. Alles zusammen wird nach ca. 5-10 Min. mit Rotwein und dem Hühnerfond abgelöscht und kurz aufgekocht. Die Filetstücken legt man nun auf das Gemüse und gibt die Pfanne für ca. 35 Min in den auf 180 Grad vorgeheizten Ofen."},{s:4,n:"Gemüse anbraten und Soße anrühren",d:"Nun wird das Fleisch zur Seite gestellt und das grob geschnittene Gemüse sowie die Champignons in der gleichen Pfanne scharf angebraten. Tomatenmark hinzufügen und drunterrühren. Alles zusammen wird nach ca. 5-10 Min. mit Rotwein und dem Hühnerfond abgelöscht und kurz aufgekocht. Die Filetstücken legt man nun auf das Gemüse und gibt die Pfanne für ca. 35 Min in den auf 180 Grad vorgeheizten Ofen."},{s:5,n:"Tipp",d:"Wenn es denn eine schöne Pfanne ist, putzt man noch kurz den Rand sauber und stellt die Pfanne samt Inhalt auf den Tisch. Petersilie drüber und wohl bekomms :-)');"},{s:5,n:"Tipp",d:"Wenn es denn eine schöne Pfanne ist, putzt man noch kurz den Rand sauber und stellt die Pfanne samt Inhalt auf den Tisch. Petersilie drüber und wohl bekomms :-)');"}],p:"00:15",c:"1:00",tot:80,srv:"5",cats:["Geflügel"]},{id:1616,t:"Marinade Fur Rippchen",i:[{n:"Honig",u:"EL",a:"3"},{n:"Tomatenketchup",u:"EL",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"passierte Tomaten",u:"",a:""},{n:"schwarzer Balsamico",u:"EL",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Thymian",u:"",a:""},{n:"Rosmarin",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Sambal Oelek",u:"TL",a:"1"},{n:"Worchestersauce",u:"TL",a:"1"}],st:[{s:1,n:"Knoblauch und Kräuter vorbereiten",d:"2 Knoblauchzehen werden sehr klein gehackt oder mit einer Knoblauchpresse in die Schüssel gegeben. Ich hatte gerade noch ein paar frische Kräuter übrig, sodass hier die Rosmarinnadeln, der Thymian sowie der Majoran ebenfalls sehr fein gehackt werden konnten."},{s:2,n:"Marinade anrühren",d:"Nun gibt man 1 EL Tomatenmark und 3 EL Tomatenketchup hinzu. Statt Ketchup können jedoch auch gern passierte Tomaten hinzufügt werden. Jetzt gibt man noch 1-2 TL Sambal Oelek, 1 TL Worchestersauce für die Schärfe und 2-3 EL Honig für die Süsse hinzu und rührt alles kräftig um."},{s:3,n:"Marinade abschmecken",d:"Abgeschmeckt wird die Soße mit Salz, Pfeffer und 1 EL schwarzem Balsamico Essig. Sollte die Marinade etwas säuerlich schmecken so gibt man noch dezent etwas Honig hinzu."}],p:"00:15",c:"00:00",tot:60,srv:"4",cats:["Grillen & Marinaden"]},{id:1618,t:"Rotbarschfilet Auf Paprikagemuse",i:[{n:"Rotbarschfilet",u:"g",a:"600"},{n:"Paprikaschoten",u:"Stk",a:"4"},{n:"Zwiebeln",u:"Stk",a:"4"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"eingelegte Oliven",u:"g",a:"150"},{n:"roher Schinken",u:"Pck",a:"1"},{n:"Brühe",u:"ml",a:"300"},{n:"Zitronensaft",u:"",a:""},{n:"Worchestersauce",u:"",a:""},{n:"Muskatnusspulver",u:"",a:""},{n:"Cayennepfeffer",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""},{n:"Zwiebellauch",u:"",a:""}],st:[{s:1,n:"Rotbarschfilet marinieren",d:"Das Rotbarschfilet mit kaltem Wasser abspülen, trockentupfen und evtl. noch von vorhandenen Gräten befreien. Die Filets portioniert in eine Schüssel geben und mit Salz, Pfeffer, Balsamicoessig, Zitronensaft und Worchestersauce kräftig würzen. Abdecken und für ca. 20 Min im Kühlschrank marinieren lassen."},{s:2,n:"Schinken und Gemüse vorbereiten",d:"Die Zwiebeln schälen, halbieren und in Ringe schneiden. Die Knoblauchzehen kleinhacken und mit einem TL Salz im Mörser zu einer Paste verreiben. Die Paprika halbieren, Stielenden sowie Kerne entfernen, abwaschen und quer in sehr schmale Streifen schneiden. Die Schinkenscheiben schneidet man in Streifen und die Oliven in Ringe. Die in Knoblauch oder Kräutern eingelegten Oliven vom Türken oder der Frischetheke eignen sich hierfür besonders gut."},{s:2,n:"Schinken und Gemüse vorbereiten",d:"Die Zwiebeln schälen, halbieren und in Ringe schneiden. Die Knoblauchzehen kleinhacken und mit einem TL Salz im Mörser zu einer Paste verreiben. Die Paprika halbieren, Stielenden sowie Kerne entfernen, abwaschen und quer in sehr schmale Streifen schneiden. Die Schinkenscheiben schneidet man in Streifen und die Oliven in Ringe. Die in Knoblauch oder Kräutern eingelegten Oliven vom Türken oder der Frischetheke eignen sich hierfür besonders gut."},{s:3,n:"Gemüse andünsten und Soße anrühren",d:"Ein großer Topf wird mit 2 EL Öl erhitzt, die Zwiebeln dazugegeben und glasig angedünstet. Nach ca. 2 Min gibt man die Knoblauchpaste hinzu. Nach weiteren 2 Minuten folgt der Paprika und wird ebenso ca. 3-4 Min angeschwitzt. Zum Schluss werden der Schinken und die Oliven untergerührt und alles zusammen mit der Brühe abgelöscht. Nun darf alles kräftig mit Salz und Pfeffer, Muskat und Cayennepfeffer abgeschmeckt werden."},{s:3,n:"Gemüse andünsten und Soße anrühren",d:"Ein großer Topf wird mit 2 EL Öl erhitzt, die Zwiebeln dazugegeben und glasig angedünstet. Nach ca. 2 Min gibt man die Knoblauchpaste hinzu. Nach weiteren 2 Minuten folgt der Paprika und wird ebenso ca. 3-4 Min angeschwitzt. Zum Schluss werden der Schinken und die Oliven untergerührt und alles zusammen mit der Brühe abgelöscht. Nun darf alles kräftig mit Salz und Pfeffer, Muskat und Cayennepfeffer abgeschmeckt werden."},{s:4,n:"Filets dünsten",d:"Jetzt dürfen die marinierten Filets in den Topf gegeben werden und für ca. 20Min. bei reduzierter Hitze köcheln."},{s:4,n:"Filets dünsten",d:"Jetzt dürfen die marinierten Filets in den Topf gegeben werden und für ca. 20Min. bei reduzierter Hitze köcheln."},{s:5,n:"Anrichten und servieren",d:"Zum Servieren wird das Gemüse mit einer Siebkelle aus dem Topf gehoben und in der Mitte vom Teller platziert. Die Rotbarschfilets werden daraufgelegt und mit Kräutern Eurer Wahl garniert. Guten Appetit"},{s:5,n:"Anrichten und servieren",d:"Zum Servieren wird das Gemüse mit einer Siebkelle aus dem Topf gehoben und in der Mitte vom Teller platziert. Die Rotbarschfilets werden daraufgelegt und mit Kräutern Eurer Wahl garniert. Guten Appetit"}],p:"00:15",c:"00:20",tot:45,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:1627,t:"Tomatensuppe",i:[{n:"große Tomaten",u:"kg",a:"1"},{n:"Sellerie",u:"Stangen",a:"2"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Öl",u:"EL",a:"2"},{n:"Brühe oder Gemüsefond",u:"ml",a:"200"},{n:"Tabascosauce",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Tomaten, Zwiebel und Staudensellerie vorbereiten",d:"Ein Wasserkocher wird mit reichlich Wasser erhitzt. Die Tomaten werden an der Spitze angeritzt, mit dem heißen Wasser in einem Topf übergossen und ca. 5-10 min stehen gelassen Während dessen wird die Zwiebel geschält und sehr klein geschnitten. Vom Staudensellerie entfernt man die Enden und schneidet den Rest in dünne Ringe. Sobald sich die Haut langsam von den Tomaten ablöst, werden diese geschält, halbiert, Stielenden sowie die Kerne entfernt und in kleine Würfel geschnitten."},{s:2,n:"Gemüse anbraten und mit Gemüsefond aufkochen",d:"Jetzt erhitzt man einen Topf mit 2 EL Öl und brät die Zwiebeln glasig an. Nun gibt man den Sellerie, ein Lorbeerblatt und die Tomaten hinzu und brat auch diese kurz mit an. Jetzt wird der Gemüsefond oder die Gemüsebrühe in den Topf gegeben und aufgekocht. Alles zusammen läßt man nun ca. 30 min bei reduzierter Hitze köcheln, bis das Gemüse weich geworden ist."},{s:3,n:"Suppe pürieren und abschmecken",d:"Alles gut miteinander pürieren und mit Salz, Pfeffer und ein paar Spritzer Tobascosauce kräftig abschmecken. Zum Schluss werden noch ein paar Basilikumblätter kleingehackt und auf die in Schüsseln oder Tassen nett angerichtete Tomatensuppe gestreut. Ich werde diese Gericht nochmals mit passierten Tomaten ausprobieren. Dadurch kann man sich das Aufbrühen und Abschälen der Tomaten ersparen und die Suppe somit noch schneller zubereiten können. Guten Appetit"}],p:"00:15",c:"00:30",tot:55,srv:"3",cats:["Suppen & Eintöpfe"]},{id:1634,t:"Pilzpfanne",i:[{n:"große Champignons",u:"Stk",a:"8"},{n:"Zwiebellauch",u:"Stängel",a:"3"},{n:"Majoran",u:"",a:""},{n:"Sahne",u:"ml",a:"200"},{n:"Weißwein",u:"ml",a:"150"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Pilze vorbereiten",d:"Hierfür nimmt man frische große Champignons, von denen man das Stielende entfernt. Nun legt man die Champignons mit den Lammellen nach oben auf den Kopf . Dort gibt man kleingehackten Knoblauch und ein paar Tropfen Weißwein hinzu. Alles zusammen läßt man kurz 10 Min. im Kühlschrank durchziehen."},{s:2,n:"Pilze anbraten",d:"Am besten geeignet für die Zubereitung ist eine gusseiserne Pfanne. Man erhitzt ein Stück Butterschmalz bis es sehr heiß geworden ist. Gibt nun die Pilze hinzu und brät diese ca. 5 Min rundherum gut an. Evtl. sollte man vorher die Knoblauchstücke entfernen, da diese recht schnell anbrennen können. Evtl. muß man die Hitze etwas reduzieren. Sobald die Pilze angebraten sind, legt man diese auf einem Teller zur Seite."},{s:3,n:"Soße zubereiten und mit Pilzen vermegen",d:"In die Pfanne gibt man nun 150 ml Weißwein und kocht diesen mit Knoblauch kräftig ein. Sobald noch ein wenig Flüssigkeit vorhanden ist, gießt man die Sahne hinzu und gibt den in Ringe geschnittenen Zwiebellauch hinzu. Mit Salz, Pfeffer und evtl. Majoran abschmecken und bei reduzierter Hitze einkochen. Während die Soße langsam einkocht gibt man die Pilze hinzu und schwenkt sie ab und zu in der Pfanne."},{s:4,n:"Anrichten und servieren",d:"Nach ca. 10 Min ist das Gericht fertig. Den Pfannenrand säubern, frische Zwiebellauchringe drüber streuen und ab auf den Tisch damit. Dazu eignet sich am besten ein Baguettebrot zum tunken in der Soße. Guten Appetit"}],p:"00:15",c:"00:15",tot:35,srv:"2",cats:["Vegetarisch"]},{id:1690,t:"Geschnetzeltes In Einer Senf Sahne Sose",i:[{n:"Kartoffeln (mehligkochend)",u:"kg",a:"1"},{n:"Schweinefleisch",u:"g",a:"600"},{n:"Brokkoli",u:"Stk",a:"1"},{n:"Zwiebeln",u:"Stk",a:"4"},{n:"Sahne",u:"ml",a:"200"},{n:"Wasser",u:"ml",a:"200"},{n:"Thymian",u:"",a:""},{n:"Dijonsenf",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Den Brokkoli von den Blättern befreien, die Röschen abschneiden und in einer Schüssel zur Seite stellen. Kartoffeln schälen, vierteln und in einem Topf mit Wasser ca. 20 Min. kochen. Während dessen wird das Fleisch abgewaschen, trockengetupft und in ca. 2 cm große Streifen geschnitten. Die Zwiebeln schälen und in Ringe schneiden."},{s:2,n:"Brokkoli garen",d:"Nun wird Wasser für den Brokkoli aufgesetzt. Sobald es kocht gibt man 2 TL Salz sowie die Brokkoliröschen für ca. 5 Min. hinein. Länger sollten diese nicht kochen, da der Brokkoli sehr schnell weich und somit unappetitlich werden kann. Nach den 5 Min. gibt man den Brokkoli in eiskaltes Wasser und läßt ihn bis zur nächsten Verwendung darin liegen. Somit bleibt er knackig und behält seine frische grüne Farbe bei."},{s:3,n:"Fleisch anbraten und Soße anrühren",d:"In einer Pfanne wird das Fleisch mit 2 EL Öl angebraten und danach in einer Schüssel zur Seite gestellt. In der gleichen Pfanne werden die Zwiebelringe in dem Bratensaft sowie einem EL Öl braun angebraten. Während dessen kann der Wasserkocher mit ca. 200-300 ml Wasser erhitzt werden. Sobald die Zwiebeln gebraten wurden, nimmt man 1/4 von den Zwiebeln heraus. Im Gegenzug wird nun das Fleisch wieder in die Pfanne gegeben und mit Wasser und Sahne abgelöscht. Dies läßt man nun kurz einkochen. Danach wird der Senf hinzugegeben. Sollte die Soße noch zu dünnflüssig sein, so rührt man eine halbe Tasse Wasser mit Kartoffelmehl an und fügt sie der Soße hinzu. Zum Schluss wird das Essen mit Salz, Pfeffer und Thymian gewürzt und abgeschmeckt."},{s:3,n:"Fleisch anbraten und Soße anrühren",d:"In einer Pfanne wird das Fleisch mit 2 EL Öl angebraten und danach in einer Schüssel zur Seite gestellt. In der gleichen Pfanne werden die Zwiebelringe in dem Bratensaft sowie einem EL Öl braun angebraten. Während dessen kann der Wasserkocher mit ca. 200-300 ml Wasser erhitzt werden. Sobald die Zwiebeln gebraten wurden, nimmt man 1/4 von den Zwiebeln heraus. Im Gegenzug wird nun das Fleisch wieder in die Pfanne gegeben und mit Wasser und Sahne abgelöscht. Dies läßt man nun kurz einkochen. Danach wird der Senf hinzugegeben. Sollte die Soße noch zu dünnflüssig sein, so rührt man eine halbe Tasse Wasser mit Kartoffelmehl an und fügt sie der Soße hinzu. Zum Schluss wird das Essen mit Salz, Pfeffer und Thymian gewürzt und abgeschmeckt."},{s:4,n:"Kartoffelpüree zubereiten und Brokkoli kurz in Butter schwenken",d:"Zu den gekochten Kartoffeln gibt man nun Milch, 1 TL Salz und ca. 100-150 g Butter hinzu. Pürrieren, abschmecken, Fertig. Wer es mag kann nun den Brokkoli noch kurz in einer mit Butter und einer Prise Salz erhitzten Pfanne schwenken. Das Geschnetzelte mit dem Gemüse schön anrichten und ... Guten Appetit :-)"},{s:4,n:"Kartoffelpüree zubereiten und Brokkoli kurz in Butter schwenken",d:"Zu den gekochten Kartoffeln gibt man nun Milch, 1 TL Salz und ca. 100-150 g Butter hinzu. Pürrieren, abschmecken, Fertig. Wer es mag kann nun den Brokkoli noch kurz in einer mit Butter und einer Prise Salz erhitzten Pfanne schwenken. Das Geschnetzelte mit dem Gemüse schön anrichten und ... Guten Appetit :-)"}],p:"00:15",c:"00:40",tot:60,srv:"4",cats:["Fleisch"]},{id:1693,t:"Spargel Mit Brauner Butter",i:[{n:"Spargel",u:"kg",a:"1.5"},{n:"Spargel",u:"kg",a:"1.5"},{n:"Butter",u:"g",a:"150"},{n:"Zitronensaft",u:"El",a:"1"},{n:"Zucker",u:"EL",a:"1"},{n:"Semmelbrösel",u:"EL",a:"4"},{n:"Butter",u:"g",a:"200"},{n:"Salz",u:"Pr",a:"1"}],st:[{s:1,n:"Spargelstangen in den Topf geben",d:"Geschälte Spargelstangen in einen Topf geben, diesen mit kaltem Wasser und einem 1,5 EL Salz, 1 EL Zucker sowie 100 g Butter füllen."},{s:2,n:"Spargel kochen",d:'Nun darf der Spargel für ca. 20 "“ 30 mit köcheln. Die Hitze eventuell etwas reduzieren.'},{s:3,n:"Zitronenspritzer",d:"Zum Schluss ein paar Spritzer Zitronensaft hinzugeben"}],p:"00:15",c:"00:25",tot:45,srv:"4",cats:["Vegetarisch"]},{id:1726,t:"Ratatouille",i:[{n:"Paprikaschoten",u:"Stk",a:"2"},{n:"mittelgroße Zucchini",u:"Stk",a:"0.5"},{n:"frische Champignons",u:"g",a:"150"},{n:"Kirschtomaten",u:"g",a:"200"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Olivenöl",u:"EL",a:"2"},{n:"Rosmarin u. Thymian",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Den Paprika halbieren, von den Kernen und dem Strunk befreien, abwaschen und in grobe Stücke schneiden. Die Zucchini waschen und in Scheiben schneiden. Die frischen Champignons vom Schmut befreien, das Stielende abschneiden und vierteln. Die Knoblauchzehe schälen und dritteln."},{s:2,n:"Kräuter, Tomaten und Oliven vorberie",d:"Die Rosmarin-und Thymianszweige abwaschen, trockenschütteln und die Blätter abzupfen. Die Tomaten waschen, abtrocknen und halbieren. Die eingelegten Oliven, am besten von der Frischetheke, vierteln."},{s:3,n:"Gemüse anbraten",d:"Nun wird eine Pfanne mit 2 EL Olivenöl erhitzt. Sobald das Öl heiß geworden ist, gibt man den Knoblauch, die Paprikastücken, Zucchini und die Pilze hinein und brät alles zusammen ca. 5 Min an. Mit Salz und Pfeffer würzen."},{s:4,n:"Gemüse zusammen mit Tomaten, Oliven einkochen und abschmecken",d:"Jetzt folgen die Tomaten, die Oliven und 5 EL Tomatensaft. Kurz einkochen und mit Salz und Pfeffer abschmecken.Fertig Das Gemüse muß nur noch schön in einer Schüssel oder einem Teller angerichtet werden. Dazu reicht man ein paar Baguettscheiben. Guten Appetit"}],p:"00:10",c:"00:10",tot:25,srv:"3",cats:["Vegetarisch"]},{id:1732,t:"Rindfleisch Mit Bohnen",i:[{n:"Rindfleischscheiben",u:"g",a:"400"},{n:"Bambusstreifen",u:"",a:""},{n:"ungesalzene Cashewkerne",u:"g",a:"50"},{n:"Koblauchzehen",u:"Stk",a:"2"},{n:"grüne Bohnen",u:"g",a:"200"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Sojasoße",u:"",a:""},{n:"Kartoffelmehl",u:"TL",a:"3"},{n:"Wasser/Brühe",u:"ml",a:"300"},{n:"Wallnussöl",u:"",a:""}],st:[{s:1,n:"Marinade zubereiten und Fleisch darin einlegen",d:"Für die Marinade 2 TL Kartoffelmehl, 3 EL Sojasoße und 2 TL Wallnussöl vermischen. Das Fleisch in 2 cm große Streifen schneiden, in eine Schüssel legen, die Marinade hinzugeben, die Fleischstücke gut miteinander vermengen und abgedeckt ca. 30 Min im Kühlschrank marinieren lassen."},{s:2,n:"Gemüse vorbereiten",d:"Die dünnen Bohnen an beiden Enden abschneiden. Die Bambusstreifen in einem Sieb abtropfen lassen. Die Zwiebel schälen und achteln. Die Knoblauchzehen leicht andrücken."},{s:3,n:"Gemüse und Fleisch anbraten",d:"Nun wird der Wok mit Wallnussöl erhitzt und den Knoblauch, die Zwiebel, die Bohnen, Cashewkerne und Bambusstreifen zugeben und ca. 5 Min. anbraten. Das Fleisch in ein Sieb geben, kurz abtropfen lassen und dann ebenso in den Wok unter ständigem Rühren anbraten."},{s:4,n:"Soße zubereiten",d:"Man erhitzt und den Wasserkocher mit ca. 300 ml Wasser. Gibt dann das heiße Wasser in einen Behälter mit der Brühe und fügt noch Sojasoße hinzu. In einer weiteren kleinen Schüssel wird noch Kartoffelmehl und kaltes Wasser miteinander glattgerührt. Gibt es nun in den Behälter mit der Brühe, verrührt dies und gießt die Soße in den Wok. Kurz aufkochen lassen, Hitze reduzieren und weitere 3-5 Min. köcheln."},{s:5,n:"Abschmecken und servieren",d:"Zum Schluss noch mit Salz und Pfeffer abschmecken und sofort servieren. Dazu gab es bei uns Reis. Na dann. Guten Appetit"}],p:"00:30",c:"00:15",tot:55,srv:"4",cats:["Fleisch"]},{id:1740,t:"Schweinefilet Mit Tomate Mozzarella",i:[{n:"Schweinefilet",u:"g",a:"400"},{n:"Basilikumpesto oder Pesto Rosso",u:"",a:""},{n:"große Tomaten",u:"Stk",a:"3"},{n:"Mozzarellakäse",u:"Stk",a:"2"}],st:[{s:1,n:"Tomaten und Mozzarella in Scheiben schneiden",d:"Die Tomaten werden gewaschen und zusammen mit dem Mozzarella-Käse in Scheiben geschnitten."},{s:2,n:"Schweinefilet vorbereiten",d:"Das Schweinefilet wird mit kaltem Wasser abgewaschen, trockengetupft und von Fett und Sehnen befreit. Je nach Größe der Pfanne kann man das Filet im Ganzen oder einmal in der Mitte geteilt anbraten."},{s:3,n:"Ofen vorheizen und Fleisch anbraten",d:"Jetzt wird der Ofen auf 200 Grad vorhgeheizt. In die gusseiserne Pfanne gibt man Butterschmalz und erhitzt dies. Erst wenn das Fett heiß geworden ist, wird das Filet hinzugegeben und von allen Seiten kross angebraten. Danach nehme ich das Fleisch heraus und schneide es in ca. 1-2 cm dicke Scheiben, gebe diese zurück in die Pfanne und brate diese nochmals ca. 1 Min von beiden Seiten mit Salz und Pfeffer kurz an."},{s:4,n:"Fleisch im Ofen überbacken",d:"Die Pfanne wird nun mit den Filetscheiben vom Herd genommen und mit Pesto, Tomaten und Mozzarella - Käse belegt. Alles zusammen geht jetzt noch einmal für ca. 5 Min in den Ofen. Sobald der Käse leicht zerlaufen ist, darf serviert werden. Basilikumblätter drüber und fertig."},{s:5,n:"Tipp",d:'Wer etwas mehr Zeit aufwenden möchte, darf natürlich das Pesto auch selbst zubereiten. In meinem Blog findet Ihr unter anderem ein leckeres Rezept zu einem Selbstgemachtes Tomatenpesto "“ fruchtig und herzhaft zubereitet. Wer mag, würzt die einzelnen Filetscheiben mit ein paar Tropfen schwarzem Balsamicoessig. Guten Appetit.'}],p:"00:10",c:"00:15",tot:30,srv:"4",cats:["Fleisch","Vegetarisch"]},{id:1742,t:"Wok Gemuse Mit Kokosmilch",i:[{n:"Möhren",u:"Stk",a:"1.5"},{n:"Shitakepilze",u:"Glas",a:"1"},{n:"Bohnensprossen",u:"g",a:"100"},{n:"chin. Nudeln",u:"g",a:"150"},{n:"Paprikaschoten",u:"Stk",a:"1.5"},{n:"mittlere Zucchini",u:"Stk",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"3"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Kokosmilch",u:"ml",a:"150"},{n:"Sojasoße",u:"EL",a:"2"},{n:"Currypaste",u:"TL",a:"2"},{n:"Austernsoße",u:"EL",a:"1"},{n:"Wasser",u:"ml",a:"100"},{n:"Maiskeimöl",u:"EL",a:"2"}],st:[{s:1,n:"Eiernudeln kochen",d:"Zu Beginn wird der Wok mit etwas Salzwasser erhitzt und die Eiernudeln für ca. 5 min bissfest gekocht."},{s:2,n:"Gemüse vorbereiten",d:"Während dessen schneidet man das Gemüse klein. Dafür schält man die Möhren und schneidet sie in schmale Sticks. Vom Zwiebellauch entfernt man die Wurzel sowie 1/3 vom oberen Grün und schneidet den verbleibenden Rest in Ringe. Die Paprikaschote wird halbiert, die Kerne entfernt und in schmale Streifen geschnitten. Nun folgt die Zucchini, welche man in dünne Ringe schneidet. Die Knoblauchzehe wird grob gehackt. Die Shitakepilze läßt man in einem Sieb abtropfen."},{s:2,n:"Gemüse vorbereiten",d:"Während dessen schneidet man das Gemüse klein. Dafür schält man die Möhren und schneidet sie in schmale Sticks. Vom Zwiebellauch entfernt man die Wurzel sowie 1/3 vom oberen Grün und schneidet den verbleibenden Rest in Ringe. Die Paprikaschote wird halbiert, die Kerne entfernt und in schmale Streifen geschnitten. Nun folgt die Zucchini, welche man in dünne Ringe schneidet. Die Knoblauchzehe wird grob gehackt. Die Shitakepilze läßt man in einem Sieb abtropfen."},{s:3,n:"Soße zubereiten",d:"Für die Soße füllt man 150 ml Kokosmilch, 2 EL Sojasoße, 2 TL Currypaste und 1 EL Austernsoße in eine Schüssel und verrührt dies miteinander."},{s:3,n:"Soße zubereiten",d:"Für die Soße füllt man 150 ml Kokosmilch, 2 EL Sojasoße, 2 TL Currypaste und 1 EL Austernsoße in eine Schüssel und verrührt dies miteinander."},{s:4,n:"Gemüse im Wok anbraten",d:"Alle Zutaten werden in die Nähe vom Herd gestellt. Den Wok erhitzt man nun mit 2 EL Maiskeimöl. Sobald dies sehr heiß geworden ist, fügt man die Zwiebellauchringe und den Knoblauch hinzu und brät dies kurz 1 Min. an. Es folgen die Möhren und die Shitakepilze. Nach weiteren 3 Min gibt man die Paprikastreifen, die Zucchini und die Bohnensprossen in den Wok."},{s:4,n:"Gemüse im Wok anbraten",d:"Alle Zutaten werden in die Nähe vom Herd gestellt. Den Wok erhitzt man nun mit 2 EL Maiskeimöl. Sobald dies sehr heiß geworden ist, fügt man die Zwiebellauchringe und den Knoblauch hinzu und brät dies kurz 1 Min. an. Es folgen die Möhren und die Shitakepilze. Nach weiteren 3 Min gibt man die Paprikastreifen, die Zucchini und die Bohnensprossen in den Wok."},{s:5,n:"Kokossoße und Nudeln in den Wok geben",d:"Nach ca. 2-3 Min. wird die Kokossoße und evtl. 100 ml heißes Wasser dazu gegeben und bei reduzierter Hitze ca. 3-4 Min. köcheln gelassen. Zum Schluss gibt man nun noch die Nudeln hinzu und hebt diese vorsichtig drunter. Fertig. Guten Appetit"},{s:5,n:"Kokossoße und Nudeln in den Wok geben",d:"Nach ca. 2-3 Min. wird die Kokossoße und evtl. 100 ml heißes Wasser dazu gegeben und bei reduzierter Hitze ca. 3-4 Min. köcheln gelassen. Zum Schluss gibt man nun noch die Nudeln hinzu und hebt diese vorsichtig drunter. Fertig. Guten Appetit"}],p:"00:20",c:"00:15",tot:45,srv:"4",cats:["Asiatisch"]},{id:1749,t:"Rindfleisch Mit Zuckererbsen",i:[{n:"Rindfleisch in 2 cm schmale Streifen schneiden)",u:"g",a:"400"},{n:"Bambusstreifen",u:"g",a:"100"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Zuckererbsen",u:"g",a:"250"},{n:"Kartoffelmehl",u:"Tl",a:"2"},{n:"Sojasauce",u:"El",a:"2"},{n:"Erdnuss oder Mandelöl",u:"Tl",a:"2"},{n:"Brühe",u:"ml",a:"125"},{n:"Sojasauce",u:"El",a:"2"},{n:"Kartoffelmehl",u:"Tl",a:"1"},{n:"Sherry/Reiswein",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""},{n:"Erdnussöl",u:"",a:""}],st:[{s:1,n:"Rindfleisch in Streifen schneiden",d:"Das Rindfleisch in dünne Streifen schneiden und in einer Schüssel zur Seite stellen."},{s:2,n:"Marinade anrühren",d:"Für die Marinade werden 2 EL Sojasoße, 2 TL Erdnuss- oder Mandelöl sowie 2 TL Kartoffelmehl miteinander glattgerührt. Diese Marinade wird zum Fleisch gegeben, gut miteinander vermengt und für ca. 20 min abgedeckt in den Kühlschrank gegeben"},{s:3,n:"Gemüse vorbereiten",d:"Währenddessen gibt man die Bambusstreifen in ein Sieb und läßt sie gut abtropfen. Für die Zuckererbsen erhitzt man einen Topf mit Wasser und gibt diese für ca. 3 Min. in das kochende Wasser. Danach werden sie mit kaltem Wasser abgeschreckt und zur Seite gestellt. Zum Schluss achtelt man eine Zwiebel und schneidet eine Knoblauchzehe in feine Streifen."},{s:4,n:"Soße zubereiten",d:"Für den letzten Schritt der Vorbereitung wird Wasser für eine Brühe aufgesetzt, mit Sojasoße und einem TL Kartoffelmehl verrührt."},{s:5,n:"Gemüse und Fleisch anbraten",d:"In den Wok mit dem sehr heiß erhitztem Öl wird der Knoblauch, die Zwiebel, die Zuckererbsen sowie die Bambusstreifen hinzugegeben und für ca. 3 Min angebraten. Das marinierte Fleisch kann nun hinzugegeben und für weitere 3 Minuten mitgebraten werden. Nun gibt man Brühemischung mit einem Schuss Sherry oder Reiswein in den Wok, vermengt diese mit dem Gemüse und läßt sie kurz aufkochen. Dann die Hitze reduzieren und für ca. 3 Minuten köcheln lassen."},{s:6,n:"Abschmecken und servieren",d:"Das fertige Gericht nochmals mit Salz und Pfeffer abschmecken und sofort servieren. Dazu gibt es Reis. Guten Appetit"}],p:"00:20",c:"00:20",tot:50,srv:"4",cats:["Fleisch"]},{id:1754,t:"Rindfleisch Mit Bohnensprossen",i:[{n:"Rindfleisch",u:"g",a:"200"},{n:"Möhre",u:"Stk",a:"0.5"},{n:"kleine braune Champignons",u:"Stk",a:"6"},{n:"gelbe Paprika",u:"Stk",a:"0.5"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"kleine Chilischoten",u:"Stk",a:"2"},{n:"Bohnensprossen",u:"g",a:"50"},{n:"dünne Scheiben Ingwer",u:"Stk",a:"6"},{n:"Sojasauce",u:"El",a:"2"},{n:"Teryakisauce",u:"El",a:"2"},{n:"Kartoffelmehl",u:"Tl",a:"1"},{n:"Kokosmilch",u:"El",a:"2"},{n:"Sojasauce",u:"El",a:"1.5"},{n:"Reisessig",u:"El",a:"2"},{n:"Zucker",u:"Tl",a:"1"}],st:[{s:1,n:"Rindfleisch in Streifen schneiden und marinieren",d:"Das Rindfleisch wird unter kaltem Wasser abgewaschen, trockengetupf, in 2 cm schmale Streifen geschnitten und in einer Schüssel zur Seite gestellt. Für die Marinade nimmt man 2 EL dunkle Sojasoße, 1 EL Teryakisoße sowei 1 TL Kartoffelmehl, rührt dies glatt und gibt es zu dem Fleisch in die Schüssel. Gut miteinander vermengen und für ca. 20 min in den Kühlschrank geben."},{s:2,n:"Nudeln kochen",d:"Nun erhitzt man entweder den Wok oder einen Topf mit Salzwasser und kocht die chinesischen Nudeln für ca. 3-5 Min bissfest. Danach werden sie abgeschreckt und zur Seite gestellt."},{s:3,n:"Gemüse vorbereiten",d:"Während das Fleisch mariniert und die Nudeln kochen wird das Gemüse kleingeschnitten. Dazu schneidet man eine halbe Paprika in grobe Stücke, den Zwiebellauch in Ringe, die halbe Möhre in schmale Streifen, den Knoblauch und den Ingwer in dünne sowie die Champignons in dicke Scheiben.Da ich mich heute selbst verköstigen durfte, wurden noch 2 frische kleine Chilischoten in Ringe geschnitten."},{s:4,n:"Soße zubereiten",d:"In einer weiteren Schüssel wird nun die Kokosmilch (2 EL), die Sojasoße (1,5 EL), der Reisessig (2 EL) und der Zucker miteinander verrührt. Ich bereite zu den asiatischen Gerichten immer noch 0,1 l heißes Wasser vor. Für den Fall, dass die Soße nicht ausreichen sollte, kann man diese mit dem Wasser noch etwas strecken."},{s:5,n:"Gemüse und Fleisch scharf anbraten",d:"Jetzt werden alle Zutaten und Soßen in die Nähe der Kochfläche gestellt. Im Gericht \\Rindfleisch mit Zuckererbsen\\ habe ich bereits ausführlich von der Notwendigkeit geschrieben.Der Wok wird mit Maiskeimöl sehr stark erhitz. Nun gibt man die Zwiebellauchringe, den Knoblauch und die Ingwerscheiben hinzu und brät diese ca. 2 Min. an. Es folgt das Fleisch 2-3 Min. Danach werden die Pilze, die Paprikastücke, die Möhren, die Chilischoten und die Bohnensprossen hineingeben und ebenfalls kurz mitgebraten. Die Kokossoße und evtl. Wasser gießt man nun hinzu und läßt alles zusammen bei reduzierter Hitze für ca. 3 Min. köcheln."},{s:6,n:"Anrichten und servieren",d:"Ganz zum Schluss werden die gekochten Nudeln untergehoben. Fertig. Es darf sofort heiß serviert werden. Guten Appetit"},{s:6,n:"Anrichten und servieren",d:"Ganz zum Schluss werden die gekochten Nudeln untergehoben. Fertig. Es darf sofort heiß serviert werden. Guten Appetit"}],p:"00:20",c:"00:15",tot:45,srv:"2",cats:["Fleisch"]},{id:1761,t:"Bechamelsose",i:[{n:"Zwiebel",u:"Stk",a:"1"},{n:"kl. Stück Speck/Schinken",u:"",a:"1"},{n:"Butter",u:"g",a:"100"},{n:"Milch",u:"l",a:"0.75"},{n:"Mehl",u:"g",a:"75"},{n:"Muskat",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Speck und Zwiebel in Butter anschwitzen",d:"Für die Mehlschwitze gibt man den Speck, die kleingeschnitte Zwiebel und die Butter in eine Pfanne oder einen Topf und schwitzt alles langsam an."},{s:2,n:"Mehl hinzufügen und einrühren",d:"Sobald die Butter flüssig geworden und die Zwiebeln glasig gebraten wurden, wird das Mehl in die Pfanne gegeben und in die Butter eingerührt. Hier muß sehr sorgfältig gearbeitet werden, da später in der Soße keine Mehlklümpchen zurückbleiben sollen."},{s:2,n:"Mehl hinzufügen und einrühren",d:"Sobald die Butter flüssig geworden und die Zwiebeln glasig gebraten wurden, wird das Mehl in die Pfanne gegeben und in die Butter eingerührt. Hier muß sehr sorgfältig gearbeitet werden, da später in der Soße keine Mehlklümpchen zurückbleiben sollen."},{s:3,n:"Milch unterrühren und Soße abschmecken",d:"Sobald beides miteinander verbunden ist, fügt man nun die Milch unter ständigem Rühren in den Topf und läßt dann alles ca. 8 Min. leicht vor sich hinköcheln. Währenddessen würzt man die Soße mit Salz, Pfeffer und Muskat. Zum Schluss kann auch noch etwas Butter hinzugefügt werden."},{s:3,n:"Milch unterrühren und Soße abschmecken",d:"Sobald beides miteinander verbunden ist, fügt man nun die Milch unter ständigem Rühren in den Topf und läßt dann alles ca. 8 Min. leicht vor sich hinköcheln. Währenddessen würzt man die Soße mit Salz, Pfeffer und Muskat. Zum Schluss kann auch noch etwas Butter hinzugefügt werden."},{s:4,n:"Soße passieren",d:"Die Konsistenz der Soße sollte leicht sämig sein. Also nicht zu dick aber auch nicht zu dünnflüssig. Nochmals abschmecken und dann gibt man alles durch ein feines Sieb in eine Schüssel. Mit dem Löffel drückt man noch vorsichtig den Sud durch das Sieb. Fertig. Nun kann die Soße zum weiteren Verarbeiten verwendet werden. :-)"},{s:4,n:"Soße passieren",d:"Die Konsistenz der Soße sollte leicht sämig sein. Also nicht zu dick aber auch nicht zu dünnflüssig. Nochmals abschmecken und dann gibt man alles durch ein feines Sieb in eine Schüssel. Mit dem Löffel drückt man noch vorsichtig den Sud durch das Sieb. Fertig. Nun kann die Soße zum weiteren Verarbeiten verwendet werden. :-)"}],p:"00:5",c:"00:15",tot:25,srv:"1",cats:["Vegetarisch"]},{id:1767,t:"Mediterane Nudeln Mit Antipasti",i:[{n:"Nudeln (Penne)",u:"",a:""},{n:"mittelgroße Zucchini",u:"Stk",a:"1"},{n:"Paprikaschoten",u:"Stk",a:"3"},{n:"Aubergine",u:"Stk",a:""},{n:"frische kleine Champignons",u:"g",a:"300"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"schwarzer Balsamico Essig",u:"EL",a:"3"},{n:"Sojasoße",u:"EL",a:"2"},{n:"Zucker",u:"",a:""},{n:"Pfeffer",u:"",a:""}],st:[{s:1,n:"Nudeln kochen",d:"Es wird ein Topf mit Salzwasser aufgesetzt und die Nudeln darin bissfest gekocht."},{s:2,n:"Gemüse vorbereiten",d:"Währendessen wird das Gemüse abgwaschen und vorbereitet. Dafür schneidet man den Paprika in grobe Stücke und die Champignons werden halbiert. Von der Zucchini entfernt man die Enden und schneidet den Rest in dünne Scheiben. Der Knoblauch wird ebenso in sehr feine Scheiben geschnitten und zum Zucchini gegeben. Als Letztes sollte die Aubergine geschnitten werden. Dadurch vermeidet man die bräunliche Färbung, welche entsteht, wenn dieses Gemüse zu lange der Luft ausgesetzt ist. Für diese Gericht halbiere ich die Aubergine und schneide nur eine Hälfte in dünne Scheiben."},{s:3,n:"Aubergine anbraten und mit Nudeln vermengen",d:"Sollten die Nudeln jetzt schon fertig sein, so gießt man das Wasser ab und gibt die Nudeln schon in eine große Schüssel. Nun wird eine Pfanne mit 2 EL Öl erhitzt und die Auberginenscheiben ca. 4 Min. mit Salz und Pfeffer angebraten und zu den Nudeln in die Schüssel gegeben."},{s:4,n:"restliches Gemüse anbraten",d:"In die gleiche Pfanne wird jetzt nochmals Öl gegeben und der Paprika und die Champignons ca. 7 min angebraten. Nach ca. 3 Minuten gibt man die Zucchini und den Knoblauch hinzu."},{s:5,n:"Soße anrühren und mit Gemüse köcheln lassen",d:"Alles zusammen mit 3 EL Balsamico Essig, 2 EL Sojasoße und 0,1 l Wasser ablöschen und einkochen. Sollte es noch zu essighaltig schmecken, gibt man einfach noch etwas Zucker hinzu."},{s:6,n:"Gemüse abschmecken und mit Nudeln vermengen",d:"Zum Schluss wird das Gemüse evtl. nochmals mit Sojasoße und Pfeffer abgeschmeckt und dann zu den Nudeln in die Schüssel gegeben. Das Gemüse und die Nudeln gut miteinander vermengen und lauwarm servieren. Der Nudelsalat kann jedoch auch für jede Party vorbereitet und kalt serviert werden. Guten Appetit"}],p:"00:10",c:"00:30",tot:45,srv:"6",cats:["Pasta & Nudeln","Vegetarisch"]},{id:1769,t:"Steak Mit Speckbohnen",i:[{n:"Rindfleisch im Stück",u:"g",a:"700"},{n:"grüne Bohnen",u:"g",a:"300"},{n:"Baconscheiben",u:"",a:""},{n:"Kartoffeln",u:"kg",a:"1"},{n:"Rosmarin",u:"",a:""},{n:"Knoblauchzehen",u:"",a:""},{n:"Butterschmalz",u:"",a:""},{n:"Steaksauce (Rezept auf der Seite)",u:"",a:""}],st:[{s:1,n:"Bohnen zubereiten",d:"Bevor das Fleisch jedoch zubereitet werden kann, muß man die Bohnen vorbereiten. Dazu entfernt man die Enden von den ganzen Bohnen und gibt diese in gesalzenes Wasser. Bohnenkraut dazu und ca. 10-20 kochen. Achtet darauf, daß sie nicht zu weich gekocht werden. Sobald die Bohnen bissfest gegart wurden, werden sie mit kaltem Wasser \\abgeschreckt\\. Dabei garen sie nicht nach und behalten ihre grüne Farbe."},{s:2,n:"Speckbohnen anbraten und Ofen vorheizen",d:"Jetzt legt man die Baconscheiben aus und rollt die Bohnen in kleine Päckchen zusammen. Sobald die Steaks im Ofen liegen, werden die Bohnenröllchen in einer Pfanne angebraten. Der Ofen kann nun auf ca. 80 Grad vorgeheizt werden."},{s:3,n:"Steaks vorbereiten",d:"Das Rindersteak sollte beim Fleischer im ganzen Stück geholt werden. Wer es mag, kann sich das Fleisch jedoch auch schon dort portionieren lassen. Dabei solltet Ihr jedoch darauf achten, daß die Scheiben eine Dicke von 3-6 cm haben. Wären sie dünner, würden die Steaks beim braten zu schnell austrocknen. Vor dem braten sollten die Steaks Zimmertemperatur angenommen haben. Danach werden sie mit klarem kalten Wasser abgespült und mit Küchenpapier trockengetupft. Dies ist wichtig, da sonst das Wasser in der Pfanne spritzen würde."},{s:4,n:"Steaks scharf anbraten",d:"Nun erhitzt man die Pfanne mit Butterschmalz. Alles andere wie Olivenöl, Butter oder Sonnenblumenöl würde bei Temperaturen von ca. 170 Grad nur verbrennen und das Fleisch bitter werden lassen. Nachdem die Pfanne heiß genug ist, wird das überflüssige Schmalz entfernt. Es sollte nur ein leichter fettiger Film zum braten genommen werden. Die Steaks werden nun in die Pfanne gegeben und jeweils ca. 2 Min. kross angebraten. Dabei sollten die Fleischscheiben nicht bewegt werden. Ich gebe zum Schluss noch kurz ein paar Rosmarinzweige und Knoblauchzehen hinzu, sodaß auch diese kurz Röstaromen entwickeln können."},{s:5,n:"Steaks mit Rosmarin umwickeln und im Ofen garen",d:"Nachdem die Steaks angebraten wurden, wickelt man diese mit den Rosmarinzweigen und dem Knoblauch in eine Alufolie und legt sie für ca. 10 - 20 min bei 180 Grad in den Ofen. Die Dauer hängt vom gewünschten Garzustand ab. Nach 20 Min. wird das Fleisch herausgenommen und für ca. 10 Min. auf einem Teller ruhen gelassen werden."},{s:6,n:"Fleisch in Buttersoße wenden",d:"Währenddessen halbiert man die Knoblauchzehen. Die gusseiserne Pfanne wird nun mit Butter auf mittlere Temperatur erhitzt und mit den halbierten Knoblauchzehen sowie den Rosmarinzweigen befüllt. Nun kann das Fleisch nochmals für ca. 1-2 Min in der Rosmarin, Buttersoße gebraten werden. Jetzt ist der Zeitpunkt gekommen, das Fleisch kräftig mit Salz und Pfeffer zu würzen."},{s:7,n:"Anrichten und servieren",d:"Danach darf es serviert werden. Ich habe heute aus Zeitmangel einfach in Salzwasser gekochte Kartoffeln gewählt. Dazu verteilt man die Steaksoße auf dem Tellerrand. Guten Appetit"}],p:"00:10",c:"00:30",tot:50,srv:"4",cats:["Fleisch"]},{id:1775,t:"Steaksose",i:[{n:"Zwiebel",u:"Stk",a:"1"},{n:"schwarzer Balsamico Essig",u:"EL",a:"3"},{n:"brauner/weißer Zucker",u:"EL",a:"2"},{n:"Rotwein",u:"l",a:"1"},{n:"Worchester Sauce",u:"ml",a:"50"},{n:"Sojasoße",u:"EL",a:"3"},{n:"Teriyaki Sauce",u:"EL",a:"2"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Senf",u:"TL",a:"2"}],st:[{s:1,n:"Zwiebel würfeln",d:"Hierzu wird eine mittelgroße Zwiebel in sehr feine Würfel geschnitten. Des weiteren sollten alle Zutaten bereitstehen, da sonst Hektik am Herd entstehen könnte. :-)"},{s:2,n:"Zwiebel glasig dünsten und verfeinern",d:"Nun erhitzt man eine Pfanne mit etwas Sonnenblumenöl und schwitzt die Zwiebeln bei mittlerer Hitze unter ständigem Rühren an. Sobald sie leicht glasig geworden sind, gibt man 3 EL Balsamico Essig und 2 EL Zucker hinzu. Brauner Zucker wäre gut, weißer tut es jedoch auch. Ich gebe jetzt noch ca. 0,1 l Rotwein hinzu und lass es ca. 2 Min. einkochen. Der saure Essiggeruch sollte währenddessen verkocht sein."},{s:2,n:"Zwiebel glasig dünsten und verfeinern",d:"Nun erhitzt man eine Pfanne mit etwas Sonnenblumenöl und schwitzt die Zwiebeln bei mittlerer Hitze unter ständigem Rühren an. Sobald sie leicht glasig geworden sind, gibt man 3 EL Balsamico Essig und 2 EL Zucker hinzu. Brauner Zucker wäre gut, weißer tut es jedoch auch. Ich gebe jetzt noch ca. 0,1 l Rotwein hinzu und lass es ca. 2 Min. einkochen. Der saure Essiggeruch sollte währenddessen verkocht sein."},{s:3,n:"restliche Zutaten unterrühren und Soße abschmecken",d:"Jetzt folgen 50 ml Worchester Sauce, 3 EL Sojasoße, 2 EL Teriyaki Sauce, 2 EL Tomatenmark und 2 TL Senf. Alles zusammen darf gut verrührt werden. Sollte die Soße zu dickflüssig sein, kann noch etwas Wasser hinzugeben werden. Für etwas Schärfe darf gern noch mit Tabasco oder Chili nachgewürzt werden."},{s:3,n:"restliche Zutaten unterrühren und Soße abschmecken",d:"Jetzt folgen 50 ml Worchester Sauce, 3 EL Sojasoße, 2 EL Teriyaki Sauce, 2 EL Tomatenmark und 2 TL Senf. Alles zusammen darf gut verrührt werden. Sollte die Soße zu dickflüssig sein, kann noch etwas Wasser hinzugeben werden. Für etwas Schärfe darf gern noch mit Tabasco oder Chili nachgewürzt werden."},{s:4,n:"Tipp",d:"Fertig.Diese Sauße soll das Gericht geschmacklich unterstützen. Sie darf also sehr würzig zubereitet sein und wird dezent auf dem Teller verteilt. Serviert werden kann es warm oder kalt. Warm ist jedoch mein Favorit. Guten Appetit"},{s:4,n:"Tipp",d:"Fertig.Diese Sauße soll das Gericht geschmacklich unterstützen. Sie darf also sehr würzig zubereitet sein und wird dezent auf dem Teller verteilt. Serviert werden kann es warm oder kalt. Warm ist jedoch mein Favorit. Guten Appetit"}],p:"00:5",c:"00:15",tot:20,srv:"1",cats:["Fleisch"]},{id:1777,t:"Bunter Salat Mit HäHnchenfilet   Herdzeit.De",i:[{n:"Salatherzen",u:"Stk",a:"3"},{n:"Radieschen",u:"Bd",a:"1"},{n:"Paprikaschoten",u:"Stk",a:"3"},{n:"Kirschtomaten",u:"",a:""},{n:"Hähnchenbrusfilet",u:"g",a:"500"},{n:"Balsamico-Vinaigrette",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Salat vorbereiten",d:"Das Gemüse wird abgewaschen und kleingeschnitten. Die Kirschtomaten halbieren, die Radieschen in Scheiben und den Paprika in schmale Streifen schneiden. Von den Salatherzen werden die Blätter einzeln entfernt und unter kaltem Wasser kurz abgespült."},{s:2,n:"Salat anrichten",d:"Ich richte jetzt schon die Teller an um später die gebratenen Hähnchenfilets sofort heiß auf dem Salat präsentieren zu können. Wer es mag, gibt noch Zwiebelringe hinzu."},{s:3,n:"Hähnchenfilet anbraten und würzen",d:"Nun gibt man die abgespülten und trockengetupften Hähnchenfilets in eine mit Butter erhitzte Pfanne. Jetzt brät man das Fleisch ca. 5 min von allen Seiten kross an und würzt dies zum Schluss mit Salz und Pfeffer."},{s:4,n:"Hähnchenfilet auf Salat anrichten und mit Vinaigrette beträufeln",d:"Das Hähnchenfilet kann nun sofort auf den Salat gegeben und mit der Balsamico-Vinaigrette verfeinert werden. Fertig. Guten Appetit"}],p:"00:20",c:"00:10",tot:40,srv:"4",cats:["Geflügel","Salate"]},{id:1779,t:"Balsamico Vinaigrette",i:[{n:"schwarzer Balsamico Essig",u:"EL",a:"6"},{n:"Sonnenblumenöl",u:"EL",a:"6"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Dijonsenf",u:"TL",a:"1"},{n:"Salz",u:"TL",a:"1"},{n:"Honig",u:"TL",a:""},{n:"Pfeffer",u:"",a:""}],st:[{s:1,n:"Dressing zubereiten",d:"Hierfür nehme ich ein schmale Schüssel mit einem hohen Rand. Das Dressing wird später mit dem Stabmixer pürriert. Durch den Rand vermeide ich natürlich nur die Spritzer. Man nehme also 6 EL schwarzen Balsamicoessig, eine grobgehackte Knoblauchzehe, einen TL Dijonsenf, 1 TL Salz, 1-2 TL Honig sowie Pfeffer aus der Mühle. Jetzt werden alle Zutaten kräftig miteinander gemixt."},{s:2,n:"Dressing verfeinern und Öl unterrühren",d:"Evtl. muß das Dressing noch einmal mit den o.g. Zutaten verfeinert werden. Sobald der richtige Geschmack \\gefunden\\ wurde, gibt man zum Schluss 6 EL Sonnenblumenöl hinzu und mixt die Soße noch einmal kräftig durch. Wichtig ist, das Öl zum Schluss hinzugegeben um die Vinaigrette zu konservieren. Der Geschmack wird somit \\eingeschlossen\\. Im Kühlschrank hält dies dann ca. 2 Wochen. Wie gesagt, diese Salatsoße sollte sehr würzig abgeschmeckt und nur dezent auf dem Salat verteilt werden. Guten Appetit:-)"}],p:"00:15",c:"00:00",tot:15,srv:"1",cats:["Salate"]},{id:1781,t:"Huhnersuppe",i:[{n:"Huhn",u:"Stk",a:"1"},{n:"Porree",u:"Stange",a:"1"},{n:"Sellerie",u:"Knolle",a:"1"},{n:"Möhren",u:"Stk",a:"3"},{n:"Zwiebeln",u:"Stk",a:"1.5"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Suppengemüse (gefroren)",u:"",a:""},{n:"Hackfleisch",u:"g",a:"250"},{n:"Senf",u:"",a:""},{n:"Ei",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Pimentkörner",u:"Stk",a:"6"},{n:"Pfefferkörner",u:"",a:""},{n:"Lorbeerblätter",u:"Stk",a:"2"},{n:"Butter",u:"EL",a:"1"},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Huhn im Topf erhitzen",d:"Dazu setzt man einen großen Topf mit kaltem Wasser auf den Herd und legt das abgespülte ganze Huhn hinein. Während der Topf also langsam erhitzt wird, schneidet man das Suppengrün klein."},{s:2,n:"Suppengrün kleinschneiden",d:"Ich nehme hierzu nicht die abgepackten Suppengrünpakete, sondern kaufe diese Zutaten einzeln. Also eine ganze Porreestange, eine Sellerieknolle und 3 Möhren. Diese werden geschält, grob zerkleinert und in den Topf gegeben. Eine Zwiebel und 2 Knoblauchzehen folgen umgehend. Gewürzt wird das ganze mit 6 Pimentkörnern, Pfefferkörner, 2 Lorbeerblättern und Salz."},{s:2,n:"Suppengrün kleinschneiden",d:"Ich nehme hierzu nicht die abgepackten Suppengrünpakete, sondern kaufe diese Zutaten einzeln. Also eine ganze Porreestange, eine Sellerieknolle und 3 Möhren. Diese werden geschält, grob zerkleinert und in den Topf gegeben. Eine Zwiebel und 2 Knoblauchzehen folgen umgehend. Gewürzt wird das ganze mit 6 Pimentkörnern, Pfefferkörner, 2 Lorbeerblättern und Salz."},{s:3,n:"Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/h_yWQk3iRfI\\ width=\\480\\ height=\\360\\]"},{s:3,n:"Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/h_yWQk3iRfI\\ width=\\480\\ height=\\360\\]"},{s:4,n:"Schaum von Wasseroberfläche abschöpfen",d:"Sobald das Wasser kocht, darf es runterreguliert werden und bei geschlossenem Deckel ca. 1,5h köchel. Zwischendurch wird der Schaum immer wieder von der Wasseroberfläche abgeschöpft."},{s:4,n:"Schaum von Wasseroberfläche abschöpfen",d:"Sobald das Wasser kocht, darf es runterreguliert werden und bei geschlossenem Deckel ca. 1,5h köchel. Zwischendurch wird der Schaum immer wieder von der Wasseroberfläche abgeschöpft."},{s:5,n:"Gemüse und Huhn aus dem Topf nehmen",d:"Nach den ca. 1,5h entnimmt man das Huhn und legt es zum abkühlen auf einen Teller zur Seite. Ich schöpfe nun das ganze Gemüse aus der Hühnersuppe. Wenn man eine weitere große Schüssel oder einen großen Topf haben sollte, so kann man alles auch einfach durch ein Sieb gießen. Dabei lohnt es sich, den restlichen Saft aus dem Gemüse vorsichtig durch das Sieb zu drücken."},{s:5,n:"Gemüse und Huhn aus dem Topf nehmen",d:"Nach den ca. 1,5h entnimmt man das Huhn und legt es zum abkühlen auf einen Teller zur Seite. Ich schöpfe nun das ganze Gemüse aus der Hühnersuppe. Wenn man eine weitere große Schüssel oder einen großen Topf haben sollte, so kann man alles auch einfach durch ein Sieb gießen. Dabei lohnt es sich, den restlichen Saft aus dem Gemüse vorsichtig durch das Sieb zu drücken."},{s:6,n:"Hühnerfleisch zerkleinern",d:"Nun sollte das Huhn soweit abgekühlt sein, daß man das Fleisch abrupfen, leicht zerkleinern und in den Topf geben kann."},{s:6,n:"Hühnerfleisch zerkleinern",d:"Nun sollte das Huhn soweit abgekühlt sein, daß man das Fleisch abrupfen, leicht zerkleinern und in den Topf geben kann."},{s:7,n:"Hackfleisch würzen, zu Kugeln formen und in die Suppe geben",d:"Nun wird noch schnell das Hackfleisch vorbereitet. Man nehme eine Schüssel und fülle diese mit Hackfleisch, Salz, Pfeffer, Dijonsenf, Majoran, Ei und Semmelbrösel. Alles gut durchkneten, zu kleinen Kugeln formen und zu der Suppe in den Topf geben. Nun folgt noch das Suppengemüse (z.B. Leipziger Allerlei). Die Suppe darf noch ca. 10 min leicht köcheln."},{s:7,n:"Hackfleisch würzen, zu Kugeln formen und in die Suppe geben",d:"Nun wird noch schnell das Hackfleisch vorbereitet. Man nehme eine Schüssel und fülle diese mit Hackfleisch, Salz, Pfeffer, Dijonsenf, Majoran, Ei und Semmelbrösel. Alles gut durchkneten, zu kleinen Kugeln formen und zu der Suppe in den Topf geben. Nun folgt noch das Suppengemüse (z.B. Leipziger Allerlei). Die Suppe darf noch ca. 10 min leicht köcheln."},{s:8,n:"Nudeln kochen",d:"Währenddessen setze ich einen kleinen Topf mit Wasser für Nudeln auf. Diese gebe ich später auf den Teller zur Hühnersuppe und nicht in den Topf. Wenn man die Hühnersuppe 2 Tage essen möchte, so würden die Nudeln im Topf einfach nur weich und labrig werden. Das kann man mit der einzelnen Verarbeitung vermeiden."},{s:8,n:"Nudeln kochen",d:"Währenddessen setze ich einen kleinen Topf mit Wasser für Nudeln auf. Diese gebe ich später auf den Teller zur Hühnersuppe und nicht in den Topf. Wenn man die Hühnersuppe 2 Tage essen möchte, so würden die Nudeln im Topf einfach nur weich und labrig werden. Das kann man mit der einzelnen Verarbeitung vermeiden."},{s:9,n:"Suppe kräftig würzen",d:"Zum Schluss wird die Suppe noch kräftig mit Salz und Butter abgeschmeckt. Dann darf es auch schon serviert werden. Gesundheit und guten Appetit :-)"},{s:9,n:"Suppe kräftig würzen",d:"Zum Schluss wird die Suppe noch kräftig mit Salz und Butter abgeschmeckt. Dann darf es auch schon serviert werden. Gesundheit und guten Appetit :-)"}],p:"00:30",c:"2:00",tot:160,srv:"8",cats:["Geflügel","Suppen & Eintöpfe"]},{id:1783,t:"Hahnchenschenkel In Paprikamarinade",i:[{n:"Hähnchenschenkel (4 Personen)",u:"Stk",a:"12"},{n:"Kartoffeln (festkochend, klein)",u:"kg",a:"1"},{n:"Paprika",u:"Stk",a:"2"},{n:"Kirschtomaten",u:"Schale",a:"1"},{n:"mittelgroße Zucchini",u:"Stk",a:"1"},{n:"edelsüsser Paprikapulver",u:"EL",a:"2"},{n:"Salz",u:"TL",a:"2"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Rosmarin",u:"TL",a:"2"},{n:"Sonnenblumenöl",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Marinade anrühren",d:"Hierzu nehme ich eine kleine Schüssel und fülle diese mit 2 EL edelsüssem Paprikapulver, 2 TL Salz, 1 EL gerebelten Majoran, Pfeffer aus der Mühle sowie 2 TL Rosmarin. Dies mischt man nun einmal gut durch, gibt 2 EL Sonnenblumenöl hinzu und vermengt alles in eine flüssige Marinade."},{s:2,n:"Hähnchenschenkel marinieren und Ofen vorheizen",d:"Die Hähnchenschenkel werden unter kaltem Wasser kurz abgespült, trockengetupft und in eine große Schüssel gegeben. Jetzt wird die Marinade gut in die Hähnchenschenkel eingerieben und ca. 10 min zur Seite gestellt. Der Ofen kann nun auf 200 Grad vorgeheizt werden."},{s:3,n:"Gemüse vorbereiten",d:"Währenddessen schneidet man das Gemüse klein. Die Kirschtomaten halbieren, den Paprika vom Strunk befreiten und in Streifen schneiden sowie die Zucchini abwaschen, Enden entfernen, einmal quer und längs halbieren und in feine Streifen schneiden. Die kleinen Kartoffeln müssen gut abgewaschen, vom Schmutz befreit und geviertelt werden."},{s:4,n:"Gemüse würzen und auf Backblech verteilen",d:"Das Gemüse gebe ich nun auf ein Backblech mit Backpapier. Alles gut darauf verteilen und mit groben Meersalz,Rosmarin würzen und miteinander vermengen."},{s:5,n:"Gemüse und Hähnchenschenkel im Ofen backen",d:"Das Gitter belege ich nun mit den Hähnchenschenkel und schiebe es über das Gemüse in den Ofen. Dadurch kann der Fleischsaft der Hühnerschenkel mit der Marinade auf das Gemüse tropfen. Dies gibt dem Gemüse eine eigene geschmackliche Note. Nach ca. 25-30 min. wendet man die Hähnchenschenkel und mischt das Gemüse einmal durch. Nach weiteren 25 min. wird das Gitter mit den Schenkeln für ca. 5 min auf die höhste Stufe geschoben. Hierbei bitte stehen bleiben, da die Haut nur kross und nicht schwarz werden soll. Nun kann es angerichtet werden. Die Kiddies lieben es:-) Guten Appetit"}],p:"00:25",c:"1:00",tot:95,srv:"4",cats:["Geflügel","Grillen & Marinaden"]},{id:1785,t:"Soljanka",i:[{n:"Rindlfleisch (Tafelspitz)",u:"g",a:"300"},{n:"Rinderhack",u:"g",a:"300"},{n:"Pustasalat",u:"Dose",a:"1"},{n:"grüne Oliven",u:"Stk",a:"9"},{n:"rote Paprika",u:"Stk",a:"2"},{n:"Jagdwurst",u:"g",a:"150"},{n:"Krakauer",u:"g",a:"150"},{n:"Salami",u:"g",a:"150"},{n:"gr. Salzdillgurke",u:"Stk",a:"1"},{n:"Gewürzgurken",u:"Stk",a:"3"},{n:"Senf",u:"TL",a:"1"},{n:"Zwiebeln",u:"Stk",a:"3"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Kartoffelmehl",u:"EL",a:"1"},{n:"heißes Wasser",u:"l",a:"1.5"},{n:"Öl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Rindfleisch und Wurst schneiden",d:"Das Rindfleisch wird kurz unter kaltem Wasser abgespült, trocken getupft, in Streifen und dann in 1 cm große Stücke geschnitten. Die Jagdwurst,die Krakauer und den Paprika schneide ich in kleine Würfel. Die Salami halbiere ich einmal und schneide dann kleine Scheiben ab. Hinweis: Für das Rindfleisch nehme ich Tafelspitz. Es ist beim kochen schneller durch"},{s:2,n:"Gemüse schneiden",d:"3 Zwiebeln abschälten. 2,5 halbieren und in Ringe schneiden. Die verbleibende halbe Zwiebel wird sehr klein geschnitten und in die Schüssel zum Hackfleisch gegeben. Die Salzdillgurke sowie die sauren Gurken werden halbiert sowie die Oliven in kleine Scheiben geschnitten. Zum Schluss kann noch eine klein gehackte Knoblauchzehe zu den Zwiebeln gegeben werden."},{s:2,n:"Gemüse schneiden",d:"3 Zwiebeln abschälten. 2,5 halbieren und in Ringe schneiden. Die verbleibende halbe Zwiebel wird sehr klein geschnitten und in die Schüssel zum Hackfleisch gegeben. Die Salzdillgurke sowie die sauren Gurken werden halbiert sowie die Oliven in kleine Scheiben geschnitten. Zum Schluss kann noch eine klein gehackte Knoblauchzehe zu den Zwiebeln gegeben werden."},{s:3,n:"Jetzt kommt die rote Farbe in die Suppe",d:"2 El Tomatenmark werden in einer großen Tasse mit einem EL Kartoffelmehl und kaltem Wasser gut vermischt. Es dürfen keine Klümpchen mehr vorhanden sein."},{s:3,n:"Jetzt kommt die rote Farbe in die Suppe",d:"2 El Tomatenmark werden in einer großen Tasse mit einem EL Kartoffelmehl und kaltem Wasser gut vermischt. Es dürfen keine Klümpchen mehr vorhanden sein."},{s:4,n:"Hackfleischbällchen zubereiten",d:"Für meine Soljanka bereite ich noch kleine Hackfleischklösschen zu. Diese sind auch schnell gemacht. Einfach Hackfleisch, Zwiebeln, Salz, Pfeffer, Majoran und einen Teelöffel Senf gut miteinander verkneten und zur Seite stellen. Ein Wasserkocher kann nun mit ca. 1,5l Wasser erhitzt werden."},{s:4,n:"Hackfleischbällchen zubereiten",d:"Für meine Soljanka bereite ich noch kleine Hackfleischklösschen zu. Diese sind auch schnell gemacht. Einfach Hackfleisch, Zwiebeln, Salz, Pfeffer, Majoran und einen Teelöffel Senf gut miteinander verkneten und zur Seite stellen. Ein Wasserkocher kann nun mit ca. 1,5l Wasser erhitzt werden."},{s:5,n:"Rindfleisch und Wurst anbraten",d:"Jetzt wird ein großer Topf mit ganz wenig Öl erhitzt. Das Rindleisch kann nun mit Salz und Pfeffer kurz angebraten und dann zurück in die Schüssel gegeben werden. Es folgen die Jagdwurst und die Krakauer. Sobald diese krossgebraten wurden, folgen sie auch dem Rindfleisch in die Schüssel"},{s:5,n:"Rindfleisch und Wurst anbraten",d:"Jetzt wird ein großer Topf mit ganz wenig Öl erhitzt. Das Rindleisch kann nun mit Salz und Pfeffer kurz angebraten und dann zurück in die Schüssel gegeben werden. Es folgen die Jagdwurst und die Krakauer. Sobald diese krossgebraten wurden, folgen sie auch dem Rindfleisch in die Schüssel"},{s:6,n:"Gemüse anschwitzen und Rest hinzugeben",d:"Die Zwiebeln mit dem Knoblauch werden nun glasig angeschwitzt und mit dem Fleisch aufgefüllt. Jetzt gebe ich den eingerührten Tomatenmark in den Topf und fülle diesen noch mit heißem Wasser auf. Es folgen die Paprikawürfel, die Gurken, die Oliven und die Salami."},{s:6,n:"Gemüse anschwitzen und Rest hinzugeben",d:"Die Zwiebeln mit dem Knoblauch werden nun glasig angeschwitzt und mit dem Fleisch aufgefüllt. Jetzt gebe ich den eingerührten Tomatenmark in den Topf und fülle diesen noch mit heißem Wasser auf. Es folgen die Paprikawürfel, die Gurken, die Oliven und die Salami."},{s:7,n:"Soljanka würzen",d:"Sobald die Suppe leicht vor sich hinköchelt, würze ich die Soljanka mit wenig Salz, einer Dose Pustasalat und edelsüssem Paprikapulver."},{s:7,n:"Soljanka würzen",d:"Sobald die Suppe leicht vor sich hinköchelt, würze ich die Soljanka mit wenig Salz, einer Dose Pustasalat und edelsüssem Paprikapulver."},{s:8,n:"Hackfleischbällchen kochen",d:"Während die Soljanka nun köchelt, wird ein kleiner Topf mit Wasser erhitzt. Sobald das Wasser kocht, formt man kleine Klöschen aus dem Hackfleisch und gibt sie für ca. 5 min in den Topf. Danach stellt man die gekochten Hackbällchen in einer Schüssel zur Seite."},{s:8,n:"Hackfleischbällchen kochen",d:"Während die Soljanka nun köchelt, wird ein kleiner Topf mit Wasser erhitzt. Sobald das Wasser kocht, formt man kleine Klöschen aus dem Hackfleisch und gibt sie für ca. 5 min in den Topf. Danach stellt man die gekochten Hackbällchen in einer Schüssel zur Seite."},{s:9,n:"Abschmecken und Hackfleischbällchen rein",d:"Zum Schluss gibt man die Hackbällchen in die Soljanka und schmeckt die Suppe noch einmal mit Salz und Pfeffer ab. Fertig. Hinweis: Die Soljanka schmeckt noch besser, wenn man sie nach dem Kochen noch ein paar Stunden ziehen läßt. Bedeutet also, diese vorbereitete Suppe ist Partytauglich :-)"},{s:9,n:"Abschmecken und Hackfleischbällchen rein",d:"Zum Schluss gibt man die Hackbällchen in die Soljanka und schmeckt die Suppe noch einmal mit Salz und Pfeffer ab. Fertig. Hinweis: Die Soljanka schmeckt noch besser, wenn man sie nach dem Kochen noch ein paar Stunden ziehen läßt. Bedeutet also, diese vorbereitete Suppe ist Partytauglich :-)"}],p:"00:20",c:"00:40",tot:70,srv:"8",cats:["Suppen & Eintöpfe"]},{id:1788,t:"Kabeljaufilet Spinat Auflauf",i:[{n:"Kabeljaufilet",u:"g",a:"500"},{n:"gr. Tomaten",u:"Stk",a:"3"},{n:"Blattspinat",u:"g",a:"500"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"3"},{n:"geriebener Käse",u:"",a:""},{n:"Bechamelsoße",u:"",a:""}],st:[{s:1,n:"Fisch vorbereiten und marinieren",d:"Für diese Gericht kann jedes beliebige Fischfilet genommen werden. Ich habe Kabeljau genommen, da es gerade im Angebot war. Das Filet wird kurz unter kaltem Wasser abgespült und tocken getupft. Evtl. müssen noch vorhandene Gräten entfernt werden. Das Filet wird dann in mundgerechte Stücke geschnitten, auf einem Teller verteilt und mit Salz, Pfeffer und Zitrone mariniert. Alles zusammen wird dann für ca. 15 min. in den Kühlschrank gegeben."},{s:2,n:"Spinat mit Zwiebeln andünsten",d:"Der Spinat sollte wenn möglich aufgetaut sein. Mir passiert es jedoch immer wieder, daß ich erst kurz vor dem Kochen die Zutaten einkaufen gehe. Somit ist der Blattspinat in der Regel noch leicht gefroren. Deshalb helfe ich insofern nach, daß ich den Spinat in einer Pfanne mit kleingeschnittenen Zwiebeln leicht dünste, sodaß er auftaut und später verwendet werden kann. Eigentlich muß der Spinat nicht gewürzt werden, da ich die Bechamelsoße etwas stärker würze. Somit gleicht sich dies wieder aus."},{s:3,n:"Ofen vorheizen und Auflaufform einfetten",d:"Während der Spinat in der Pfanne bruzelt, erwärmt man den Ofen auf ca. 200 Grad. Danach fettet man eine Auflaufform mit Butter ein."},{s:4,n:"Tomaten und Zwiebellauch kleinschneiden",d:"Des weiteren werden 3 große Tomaten abgewaschen und in Scheiben geschnitten. Vom Zwiebellauch entfernt man den oberen Teil des Grüns sowie die Wurzeln. Der verbleibende Rest wird abgewaschen, in Ringe geschnitten und zur Seite gestellt."},{s:5,n:"Auflauf schichten und ab in den Ofen",d:"Sobald der Spinat aufgetaut und angedünstet ist, kann dieser nun in die Auflaufform gegeben werden. Darüber verteilt man die Kabeljaufiletstücke, gießt die Bechalmelsoße hinein, legt die Tomatenscheiben dachziegelförmig darüber und verteilt zum Schluss den Zwiebellauch darüber. Nun streut man noch den Käse rüber und gibt die Auflaufform für ca. 30 min auf die mittlere Schiene in den Ofen."},{s:6,n:"Tipp",d:"Der Käse sollte natürlich nicht anbrennen. Für den Fall das dies doch geschehen sollte,nimmt man die Schiene eine Stufe herunter oder reguliert die Ofenwärme auf 150 Grad herunter. Na dann. Guten Appetit"}],p:"00:30",c:"00:30",tot:70,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:1790,t:"Asiatische Gemusepfanne Mit Huhnerfleisch",i:[{n:"Champignons",u:"g",a:"250"},{n:"Sojasprossen",u:"Glas",a:"0.5"},{n:"Bambusstreifen",u:"Glas",a:"0.5"},{n:"Kirschtomaten",u:"Stk",a:"10"},{n:"Möhren",u:"Stk",a:"2"},{n:"Zucchini",u:"Stk",a:"1"},{n:"Brokkoli",u:"Stk",a:"1"},{n:"rote Paprika",u:"Stk",a:"2"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Mais",u:"Dose",a:"1"},{n:"Sojasoße",u:"EL",a:"5"},{n:"Reisessig",u:"EL",a:"2"},{n:"Glasnudeln",u:"",a:""},{n:"Reis",u:"",a:""},{n:"Kräutersalz",u:"",a:""},{n:"Chinagewürz",u:"",a:""},{n:"Rapsöl",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Zuallererst wird das ganze Gemüse vorbereitet. Das vereinfacht später dann das Verarbeiten der vielen Zutaten. Die eingelegten Sojasprossen, den Mais und die Bambusstreifen gibt man in ein Sieb und spült diese mit kaltem Wasser ab. Abtropfen lassen, in eine Schüssel geben und zur Seite stellen. Generell wird jede einzelne Gemüsesorte jeweils in eine Schüssel gegeben. Nun schält, halbiert und schneidet man die Möhren in dünne Scheiben. Den Paprika und die Kirschtomaten werden in grobe Stücke zerkleinert. Die Zucchini halbiert man, schneidet diese in dicke Streifen und teilt diese dann noch in 1 cm große Stücke. Von den Champignons wird das braune Stielende entfernt und der Kopf in Scheiben geschnitten. Vom Brokkoli entfernt man den unteren Teil vom Strunk und teilt den Kopf in kleine Röschen. Zum Schluss schäle ich noch eine Zwiebel sowie den Knoblauch und scheide diese sehr klein."},{s:2,n:"Hühnerfleisch kleinschneiden",d:"Das Hühnerfleisch wird mit kaltem Wasser abgespült, trockengetupft und in 1 cm große Stücke geschnitten. Nun sind die Vorbereitungen abgeschlossen und es darf gekocht werden."},{s:2,n:"Hühnerfleisch kleinschneiden",d:"Das Hühnerfleisch wird mit kaltem Wasser abgespült, trockengetupft und in 1 cm große Stücke geschnitten. Nun sind die Vorbereitungen abgeschlossen und es darf gekocht werden."},{s:3,n:"Brokkoli blanchieren",d:"Während man das Gemüse schnippelt darf ein Topf mit Wasser aufgesetzt werden. Sobald das Wasser kocht, gibt man die Brokkoliröschen hinein und blanchiert diese ca. 3-5 min. Dieser Schritt ist notwendig, da der Brokkoli sonst in der Gemüsepfanne recht schnell zerkochen würde. Sobald der Brokkoli blanchiert wurde, schreckt man die Röschen in eiskaltem Wasser ab. Dadurch bleibt die grüne Farbe und die Bissfestigkeit erhalten."},{s:4,n:"Hühnerfleisch anbraten",d:"Nun erhitzt man in einem Wok oder einem großen Topf etwas Rapsöl und fügt das Hühnerfleisch hinzu. Nachdem dies angebraten wurde, stellt man das Fleisch in einer Schüssel zur Seite."},{s:5,n:"Gemüse anbraten",d:"Ich brate nun die Zwiebel mit dem Knoblauch an. Soblad diese glasig angebraten wurden, folgen die Möhren und die Bambusstreifen. Nach ca. 3 Min. gibt man die Sojasprossen, die Zucchini und den Paprika in den Topf. Nach weiteren 5 Min. fügt man den Mais, die Tomaten und das Hühnerfleisch hinzu. Zwischendurch gießt man immer mal ein wenig von dem Brokkoliwasser hinzu. Nicht gleich alles."},{s:6,n:"Gericht abschmecken",d:"Bis jetzt mußte noch nichts gewürzt werden. Doch jedes Gericht lebt ja davon, also darf nun der Geschmack in das Essen gebracht werden. Ich nehme dazu 1-2 EL Reisessig, jeweils 2 -3 EL Sojasoße (süß und ormal\\), Kräutersalz, 1 -2 EL Honig sowie Chinagewürz (7 Kräuter). Es liegt natürlich an jedem selbst darüber zu entscheiden, inwieweit man mit den Zutaten variiert. Es darf natürlich mehr oder auch weniger gewürzt werden."},{s:7,n:"Glasnudeln im heißen Wasser ziehen lasseen",d:"Für die Glasnudeln erhitzt man einen Topf. Sobald das Wasser kocht, nimmt man diesen vom Herd, gibt die Glasnudeln hinein und läßt diese noch ca. 5 Min ziehen."},{s:8,n:"Anrichten und servieren",d:"Kurz vor Schluss fügt man nun noch den Brokkoli in den Topf, hebt diesen unter das Gemüse und läßt alles zusammen ca. 2 Min. ziehen. Dazu eignet sich am besten Reis. Guten Appetit."},{s:8,n:"Anrichten und servieren",d:"Kurz vor Schluss fügt man nun noch den Brokkoli in den Topf, hebt diesen unter das Gemüse und läßt alles zusammen ca. 2 Min. ziehen. Dazu eignet sich am besten Reis. Guten Appetit."}],p:"00:25",c:"00:30",tot:80,srv:"8",cats:["Geflügel","Asiatisch"]},{id:1792,t:"Selbstgemachtes Tomatenpesto Fruchtig Und Herzhaft Zubereitet",i:[{n:"eingelegte getrocknete Tomaten",u:"g",a:"300"},{n:"Parmesankäse",u:"g",a:"150"},{n:"Pinienkerne",u:"g",a:"50"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Basilikum",u:"Bund",a:"0.5"},{n:"Petersilie",u:"Zweige",a:"2"},{n:"Oregano",u:"Zweige",a:"6"},{n:"schwarzer Balsamico Essig",u:"EL",a:"5"},{n:"Olivenöl",u:"EL",a:"5"},{n:"Sonnenblumenöl",u:"EL",a:"5"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Pinienkerne anbraten",d:"Die Pinienkerne werden in einer Pfanne mit einem kleinen Stück Butter angebraten. Sobald die Kerne leicht braun werden, wird die Flamme auf mindestens die Hälfte runterreguliert. Hinweis: Während des bratens wendet man die Kerne immer wieder, da diese sonst sehr schnell anbrennen können."},{s:2,n:"Tomaten schneiden",d:"Die getrockneten Tomaten schneidet man in Streifen und zerkleinert diese. Wer eine leistungsstarke Küchenmaschine hat, kann evtl. darauf verzichten. Wer jedoch wie ich ur\\ über einen Pürrierstab verfügt, erleichtert sich später das zerkleinern. Hinweis: Wer noch mehr Frische in das Pesto bringen möchte, schneidet noch eine handvoll Datteltomaten mit hinein. Diese sind sehr kräftig im Geschmack und verleihen dem Pesto eine angenehme Frische."},{s:3,n:"Kräuter und Gemüse schneiden",d:"Ebenso wird die Knoblauchzehe grob gehackt. Wer es mag, kann natürlich auch mehr Knoblauch hinzugeben. Zum Schluss schneidet man noch einen halben Bund Basilikum, 6 Zweige Oregano, 2 Zweige Petersilie ab, zerkleinert 8 kleine Tomaten und hackt auch diese grob klein."},{s:4,n:"Pürieren",d:"Nun gibt man die Tomaten, die Kräuter, die Knoblauchzehe, den Tomatenmark und die abgekühlten Pinienkerne in eine große Schüssel mit einem möglichst hohem Rand und pürriert alles in eine cremige Masse."},{s:5,n:"Parmesan unterheben",d:"Sobald alles schön zerkleinert ist, wird der Parmesankäse gerieben und ebenso unter die Masse gehoben."},{s:6,n:"Würzen und abschließend pürieren",d:"Nachdem alle Zutaten gut miteinander verbunden sind, gibt man 3 EL Balsamico Essig, 5 EL Olivenöl, 5 EL Sonnenblumenöl hinzu und püriert auch dies noch kurz mit ein."},{s:7,n:"Abschmecken",d:"Zum Schluss wird das Pesto mit Salz und Pfeffer abgeschmeckt und in den Kühlschrank gegeben. Hinweis: Es kann sofort serviert werden. Wer jedoch noch etwas Zeit hat, lässt das Pesto einen Tag im Kühlschrank ziehen. Der Geschmack wird dadurch noch etwas aromatischer. Im Kühlschrank ist das Pesto Rosso eine Woche lang haltbar."}],p:"00:20",c:"00:0",tot:20,srv:"1",cats:["Vegetarisch"]},{id:1794,t:"Bolognese",i:[{n:"Hackfleisch",u:"kg",a:"1"},{n:"Porree",u:"Stange",a:"1"},{n:"Sellerieknolle (klein)",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"2"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Majoran",u:"TL",a:"3"},{n:"Oregano",u:"EL",a:"1"},{n:"Olivenöl",u:"",a:""},{n:"geschälte Tomaten",u:"gr. Dose",a:"1"},{n:"passierte Tomaten",u:"gr. Packung",a:"1"},{n:"Butter",u:"",a:""},{n:"Zucker",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse schneiden",d:"Der Sellerie wird von der Schale befreit, in Scheiben und dann in kleine Würfel geschnitten. Die Möhren werden geschält und ebenso wie der Sellerie in kleine Würfel geschnitten. Es folgt die Porrestange. Dort schneidet man den oberen Teil des Grüns ab, entfernt die erste Schicht der Schale und wäscht den verbleibenden Strunk ordentlich mit kaltem Wasser ab. Achtet bitte hierbei insbesondere auf den oberen Teil, da sich hier gern noch etwas Sand abgelagert hat. Dieser soll später nicht zwischen den Zähnen knirschen. Nun wird die Stange noch halbiert und kleingeschnitten. Am Ende der Vorbereitung werden zwei Knoblauchzehen geschält und sehr klein gehackt."},{s:2,n:"Hackfleisch anbraten",d:"Nachdem die Vorbereitung abgeschlossen wurde, erhitzt man einen großen Topf mit Olivenöl und fügt das Hackfleisch portionsweise hinzu. Ich würze das Hackfleisch schon beim braten mit Salz, Pfeffer und einem Teelöffel Majoran. Sobald alles krümelig gebraten wurde, stellt man das Hackfleisch in einer Schüssel zur Seite."},{s:3,n:"Gemüse anbraten",d:"Im gleichen Topf wird nun das Gemüse angebraten. Zuerst den Sellerie und die Möhren. Nach ca. 5 min gibt man den Porree und den Knoblauch hinzu. Auch hier kann man schon ein wenig mit Salz und Pfeffer würzen."},{s:4,n:"Hackfleisch und Wein hinzufügen",d:"Nach ca. 10-15 min. fügt man dem Topf das Hackfleisch hinzu, gibt 2 EL Tomatenmark dazu und brät es noch mit an. Schließlich löscht man alles mit Rotwein ab und kocht diesen ein. Sobald der typische Alkoholgeruch verflogen ist (dann kann man davon ausgehen, daß der Alkohol verkocht wurde), wird eine große Dose geschälte Tomaten sowie eine große Packung passierte Tomaten hinzugegeben. Ich gebe nun noch etwas heißes Wasser in den Topf, sodaß alles leicht mit Flüssigkeit bedeckt ist. Es folgen noch die Kräuter Majoran und Oregano."},{s:5,n:"Bolognes schmoren lassen",d:"Nun darf alles zusammen bei schwacher Hitze 1,5-2 Stunden leicht köcheln. Kurz vor dem Ende des Kochvorganges schmeckt man die Bolognese noch mit Zucker (falls es zu säuerlich schmecken sollte), Butter, Salz und Pfeffer ab. Fertig."}],p:"00:30",c:"2:00",tot:160,srv:"8",cats:["Pasta & Nudeln"]},{id:1823,t:"Ruhreier Mit Speck Und Wurstchen",i:[{n:"kleine Bratwürste",u:"Stk",a:"5"},{n:"Eier",u:"Stk",a:"10"},{n:"Sahne",u:"ml",a:"200"},{n:"Schinkenspeck",u:"g",a:"200"},{n:"Butter",u:"EL",a:"2"},{n:"Öl",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Petersilie oder Schnittlauch",u:"",a:""}],st:[{s:1,n:"Bratwürste braten",d:"Die kleinen Bratwürste im Öl in einer Pfanne von allen Seiten braun braten."},{s:2,n:"Eimasse vorbereiten",d:"Die Eier mit der Sahne verquirlen und mit Salz und Peffer würzen."},{s:3,n:"Speck anbraten und Rührei zubereiten",d:"Die Butter in einer Pfanne erhitzen, die Speckwürfel darin knusprig braten. Die Eimasse zugeben und unter Rühren stocken lassen. Die Würstchen unter das Rüherei heben und wahlweise mit Petersilie oder Schnittlauch bestreuen."},{s:4,n:"Tipp",d:"Das Rührei neben Salz und Pfeffer je nach Geschmack mit Kräutern der Provence oder einer italienischen Kräutermischung würzen."}],p:"00:10",c:"00:10",tot:25,srv:"3",cats:["Fleisch","Vegetarisch","Frühstück & Eier"]},{id:1825,t:"Selbstgemachte Fischstabchen In Einer Zitrone Senf Marinade",i:[{n:"Fischfilet",u:"g",a:"400"},{n:"Mehl",u:"g",a:"150"},{n:"Ei",u:"Stk",a:"1"},{n:"Semmelbrösel",u:"g",a:"200"},{n:"Milch",u:"EL",a:"2"},{n:"Dijonsenf",u:"Tl",a:"1"},{n:"Butter",u:"EL",a:"3"},{n:"Zitronensaft",u:"TL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fischfilet vorbereiten und marinieren",d:"Das Filet abspülen und trockentupfen. Noch vorhandene Gräten entfernen und in fischstäbchengerechte Stück schneiden. Die einzelnen Teile werden mit einer Marinade aus Salz, Pfeffer, Zitronensaft und Dijonsenf gewürzt (am einfachsten geht das in einer Schüssel). Die Schüssel mit dem marinierten Fisch stellt man zugedeckt für ca. eine halbe Stunde in den Kühlschrank. Hinweis: Es kann ein beliebiges Fischfilet gekauft werden. Empfehlenswert ist es, ein großes ganzes Stück zu kaufen, da sich dieses einfacher zu einzelnen \\Stäbchen\\ portionieren läßt"},{s:2,n:"Panade vorbereiten",d:"In der Zwischenzeit werden drei Teller nacheinander mit Mehl, Ei und Semmelbrösel befüllt. Zu dem Ei gibt man einen Schluck Milch hinzu und verquirlt es leicht miteinander. Die Semmelbrösel erhalten noch einen halben Teelöffel Salz. Das macht die Panade schön würzig und sie muß später nicht mehr nachgewürzt werden."},{s:3,n:"Fischfilets panieren und braten",d:"Die in der Panade ausreichend gewälzten Fischstäbchen werden nun in eine mit ausreichend Butter vorgeheizte Pfanne gegeben und ca. 5 min von beiden Seiten kross angebraten. Zum Schluss läßt man das überflüssige Fett auf Küchenpapier abtropfen. Damit die Panade nicht anbrennt, sollte die Hitze zwischendurch auf die Hälfte runterreguliert werden."},{s:4,n:"Welche Beilage passt dazu?",d:"Zu den Fischstäbchen kann natürlich alles Mögliche serviert werden. Wir bevorzugen gebackene Kartoffelspalten aus dem Ofen."}],p:"00:40",c:"00:15",tot:60,srv:"4",cats:["Fisch & Meeresfrüchte","Grillen & Marinaden"]},{id:1827,t:"Wiener Schnitzel   Herdzeit.De",i:[{n:"Kalbschnitzel",u:"Scheiben",a:"4"},{n:"Zitrone",u:"Stk",a:"1"},{n:"Mehl",u:"",a:""},{n:"Eier",u:"Stk",a:"2"},{n:"Semmelbrösel",u:"",a:""},{n:"Salz",u:"",a:""},{n:"Butterschmalz (oder Öl)",u:"",a:""}],st:[{s:1,n:"Kalbschnitzel vorbereiten",d:"Ich mag eher die dünneren Scheiben beim Schnitzel. Somit kauft man 4 große Scheiben Kalbfleisch ca. 8 mm dünn. Diese werden kurz mit kaltem Wasser abgespült und mit Küchenpapier trocken getupft. Die einzelnen Kalbschnitzelscheiben klopfen bis sie noch ca. 5 mm dünn sind. Eine halbe Zitrone auspressen und auf den Scheiben verteilen sowie alles leicht mit Salz würzen."},{s:2,n:"Schnitzel panieren",d:"Nun stellt man 3 Teller auf und füllt einen nach dem anderen mit Mehl, 2 Eiern und Semmelbrösel. In das Mehl gebe ich auch noch etwas Salz. Nun gibt man nacheinander die Scheiben erst in das Mehl (zuviel einfach abklopfen), dann in das Ei und zum Schluss in den Semmelbröselteller. Hier empfiehlt es sicht, die Börsel nur leicht anzudrücken. Wenn die Brösel zu fest angedrückt werden, kann die Panade evtl. keine Blasen mehr bilden."},{s:3,n:"Schnitzel braten",d:"Jetzt wird eine Pfanne mit mit Butterschmalz, Butter oder Öl auf 180 Grad erhitzt. Es sollte so viel Bratfett in der Pfanne sein, daß das Schnitzel darin schwimmen kann. Nun wird das Schnitzel ca. 3 Minuten gebraten, wobei die Scheiben gelegentlich gewendet werden dürfen und die Oberfläche auch immer wieder mit dem Fett übergossen werden muss. Wenn die Panade goldbraun angebraten ist, kann das Fleisch herausgenommen werden und auf Küchenpapier von überflüssigem befreit werden. Fertig."},{s:4,n:"Tipp",d:"Dazu serviert man Gurkensalat und Bratkartoffeln. Guten Appetit"}],p:"00:15",c:"00:30",tot:50,srv:"4",cats:["Fleisch"]},{id:1831,t:"Gurkensalat",i:[{n:"Gurke",u:"Stk",a:"1"},{n:"Dill",u:"Zweige",a:"3"},{n:"Zwiebel",u:"Stk",a:"0.5"},{n:"Zitronensaft",u:"EL",a:"1"},{n:"Öl",u:"EL",a:"1"},{n:"Zucker",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gurken vorbereiten",d:"Die Gurke waschen, schälen, halbieren und in dünne Scheiben schneiden."},{s:2,n:"Vinaigrette zubereiten",d:"Für die Vinaigrette gibt man eine halbe sehr fein geschnittene Zwiebel, Zitronensaft, Zucker, Salz, Pfeffer und Öl in eine Schüssel und verrührt diese schön miteinander"},{s:3,n:"Dill fein hacken",d:"3 Zweige Dill sehr fein hacken"},{s:4,n:"Salat vermengen",d:"Die Gurkenscheiben und der Dill werden jetzt in die Vinaigrette gegeben und gut vermischt. Fertig ist der Gurkensalat. Guten Appetit"}],p:"00:10",c:"00:00",tot:15,srv:"4",cats:["Salate"]},{id:1836,t:"Tim MäLzers Chili Con Carne ( Leicht Abgewandelt)   Herdzeit.De",i:[{n:"Rinderhack",u:"kg",a:"1"},{n:"Gemüsezwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Olivenöl oder Speiseöl",u:"",a:""},{n:"Salz",u:"",a:""},{n:"Tomatenmark",u:"EL",a:"3"},{n:"Cayenpfeffer",u:"TL",a:"1"},{n:"brauner Zucker",u:"TL",a:"2"},{n:"gemahlener Kreuzkümmel",u:"TL",a:"1"},{n:"geschälte Tomaten",u:"Dose",a:"1"},{n:"Gemüsebrühe",u:"ml",a:"200"},{n:"Mais",u:"Dose",a:"1"},{n:"Kidneybohnen",u:"Dose",a:"1"},{n:"dunkle Schokolade",u:"g",a:"25"},{n:"Koriandergrün",u:"",a:""},{n:"Schmand",u:"",a:""},{n:"rote, 2 gelbe Paprikaschoten",u:"Stk",a:"2"}],st:[{s:1,n:"Gemüse putzen und würfeln",d:"Die Zwiebel fein würfeln, Paprika putzen, waschen und 1 cm groß würfeln. Knoblauch in dünne Scheiben schneiden."},{s:2,n:"Hackfleisch anbraten",d:"Hackfleisch von allen Seiten scharf anbraten, mit Salz würzen und herausnehmen."},{s:3,n:"Gemüse anbraten",d:"Noch etwas Öl, Paprika, Zwiebeln, Knoblauch in die Bratenflüssigkeit geben und ca. 5 Minuten braten."},{s:4,n:"Zutaten im Topf vermengen",d:"Das Fleisch wieder dazugeben, das Tomatenmark einrühren. Mit dem Paprikapulver, Cayennepfeffer, braunen Zucker und Kreuzkümmel würzen. Dosentomaten und Gemüsebrühe dazugeben. Alles aufkochen und zugedeckt bei mittlerer Temperatur etwa eine dreiviertel Stunde garen."},{s:5,n:"Mais und Bohnen hinzufügen",d:"Mais und Bohnen abgießen, mit kaltem Wasser abspülen und gut abtropfen lassen."},{s:6,n:"Dunkle Schokolade hinzufügen und abschmecken",d:"Die dunkle Schokolade (gibt dem Chili einen wirklich besonderen Geschmack) fein reiben, mit Bohnen und Mais unter das fertige Chili mischen. Das Chili noch einmal abschmecken und mit grob gehacktem Koriandergrün und Schmand servieren."}],p:"00:10",c:"1:00",tot:80,srv:"8",cats:["Fleisch"]},{id:1838,t:"Rinderrouladen",i:[{n:"Rindfleisch in Scheiben",u:"",a:""},{n:"Gewürzgurken",u:"",a:""},{n:"Zwiebeln",u:"",a:""},{n:"Senf",u:"",a:""},{n:"Rinderbrühe",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""},{n:"Creme fraiche",u:"",a:""}],st:[{s:1,n:"Fleisch flach klopfen und marinieren",d:"Das Fleisch abwaschen, trocken tupfen, leicht klopfen, mit Senf bestreichen und mit Salz und Pfeffer bestreuen."},{s:2,n:"Gewürzgurken und Zwiebeln schneiden",d:"Die Gewürzgurken in schmale Streifen schneiden, die Zwiebeln in Scheiben schneiden."},{s:3,n:"Rouladen vorbereiten",d:"Gurken und Zwieblen auf den Fleischscheiben verteilen und diese von der schmalen Seite her aufrollen, mit Rouladennadeln oder Küchengarn zusammenhalten."},{s:4,n:"Rouladen anbraten und anschließend schmoren lassen",d:"Schweineschmalz oder Speiseöl in einem Schmortopf erhitzen, die Rouladen von allen Seiten scharf darin anbraten, etwas Rinderbrühe hinzugießen und die Rouladen etwa 1 1/2 bis 2 Stunden schmoren lassen. Ich gebe ca. alle dreißig Minuten Brühe dazu. Meine Rouladen sind immer gut mit Flüssigkeit bedeckt, damit später genug Soße entstehen kann."},{s:5,n:"Soße zubereiten",d:"Wenn die Rouladen fertig sind, aus dem Topf nehmen. Die Schmorflüssigkeit aufkochen, gegebenenfalls andicken, mit Creme fraiche verfeinern und mit Salz und Pfeffer nachwürzen."},{s:6,n:"Tipp",d:"Als Beilage dazu passen Salzkartoffeln, Bohnen oder Erbsen."}],p:"00:30",c:"2:10",tot:170,srv:"7",cats:["Fleisch"]},{id:1841,t:"Bohnensuppe",i:[{n:"gefrorene Bruchbohnen",u:"g",a:"450"},{n:"Hühnerbrustfilet",u:"g",a:"400"},{n:"Tomaten (400 ml)",u:"Dose",a:"1"},{n:"Mais",u:"Dose",a:"1"},{n:"gr. Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Brühe",u:"ml",a:"300"},{n:"Maiskeimöl",u:"EL",a:"2"},{n:"Majoran",u:"EL",a:"1"},{n:"Cayennepfeffer",u:"",a:""},{n:"Salz",u:"",a:""},{n:"Bacon",u:"Pck",a:"1"},{n:"Karottensaft",u:"ml",a:"200"}],st:[{s:1,n:"Hähnchenfleisch vorbereiten",d:"Hühnerfleisch mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen und in kleine mundgerechte Stücke schneiden."},{s:2,n:"Gemüse und Co schneiden",d:"Die Zwiebel sehr klein schneiden, Knoblauch klein hacken und Bacon in kleine Würfel schneiden."},{s:3,n:"Bacon und Fleisch anbraten",d:"Ein Topf erhitzt man mit Maiskeimöl, gibt dann den Bacon hinzu und brät diesen scharf an. Sobald das geschehen ist, fügt ihr das Hähnchenfleisch dazu und bratet auch das Fleisch scharf an."},{s:4,n:"Gemüse und Brühe hinzufügen",d:"Zum Schluss Zwiebel und Knoblauch in den Topf geben und alles zusammen kurz mitbraten. Nach ca. 1-2 Minuten das Gebratene mit heißer Brühe ablöschen, zum Kochen bringen und dann mit Karottensaft auffüllen."},{s:5,n:"Bohnen und Tomatensoße in den Topf geben",d:"Sobald es leicht vor sich hin köchelt, die gefrorenen Bruchbohnen und die Dose mit der Tomatensoße hinzugeben. Die ganzen Tomaten leicht zerdrücken."},{s:6,n:"Würzen und abschmecken",d:"Nun würzt man alles kräftig mit Salz, Pfeffer und Majoran und lässt es ca. 15 Minuten vor sich hin köcheln."},{s:7,n:"Mais hinzufügen",d:"Zum Schluss den Mais aus der Dose schütten und in einem Sieb unter klarem Wasser abspülen. Im Anschluss in den Topf geben und noch ca. 5 Min. köcheln lassen. Evtl. kann man jetzt noch mal alles abschmecken. Fertig."}],p:"00:15",c:"00:40",tot:60,srv:"4",cats:["Suppen & Eintöpfe"]},{id:1842,t:"Nudeln Mit Mediteraner Tomatensosse   Herdzeit.De');",i:[{n:"Penne",u:"g",a:"300"},{n:"gelbe Paprika",u:"Stk",a:"1"},{n:"kleine Zucchini",u:"Stk",a:"1"},{n:"braune Champignons",u:"Stk",a:"6"},{n:"rote Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"herzhafte Oliven",u:"Stk",a:"9"},{n:"eingelegte getrocknete Tomaten",u:"Stk",a:"4"},{n:"passierte Tomatensoße",u:"Pck",a:"2"},{n:"Parmesankäse",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Oregano",u:"",a:""}],st:[{s:1,n:"Gemüse schneiden",d:"Die gelbe Paprika vom Stiel und den Kernen befreien und in 1 cm große Stücke schneiden. von den 6 frischen braunen Champignons das Stielende abschneiden und den Kopf halbieren und in Scheiben schneiden. eine rote Zwiebel schälen, halbieren und vierteln. Nun pult man die einzelnen Zwiebelschichten auseinander. Die Zucchini waschen, Enden entfernen und den Rest in grobe Stücke schneiden. Die Knoblauchzehe und die eingelegten getrockneten Tomaten werden sehr fein gehackt und die Oliven geviertelt."},{s:2,n:"Nudeln kochen",d:"Topf mit ausreichend Wasser aufsetzen, Salz hinzufügen und die Penne Nudeln bissfest kochen."},{s:3,n:"Gemüse in der Pfanne anbraten",d:"Jetzt wird eine Pfanne mit der Butter erhitzt. Sobald diese zerlaufen ist, gibt man zuerst die Pilze hinzu und brät diese ca. 2 min. Nun folgt die Zucchini. Nach einer weiteren Minute folgt die Zwiebel mit dem Knoblauch. Nach einer weiteren Minute gibt man den Paprika und die Oliven mit den gehackten Tomaten hinzu. Alles zusammen wird noch kurz angebraten und mit Salz und Pfeffer gewürzt."},{s:4,n:"Tomatensoße würzen",d:"Danach gießt man die passierten Tomaten in die Pfanne und kocht alles zusammen ein. Jedoch nicht zu lang, da das Gemüse knackig bleiben soll. Die Soße wird noch mit Majoran, Oregano, Salz und Pfeffer abgeschmeckt. Gelegentlich kann man auch noch etwas von dem Nudelwasser abschöpfen und mit zur Soße geben. Sollte es noch etwas säuerlich schmecken, so verfeinert man den Geschmack noch ein wenig mit Zucker."},{s:5,n:"Penne und Tomatensoße vermengen",d:"Die Pasta dürfte nun auch fertig sein. Das Wasser gießt man ab und die verbleibenden Nudeln werden in die Pfanne zu der Tomaten-Gemüsesoße gegeben und miteinaner vermengt"}],p:"15",c:"30",tot:50,srv:"4",cats:["Pasta & Nudeln"]},{id:1844,t:"Kartoffelpuree Mit Buletten Und Mischgemuse",i:[{n:"Hackfleisch",u:"kg",a:"1"},{n:"Kartoffeln",u:"kg",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Ei",u:"Stk",a:"1"},{n:"Mischgemüse (gefroren)",u:"",a:""},{n:"Semmelbrösel",u:"",a:""},{n:"Dijonsenf",u:"EL",a:"2"},{n:"Majoran",u:"EL",a:"1.5"},{n:"Thymian",u:"TL",a:"1"},{n:"Butter",u:"g",a:"150"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hackfleisch vorbereiten",d:"Das Hackfleisch wird in eine Schüssel gegeben. Die Zwiebel wird sehr fein geschnitten und mit zum Hackfleisch gegeben. Des weiteren werden noch 1 Ei, Semmelbrösel, 1 EL Dijonsenf, Majoran, Salz und Pfeffer in die Schüssel gegeben und alles zusammen gut miteinander vermischt."},{s:2,n:"Hackbällchen formen",d:"Anschließend formt man mittelgroße Kugeln, plättet diese und legt sie auf einen Teller um sie später braten zu können."},{s:2,n:"Hackbällchen formen",d:"Anschließend formt man mittelgroße Kugeln, plättet diese und legt sie auf einen Teller um sie später braten zu können."},{s:3,n:"Buletten braten und anschließend im Ofen warmhalten",d:"Jetzt werden die Buletten nach einander von beiden Seiten gebraten. Man sollte sehr wenig Öl zum anbraten nehmen, da es sonst zu fettig werden könnte. Die fertigen Buletten sammelt man in einer Schüssel und hält sie bei 50 Grad im Ofen warm."},{s:3,n:"Buletten braten und anschließend im Ofen warmhalten",d:"Jetzt werden die Buletten nach einander von beiden Seiten gebraten. Man sollte sehr wenig Öl zum anbraten nehmen, da es sonst zu fettig werden könnte. Die fertigen Buletten sammelt man in einer Schüssel und hält sie bei 50 Grad im Ofen warm."},{s:4,n:"Kartoffelpüree zubereiten",d:"Die Kartoffeln werden geschält, kleingeschnitten und abgewaschen. Anschließend werden diese im Wasser gekocht (ohne Salz). Zum Schluss nimmt man den Topf vom Herd, fängt das Kartoffelwasser in einer Schüssel für die spätere Soße auf. Zu den Kartoffeln werden nun noch Butter, Milch und Salz hinzugegeben. Alles zusammen wird nun mit dem Mixer gut püriert"},{s:4,n:"Kartoffelpüree zubereiten",d:"Die Kartoffeln werden geschält, kleingeschnitten und abgewaschen. Anschließend werden diese im Wasser gekocht (ohne Salz). Zum Schluss nimmt man den Topf vom Herd, fängt das Kartoffelwasser in einer Schüssel für die spätere Soße auf. Zu den Kartoffeln werden nun noch Butter, Milch und Salz hinzugegeben. Alles zusammen wird nun mit dem Mixer gut püriert"},{s:5,n:"Gemüse zubereiten",d:"Ich greife durchaus auch auf gefrorenes Gemüse zurück. Also das Gemüse kommt in einen Topf. Der Boden wird leicht mit Wasser bedeckt und zum kochen gebracht. Achtet bitte darauf, daß das Gemüse knackig bleiben soll, also nicht zu lange kochen. Während des Kochens wird noch Salz und ganz zum Schluss Butter hinzugegeben. Abschmecken...fertig."},{s:5,n:"Gemüse zubereiten",d:"Ich greife durchaus auch auf gefrorenes Gemüse zurück. Also das Gemüse kommt in einen Topf. Der Boden wird leicht mit Wasser bedeckt und zum kochen gebracht. Achtet bitte darauf, daß das Gemüse knackig bleiben soll, also nicht zu lange kochen. Während des Kochens wird noch Salz und ganz zum Schluss Butter hinzugegeben. Abschmecken...fertig."},{s:6,n:"Mehlschwitze anrühren",d:"Hier kommt die klassische Mehlschwitze zur Anwendung. Die Pfanne mit den Röstrückständen der Buletten wird mit Butter erhitzt. Sobald die Butter flüssig geworden ist, gibt man 1 EL Mehl hinzu und verrührt dies miteinander, bis keine Klümpchen mehr vorhanden sind. Ein Schneebesen ist hierfür sehr hilfreich. Jetzt gießt man das Kartoffelwasser unter ständigem Rühren in die Pfanne und kocht alles 11 min ein."},{s:6,n:"Mehlschwitze anrühren",d:"Hier kommt die klassische Mehlschwitze zur Anwendung. Die Pfanne mit den Röstrückständen der Buletten wird mit Butter erhitzt. Sobald die Butter flüssig geworden ist, gibt man 1 EL Mehl hinzu und verrührt dies miteinander, bis keine Klümpchen mehr vorhanden sind. Ein Schneebesen ist hierfür sehr hilfreich. Jetzt gießt man das Kartoffelwasser unter ständigem Rühren in die Pfanne und kocht alles 11 min ein."},{s:7,n:"Soße abschmecken",d:"Während dessen wird nun der Geschmack in Form von Majoran, Thymian, Salz, Pfeffer und Dijonsenf in die Soße gebracht und eingekocht. Sollte die Soße noch zu dünn sein, dann kann man auch etwas Soßenbinder hinzugeben."},{s:7,n:"Soße abschmecken",d:"Während dessen wird nun der Geschmack in Form von Majoran, Thymian, Salz, Pfeffer und Dijonsenf in die Soße gebracht und eingekocht. Sollte die Soße noch zu dünn sein, dann kann man auch etwas Soßenbinder hinzugeben."},{s:8,n:"Anrichten und servieren",d:"Sollte die Soße noch zu dünn sein, dann kann man auch etwas Soßenbinder hinzugeben. Nun kann alles zusammen serviert werden. Die Kinder lieben es und die Buletten reichen auch für eine zweite Mahlzeit bzw. kann man diese auch mit in die Schule geben. Guten Appetit"},{s:8,n:"Anrichten und servieren",d:"Sollte die Soße noch zu dünn sein, dann kann man auch etwas Soßenbinder hinzugeben. Nun kann alles zusammen serviert werden. Die Kinder lieben es und die Buletten reichen auch für eine zweite Mahlzeit bzw. kann man diese auch mit in die Schule geben. Guten Appetit"}],p:"00:20",c:"00:35",tot:70,srv:"6",cats:["Fleisch"]},{id:1853,t:"Nudel Brokkoli Auflauf",i:[{n:"Brokkoli",u:"g",a:"500"},{n:"Fussili",u:"g",a:"400"},{n:"Sahne",u:"ml",a:"100"},{n:"Milch",u:"ml",a:"50"},{n:"Eier",u:"Stk",a:"3"},{n:"Kochschinken",u:"g",a:"200"},{n:"Oregano",u:"Bd",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"}],st:[{s:1,n:"Brokkoli zubereiten und Nudeln kochen",d:"Vom Brokkoli die Röschen abschneiden. Einen Topf mit reichlich Salzwasser erhitzen und die Nudeln darin bissfest kochen. Kurz vor dem Ende der Kochzeit gibt man die Brokkoliröschen für max. 3 Min in den Topf. Länger ist nicht ratsam, da der Brokkoli sonst sehr schnell weich und zerkochen würde. Das Wasser kann nun abgegossen werden."},{s:2,n:"Zwiebel, Kochschinken und Oregano kleinschneiden",d:"Während die Nudeln kochen, schneidet man die Zwiebel sehr klein, hackt die Oreganoblättchen und schneidet den Kochschinken in Würfel."},{s:3,n:"Zwiebel und Kochschinken anschwitzen",d:"Die Zwiebel schwitzt man in einer Pfanne mit Butter etwas an und gibt dann die Kochschinkenwürfel für 3 Min. hinzu und stellt die Pfanne danach zur Seite."},{s:4,n:"Eimasse anrühren",d:"In einer weiteren Schüssel werden die Sahne, die Milch und die Eier verrührt und kräftig mit Salz und Pfeffer abgeschmeckt."},{s:5,n:"Auflauf schichten und ab in den Ofen",d:"In die eingefettete Auflaufform werden nun die Nudeln, der Brokkoli, die Zwiebeln, der Kochschinken und der Oregano gegeben und miteinander vermengt. Die vorbereitete Soße darübergießen, den Käse darauf verteilen und für ca. 25 Min in den auf 180 Grad vorgeheizten Ofen geben.Fertig. Guten Appetit"}],p:"00:25",c:"00:30",tot:60,srv:"6",cats:["Pasta & Nudeln"]},{id:1861,t:"Lachstatar Auf Kartoffelrosti",i:[{n:"festkochende Kartoffeln",u:"g",a:"500"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"geräucherter Lachs",u:"g",a:"200"},{n:"Lauchzwiebeln",u:"Bd",a:"1"},{n:"Limette",u:"Stk",a:"1"},{n:"Honig",u:"Tl",a:"1"},{n:"Creme Fraiche",u:"g",a:"150"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Muskat",u:"Tl",a:"0.5"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln reiben und würzen",d:"Kartoffel schälen und grob raspeln. Zwiebel klein schneiden. Mit Salz, Pfeffer und Muskat würzen. ca. 5 Min. stehen lassen.Die geraspelten Kartoffeln in einem sauberen Tuch gut ausdrücken."},{s:2,n:"Kartoffelrösti braten",d:"Eine Pfanne mit Butterschmalz erhitzen und die Kartoffelraspeln in kleine flache \\Platten\\ formen und jeweils 10 Min von jeder Seite kross braten. Sobald diese fertig sind herausnehmen und auf Küchenpapier das Fett abtropfen lassen."},{s:3,n:"Lachs, Lauchzwiebeln und Knoblauch vorbereiten",d:"Den Lachs in Würfel schneiden, die Lauchzwiebeln waschen und in kleine Ringe schneiden. Die Knoblauchzehe sehr klein hacken."},{s:4,n:"Limette vorbereiten",d:"Die Limette gut abwaschen, abtrocknen, die Schale abraspeln und den Saft in einer kleinen Schüssel auffangen."},{s:5,n:"Lachstatar zubereiten",d:"Lachs, Lauchzwiebeln, Knoblauchzehe zusammen mit einem Teelöffel Honig, der geraspelten Limettenschale und die Hälfte des Limettensaftes gut vermengen."},{s:6,n:"Lachstatar abschmecken",d:"Zum Schluss alles noch mit Salz und Pfeffer abschmecken und für ca. 10 min kühl stellen. Zum verbliebenen Limettensaft wird Cremefraiche vermischt und ebenso mit Salz und Pfeffer abgeschmeckt. Nun kann alles serviert werden. Kalt wie auch warm ein kleiner Leckerbissen. Guten Appetit"},{s:7,n:"Anrichten und servieren",d:"Nun kann alles serviert werden. Kalt wie auch warm ein kleiner Leckerbissen. Guten Appetit"}],p:"00:25",c:"00:15",tot:50,srv:"2",cats:["Fisch & Meeresfrüchte"]},{id:1863,t:"Hahnchenflugel Aus Dem Ofen",i:[{n:"Hähnchenflügel",u:"Stk",a:"24"},{n:"Majoran",u:"",a:""},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Hähnchen vorbereiten und Ofen vorheizen",d:"Hähnchenflügel unter kalten Wasser abspülen und mit Küchenpapier trockentupfen. Das Backblech herausnehmen und das Ofengitter darauflegen und den Ofen selbst auf 200 Grad vorheizen."},{s:2,n:"Hähnchenflügel würzen",d:"Die Hähnchenflügel auf dem Gitter verteilen und gut mit Salz und gerebeltem Majoran würzen. Es darf ruhig etwas mehr Salz sein, da durch das spätere übergießen der Flügel dieses teilweise wieder verloren geht."},{s:3,n:"Hähnchen im Ofen braten",d:"Jetzt wird noch in das Backblech genügend Wasser hinzugefügt. Dieses dient dem übergießen der Flügel um ein austrocknen zu vermeiden. Alles in den Ofen. Nach ca. 30 min übergießt man die Hähnchenflügel mit dem Wasser. Nach weiteren 20 min werden die Flügel umgedreht und von der anderen Seite gebacken. Nach weiteren 20 min werden die Flügel ein letztes Mal umgedreht und für ca. 10 min unter starker Hitze kross gebacken."},{s:4,n:"Tipp:",d:"Fertig. Es kann sofort heiß serviert werden. Diese Flügel eignen sich auch gut als Kaltspeise für Party´s. (Huhn) Guten Appetit"}],p:"00:10",c:"1:00",tot:75,srv:"4",cats:["Geflügel"]},{id:1865,t:"Huhnerherzenragout Mit Farfalle",i:[{n:"Farfalle",u:"g",a:"500"},{n:"Hühnerherzen",u:"g",a:"500"},{n:"frische Champignons",u:"g",a:"250"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Sojasoße",u:"EL",a:"1"},{n:"Öl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Herzen vorbereiten",d:"Die Herzen werden in einem Sieb unter kaltem Wasser abgespült und trockengetupft und geviertelt."},{s:2,n:"Gemüse schneiden",d:"Das Stielende der Champignons wird entfernt und der Kopf halbiert und in Scheiben geschnitten. Die Zwiebel wird sehr fein geschnitten und die Knoblauchzehe kleingehackt."},{s:2,n:"Gemüse schneiden",d:"Das Stielende der Champignons wird entfernt und der Kopf halbiert und in Scheiben geschnitten. Die Zwiebel wird sehr fein geschnitten und die Knoblauchzehe kleingehackt."},{s:3,n:"Hühnerherzen anbraten",d:"Öl in einem Topf erhitzen, Salz und Pfeffer rein und dann die Herzen portionsweise mit Majoran gewürzt, kräftig anbraten. Der Bratensaft mit den bereits gebratenen Herzen werden in einer Schüssel aufgefangen und kurz zur Seite gestellt."},{s:3,n:"Hühnerherzen anbraten",d:"Öl in einem Topf erhitzen, Salz und Pfeffer rein und dann die Herzen portionsweise mit Majoran gewürzt, kräftig anbraten. Der Bratensaft mit den bereits gebratenen Herzen werden in einer Schüssel aufgefangen und kurz zur Seite gestellt."},{s:4,n:"Gemüse im Bratensaft anbraten",d:"Nachdem dies geschehen ist, gibt man den Bratensaft und das Öl wieder in den Topf und läßt die Champignons, Zwiebeln und Knoblauch darin abraten."},{s:4,n:"Gemüse im Bratensaft anbraten",d:"Nachdem dies geschehen ist, gibt man den Bratensaft und das Öl wieder in den Topf und läßt die Champignons, Zwiebeln und Knoblauch darin abraten."},{s:5,n:"Ragout würzen",d:"Nach ca. 5-7 min werden die Herzen wieder in den Topf gegeben und Tomatenmark kurz mitgebraten. Jetzt wird alles mit Rotwein abgelöscht und eingekocht. Wenn der Alkohol sich verflüchtigt hat, wird heißes Wasser dazugegeben und alles zusammen ca. 20 min leicht vor sich hinköcheln lassen. Jetzt werden die Nudeln aufgesetzt. Fertig."},{s:5,n:"Ragout würzen",d:"Nach ca. 5-7 min werden die Herzen wieder in den Topf gegeben und Tomatenmark kurz mitgebraten. Jetzt wird alles mit Rotwein abgelöscht und eingekocht. Wenn der Alkohol sich verflüchtigt hat, wird heißes Wasser dazugegeben und alles zusammen ca. 20 min leicht vor sich hinköcheln lassen. Jetzt werden die Nudeln aufgesetzt. Fertig."}],p:"00:20",c:"00:40",tot:65,srv:"4",cats:["Geflügel","Pasta & Nudeln"]},{id:1867,t:"Gemuse Nudel Auflauf",i:[{n:"Nudeln",u:"g",a:"700"},{n:"Kochschinken",u:"Pck",a:"1"},{n:"Paprika (gelb, rot)",u:"Stk",a:"2"},{n:"Möhren",u:"Stk",a:"5"},{n:"Zwiebellauchstangen",u:"Stk",a:"6"},{n:"Mais",u:"Dose",a:"1"},{n:"Currypulver",u:"EL",a:"1"},{n:"Öl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Nudeln kochen",d:"Die Nudel werden mit etwas Salz bissfest gekocht."},{s:2,n:"Gemüse und Kochschinken kleinschneiden",d:"Währenddessen wird das Gemüse (Lauchzwiebeln und Paprika) abgewaschen und in kleine Stücke und die Möhren in schmale Streifen geschnitten. Der Mais wird abgegossen und ggfs. in einem Sieb unter kaltem Wasser abgespült und der Kochschinken klein geschnitten."},{s:3,n:"Ofen vorheizen",d:"Der Ofen kann jetzt auf ca. 180 Grad vorgeheizt werden."},{s:4,n:"Gemüse dünsten, Kochschinken anbraten und würzen",d:"Nun wird Öl in einer Pfanne erhitzt und die Lauchzwiebeln und Möhren ca. 5 min gedünstet. Jetzt werden der Paprika, der Mais und der Kochschinken hinzugegeben, mit Salz und Pfeffer und Currypulver kräftig gewürzt. Die passierten Tomaten werden nun hinzugegeben und alles zusammen noch ca. 10 min eingekocht. ggfs. nochmals nachgewürzt."},{s:5,n:"Auflauf schichten und im Ofen backen",d:"Die Nudeln kommen nun in eine Auflaufform, die Gemüse Schinken Soße wird darüber gegeben und alles kurz miteinander vermischt. Zum Schluss wird noch der Käse darüber gestreut und für ca. 15 min im Ofen gebacken. Fertig. Guten Appetit"}],p:"00:15",c:"00:35",tot:60,srv:"6",cats:["Pasta & Nudeln"]},{id:1869,t:"Apfelkuchen Mit Cranberries   Herdzeit.De",i:[{n:"Mehl",u:"g",a:"300"},{n:"Backpulver",u:"TL",a:"2"},{n:"Zucker",u:"g",a:"100"},{n:"Salz",u:"Prise",a:"1"},{n:"Ei",u:"Stk",a:"1"},{n:"Zimt",u:"Tl",a:"1"},{n:"Milch",u:"EL",a:"1"},{n:"Butter",u:"g",a:"150"},{n:"Äpfel",u:"kg",a:"15"},{n:"Zitrone, Saft davon",u:"Stk",a:"05"},{n:"Zucker",u:"g",a:"50"},{n:"Cranberries (getrocknet)",u:"g",a:"100"},{n:"Päckchen Puddingpulver (Vanille)",u:"Stk",a:"05"},{n:"Milch",u:"EL",a:"2"}],st:[{s:1,n:"Teig zubereiten",d:"Folgende Zutaten werden miteinander auf einer Arbeitsplatte oder einer Schüssel gut miteinander verknetet: Mehl, Backpulver, 100 g Zucker, Salz, 1/2 Eigelb, Eiweiß, Milch und Butter. Sollte der Teig noch zu feucht sein, so gibt man evtl. noch etwas Mehl hinzu oder läßt den Teig im Kühlschrank abkühlen. Jetzt wird eine Springform eingefettet und mit 2/3 des Teiges auf dem Boden angedrückt. Der Ofen wird währenddessen auf 200 Grad vorgeheizt."},{s:2,n:"Äpfel schälen und in Stücke schneiden",d:"Nun werden noch die Äpfel geschält, entkernt, in grobe Stücke geschnitten und mit Zitronensaft vermischt."},{s:2,n:"Äpfel schälen und in Stücke schneiden",d:"Nun werden noch die Äpfel geschält, entkernt, in grobe Stücke geschnitten und mit Zitronensaft vermischt."},{s:3,n:"Äpfel mit restlichen Zutaten mischen",d:"Zimt, Zucker, Puddingpulver und Cranberries werden noch unter die Äpfel gemischt."},{s:3,n:"Äpfel mit restlichen Zutaten mischen",d:"Zimt, Zucker, Puddingpulver und Cranberries werden noch unter die Äpfel gemischt."},{s:4,n:"Teigmasse in Springform füllen",d:"Die Masse gibt man nun in die Springform. Jetzt kann man entscheiden, wie der \\Deckel\\ aussehen soll. Entweder man rollt den restlichen Teig aus und legt ihn einfach drüber oder man bröselt kleine Stücke über den Kuchen. Ich mag die 2. Variante lieber."},{s:4,n:"Teigmasse in Springform füllen",d:"Die Masse gibt man nun in die Springform. Jetzt kann man entscheiden, wie der \\Deckel\\ aussehen soll. Entweder man rollt den restlichen Teig aus und legt ihn einfach drüber oder man bröselt kleine Stücke über den Kuchen. Ich mag die 2. Variante lieber."},{s:5,n:"Ab in den Ofen!",d:"Jetzt noch für ca. 50 - 60 Minuten in den Ofen. Zum Schluss noch Zuckerpulver darüber gestreut. Fertig. Guten Appetit"},{s:5,n:"Ab in den Ofen!",d:"Jetzt noch für ca. 50 - 60 Minuten in den Ofen. Zum Schluss noch Zuckerpulver darüber gestreut. Fertig. Guten Appetit"}],p:"00:30",c:"1:00",tot:100,srv:"12",cats:["Backen & Desserts"]},{id:1883,t:"Huhnersuppe Nach Omas Art",i:[{n:"Suppenhuhn",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"3"},{n:"Porree",u:"Stangen",a:"2"},{n:"dicke Scheibe Sellerie",u:"Stk",a:"1"},{n:"Rosenkohl",u:"g",a:"250"},{n:"Blumenkohl",u:"Röschen",a:"4"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"mittelgroße festkochende Kartoffeln",u:"Stk",a:"4"},{n:"Pimentkörner",u:"Stk",a:"2"},{n:"Pfefferkörner",u:"Stk",a:"4"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Huhn weich kochen",d:"Das Suppenhuhn, am besten in einem Schnellkochtopf, mit einer Zwiebel und den Gewürzkörnern weich kochen. Sobald das Huhn weich genug ist, wird es aus dem Topf genommen und auf einem Teller zum abkühlen zur Seite gestellt."},{s:2,n:"Gemüse vorbereiten",d:"In der Zwischenzeit putzt Ihr das Gemüse und schneidet es in grobe Stücke. Das Gemüse sollte einzeln nacheinander gekocht werden. Grund hierfür ist, daß jede Gemüsesorte unterschiedliche Garzeiten hat. Letztendlich soll es knackig bleiben und nicht matschig werden."},{s:3,n:"Gemüse garen",d:"In folgender Reihenfolge wird nun das Gemüse in den Topf gegeben: Zuerst die Möhren, dann die Kartoffeln, der Blumenkohl und den Porree. Zum Schluss werden noch der Sellerie und der Rosenkohl hinzugeben. Wann die jeweiligen Gemüsesorten hinzugegeben werden, hängt vom Geschmack ab. Wer es gern etwas weicher haben möchte, kocht entsprechend länger. Für die knackige Variante sind die Abstände zwischen den Zugaben natürlich kürzer."},{s:4,n:"Hühnchenfleisch vom Knochen abtrennen",d:"Sobald das Huhn ausgekühlt ist, wird das Fleisch vom Knochen gelöst, evtl. noch zerkleinert und mit in den Topf gegeben. Es kommt nur das Fleisch in den Topf, keine Knochen oder Knorpel. Die Haut des Huhn wird in eine kleine Schüssel zur Seite gestellt."},{s:5,n:"Hühnerbrühe abschmecken und Hühnchenhaut anbraten",d:"Nun wird die Brühe noch kräftig mit Salz und Pfeffer abgeschmeckt. Die gekochte Haut, wird nun noch in einer Pfanne schön kross angebraten und in die Schüssel zurück gelegt."},{s:6,n:"Anrichten und servieren",d:"Nun kann alles serviert werden. Die Schüssel mit der Hühnerbrühe wird noch mit Kräutern und kleine Paprikastücken garniert. Dazu serviert man die kross gebratene Haut. Ein Brot dazu und fertig ist die Wundersuppe für leidende Männer :-)"}],p:"00:15",c:"00:90",tot:110,srv:"3",cats:["Geflügel","Suppen & Eintöpfe"]},{id:1884,t:"Bratkartoffeln Mit Spiegelei",i:[{n:"Kartoffeln",u:"g",a:"800"},{n:"Eier",u:"Stk",a:"4"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"frische Champignons",u:"g",a:"250"},{n:"Schinkenwürfel",u:"",a:""},{n:"Sure Gurken",u:"",a:""},{n:"Tomaten",u:"",a:""},{n:"Gurken",u:"",a:""}],st:[{s:1,n:"Kartoffeln, Champignons und Zwiebel vorbereiten",d:"Kartoffeln schälen, waschen und in kleine Stücke schneiden. Das Stielende der Champignons abschneiden, Kopf halbieren und in Scheiben schneiden. Zwiebel schälen und zerkleinern. In einer Pfanne Öl und Butter erhitzen, Salz und Pfeffer hinzugeben. Wenn alles zerlaufen ist kurz schwenken und Gewürze verteilen."},{s:2,n:"Kartoffeln anbraten",d:"Nun werden die kleingeschnittenen rohen Kartoffeln in die Pfanne gegeben und unter schwenken angebraten und immer mal wieder gewendet (mit ein wenig Übung bleibt auch alles in der Pfanne und landet nicht mehr auf dem Herd)."},{s:3,n:"Schinkenwürfel, Champignons und Zwiebel anbraten",d:"Nach ca. 5 min wird eine weitere Pfanne erhitzt und die Schinkenwürfel zusammen mit den Champignons angebraten. Nach weiteren 5 min wird die Zwiebel dazugegeben und mitgebraten."},{s:4,n:"Spiegeleier zubereiten",d:"Sollte keine weitere Pfanne zur Verfügung stehen, so können nun die Bratkartoffeln in eine Schüssel gegeben werden und noch kurz im auf 70 Grad vorgeheizten Ofen warm gehalten werden. In der nun freigewordenen Pfanne müssen nur noch die Spiegeleier gebraten werden."},{s:5,n:"Anrichten und servieren",d:"Ein Teller wird mit ein wenig Gemüse (saure Gurken, Tomaten,...) garniert und zum Schluss mit den Kartoffeln, dem Pilz/Schinkengemisch und dem Spiegelei befüllt. Das Gericht ist schnell zubereitet und eignet sich auch wunderbar zur \\Resteverwertung\\. Guten Appetit"}],p:"00:10",c:"00:30",tot:50,srv:"4",cats:["Frühstück & Eier"]},{id:1887,t:"Rindfleisch Gemuse Pfanne",i:[{n:"Rindfleisch",u:"g",a:"500"},{n:"Paprika (rot, gelb, grün)",u:"Stk",a:"3"},{n:"Zucchini",u:"Stk",a:"1"},{n:"große rote Zwiebel",u:"Stk",a:"1"},{n:"Sojasoße",u:"EL",a:"3"},{n:"Austernsoße",u:"EL",a:"2"},{n:"Speisestärke",u:"EL",a:"1"},{n:"Wasser",u:"ml",a:"300"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Rindfleisch in Streifen schneiden und würzen",d:"Das Rindfleisch abwaschen und mit Küchenpapier trockentupfen. Danach in kleine Streifen schneiden. In einer kleinen Schüssel wird Sojasoße, Speisestäre und Pfeffer miteinander vermischt, zum Fleisch gegeben und in der Schüssel zur Seite gestellt"},{s:2,n:"Gemüse kleinschneiden und kurz anbraten",d:"Das Gemüse (Paprika, Zucchini) in feine Streifen und die Zwiebel in Halbringe schneiden. Öl in einer Pfanne erhitzen und das Gemüse darin ca. 4 min anbraten, wieder aus der Schüssel nehmen und zur Seite stellen."},{s:3,n:"Zwiebel glasig dünsten",d:"Nun wird die Zwiebel glasig angebraten und ebenfalls wieder zur Seite gestellt."},{s:4,n:"Fleisch anbraten und Zwiebeln hinzufügen",d:"Jetzt wird das marinierte Fleisch kräftig angebraten und nach ca. 5 min werden die Zwiebeln hinzugegeben."},{s:5,n:"mit Rotwein und Austernsoße ablöschen",d:"Bei der kinderfreundlichen Variante verzichtet man auf den Rotwein, sonst gibt man jetzt den Rotwein und die Austernsoße hinzu. Nach ca. 10 min wird Wasser aufgegossen und alles zusammen auf niedriger Stufe leicht vor sich hinköcheln lassen."},{s:6,n:"Gemüse dazugeben und durchschwenken",d:"Nach weiteren 15 -20 min (Fleisch sollte schön zart sein) wird noch das Gemüse in den Topf gegeben und ein weinig in der Soße mit dem Fleisch geschwenkt."},{s:7,n:"Tipp",d:"Dazu serviert man Basmatireis wie in dem Gericht \\Hühnergeschnetzeltes auf Basmatireis\\ beschrieben. Guten Appetit"}],p:"00:15",c:"00:35",tot:60,srv:"4",cats:["Fleisch"]},{id:1889,t:"Hahnchenragout Mit Kartoffelgratin",i:[{n:"Kartoffeln",u:"g",a:"800"},{n:"Hühnerbrustfilet",u:"g",a:"600"},{n:"gr. Tomaten",u:"Stk",a:"2"},{n:"Zwiebellauch",u:"Stangen",a:"6"},{n:"Sahne",u:"ml",a:"200"},{n:"Brühe",u:"ml",a:"300"},{n:"Mehl",u:"EL",a:"1"},{n:"Butter",u:"",a:""},{n:"Sonnenblumenöl",u:"",a:""},{n:"Muskat",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch vorbereiten",d:"Fleisch waschen, trockentupfen und in kleine Würfel schneiden"},{s:2,n:"Gemüse in Scheiben schneiden",d:"Den Zwiebellauch waschen und in Ringe sowie die Kartoffeln waschen und in dünne Scheiben schneiden. Zum Schluss werden noch 2 gr. Tomaten in Scheiben geschnitten."},{s:3,n:"Hühnerfleisch anbraten",d:"Öl und Butter in einer Pfanne erhitzen, Salz, Pfeffer rein und das Hühnerfleisch darin kräftig anbraten."},{s:4,n:"Lauchringe dazugeben und einkochen lassen",d:"Wenn es gut durch aber nicht trocken ist, werden die Lauchzwiebelringe kurz mit gebraten, Mehl darüber gestreut, umgerührt und um dann mit Brühe und Sahne abgelöscht und kurz eingekocht zu werden."},{s:5,n:"Ofen vorheizen und Auflaufform vorbereiten",d:"Währendessen wird der Ofen auf 200 Grad vorgeheizt, eine Auflaufform mit Butter eingefettet und 2/3 der Kartoffeln darin verteilt."},{s:6,n:"Fleisch abschmecken und in Auflaufform schichten",d:"Wenn die Soße mit dem Fleisch die richtige Konsistenz hat, (nochmal mit Salz, Pfeffer und Muskat abschmecken) werden nun die Lauchzwiebeln und das Hühnerfleisch mit einer Siebkelle auf den Kartoffeln verteilt und dann mit der Soße soweit aufgefüllt, dass die Kartoffeln und das Fleisch leicht bedeckt. Zum Schluss werden nun noch die restlichen Kartoffelscheiben und die Tomaten darauf verteilt sowie der Käse darüber gestreut."},{s:7,n:"Ab in den Ofen",d:"Alles zusammen kommt dann für ca. 45 min auf die mittlere Schiene in den Ofen. Es kann danach sofort heiß serviert werden. Guten Appetit"}],p:"00:15",c:"00:55",tot:75,srv:"4",cats:["Geflügel","Vegetarisch"]},{id:1891,t:"Rindfleischragout Mit Penne Rigate",i:[{n:"Rindfleisch",u:"g",a:"800"},{n:"Penne Rigata",u:"",a:""},{n:"gr. rote Zwiebel",u:"Stk",a:"1"},{n:"frische Champignons",u:"g",a:"250"},{n:"Sojasoße",u:"EL",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"gestrichener EL Speisestärke",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch in Streifen schneiden",d:"Das Rindfleisch abwaschen, trockentupfen und in 1 cm kleine Streifen schneiden"},{s:2,n:"Gemüse vorbereiten",d:"Von den Pilzen wird das Ende des Stiels abgeschnitten, der Kopf halbiert und in Scheiben geschnitten. Die rote Zwiebel sehr fein schneiden und 1 Knoblauchzehe kleinhacken."},{s:3,n:"Fleisch anbraten und Sud anrühren",d:"Ein Topf wird mit Öl, Salz und Pfeffer erhitzt. Sobald es heiß genug ist, wird das Fleisch portionsweise in den Topf gegeben und scharf angebraten und mit Majoran gewürzt. Austretende Flüssigkeit vom Fleisch wird in einer kleinen Schüssel aufgefangen und später mit Sojasoße und Speisestärke vermischt."},{s:4,n:"Fleisch in Marinade ziehen lassen",d:"Nachdem das Fleisch fertig und in einer Schüssel zur Seite gestellt wurde, wird die Fleischsaftmarinade zum Fleisch gegeben"},{s:5,n:"Gemüse dünsten",d:"Nun wird erst die Zwiebel glasig angedünstet und gleich wieder in einer Schüssel zur Seite gestellt. Danach werden die Pilze angebraten. Nach ca. 5 min werden die Zwiebeln und das Fleisch in den Topf gegeben."},{s:6,n:"Zutaten im Sud köcheln lassen",d:"1 EL Tomatenmark druntergemischt und Rotwein eingekocht. Sobald der Alkohol verdunstet ist, wird Wasser dazugegeben und alles ca. 20-30 min. langsam vor sich hinköcheln lassen. Ein würzen der Soße sollte nicht mehr notwendig sein. Dazu reicht man Penne oder Spiralnudeln. Fertig. Guten Appetit"}],p:"00:10",c:"00:45",tot:60,srv:"4",cats:["Fleisch","Pasta & Nudeln"]},{id:1893,t:"Garnelen In Tomaten Krautersud",i:[{n:"Garnelen (frisch oder gefroren)",u:"g",a:"500"},{n:"Kirschtomaten",u:"g",a:"500"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"kleine Chilischote",u:"Stk",a:"0.5"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Paprikapulver",u:"Tl",a:"2"},{n:"Currypulver",u:"Tl",a:"1"},{n:"frischer Dill",u:"Stängel",a:"4"},{n:"Olivenöl",u:"EL",a:"1"},{n:"Zitronensaft",u:"TL",a:"2"},{n:"frischen Basilikum",u:"Blätter",a:"8"},{n:"Butter",u:"",a:""}],st:[{s:1,n:"Vorab nicht vergessen",d:"Den Ofen auf 250 Grad vorheizen. Garnelen ggfs. auftauen."},{s:2,n:"Gemüse kleinschneiden",d:"Tomaten in kleine Stücke und die Zwiebeln sehr fein schneiden. Knoblauchzehe in feine Scheiben schneiden, weitere 5 Knoblauchzehen schälen und mit dem Messer leicht andrücken. Klein geschnittenes Gemüse in eine große Aluschüssel oder ofenfeste Schüssel geben."},{s:3,n:"Kräuter klein hacken",d:"Dill bzw. Kräuter nach Belieben sehr klein hacken."},{s:4,n:"Würzen",d:"Paprikapulver, Currypulver, Salz, Pfeffer, Öl und Kräuter hinzugeben."},{s:5,n:"Garnelen anbraten",d:"Eine Pfanne mit Öl heiß erhitzen. Die aufgetauten Garnelen hinzugeben und ca. 5 Minuten anbraten, mit Salz würzen und ca. 3 Minuten vor Schluss die angedrückten Knoblauchzehen hinzufügen."},{s:6,n:"Vermengen und in den Ofen geben",d:"Die Garnelen zum Gemüse in die Schüssel geben und unterheben. Butterflocken darauf geben und für ca. 20-30 Minuten in den Ofen geben. Die Schüssel mit Alufolie abdecken"},{s:7,n:"Baguettescheiben anrösten",d:"Wer mag schneidet noch ein paar Scheiben Baguette und röstet eine Seite sehr kurz in der Pfanne in leicht gesalzener Butter an. Dies eignet sich ideal zum Dippen der leckeren Tomatensoße mit Garnelen."},{s:8,n:"Mein Küchen-Tipp",d:"Gefrorene Garnelen für ca. 20 Minuten in kaltes Wasser legen. So tauen sie zügiger auf. Marinierte gefrorene Garnelen einfach im Plastikbeutel belassen und ebenso in kaltes Wasser legen."}],p:"00:15",c:"00:30",tot:50,srv:"3",cats:["Fisch & Meeresfrüchte"]},{id:1894,t:"Nudeln Mit Mediteraner Tomatensosse 2",i:[{n:"Penne",u:"g",a:"300"},{n:"gelbe Paprika",u:"Stk",a:"1"},{n:"kleine Zucchini",u:"Stk",a:"1"},{n:"braune Champignons",u:"Stk",a:"6"},{n:"rote Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"herzhafte Oliven",u:"Stk",a:"9"},{n:"eingelegte getrocknete Tomaten",u:"Stk",a:"4"},{n:"passierte Tomatensoße",u:"Pck",a:"2"},{n:"Parmesankäse",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Oregano",u:"",a:""}],st:[{s:1,n:"Gemüse schneiden",d:"Die gelbe Paprika vom Stiel und den Kernen befreien und in 1 cm große Stücke schneiden. von den 6 frischen braunen Champignons das Stielende abschneiden und den Kopf halbieren und in Scheiben schneiden. eine rote Zwiebel schälen, halbieren und vierteln. Nun pult man die einzelnen Zwiebelschichten auseinander. Die Zucchini waschen, Enden entfernen und den Rest in grobe Stücke schneiden. Die Knoblauchzehe und die eingelegten getrockneten Tomaten werden sehr fein gehackt und die Oliven geviertelt."},{s:2,n:"Nudeln kochen",d:"Topf mit ausreichend Wasser aufsetzen, Salz hinzufügen und die Penne Nudeln bissfest kochen."},{s:3,n:"Gemüse in der Pfanne anbraten",d:"Jetzt wird eine Pfanne mit der Butter erhitzt. Sobald diese zerlaufen ist, gibt man zuerst die Pilze hinzu und brät diese ca. 2 min. Nun folgt die Zucchini. Nach einer weiteren Minute folgt die Zwiebel mit dem Knoblauch. Nach einer weiteren Minute gibt man den Paprika und die Oliven mit den gehackten Tomaten hinzu. Alles zusammen wird noch kurz angebraten und mit Salz und Pfeffer gewürzt."},{s:4,n:"Tomatensoße würzen",d:"Danach gießt man die passierten Tomaten in die Pfanne und kocht alles zusammen ein. Jedoch nicht zu lang, da das Gemüse knackig bleiben soll. Die Soße wird noch mit Majoran, Oregano, Salz und Pfeffer abgeschmeckt. Gelegentlich kann man auch noch etwas von dem Nudelwasser abschöpfen und mit zur Soße geben. Sollte es noch etwas säuerlich schmecken, so verfeinert man den Geschmack noch ein wenig mit Zucker."},{s:5,n:"Penne und Tomatensoße vermengen",d:"Die Pasta dürfte nun auch fertig sein. Das Wasser gießt man ab und die verbleibenden Nudeln werden in die Pfanne zu der Tomaten-Gemüsesoße gegeben und miteinaner vermengt"}],p:"00:15",c:"00:30",tot:50,srv:"4",cats:["Pasta & Nudeln"]},{id:1895,t:"Kartoffelsuppe",i:[{n:"Kartoffeln (mehligkochend)",u:"kg",a:"1"},{n:"Lauchzwiebel",u:"Stangen",a:"12"},{n:"große Möhren",u:"Stk",a:"4"},{n:"kl. Sellerieknolle",u:"Stk",a:"1"},{n:"Sahne",u:"ml",a:"200"},{n:"Wasser",u:"L",a:"1"},{n:"Butter",u:"",a:""},{n:"Öl",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln und Gemüse schneiden",d:"Die Kartoffeln schälen, waschen und in Stücke schneiden. Die Möhren und die Sellerieknolle schälen und in Würfel sowie die Zwiebellauchstangen in Ringe schneiden. Das Wasser in einem Wasserkocher erhitzen."},{s:2,n:"Gemüse anbraten",d:"Währenddessen wird ein großer Topf mit 1 EL Öl + 2-3 EL Butter erhitzt und mit dem Gemüse (Möhren und Sellerie) angebraten. Nach ca. 5 min kommt der Zwiebellauch und Majoran hinzu. Mit Salz und Pfeffer gewürzt. jetzt werden die Kartoffeln hinzugeben und der Topf mit dem heißen Wasser aufgegossen."},{s:3,n:"Köcheln lassen",d:"Jetzt läßt man alles ca. 20-30 min. leicht vor sich hinköcheln. Die Kartoffeln sollten sich mit leichtem Widerstand zerdrücken lassen, dann kann der Topf vom Herd genommen werden."},{s:4,n:"Kartoffelsuppe pürieren und abschmecken",d:"Die Suppe mit dem Pürierstab oder im Mixer pürieren. Ich mag es gern etwas dicker. Wer jedoch mehr Flüssigkeit haben möchte, gibt einfach noch ein wenig heißes Wasser hinzu. Zum Schluß noch die Sahne einrühren und kräftig mit Salz und Pfeffer abschmecken. Die Wiener wurden während dessen schon in einem anderem Topf erwärmt und die Petersilie kleingehackt und später über die Suppe auf den Teller gestreut."}],p:"00:15",c:"00:40",tot:65,srv:"7",cats:["Suppen & Eintöpfe"]},{id:1897,t:"Griesbrei Mit Pflaumen",i:[{n:"Milch",u:"l",a:"1"},{n:"Weichweizen Grieß",u:"EL",a:"6"},{n:"Zucker",u:"EL",a:"6"},{n:"Ei",u:"Stk",a:"1"},{n:"Pflaumen",u:"Glas",a:"1"},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Milch aufkochen",d:"Milch aufkochen, bis diese leicht im Topf nach oben kocht."},{s:2,n:"Grieß verrühren",d:"Währenddessen wird mit einer großen Kelle etwas Milch in eine kleine Schüssel gegeben und der Grieß darin verrührt damit später dann keine Klumpen entstehen."},{s:2,n:"Grieß verrühren",d:"Währenddessen wird mit einer großen Kelle etwas Milch in eine kleine Schüssel gegeben und der Grieß darin verrührt damit später dann keine Klumpen entstehen."},{s:3,n:"Eigelb einrühren",d:"Sobald die Milch aufgekocht ist, vom Herd nehmen, Grieß und Eigelb 5 min. unter ständigem rühren in den Topf geben."},{s:3,n:"Eigelb einrühren",d:"Sobald die Milch aufgekocht ist, vom Herd nehmen, Grieß und Eigelb 5 min. unter ständigem rühren in den Topf geben."},{s:4,n:"Mit Zucker abschmecken",d:"Danach mit Zucker und einer Prise Salz abschmecken."},{s:4,n:"Mit Zucker abschmecken",d:"Danach mit Zucker und einer Prise Salz abschmecken."},{s:5,n:"Eiweiß steif schlagen",d:"Nun wird noch das Eiweiß, welches vom Eigelb getrennt wurde, in einer Schüssel steif geschlagen und zum Schluss unter den Grießbrei gehoben. Dadurch wird alles noch schön fluffig."},{s:5,n:"Eiweiß steif schlagen",d:"Nun wird noch das Eiweiß, welches vom Eigelb getrennt wurde, in einer Schüssel steif geschlagen und zum Schluss unter den Grießbrei gehoben. Dadurch wird alles noch schön fluffig."},{s:6,n:"Pflaumen hinzufügen",d:"Pflaumen dazu fertig."},{s:6,n:"Pflaumen hinzufügen",d:"Pflaumen dazu fertig."},{s:7,n:"Tipp",d:"Man kann auch gern noch Vanille hinzugeben."},{s:7,n:"Tipp",d:"Man kann auch gern noch Vanille hinzugeben."}],p:"00:5",c:"00:15",tot:20,srv:"4",cats:["Vegetarisch","Backen & Desserts"]},{id:1898,t:"Schweinefilet In Balsamico Rosmarin Marinade   Herdzeit.De",i:[{n:"Schweinefilet",u:"g",a:"900"},{n:"Rotwein",u:"ml",a:"200"},{n:"dunkler Balsamicoessig",u:"ml",a:"100"},{n:"Butter",u:"",a:""},{n:"Honig",u:"",a:""},{n:"Rosmarin",u:"Zweige",a:"8"},{n:"Sojasoße",u:"EL",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Schweinefilet putzen",d:"Schweinefilet waschen, trockentupfen und von Sehnen und überflüssigem Fett befreien."},{s:2,n:"Kräuter und Balsamicomarinade vorbereiten",d:"2 Knoblauchzehen schälen und vierteln. 3 Rosmarinzweige waschen und trockentupfen. In einer großen Tasse oder Schüssel 200 ml Rotwein, 100 ml schwarzen Balsamicoessig sowie 1 EL Sojasoße und Pfeffer gründlich verrühren. Schweinefilet kräftig mit Salz und Pfeffer würzen."},{s:3,n:"Schweinefilet anbraten",d:"In einer Pfanne Öl und Butter erhitzen, den geviertelten Knoblauch hinzugegeben und das Schweinefilet von allen Seiten ca. 10 -15 min gut anbraten. Währenddessen immer mal wieder Rosmarinnadeln darüber streuen."},{s:4,n:"Marinade portionsweise hinzufügen",d:"Nachdem das Fleisch angebraten wurde, die Marinade portionsweise in die Pfanne geben und mit dem Fleisch zusammen einkochen. (1/3 der Marinade verbleibt in der Schüssel.) Dabei muss das Filet immer wieder gewendet werden."},{s:5,n:"Fleisch ruhen lassen",d:"10 min. später Fleisch herausnehmen, in Alufolie wickeln und kurz ruhen lassen. Dabei sammelt sich der Fleischsaft, der später wieder in die Pfanne zur Marinade gegeben wird."},{s:6,n:"Balsamico Marinade einkochen",d:'Nun den Rest Marinade in die Pfanne geben und kräftig einkochen. Es werden noch weitere Rosmarinzweige sowie eine Knoblauchzehe hinzugefügt. Da es zu diesem Zeitpunkt noch sehr sauer schmeckt, wird Honig hinzugegeben, bis der gewünschte Geschmack entsteht. Das Schweinefilet in Balsamico-Rosmarin Marinade sollte weder zu süß noch zu sauer schmecken. Mit Salz und Pfeffer abschmecken. Die Marinade sehr würzig abschmecken, da sie das Tüpfelchem auf dem "ži" ist. ;). Ist die Marinade leicht dickflüssig, kann die Pfanne vom Herd genommen werden.'},{s:7,n:"Schweinefilet filetieren",d:"Das Filet wird nun aus der Alufolie nehmen und den Fleischsaft in die Pfanne geben. Das Fleisch nun in schmale Streifen schneiden und diese auf einem Teller anrichten. Mit einem Löffel jetzt die Soße über die Fleischstücken träufeln und einfach nur genießen. Schweinefilet in Balsamico-Rosmarin Marinade kann kalt wie auch warm gegessen werden."}],p:"00:5",c:"00:20",tot:30,srv:"4",cats:["Fleisch","Grillen & Marinaden"]},{id:1899,t:"Obstsalat",i:[{n:"Äpfel",u:"Stk",a:"2"},{n:"Apfelsinen",u:"Stk",a:"3"},{n:"Kiwis",u:"Stk",a:"3"},{n:"Mango",u:"Stk",a:"1"},{n:"Banane",u:"Stk",a:"1"},{n:"Ananas",u:"Stk",a:"1"},{n:"Weintrauben",u:"Stk",a:"15"},{n:"Honig",u:"EL",a:"2"},{n:"Zitronen-/Limettensaft",u:"EL",a:"3"}],st:[{s:1,n:"Obst vorbereiten",d:"Die Äpfel, Apfelsinen, Kiwis, die Mango, die Weintrauben und die Ananas werden abgewaschen, geschält, in kleine Stücke geschnitten und in einer Schüssel vorsichtig miteinander vermischt."},{s:2,n:"Soße anrühren und mit Obst vermischen",d:"Jetzt werden 2-3 Esslöffel Zitronen- oder Limettensaft und 2 EL Honig in eine kleine Schüssel gegeben und gut verrührt. Sobald sich der Honig und der Zitronensaft miteinander verbunden haben, wird die Flüssigkeit über den Obstsalat gegeben und wieder vorsichtig vermischt. Das Ganze läßt man nun ca. 2h ruhen"},{s:3,n:"Banane unter Obstsalat heben",d:"Kurz bevor der Salat serviert wird, muß die Banane in Scheiben geschnitten und unter den Obstsalat gehoben werden."},{s:4,n:"Tipp",d:"Bei der Kinderversion ist der Salat nun fertig. Für die Erwachsenen kann nun noch in jede einzelne Schüssel ein Schluck Mandellikör hinzugegeben werden. Statt des Zitronen-oder Limettensaftes kann auch frisch gepresster Johannisbeersaft oder Kirschsaft genommen werden oder wenn man alles da hat, dann darf auch alles hinzugegeben werden."}],p:"00:15",c:"00:00",tot:20,srv:"6",cats:["Salate","Vegetarisch","Backen & Desserts"]},{id:1900,t:"Spareribs",i:[{n:"Rippchen",u:"kg",a:"1.5"},{n:"Marinade",u:"",a:""},{n:"kleine Kartoffeln",u:"kg",a:"1"},{n:"Rosmarin",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch und Gemüse vorbereiten",d:"In jedem Fall sollte das sichtbare Fett vorsichtig mit dem Messer entfernt werden. Sobald dies geschehen ist, wird das Fleisch abgewaschen und in einen Topf mit kaltem Wasser gegeben. Nun fügt man noch Salz, eine geachtelte Zwiebel, 2 Koblauchzehen und etwas Suppengrün hinzu, aufkochen lassen und bei reduzierter Hitze ca. 20-30 Min. köcheln lassen."},{s:2,n:"Fleisch marinieren und Ofen vorheizen",d:"Fleisch herausnehmen, abkühlen lassen und mit der Rippchenmarinade einreiben. Die Rippchen läßt man nun abgedeckt im Kühlschrank ca. 30 min marinieren. Kurz vor Schluss sollte der Ofen auf ca. 220 Grad erhitzt werden."},{s:3,n:"Spareribs im Ofen braten",d:"Sobald der Ofen heiß genug ist, legt man die Spareribs auf ein Blech und schiebt diese auf die mittlere Schiene für ca. 30 Min in den Ofen. Zwischendurch darf das Fleisch gewendet werden. In jedem Fall sollten die Rippchen eine schöne Kruste entwickeln. Um das zu erreichen, muß evtl. in den letzten Minuten die Temperatur hochgedreht oder das Blech knapp unter den Ofengrill geschoben werden. Bleibt dabei stehen um eine Anbrennen des Fleisches zu vermeiden."},{s:4,n:"Anrichten und servieren",d:"Bei uns gab es Rosmarinkartoffeln dazu. Anrichten und schmecken lassen :-) Guten Appetit"}],p:"1:00",c:"00:30",tot:100,srv:"4",cats:["Fleisch","Grillen & Marinaden"]},{id:2009,t:"Lauwarmer Bohnensalat Mit Putenbrustfilet",i:[{n:"frische Bohnen",u:"g",a:"800"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Kirschtomaten",u:"g",a:"200"},{n:"Putenbrustfilet",u:"g",a:"500"},{n:"Weinessig",u:"El",a:"4"},{n:"groben Senf",u:"EL",a:"15"}],st:[{s:1,n:"Bohnen putzen und garen",d:"Die Bohnen putzen, halbieren, abwaschen und in einem Topf mit Salzwasser ca. 13 Min. garen."},{s:2,n:"Putenbrustfilet vorbereiten und Tomaten halbieren",d:"Das Putenbrustfilet unter kaltem Wasser abwaschen, trockentupfen und in schmale Streifen schneiden. Die Tomaten abwaschen, halbieren und in einer Schüssel zur Seite stellen."},{s:3,n:"Vinaigrette zubereiten",d:"Die Zwiebel sehr fein schneiden und zusammen mit dem Essig, Senf und dem Öl verrühren. Mit Salz und Pfeffer abschmecken."},{s:4,n:"Fleisch anbraten und mit restlichen Zutaten vermengen",d:"Nun wird eine Pfanne mit Öl erhitzt und das Putenbrustfilet darin knusprig mit Salz und Pfeffer angebraten. Nun dürften die Bohnen fertig gegart sein. In eine Schüssel gibt man nun die Bohnen, das gebratene Filet, die Tomaten und die Marinade. Vermengt alles schön miteinander und läßt es noch kurz durchziehen. Es darf serviert werden. Dazu gab es bei uns Kräuterbaguette. Guten Appetit :-)"}],p:"00:10",c:"00:15",tot:30,srv:"4",cats:["Geflügel","Salate"]},{id:2020,t:"Entrecote Auf Rosmarinkartoffeln",i:[{n:"Steaksoße (Rezept auf de Seite)",u:"",a:""},{n:"Entrecote (3 cm dick)",u:"Scheiben",a:"4"},{n:"große Möhren",u:"Stk",a:"5"},{n:"kleine festkochende Kartoffeln",u:"g",a:"500"},{n:"Rosmarin",u:"",a:""},{n:"Thymian",u:"",a:""},{n:"Öl",u:"",a:""},{n:"Butter",u:"EL",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"4"},{n:"Apfelsaft",u:"ml",a:"200"},{n:"Sojasoße",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Ofen vorheizen, Kartoffeln marinieren und Gemüse schneiden",d:"Der Ofen wird auf 180 Grad vorgeheizt. Die kleinen Kartoffeln längs und quer halbieren,abwaschen, in eine Schüssel geben, mit Rosmarin, Thymian, Salz und etwas Öl marinieren. Ein Backblech mit Backpapier auslegen und die Kartoffeln darauf verteilen. Die Möhren schälen und leicht schräg in schmale Scheiben schneiden. Eine Zwiebel sehr fein hacken und 4 Knoblauchzehen schälen."},{s:2,n:"Vorbereitung für den Bratvorgang",d:"Für den Bratvorgang sollten nun alle Zutaten griffbereit an den Herd gestellt werden. Dazu gehören die Zwiebeln, die Möhren, Butter + Butterschmalz, Balsamicoessig, Wochestersauce, Teryakisoße, Sojasoße, Öl, brauner oder weißer Zucker, Rotwein, Tomatenmark, Senf, Rosmarin, Knoblauch und 2-3 Pfannen."},{s:2,n:"Vorbereitung für den Bratvorgang",d:"Für den Bratvorgang sollten nun alle Zutaten griffbereit an den Herd gestellt werden. Dazu gehören die Zwiebeln, die Möhren, Butter + Butterschmalz, Balsamicoessig, Wochestersauce, Teryakisoße, Sojasoße, Öl, brauner oder weißer Zucker, Rotwein, Tomatenmark, Senf, Rosmarin, Knoblauch und 2-3 Pfannen."},{s:3,n:"Kartoffeln im Ofen backen und Fleisch anbraten",d:"Nun werden die Kartoffeln in den Ofen gegeben. Für das Fleisch wird nach Möglichkeit eine gusseiserne Pfanne mit Butterschmalz erhitzt. Sobal die richtige Temperatur erreicht ist, gibt man die Entrecotescheiben in die Pfanne. Diese sollten nur ca. 2-3 Minuten auf beiden Seiten kross angebraten werden, sodaß eine feste Kruste entsteht. Danach legt man die Scheiben auf eine Alufolie für 20 Min. in den Ofen."},{s:3,n:"Kartoffeln im Ofen backen und Fleisch anbraten",d:"Nun werden die Kartoffeln in den Ofen gegeben. Für das Fleisch wird nach Möglichkeit eine gusseiserne Pfanne mit Butterschmalz erhitzt. Sobal die richtige Temperatur erreicht ist, gibt man die Entrecotescheiben in die Pfanne. Diese sollten nur ca. 2-3 Minuten auf beiden Seiten kross angebraten werden, sodaß eine feste Kruste entsteht. Danach legt man die Scheiben auf eine Alufolie für 20 Min. in den Ofen."},{s:4,n:"Möhren in Sud garen",d:"Währenddessen wird eine weitere Pfanne mit 2 EL Butter erhitzt und die Möhren darin kurz angebraten. Nach ca. 5 Min fügt man eine Prise Salz und braunen Zucker hinzu. Schwenkt die Möhren darin und fügt zum Schluss noch Apfelsaft und 1 EL Sojasoße hinzu. Nun kann man das Ganze bei stark reduzierter Hitze leicht köcheln lassen. Die Möhren sollten zum Ende noch bissfest sein."},{s:4,n:"Möhren in Sud garen",d:"Währenddessen wird eine weitere Pfanne mit 2 EL Butter erhitzt und die Möhren darin kurz angebraten. Nach ca. 5 Min fügt man eine Prise Salz und braunen Zucker hinzu. Schwenkt die Möhren darin und fügt zum Schluss noch Apfelsaft und 1 EL Sojasoße hinzu. Nun kann man das Ganze bei stark reduzierter Hitze leicht köcheln lassen. Die Möhren sollten zum Ende noch bissfest sein."},{s:5,n:"Steaksoße zubereiten",d:"Die Steaksoße wird nun zubereitet. Das Rezept hierfür findet Ihr hier in meinem Blog. Jetzt dürften die 20 Min um sein und das Fleisch kann nun herausgenommen und für ca. 10 Min. auf einem Teller ruhen gelassen werden."},{s:5,n:"Steaksoße zubereiten",d:"Die Steaksoße wird nun zubereitet. Das Rezept hierfür findet Ihr hier in meinem Blog. Jetzt dürften die 20 Min um sein und das Fleisch kann nun herausgenommen und für ca. 10 Min. auf einem Teller ruhen gelassen werden."},{s:6,n:"Fleisch erneut in Pfanne braten, anschließend würzen",d:"Währenddessen halbiert man die Knoblauchzehen. Die gusseiserne Pfanne wird nun mit Butter auf mittlere Temperatur erhitzt und mit den halbierten Knoblauchzehen sowie den Rosmarinzweigen befüllt. Nun kann das Fleisch nochmals für ca. 1-2 Min in der Rosmarin, Buttersoße gebraten werden. Jetzt ist der Zeitpunkt gekommen, das Fleisch kräftig mit Salz und Pfeffer zu würzen."},{s:6,n:"Fleisch erneut in Pfanne braten, anschließend würzen",d:"Währenddessen halbiert man die Knoblauchzehen. Die gusseiserne Pfanne wird nun mit Butter auf mittlere Temperatur erhitzt und mit den halbierten Knoblauchzehen sowie den Rosmarinzweigen befüllt. Nun kann das Fleisch nochmals für ca. 1-2 Min in der Rosmarin, Buttersoße gebraten werden. Jetzt ist der Zeitpunkt gekommen, das Fleisch kräftig mit Salz und Pfeffer zu würzen."},{s:7,n:"Anrichten und servieren",d:"Et voila, das nahezu perfekte Steak wartet auf den Verzehr. :-) Die Möhren, die Kartoffeln sowie die Steaksoße sind nun ebenso auf den Punkt fertig geworden. Alles zusammen schön auf einem großen Teller anrichten und schmecken lassen."},{s:7,n:"Anrichten und servieren",d:"Et voila, das nahezu perfekte Steak wartet auf den Verzehr. :-) Die Möhren, die Kartoffeln sowie die Steaksoße sind nun ebenso auf den Punkt fertig geworden. Alles zusammen schön auf einem großen Teller anrichten und schmecken lassen."}],p:"00:10",c:"00:40",tot:60,srv:"4",cats:["Fleisch"]},{id:2057,t:"Ruherei Mit Frischem Gemuse",i:[{n:"Eier",u:"Stk",a:"6"},{n:"Milch",u:"ml",a:"50"},{n:"frische Champignons",u:"Stk",a:"5"},{n:"Paprikaschote",u:"Stk",a:"0.5"},{n:"Kirschtomaten",u:"Stk",a:"6"},{n:"Kochschinken",u:"Scheiben",a:"2"},{n:"Zwiebellauch",u:"",a:""},{n:"Öl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse und Kochschinken kleinschneiden",d:"Zuerst die halbe Paprikaschote in kleine Stücke schneiden, die Kirschtomaten vierteln und vom Zwiebellauch den obersten grünen Rand entfernen und danach vom Rest ca. 1cm in kleine Ringe schneiden. Die Pilze putzen, halbieren und in grobe Scheiben schneiden. Zum Schluss werden noch 2 Scheiben Kochschinken in kleine Würfel geschnitten."},{s:2,n:"Rührei vorbereiten",d:"Für die Vorbereitung des Rüherei´s nimmt man eine Schüssel mit hohem Rand, fügt 6 Eier, 1/2 TL Salz, Pfeffer und 50 ml Milch hinzu, rührt dies mit einer Gabel gut durch und stellt es zur Seite."},{s:3,n:"Ei mit Gemüse braten",d:"Jetzt erhitzt man eine Pfanne mit etwas Öl, brät die Pilze für ca. 3 Min an, fügt den den Kochschinken für 1 Min. hinzu und läßt dies noch kurz mit anbraten. Nun folgen der Paprika, die Tomate sowie die Zwiebellauchringe. Das Rüherei wird ebenso in die Pfanne gegossen und vorsichtig mit dem Gemüse angebraten und gelegentlich umgerührt."},{s:4,n:"Anrichten und servieren",d:"Sobald das Ei die richtige Konsistenz erhalten hat kann die Pfanne vom Herd genommen, auf dem Teller gegeben, mit Brot und Zwiebellauch garniert werden. Fertig. Guten Appetit"}],p:"00:10",c:"00:05",tot:20,srv:"2",cats:["Sonstiges"]},{id:2062,t:"Zucchini Wurziger Balsamico Marinade",i:[{n:"Zucchini",u:"Stk",a:"3"},{n:"Knoblauchzehen",u:"Stk",a:"5"},{n:"Chilischoten (größenabhängig)",u:"Stk",a:"1"},{n:"Öl",u:"",a:""},{n:"schwarzer Balsamico Essig",u:"",a:""}],st:[{s:1,n:"Zucchini in Scheiben schneiden und anbraten",d:"Von der Zucchini werden die Enden entfernt und der Rest in ca. 0,5cm dicke Scheiben geschnitten. Nun wird eine Pfanne mit etwas Öl erhitzt, die Zucchinischeiben darin von beiden Seiten angebraten und auf einem Backblech oder einer großen Servierschale dachziegelförmig verteilt"},{s:2,n:"Knoblauch und Chillischoten kleinschneiden",d:"Nun werden die Knoblauchzehen sowie die Chilischoten kleingehackt und auf den Zucchinischeiben verteilt."},{s:3,n:"Abschmecken und eine Weile ziehen lasse",d:"Alles zusammen kann nun mit Salz und Pfeffer gewürzt werden. Zum Schluss verteilt man noch vorsichtig Öl sowie schwarzen Balsamicoessig darauf. Mit Alufolie abdecken und zur Seite stellen. In den kommenden 24 Stunden kann die Schale gelegentlich ganz vorsichtig geschwenkt werden um die Oberfläche der Zucchinischeiben anzufeuchten. Guten Appetit"},{s:4,n:"Tipp",d:"Damit die Marinade erst richtig ihren Geschmack entwickeln kann, müssen die Zucchinischeiben ca. 24h durchziehen. Es eignet sich als Beilage für jede kleine Party."}],p:"00:15",c:"00:00",tot:1440,srv:"8",cats:["Vegetarisch","Grillen & Marinaden"]},{id:2085,t:"Spaghetti Mit Garnelen Und Rucola",i:[{n:"Garnelen",u:"g",a:"400"},{n:"Spaghetti (No. 3)",u:"",a:""},{n:"Rucola",u:"",a:""},{n:"Kirschtomaten",u:"g",a:"300"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Wasser",u:"ml",a:"100"},{n:"Weißwein",u:"ml",a:"100"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten und Garnelen auftauen",d:"Die Tomaten waschen und halbieren, die Zwiebel sehr fein schneiden, die gefrorenen Garnelen kurz unter warmen Leitungswasser auftauen und die 3 Knoblauchzehen in feine Scheiben schneiden."},{s:2,n:"Soße anrühren und Salat putzen",d:"In einer kleinen Schüssel einen EL Tomatenmark geben, mit ca. 100 ml kaltem Wasser auffüllen, glattrühren und mit Salz und Pfeffer abschmecken. Den Rucola waschen und die langen Stile entfernen."},{s:2,n:"Soße anrühren und Salat putzen",d:"In einer kleinen Schüssel einen EL Tomatenmark geben, mit ca. 100 ml kaltem Wasser auffüllen, glattrühren und mit Salz und Pfeffer abschmecken. Den Rucola waschen und die langen Stile entfernen."},{s:3,n:"Spaghetti kochen",d:"Die Spaghetti werden nun in Salzwasser al dente gekocht und kurz zur Seite gestellt."},{s:3,n:"Spaghetti kochen",d:"Die Spaghetti werden nun in Salzwasser al dente gekocht und kurz zur Seite gestellt."},{s:4,n:"Zwiebeln, Knoblauch und Garnelen anbraten",d:"Eine Pfanne wird nun mit Olivenöl erhitzt, gibt die Zwiebeln sowie den Knoblauch hinzu und brät alles zusammen glasig an. Sobald dies geschehen ist, folgen die Garnelen und werden ebenso kurz angebraten. Nicht zu lange, da diese sonst hart und trocken werden könnten."},{s:4,n:"Zwiebeln, Knoblauch und Garnelen anbraten",d:"Eine Pfanne wird nun mit Olivenöl erhitzt, gibt die Zwiebeln sowie den Knoblauch hinzu und brät alles zusammen glasig an. Sobald dies geschehen ist, folgen die Garnelen und werden ebenso kurz angebraten. Nicht zu lange, da diese sonst hart und trocken werden könnten."},{s:5,n:"Sud einkochen und Zutaten vermengen",d:"Jetzt gießt man 100 ml Weißwein hinein und kocht dies richtig ein, sodaß nur noch ein gewisser Sud vorhanden bleibt. Jetzt folgen der angerührte Tomatenmark sowie die halbierten Tomaten. Alles zusammen mit Salz und Pfeffer abschmecken. Die Pfanne kann nun vom Herd genommen werden. Den Rucola sowie die Spaghetti werden gut unter die Soße gehoben. Ca. 1 Min ziehen lassen und auf Tellern servieren. Parmesankäse darüber streuen. Fertig. Guten Appetit"},{s:5,n:"Sud einkochen und Zutaten vermengen",d:"Jetzt gießt man 100 ml Weißwein hinein und kocht dies richtig ein, sodaß nur noch ein gewisser Sud vorhanden bleibt. Jetzt folgen der angerührte Tomatenmark sowie die halbierten Tomaten. Alles zusammen mit Salz und Pfeffer abschmecken. Die Pfanne kann nun vom Herd genommen werden. Den Rucola sowie die Spaghetti werden gut unter die Soße gehoben. Ca. 1 Min ziehen lassen und auf Tellern servieren. Parmesankäse darüber streuen. Fertig. Guten Appetit"}],p:"00:10",c:"00:15",tot:30,srv:"8",cats:["Fisch & Meeresfrüchte","Pasta & Nudeln"]},{id:2092,t:"Spaghetti Champignon Rahm Sose",i:[{n:"frische Champginons",u:"g",a:"175"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Sahne",u:"ml",a:"200"},{n:"Spaghetti",u:"",a:""},{n:"Butter+Öl",u:"",a:""},{n:"Majoran",u:"TL",a:"1"},{n:"Estragon",u:"TL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Dafür mußten die Pilze geputzt, halbiert und in grobe Scheiben geschnitten werden. Die Zwiebel und die Knoblauchzehe werden sehr fein gehackt und in eine kleine Schüssel gegeben"},{s:2,n:"Gemüse und Spaghetti anbraten",d:"Nun erhitzt man eine Pfanne mit etwas Öl und brät die Pilze für ca: 5-8 Min. an. Während dessen kann eine zweite Pfanne mit Butter erhitzt werden um die Spaghetti vorsichtig anzubraten. Diese sollte während der nächsten 10 Min. immer mal wieder gewendet werden, damit nichts anbrennen kann."},{s:3,n:"Champignon-Rahm-Sauce zubereiten",d:"Die Pilze können nun aus der Pfanne genommen und kurz auf einem Teller oder einer Schüssel zur Seite gestellt werden. In der gleichen Pfanne werden die Zwiebeln sowie der Knoblauch glasig angeschwitzt, dann mit 100 ml Weißwein abgelöscht und stark eingekocht werden. Sahne hinzugießen, Pilze hineingeben und mit Salz, Pfeffer, Estragon und Majoran abschmecken."},{s:4,n:"Anrichten und servieren",d:"Die Nudeln sind nun auch fertig. Nett auf einem Teller anrichten und schmecken lassen. Als kleiner Snack zwischendurch ideal geeignet. Guten Appetit"}],p:"00:5",c:"00:10",tot:20,srv:"3",cats:["Pasta & Nudeln"]},{id:2097,t:"Seelachsfilet Auf Fenchel Risotto",i:[{n:"Fenchelsamen",u:"EL",a:"2"},{n:"Risottoreis",u:"g",a:"200"},{n:"Zitronensaft",u:"",a:""},{n:"Radicchio Salat",u:"Stk",a:"1"},{n:"Knobauchzehe",u:"Stk",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Pinienkerne",u:"g",a:"40"},{n:"Weißwein",u:"ml",a:"100"},{n:"Gemüsefond",u:"ml",a:"400"},{n:"Wasser",u:"ml",a:"300"},{n:"Seelachfilet",u:"g",a:"500"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fencheltee kochen und Fisch marinieren",d:"Wasser aufkochen, auf den Fenchelsamen gießen und ca. 15 Min. ziehen lassen. Das Seeslachsfilet kalt abwaschen, trockentupfen, mit Salz, Pfeffer und Zitrone von beiden Seiten würzen. In Portionen schneiden und auf einem Teller zur Seite stellen. Eine frische Zitrone zum marinieren wäre schön gewesen, doch hatte ich die gerade nicht im Haus. Zitronensaft hilft zur Not auch."},{s:2,n:"Gemüse vorbereiten und Tee abgießen",d:"Die Zwiebel und den Knoblauch sehr fein schneiden sowie den Radicchio von den äußeren Blättern befreien und die restlichen Blätter in grobe Stücke schneiden. Sobald die 15 Min vorbei sind, kann der Fencheltee durch ein feines Sieb in eine Kanne gegossen werden. Den Wein, die Fencheltee sowie den Gemüsefond stellt man nun in die Nähe vom Herd."},{s:2,n:"Gemüse vorbereiten und Tee abgießen",d:"Die Zwiebel und den Knoblauch sehr fein schneiden sowie den Radicchio von den äußeren Blättern befreien und die restlichen Blätter in grobe Stücke schneiden. Sobald die 15 Min vorbei sind, kann der Fencheltee durch ein feines Sieb in eine Kanne gegossen werden. Den Wein, die Fencheltee sowie den Gemüsefond stellt man nun in die Nähe vom Herd."},{s:3,n:"Pinienkerne rösten und Zwiebel, Knoblauch glasig dünsten",d:"Nun wird ein großer Topf mit etwas Öl erhitzt und die Pinienkerne darin leicht bräunlich angebraten. Danach herausnehmen und zur Seite stellen. Nun werden in dem gleichen Topf mit dem nussigen Öl die Zwiebel sowie der Knoblauch glasig angeschwitzt."},{s:3,n:"Pinienkerne rösten und Zwiebel, Knoblauch glasig dünsten",d:"Nun wird ein großer Topf mit etwas Öl erhitzt und die Pinienkerne darin leicht bräunlich angebraten. Danach herausnehmen und zur Seite stellen. Nun werden in dem gleichen Topf mit dem nussigen Öl die Zwiebel sowie der Knoblauch glasig angeschwitzt."},{s:4,n:"Risotto zubereiten",d:"Reis dazugeben und ebenso kurz mit anbraten. Nun wird in den nächsten 30 Min nach und nach die Flüssigkeit, bestehend aus Weißwein, Gemüsefond sowie Fencheltee unter häufigen Rühren hinzu gegeben. Dabei sollte die Flüssigkeit immer dann hinzugefügt werden, wenn der Reis die restliche Flüssigkeit aufgenommen hat."},{s:4,n:"Risotto zubereiten",d:"Reis dazugeben und ebenso kurz mit anbraten. Nun wird in den nächsten 30 Min nach und nach die Flüssigkeit, bestehend aus Weißwein, Gemüsefond sowie Fencheltee unter häufigen Rühren hinzu gegeben. Dabei sollte die Flüssigkeit immer dann hinzugefügt werden, wenn der Reis die restliche Flüssigkeit aufgenommen hat."},{s:5,n:"Fisch anbraten",d:"Ca. 6 Min vor dem Ende wird eine Pfanne mit Öl oder Butter erhitzt. Das Seelachsfilet wird zuerst mit der Hautseite nach unten danach mit der anderen Seite jeweils ca. 2 Min angebraten."},{s:5,n:"Fisch anbraten",d:"Ca. 6 Min vor dem Ende wird eine Pfanne mit Öl oder Butter erhitzt. Das Seelachsfilet wird zuerst mit der Hautseite nach unten danach mit der anderen Seite jeweils ca. 2 Min angebraten."},{s:6,n:"Risotto verfeinern und anrichten",d:"Die Pinienkerne sowie der Radicchio werden nun unter das Risotto gehoben. Das Ganze noch mit Salz, Pfeffer und Zitronensaft kräftig abschmecken. Die Teller können jetzt mit dem Risotto aufgefüllt und mit dem Seelachs garniert werden. Guten Appetit"},{s:6,n:"Risotto verfeinern und anrichten",d:"Die Pinienkerne sowie der Radicchio werden nun unter das Risotto gehoben. Das Ganze noch mit Salz, Pfeffer und Zitronensaft kräftig abschmecken. Die Teller können jetzt mit dem Risotto aufgefüllt und mit dem Seelachs garniert werden. Guten Appetit"}],p:"00:15",c:"00:35",tot:55,srv:"4",cats:["Fisch & Meeresfrüchte","Vegetarisch"]},{id:2127,t:"Chicken Curry",i:[{n:"Hühnerbrustfilet",u:"g",a:"500"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"2"},{n:"Paprikaschoten",u:"Stk",a:"2"},{n:"große Möhre",u:"Stk",a:"1"},{n:"Kokosmilch",u:"ml",a:"400"},{n:"Joghurt",u:"g",a:"100"},{n:"gehäufter TL Currypulver",u:"Stk",a:"1"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hähnchenbrustfilets und Gemüse vorbereiten",d:"Die Hähnchenbrustfilets abwaschen, trockentupfen, in schmale Streifen schneiden und auf einem Teller zur Seite stellen. Die Zwiebel sehr fein schneiden, die Lauchstangen von der Wurzel und ca. 5 cm vom oberen Grün entfernen und den Rest in feine Ringe schneiden. Die Paprikaschoten vom Stiel und den Kernen entfernen und in grobe Stücke schneiden. Die Möhren schälen, längs halbieren und in feine Streifen schneiden. Die Knoblauchzehe schälen und kleinhacken."},{s:2,n:"Reis kochen",d:"Der Reis kann nun angesetzt werden."},{s:3,n:"Fleisch scharf anbraten und Gemüse dünsten",d:"Das Fleisch wird nun in einem Wok mit etwas Öl, Salz und Pfeffer scharf angebraten, herausgenommen und kurz zur Seite gestellt. Nun gibt man die Zwiebeln hinzu und dünstet diese glasig an. Jetzt fügt man den Paprika, die Möhren und den Knoblauch hinzu und brät auch dies kurz mit an."},{s:4,n:"Mit Gewürzen und Kokosmilch verfeinern",d:"Das Currypulver darüber streuen, den Joghurt, die Kokosmilch sowie das Tomatenmark hinzugeben und gut verrühren. Nun muß alles zusammen noch für ca. 20 min. bei reduzierter Hitze und geschlossenem Deckel köcheln. Ab und zu sollte umgerührt werden, damit sich nichts am Boden festsetzen kann. Kurz vor Schluss gebt ihr das Fleisch und die Lauchzwiebeln hinzu."},{s:5,n:"Anrichten und Servieren",d:"Der Reis dürfte nun fertig sein. Das Chicken Curry sowie der Reis wird schön auf einem Teller angerichtet und kann sofort serviert werden. Guten Appetit"}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Geflügel","Asiatisch"]},{id:2132,t:"Rindfleisch Mit Mungobohnensprosslingen",i:[{n:"Rindfleisch",u:"g",a:"500"},{n:"Mungobohnensprösslinge",u:"Glas",a:"1"},{n:"frische Champignons",u:"Stk",a:"6"},{n:"Zuckererbsen",u:"g",a:"200"},{n:"Sojasoße",u:"EL",a:"3"},{n:"Wallnussöl",u:"EL",a:"1"},{n:"Maiskeimöl",u:"EL",a:"1"},{n:"kleines Stück frischen Ingwer",u:"",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Worchester Sauce",u:"TL",a:"1"},{n:"Rinderbrühe",u:"ml",a:"150"},{n:"Kartoffelmehl",u:"TL",a:"1"}],st:[{s:1,n:"Rindfleischstreifen marinieren",d:"Die dünnen Rindfleischeiben mit kaltem Wasser abspülen, trockentupfen in schmale Streifen schneiden und in eine Schüssel geben. Ein kleines Stück Ingwer sowie eine Knoblauchzehe schälen, sehr fein schneiden bzw. hacken und zu dem Rindfleisch in die Schüssel geben. Nun fügt man noch 2 EL Sojasoße, 1 EL Wallnussöl sowie 1/2 Tl Kartoffelmehl in die Schüssel hinzu. Alles zusammen gut miteinander vermengen und für ca. 15 min im Kühlschrank marinieren lassen."},{s:2,n:"Reis kochen",d:"Der Reis kann nun angesetzt werden."},{s:3,n:"Gemüse vorbereiten",d:"Die Zuckererbsen evtl. vom braunen Stiel befreien, die Pilze putzen, halbieren und in Scheiben schneiden. Die Mungobohnensprösslinge in einem Sieb geben und abtropfen lassen."},{s:4,n:"Soße anrühren",d:"Für die Sauce wird 150 ml Wasser erhitzt. Dies gießt man in eine Schüssel, fügt 2 EL Sojasoße, 1 TL Worchestersauce, 1 EL Brühe sowie 1 TL Kartoffelmehl hinzu, verührt die gut miteinander und stellt dies zur Seite."},{s:5,n:"Gemüse und Fleisch scharf anbraten, anschließend in Soße köcheln lassen",d:"Jetzt erhitzt man einen Wok mit 1 EL Maiskeimöl, gibt die Zuckererbsen für ca. 3 Min hinzu. Danach folgt das Fleisch, welches unter gelegentlichem Rühren scharf angebraten wird. Danach gibt man die Pilze, die Mungobohnensprösslinge sowie den kleingehackten Ingwer hinzu, brät dies noch kurz mit an und gießt zum Schluss die vorbereitete Soße hinzu. Alles zusammen darf noch ca. 5 Min. köcheln."},{s:6,n:"Anrichten und servieren",d:"Jetzt wird der Reis sowie das Fleisch und das Gemüse aus dem Wok auf einem Teller angerichtet und darf sofort verzehrt werden. Guten Appetit"}],p:"00:20",c:"00:20",tot:45,srv:"4",cats:["Fleisch","Asiatisch"]},{id:2138,t:"Mediterraner Nudelsalat   Herdzeit.De",i:[{n:"Fussili",u:"g",a:"400"},{n:"Rucola",u:"Pck",a:"1"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"Parmesankäse",u:"g",a:"50"},{n:"gerebelter Oregano",u:"TL",a:"1"},{n:"gerebelter Basilikum",u:"TL",a:"1"},{n:"Balsamico Essig",u:"EL",a:"4"},{n:"Olivenöl",u:"EL",a:"4"},{n:"Salz/Pfeffer",u:"');",a:""}],st:[{s:1,n:"Nudeln kochen",d:"Einen Topf mit Salzwasser aufsetzen und die Fussili darin entsprechend der Packungsanweisung bissfest kochen. Danach abgießen, abschrecken und in eine große Schüssel zum abkühlen geben."},{s:2,n:"Tomaten kleinschneiden und Salat putzen",d:"Während die Nudeln kochen, werden die Tomaten je nach Größe halbiert, geviertelt oder geachtelt. Den Rucola abwaschen, tockenschütteln und in mundgerechte Stücke rupfen. Der Stiel sollte überall entfernt werden."},{s:2,n:"Tomaten kleinschneiden und Salat putzen",d:"Während die Nudeln kochen, werden die Tomaten je nach Größe halbiert, geviertelt oder geachtelt. Den Rucola abwaschen, tockenschütteln und in mundgerechte Stücke rupfen. Der Stiel sollte überall entfernt werden."},{s:3,n:"Vinaigrette zubereiten",d:"In einer kleinen Schüssel rührt man nun Balsamico, Olivenöl, Basilikum, Oregano sowie Salz und Pfeffer an."},{s:3,n:"Vinaigrette zubereiten",d:"In einer kleinen Schüssel rührt man nun Balsamico, Olivenöl, Basilikum, Oregano sowie Salz und Pfeffer an."},{s:4,n:"Salat verfeinern und servieren",d:"Zum Schluss wird der Parmesankäse grob gehobelt und mit dem Gemüse, den Nudeln und der Vinaigrette vermengt und für ca. 30 min. ziehen gelassen. Dazu kann man ein Baguette reichen sowie einen leichten Roséwein genießen. Guten Appetitn"},{s:4,n:"Salat verfeinern und servieren",d:"Zum Schluss wird der Parmesankäse grob gehobelt und mit dem Gemüse, den Nudeln und der Vinaigrette vermengt und für ca. 30 min. ziehen gelassen. Dazu kann man ein Baguette reichen sowie einen leichten Roséwein genießen. Guten Appetitn"}],p:"00:5",c:"00:15",tot:50,srv:"4",cats:["Pasta & Nudeln","Salate"]},{id:2151,t:"Grillfleisch In Einer Wurzigen Krautermarinade 2",i:[{n:"Olivenöl",u:"",a:""},{n:"Rosmarin",u:"",a:""},{n:"Thymian",u:"",a:""},{n:"Majoran",u:"",a:""},{n:"Zwiebel",u:"",a:""},{n:"grobkörnigen Senf",u:"Glas",a:"1"},{n:"Knoblauchzehen",u:"",a:""},{n:"Rindfleisch",u:"Scheiben",a:"10"},{n:"Chillischoten",u:"",a:""}],st:[{s:1,n:"Fleisch vorbereiten",d:"Ich habe mich bei diesem Rezept für Rindfleisch aus der Hüfte entschieden. Die Scheiben lasst ihr euch am besten schon beim Fleischer auf die richtige Dicke zuschneiden, bevor es endlich losgehen kann: Das Fleisch unter klarem Wasser abspülen, trockentupfen und auf einer Arbeitsfläche verteilen."},{s:2,n:"Fleisch mit Senf bestreichen",d:"Nun den grobkörnigen Senf auf die Scheiben streichen. Eine Seite reicht, da das Fleisch später aufgeschichtet und somit die unbehandelte Seite ebenso mariniert wird."},{s:3,n:"Gemüse vorbereiten",d:"Zwiebel halbieren und in Ringe schneiden. Knoblauchzehen und Chilischoten kleinhacken. Kräuter - Majoran, Thymian und Rosmarin - in einer Pfanne mit wenig Öl kurz anbraten und vom Herd nehmen."},{s:4,n:"Fleisch, Gemüse und Kräuter in die Schüssel schichten",d:"Das Fleisch, die Kräuter, Zwiebeln und Olivenöl jeweils Schicht für Schicht in die Schüssel geben. Jedes Mal mit Salz und Pfeffer würzen. Damit das Fleisch nicht austrocknet, wird auf jede Schicht ein paar Tropfen Olivenöl verteilt."},{s:5,n:"Ziehen lassen und für den Grill vorbereiten",d:"Die Schüssel mit Alufolie abdecken. Das Ganze für 24 h im Kühlschrank marinieren. Am nächsten Tag nehmt ihr das Fleisch ca. 2h vor dem Grillen aus dem Kühlschrank, sodass es bereits auf Temperatur kommt. Bevor das leckere Grillgut über dem Feuer brutzelt, Kräuter und Zwiebeln entfernen. Diese würden nur anbrennen. Das Fleisch selbst sollte nur kurz braten, damit die Marinade zum einen nicht verbrennt und zum anderen das Fleisch nicht zu trocken wird."}],p:"00:30",c:"00:10",tot:1440,srv:"10",cats:["Grillen & Marinaden"]},{id:2162,t:"Clubsandwich Mit Huhnerbrustfilet",i:[{n:"Hühnerbrustfilet",u:"Stk",a:"350"},{n:"Knoblauchzehe",u:"",a:"1"},{n:"Baconscheiben",u:"",a:""},{n:"Koriander",u:"Stiele",a:"2"},{n:"Worchester Sauce",u:"EL",a:"2"},{n:"Olivenöl",u:"EL",a:"4"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Paprikapulver",u:"TL",a:"1"},{n:"Zitronensaft",u:"EL",a:"1.5"},{n:"reife Avocado",u:"Stk",a:"1"},{n:"Kopfsalat",u:"",a:""},{n:"Fleischtomate",u:"Stk",a:"1"},{n:"Toastbrot",u:"",a:""}],st:[{s:1,n:"Marinade zubereiten",d:"Den Knoblauch schälen und mörsern bzw. wer hat mit der Knoblauchpresse in eine mittelgroße Schüssel geben. In diese Schüssel folgen nun das Öl, das Paprikapulver, Worchestersauce, Salz und Pfeffer."},{s:2,n:"Hähnchenbrustfilets marinieren und Avocadocreme zubereiten",d:"Die Hähnchenbrustfilets abwaschen, trockentupfen, in die Schüssel zur Marinade geben und im Kühlschrank ca. 15 Min. ziehen lassen. Während das Fleisch in der Marinade liegt, wird eine reife Avocado halbiert, vom Kern befreit, das Fruchtfleisch mit dem Löffel herausgenommen und in ein Gefäß mit hohem Rand gegeben. Nun fügt man Zitronensaft, Salz und Pfeffer hinzu und pürriert alles gut miteinander. Nochmals abschmecken."},{s:3,n:"Salat und Kräuter putzen, Zwiebel schneiden",d:"Die Salatblätter abwaschen, das feste Ende entfernen, die Zwiebel in Ringe schneiden, den Koriander abwaschen, trockenschütteln und die Blätter abzupfen."},{s:4,n:"Hühnerbrust und Bacon anbraten",d:"Nun wird eine Pfanne erhitzt und das Fleisch kann darin kross angebraten werden. Sollte das Hühnerbrustfilet evtl. nach ca. 5 Min noch nicht ganz durchgebraten sein, so kann man das Filet auch in Streifen schneiden und diese kurz kross anbraten. Sobald dies geschehen ist, zur Seite stellen und die Baconstreifen in der gleichen Pfanne ebenso kross anbraten."},{s:5,n:"Brot belegen und anrichten",d:"Da nun alles vorbereitet ist, darf das Sandwich belegt werden. Ich toste die Weißbrotscheiben vorher noch. Wer diesen Schritt übergehen möchte, dem sei es gewährt :-) Wie gesagt, man darf fast alles bei der Zubereitung und der Belegung der Brote. Dieses Clubsandwich wird nun mit der Avocadocreme beschmiert und mit einem Salatblatt, dem Hühnerbrustfilet, einer Tomatenscheibe, Baconstreifen, Zwiebeln und Koriander belegt. Auf die obere Seite habe ich dieses Mal meinem Lieblingskräuterfrischkäse geschmiert. Nun noch einmal halbieren und mit Zahnstochern fixieren. Fertig. Laßt es Euch schmecken. Meine Kinder haben es verschlungen. Guten Appetit."}],p:"00:20",c:"00:10",tot:35,srv:"4",cats:["Geflügel","Sandwiches & Snacks"]},{id:2168,t:"Steaksandwich Mit Salsa",i:[{n:"Rindersteaks",u:"g",a:"350"},{n:"Salatblätter",u:"Stk",a:"2"},{n:"geröstete Paprika",u:"Glas",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse kleinschneiden und kräftig würzen",d:"Die Zwiebel und den Knoblauch schälen und sehr fein würfeln. Den eingelegten gerösteten Paprika ebenso sehr fein schneiden bzw. hacken. Die Salatblätter abwaschen, trockenschütteln und ebenso kleinschneiden. Alles zusammen gibt man in eine Schüssel und würzt dies kräftig mit Salz und Pfeffer."},{s:2,n:"Fleisch anbraten",d:"Das Fleisch abwaschen, trockentupfen und in einer Pfanne von beiden Seiten kurz kräftig anbraten und mit Salz und Pfeffer würzen."},{s:3,n:"Brot belegen und anrichten",d:"Das Brot oder die getoasteten Weißbrotscheiben mit einem Salatblatt belegen, die Gemüsesalsa drauf, das Fleich in mundgerechte Stücke schneiden und auf die Sandwiches geben. Zum Schluss gibt man noch einen Esslöffel Salsa, \\Deckel\\ drauf und mit einem Zahnstocher fixieren. Fertig. Guten Appetit"}],p:"00:10",c:"00:5",tot:15,srv:"2",cats:["Fleisch","Sandwiches & Snacks"]},{id:2174,t:"Sandwich Mit Bacon Und Tomaten",i:[{n:"Baconstreifen",u:"",a:""},{n:"Fleischtomate",u:"Stk",a:"1"},{n:"Salatblätter",u:"",a:""},{n:"Pepperoncini von der Frischetheke",u:"Stk",a:"2"},{n:"würzige Mayonaise",u:"",a:""},{n:"Zitronensaft",u:"EL",a:"1"},{n:"Tabascosauce",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Tomate und Pepperoncini vorbereiten",d:"Die Tomate in Scheiben schneiden Die eingelegten Pepperoncini vom Stiel befreien und den Rest in Ringe schneiden"},{s:2,n:"Salat putzen und Dressing zubereiten",d:"Ein paar Salatblätter abwaschen, das feste Ende entfernen und zur Seite stellen Eine Mayoinnaise mit Zitronensaft, Salz, Pfeffer und etwas Tabasco würzen."},{s:2,n:"Salat putzen und Dressing zubereiten",d:"Ein paar Salatblätter abwaschen, das feste Ende entfernen und zur Seite stellen Eine Mayoinnaise mit Zitronensaft, Salz, Pfeffer und etwas Tabasco würzen."},{s:3,n:"Brot toasten und Bacon kross anbraten",d:"Das Toastbrot toasten In einer Pfanne werden die Baconstreifen kross angebraten und danach noch kurz auf Küchenpapier abtropfen lassen."},{s:4,n:"Brot belegen",d:"Nun wird das Sandwich mit der Mayonnaise bestrichen, mit dem Salatblatt, der Tomate, den Pepperonciniringen sowie dem Baconstreifen belegt. Deckel drauf und.. Guten Appetit"},{s:4,n:"Brot belegen",d:"Nun wird das Sandwich mit der Mayonnaise bestrichen, mit dem Salatblatt, der Tomate, den Pepperonciniringen sowie dem Baconstreifen belegt. Deckel drauf und.. Guten Appetit"}],p:"00:8",c:"00:5",tot:15,srv:"2",cats:["Sandwiches & Snacks"]},{id:2179,t:"Tomate Mozzarella Sandwich",i:[{n:"Fleischtomate",u:"Stk",a:"1"},{n:"Mozzarellakäse",u:"Pck",a:"1"},{n:"Balsamico",u:"EL",a:"2"},{n:"Olivenöl",u:"EL",a:"2"},{n:"Basilikumblätter",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Tomaten und Mozzarella in Scheiben schneiden",d:"Die Tomaten abwaschen und wie auch den Mozzarella in Scheiben schneiden"},{s:2,n:"Basilikum vorbereiten und Tomaten sowie Mozzarella marinieren",d:"Die Basilikumblätter abwaschen und trockenschütteln In einer Schüssel Balsamico, Olivenöl, Salz und Pfeffer verrühren und die Tomaten sowie den Mozzarella darin wenden"},{s:3,n:"Brot toasten und Salat putzen');",d:"Das Brot toasten und während dessen die Salatblätter abwaschen und trockenschütteln."},{s:4,n:"Brot belegen und anrichten",d:"Das Brot mit dem Salatblat, den Tomaten, dem Mozzarella sowie den Basilikumblättern belegen. Nun kan das Sandwich noch halbiert und mit Zahnstochern fixiert werden. Guten Appetit"}],p:"00:10",c:"00:00",tot:10,srv:"2",cats:["Vegetarisch","Sandwiches & Snacks"]},{id:2198,t:"Marinierte Sardellen",i:[{n:"unbehandelte Sardellenfilets",u:"g",a:"150"},{n:"Gurkenwasser",u:"EL",a:"4"},{n:"mittelgroße saure Gurke",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Olivenöl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Knoblauch und saure Gurken schneiden",d:"Die eingelgten Sardellenfilets dürfen sehr kräftig gewürzt werden. Diese sollen später als geschmackliche Unterstützung für das andere weniger gewürzte Gemüse dienen. Für die Zubereitung nimmt man unbehandelte Sardellenfilets. Diese gibt man in eine Schüssel. Nun werden Knoblauchzehen geschält und in sehr feine Scheiben geschnitten. Die saure Gurke längs vierteln und ebenso sehr fein schneiden. Beides gibt man nun zu den Sardellen in die Schüssel."},{s:2,n:"Sardellen würzen und mit restlichen Zutaten vermengen",d:"Jetzt fügt man etwas Gurkenwasser, Olivenöl, Salz und Pfeffer hinzu. Wie bereits in der Einleitung erwähnt, darf hier sehr kräftig gewürzt werden. Alles zusammen abschmecken, gut miteinander vermischen und über Nacht abgedeckt in den Kühlschrank geben."}],p:"00:10",c:"00:00",tot:720,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2210,t:"Antipasti Gebratene Paprika",i:[{n:"längliche rote Paprikaschoten",u:"Stk",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Thymianzweige",u:"",a:""},{n:"Olivenöl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Knoblauchzehen und Paprika putzen",d:"Die Knoblauchzehen schälen und in sehr feine Scheiben schneiden. Die Paprikaschoten je nach Größe halbieren oder vierteln."},{s:2,n:"Knoblauch und Thymian anbraten",d:"Eine Pfanne mit Olivenöl erhitzen und mit Knoblauch und Thymianzweigen befüllen. Das Ganze circa eine Minute braten und danach die Paprikastreifen in die Pfanne geben. Kurz schwenken, sodass sich das Olivenöl überall verteilt."},{s:2,n:"Knoblauch und Thymian anbraten",d:"Eine Pfanne mit Olivenöl erhitzen und mit Knoblauch und Thymianzweigen befüllen. Das Ganze circa eine Minute braten und danach die Paprikastreifen in die Pfanne geben. Kurz schwenken, sodass sich das Olivenöl überall verteilt."},{s:3,n:"Paprika hinzugeben",d:"Jetzt die Hitze auf die Hälfte reduzieren, damit die Paprikaschoten in den folgenden ca. 20 Minuten nicht anbrennen.Die in der Pfanne befindlichen Thymianzweige und Knoblauchscheiben auf den einzelnen Paprikastreifen verteilen. Zum einen damit diese nicht anbrennen, zum anderen um zu vermeiden, dass Knoblauch bitter wird. So kann sich das Aroma optimal entfalten. Während das Ganze vor sich hinköchelt mit Salz und Pfeffer würzen."},{s:3,n:"Paprika hinzugeben",d:"Jetzt die Hitze auf die Hälfte reduzieren, damit die Paprikaschoten in den folgenden ca. 20 Minuten nicht anbrennen.Die in der Pfanne befindlichen Thymianzweige und Knoblauchscheiben auf den einzelnen Paprikastreifen verteilen. Zum einen damit diese nicht anbrennen, zum anderen um zu vermeiden, dass Knoblauch bitter wird. So kann sich das Aroma optimal entfalten. Während das Ganze vor sich hinköchelt mit Salz und Pfeffer würzen."},{s:4,n:"Servieren",d:"Sobald die Paprika eine leicht weiche Konsistenz angenommen hat, kann diese auf einem Teller schön angerichtet werden."},{s:4,n:"Servieren",d:"Sobald die Paprika eine leicht weiche Konsistenz angenommen hat, kann diese auf einem Teller schön angerichtet werden."}],p:"00:5",c:"00:20",tot:30,srv:"2",cats:["Vegetarisch"]},{id:2238,t:"Curryhuhnchen Aus Der Pfanne",i:[{n:"Hühnerbrustfilet",u:"g",a:"600"},{n:"mittelgroße Zucchini",u:"Stk",a:"1"},{n:"grobgehackte Tomaten aus der Dose",u:"g",a:"400"},{n:"Cherrytomaten",u:"Stk",a:"7"},{n:"gerebelter Oregano",u:"Prise",a:"1"},{n:"Currypulver",u:"TL",a:"2"},{n:"Currypaste",u:"TL",a:"1"},{n:"Öl",u:"EL",a:"3"},{n:"Zwiebel",u:"Stk",a:"1"}],st:[{s:1,n:"Hühnerbrustfilet marinieren und Tomaten vorbereiten",d:"Das Hühnerbrustfilet abwaschen, trockentupfen und in ca. 7 cm. große Stücke schneiden. Eine Schüssel wird mit Sonnenblumenöl, Currypulver, Currypaste und Salz befüllt und gut miteinander vermischt. Nun fügt man die Hühnerbrustfilets hinzu und mariniert das Fleisch von allen Seiten für ca. 5 Min. Ein paar Cherrytomaten abwaschen, vom Strunk befreiten und in kleine Stücke schneiden. Diese gibt man zusammen mit gehackten Tomaten aus der Dose, Oregano, Salz und Pfeffer in eine Schüssel und rührt dies ebenso gut durch."},{s:2,n:"Ofen vorheizen und Gemüse schneiden",d:"Der Ofen kann nun auf 200 Grad erhitzt werden. Die Zucchini abwaschen, von den Enden befreien und in ca. 0,5 cm breite Scheiben schneiden. Die Zwiebel schälen, halbieren und längs in Streifen schneiden."},{s:3,n:"Fleisch anbraten und anschließend im Ofen nachgaren",d:"Nun wird eine ofenfeste Pfanne mit etwas Öl erhitzt. Das Fleisch wird jetzt für ca. 1 Min rundherum kross angebraten. Bitte nur sehr kurz anbraten, da die Pfanne später noch in den Ofen gegeben wird und das Fleisch darin noch nachgart. Sobald dies geschehen ist, wird das Fleisch herausgenommen und auf einem Teller zur Seite gestellt."},{s:4,n:"Tomatensoße zubereiten",d:"In der gleichen Pfanne gibt man nun die Zucchini sowie die Zwiebeln und brät diese ca. 5 Min an. Danach gibt man die Tomatensoße hinein, verrührt dies ein wenig, schmeckt alles noch mit Salz und Pfeffer ab und nimmt dann die Pfanne vom Herd."},{s:5,n:"Fleisch und Gemüse im Ofen schmorren lassen, anschließend servieren",d:"Das Fleisch kommt nun oben auf das Gemüse in die Pfanne. Alles zusammen gibt man für ca. 20 Min in den Ofen. Danach kann es sofort verzehrt werden. Zu dem Curryhühnchen kann man Reis, Baguette oder nichts weiter essen. Guten Appetit :-)"}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Geflügel","Asiatisch"]},{id:2244,t:"Pizzabrote",i:[{n:"Schinken",u:"g",a:"200"},{n:"Sahne",u:"ml",a:"200"},{n:"Gouda",u:"",a:""},{n:"Currypulver",u:"",a:""},{n:"Paprikapulver",u:"",a:""},{n:"Pizzagewürz",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Sahne steif schlagen und Pizzabelag vorbereiten",d:"Für vier Portionen Pizzabrot werden 200 ml Sahne steif geschlagen. Nach Belieben würfelt man ca. 200 g Schinken oder Salami sowie ein Stück würzigen Käse (z.B. Gouda). Schinken bzw. Salami und Käse werden unter die steif geschlagene Sahne gehoben. Das Ganze dann mit Salz, Pfeffer, Curry, Paprikapulver und Pizzagewürz abgeschmeckt."},{s:2,n:"Baguettes belegen und ab in den Ofen",d:"Die Masse gleichmäßig auf frische Baguettehälften aufstreichen und alles für ca. 20 min in den auf 180 Grad heißen Ofen schieben."},{s:3,n:"Tipp",d:"Je nach Geschmack können die Pizzabrote natürlich auch mit Pilzen, Tomaten, Paprikastücken etc. belegt werden. Der Fantasie sind keine Grenzen gesetzt."}],p:"00:5",c:"00:20",tot:30,srv:"3",cats:["Sandwiches & Snacks"]},{id:2247,t:"Gebratene Dorade",i:[{n:"Doraden",u:"Stk",a:"4"},{n:"Brokkolikopf",u:"Stk",a:"1"},{n:"Kartoffeln",u:"",a:""},{n:"Thymian",u:"Zweige",a:"8"},{n:"Estragon",u:"Zweige",a:"8"},{n:"Rosmarin",u:"Zweige",a:"4"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Zitronensaft",u:"",a:""},{n:"Butter",u:"",a:""},{n:"Mehl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen und Brokkoli vorbereiten",d:"Die Kartoffeln schälen, in mundgerechte Stücke schneiden, in einen Topf geben, mit etwas Salz bissfest kochen. Den Brokkoli in kleine Röschen schneiden, abwaschen und zur Seite stellen."},{s:2,n:"Dorade würzen und panieren",d:"Die Dorade muß nur noch kurz unter kaltem Wasser abgespült werden. Evtl. vorhandene Flossen bzw. Innerein können bereits an der Fischtheke vom Fachmann entnommen werden. Nun wird der Fisch innen kräftig mit Salz und Pfeffer gewürzt. Hinzu kommen ein paar abgespülte Zweige Thymian, Estragon, ein Zweig Rosmarin, etwas Zitronensaft sowie eine Knoblauchzehe. Außen wird der Fisch mit etwas Salz bestreut und kurz in etwas Mehl gewälzt. Überschüssiges Mehl einfach abklopfen."},{s:2,n:"Dorade würzen und panieren",d:"Die Dorade muß nur noch kurz unter kaltem Wasser abgespült werden. Evtl. vorhandene Flossen bzw. Innerein können bereits an der Fischtheke vom Fachmann entnommen werden. Nun wird der Fisch innen kräftig mit Salz und Pfeffer gewürzt. Hinzu kommen ein paar abgespülte Zweige Thymian, Estragon, ein Zweig Rosmarin, etwas Zitronensaft sowie eine Knoblauchzehe. Außen wird der Fisch mit etwas Salz bestreut und kurz in etwas Mehl gewälzt. Überschüssiges Mehl einfach abklopfen."},{s:3,n:"Brokkoli garen und Fisch von beiden Seiten anbraten",d:"Das Wasser für den Brokkoli kann nun nach Belieben mit mehr oder weniger Salz angesetzt werden. Eine Pfanne wird mit Butter erhitzt, sodaß der Fisch ca. 2-3 Min von der einen sowie die gleiche Zeit von der anderen Seite angebratem werden kann. Während dessen sollte das Wasser für den Brokkoli kochen. Die Brokkoliröschen gibt man nur kurz ca. 1-2 Min in das Wasser. Danach sollten diese sofort herausgenommen und in eiskaltes Wasser gegeben werden. Dadurch behalten sie die grüne Farbe und garen nicht nach. In einem weiteren Topf wird ein wenig Butter mit einer prise Salz erhitzt, verflüssigt und über den Brokkoli sowie die Kartoffeln gegeben. Kurz darin schwenken. Fertig. Nun kann alles auf einem Teller angerichtet werden. Sollte der Fisch evtl. schon vor den Kartoffeln bzw. dem Brokkoli fertig sein, so stellt man diesen bei ca. 60 Grad kurz zum warmhalten in den Ofen. Guten Appetit."},{s:3,n:"Brokkoli garen und Fisch von beiden Seiten anbraten",d:"Das Wasser für den Brokkoli kann nun nach Belieben mit mehr oder weniger Salz angesetzt werden. Eine Pfanne wird mit Butter erhitzt, sodaß der Fisch ca. 2-3 Min von der einen sowie die gleiche Zeit von der anderen Seite angebratem werden kann. Während dessen sollte das Wasser für den Brokkoli kochen. Die Brokkoliröschen gibt man nur kurz ca. 1-2 Min in das Wasser. Danach sollten diese sofort herausgenommen und in eiskaltes Wasser gegeben werden. Dadurch behalten sie die grüne Farbe und garen nicht nach. In einem weiteren Topf wird ein wenig Butter mit einer prise Salz erhitzt, verflüssigt und über den Brokkoli sowie die Kartoffeln gegeben. Kurz darin schwenken. Fertig. Nun kann alles auf einem Teller angerichtet werden. Sollte der Fisch evtl. schon vor den Kartoffeln bzw. dem Brokkoli fertig sein, so stellt man diesen bei ca. 60 Grad kurz zum warmhalten in den Ofen. Guten Appetit."},{s:4,n:"Zerlassene Butter über Gemüse geben und Dorade anrichten",d:"In einem weiteren Topf wird ein wenig Butter mit einer Prise Salz erhitzt, verflüssigt und über den Brokkoli sowie die Kartoffeln gegeben. Kurz darin schwenken. Fertig. Nun kann alles auf einem Teller angerichtet werden. Sollte der Fisch evtl. schon vor den Kartoffeln bzw. dem Brokkoli fertig sein, so stellt man diesen bei ca. 60 Grad kurz zum warmhalten in den Ofen. Guten Appetit."},{s:4,n:"Zerlassene Butter über Gemüse geben und Dorade anrichten",d:"In einem weiteren Topf wird ein wenig Butter mit einer Prise Salz erhitzt, verflüssigt und über den Brokkoli sowie die Kartoffeln gegeben. Kurz darin schwenken. Fertig. Nun kann alles auf einem Teller angerichtet werden. Sollte der Fisch evtl. schon vor den Kartoffeln bzw. dem Brokkoli fertig sein, so stellt man diesen bei ca. 60 Grad kurz zum warmhalten in den Ofen. Guten Appetit."}],p:"00:10",c:"00:25",tot:45,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2261,t:"Rindfleisch Im Wok Mit Brauner Sose",i:[{n:"Rindfleisch",u:"g",a:"450"},{n:"grüne Bohnen",u:"g",a:"150"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Ingwerwurzel",u:"cm",a:"6"},{n:"Cashewkerne",u:"g",a:"80"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Bambussprossen",u:"Glas",a:"1"},{n:"Sojasoße",u:"EL",a:"5"},{n:"Kartoffelmehl",u:"TL",a:"15"},{n:"Wallnussöl",u:"EL",a:"3"},{n:"Tabasco+ Worchestersauce",u:"",a:""}],st:[{s:1,n:"Rindfleisch marinieren",d:"In einer Schüssel werden 3 EL dunkle Sojasoße, 2 TL Wallnussöl sowie einen TL Kartoffelmehl gegeben und glattgerührt. Das Rindfleisch unter kaltem Wasser abspülen, mit Küchenpapier trockentupfen, in kurze schmale Streifen schneiden und in die Schüssel mit der Sojasoßenmarinade geben. Alles zusammen ordentlich miteinander vermengen und für ca. 30 Min in den Kühlschrank zum marinieren geben."},{s:2,n:"Gemüse und Cashewkerne vorbereiten",d:"Während dessen wird das Gemüse vorbereitet. Dafür wird die Ingwerwurzel geschält und sehr fein gehackt. Die Bohnen waschen, die Enden abschneiden und zur Seite stellen. Die braunen Champignons evtl. vom Sand befreien, halbieren und in Scheiben schneiden. Eine Knoblauchzehe schälen und feinhacken sowie eine Zwiebel schälen, halbieren und längs in Streifen schneiden. Die Cashewkerne grob zerdrücken. Die Bambusstreifen aus dem Glas in ein Sieb geben und abtropfen lassen."},{s:3,n:"Soße anrühren und Nudeln kochen",d:"Zuletzt kann schon der Wasserkocher mit ca. 300 ml Wasser aufgefüllt und ein Gefäß mit 2 TL Rinderbrühe, 2 EL Sojasoße und einen halben TL Kartoffelmehl vorbereitet werden. Nun darf ein Topf für das Nudelwasser aufgesetzt werden. Ich habe die Suppennudeln genommen. Auf Reis hatte ich keinen Appetit, also habe ich dieses Gericht mit Nudeln ausprobiert. Es war ausgesprochen schmackhaft."},{s:4,n:"Gemüse und Fleisch im Wok scharf anbraten",d:"Nun dürften die 30 Min. so langsam vergangen sein und somit kann nun alles im Wok zubereitet werden. Dafür erhitzt man den Wok mit 2 EL Maiskeimöl. Sobald dies schön heiß geworden ist, werden nun die Bohnen, der Ingwer, die Zwiebel, der Knoblauch sowie die Cashewkerne in den Wok gegeben und ca. 5 Min unter ständigem rühren angebraten. Danach gibt man das Fleisch hinzu und brät auch dieses unter gelegentlichem Rühren ca. 3 Min an."},{s:5,n:"In Soße köcheln lassen",d:"Währenddessen wird der Wasserkocher erhitzt und in das vorbereitete Gefäß gegeben. Sobald das Fleisch angebraten ist, kann die Flüssigkeit in den Wok gegossen werden. Alles zusammen darf noch ca. 2-5 Min bei etwas reduzierter Hitze köcheln. Für die leichte Schärfe darf noch mit etwas Tabasco und Worchestersauce gewürzt werden. Alles zusammen kann nun mit den Nudeln appetitlich auf einem Teller angerichtet werden. Guten Appetit."}],p:"00:30",c:"00:10",tot:45,srv:"4",cats:["Fleisch","Asiatisch"]},{id:2267,t:"Kartoffelpfanne Mit Grunen Bohnen",i:[{n:"kleine Kartoffeln",u:"g",a:"500"},{n:"grüne Bohnen",u:"g",a:"200"},{n:"Schalotten",u:"Stk",a:"4"},{n:"Knoblauchzehen",u:"Stk",a:"1"},{n:"Thymian",u:"Zweige",a:"5"},{n:"Rosmarin",u:"Zweige",a:"2"},{n:"geräucherter Bauchspeck",u:"g",a:"150"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln und Bohnen putzen",d:"Die kleinen Kartoffeln gut abwaschen, abtrocknen und je nach Größe halbieren oder vierteln. Die grünen Bohnen waschen und von den Enden befreien."},{s:2,n:"Gemüse und Speck schneiden",d:"Schalotten schälen und längs vierteln. Bauchspeck in Würfel schneiden sowie die Knoblauchzehen schälen und in feine Scheiben schneiden."},{s:3,n:"Kräuter putzen",d:"Die Thymian- und Rosmarinzweige abwaschen, trocken schütteln, Blätter von den Stielen abziehen und feinhacken."},{s:4,n:"Bohnen kochen",d:"Nun wird ein Topf mit Salzwasser für die Bohnen aufgesetzt. Sobald das Wasser kocht, Bohnen für ca. 5 Min. hinzugeben. Danach vom Herd nehmen, abschrecken und im Eiswasser liegen lassen. Die Bohnen garen nicht nach, bleiben bissfest und behalten ihre frische, grüne Farbe. Eine Pfanne mit etwas Öl erhitzen. Bauchspeck kross anbraten. Danach herausnehmen und in einer Schüssel zur Seite stellen. In die gleiche Pfanne die Kartoffeln geben und für ca. 15 Min anbraten. Je nach Bedarf salzen und pfeffern. Danach Bohnen, Schalotten, Knoblauch sowie Kräuter hinzugeben. Kurz darin schwenken, sodass sich alle Zutaten miteinander vermengen und weitere 5 Min braten."},{s:5,n:"Bohnen hinzufügen und abschmecken",d:"Die Bohnen vorsichtig in die Pfanne geben und unterheben. Sie sollen nun noch einmal kurz Hitze erhalten und sehr kurz angebraten werden. Mit Salz und Pfeffer abschmecken."},{s:6,n:"Anrichten und servieren",d:"Es darf serviert werden. Wer es uriger mag, isst direkt aus der Pfanne, genießt ein Baguette dazu und rundet dieses Gericht mit einem kalten Bier oder Wein ab."}],p:"00:10",c:"00:25",tot:40,srv:"4",cats:["Vegetarisch"]},{id:2273,t:"Marinierte Hahnchenflugel",i:[{n:"Hähnchenflügel",u:"Pck",a:"3"},{n:"edelsüßes Paprikapulver",u:"TL",a:"3"},{n:"gerebelter Rosmarin",u:"TL",a:"1"},{n:"Majoran",u:"TL",a:"2"},{n:"Salz",u:"TL",a:"15"},{n:"Sonnenblumenöl",u:"EL",a:"3"},{n:"Pfeffer",u:"",a:""}],st:[{s:1,n:"Ofen vorheizen",d:"Der Ofen wird auf 200 Grad Umluft erhitzt."},{s:2,n:"Marinade zubereiten",d:"In einer größeren Schüssel werden 3 TL Paprikapulver, 1 TL Rosmarin, 2 TL Majoran, 1,5 TL Salz, Pfeffer und 3-4 EL Sonneblumenöl miteinander vermischt. Evtl. sollte nochmals mit Salz abgeschmeckt werden."},{s:2,n:"Marinade zubereiten",d:"In einer größeren Schüssel werden 3 TL Paprikapulver, 1 TL Rosmarin, 2 TL Majoran, 1,5 TL Salz, Pfeffer und 3-4 EL Sonneblumenöl miteinander vermischt. Evtl. sollte nochmals mit Salz abgeschmeckt werden."},{s:3,n:"Hähnchen marinieren und backen",d:"Nun werden die Hähnchenflügel rundherum in der Marinade gewältzt, sodaß alle Stellen bedeckt sind. Alle Flügel auf dem Ofengitter für ca. 50 Min in den Ofen geben. Nach ca. 25 Min einmal wenden. Kurz vor dem Ende werden die Flügel nochmals umgedreht und für ca. 5 Min kur unter dem Grill kross gebacken."},{s:3,n:"Hähnchen marinieren und backen",d:"Nun werden die Hähnchenflügel rundherum in der Marinade gewältzt, sodaß alle Stellen bedeckt sind. Alle Flügel auf dem Ofengitter für ca. 50 Min in den Ofen geben. Nach ca. 25 Min einmal wenden. Kurz vor dem Ende werden die Flügel nochmals umgedreht und für ca. 5 Min kur unter dem Grill kross gebacken."},{s:4,n:"Anrichten und servieren",d:"Herausnehmen und servieren. Dieses Gericht eignet sich ebenso für Partys als Fingerfood. Guten Appetit"},{s:4,n:"Anrichten und servieren",d:"Herausnehmen und servieren. Dieses Gericht eignet sich ebenso für Partys als Fingerfood. Guten Appetit"}],p:"00:8",c:"00:50",tot:60,srv:"4",cats:["Geflügel"]},{id:2283,t:"Zucchini Kartoffel Gratin",i:[{n:"mittegroße Zucchini",u:"Stk",a:"1"},{n:"Tomaten",u:"Stk",a:"5"},{n:"grüne Oliven",u:"Stk",a:"9"},{n:"Knoblauchzehen",u:"Stk",a:"1"},{n:"Thymian",u:"Zweige",a:"5"},{n:"Kartoffeln",u:"g",a:"500"},{n:"Brühe",u:"ml",a:"100"},{n:"Öl",u:"EL",a:"5"},{n:"Mozzarellakäse",u:"Pck",a:"1"},{n:"Zwiebeln",u:"Stk",a:"1"}],st:[{s:1,n:"Wasser aufsetzen und Gemüse vorbereiten",d:"Einen kleinen Topf mit Wasser aufsetzen. Die Zucchini und Tomaten waschen, von den Enden und dem Strunk befreien und alles in feine Scheiben schneiden. Die Knoblauchzehen, die Zwiebeln sowie die Kartoffeln schälen und in feine Scheiben schneiden. Die Oliven, am besten von der Frischetheke, vierteln. Die Thymianzweige abwaschen, trockenschütteln und sehr feinhacken."},{s:2,n:"Kartoffeln kurz kochen",d:"Die Kartoffeln werden nun für ca. 3 Min in das kochende Wasser gegeben. Danach herausnehmen und abschrecken."},{s:3,n:"Ofen vorheizen und Zutaten vermengen",d:"Der Ofen wird nun auf 200 Grad vorgeheizt und die Auflaufform mit Öl ausgestrichen. Das geschnittene Gemüse und der gehackte Thymian gibt man in einen großen Topf oder eine Schüssel. In einer kleinen Schüssel werden etwas Wasser, Brühe und Öl miteinander vermengt und zum Gemüse gegeben. Nun darf alles schön miteinander vermengt werden. Zum Schluss muß alles noch mit Salz und Pfeffer abgeschmeckt werden."},{s:4,n:"Ab in den Ofen",d:"Jetzt kann das marinierte Gemüse in die Auflaufform gegeben und für ca. 60 min in den Ofen gegeben werden. ca. 15 Min vor dem Ende streut man noch etwas Mozzarellakäse darüber."},{s:5,n:"Tipp",d:"Dazu eignet sich ein Glas Weißwein. Guten Appetit."}],p:"00:15",c:"1:00",tot:80,srv:"4",cats:["Vegetarisch"]},{id:2290,t:"Mais Mit Butter",i:[{n:"Maiskolben",u:"Stk",a:"4"},{n:"Butter",u:"",a:""},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Mais vorbereiten",d:"Der gekaufte Mais ist in der Regel von den Blättern und den Maisfäden befreit. Sonst muß man diese natürlich noch entfernen."},{s:2,n:"Mais kochen",d:"Nun wird ein Topf mit Salzwasser aufgesetzt. Sobald das Wasser kocht, wird die Hitze leicht herunterreduziert und der Mais kann für ca. 20 Min. in den Topf gegeben werden."},{s:3,n:"Mais in Butter wenden und abschmecken",d:"Danach kurz in Butter wenden, salzen und schmecken lassen. Ein gelungener Snack für den kleinen Hunger. Guten Appetit"}],p:"00:00",c:"00:20",tot:25,srv:"3",cats:["Vegetarisch"]},{id:2293,t:"Bayerischer Kassler Sauerkraut Auflauf",i:[{n:"Kassler",u:"g",a:"600"},{n:"Sauerkraut",u:"g",a:"500"},{n:"Kartoffeln",u:"g",a:"500"},{n:"Sahne",u:"ml",a:"200"},{n:"Zwiebellauch",u:"Stangen",a:"2"},{n:"Petersilie",u:"",a:""},{n:"Laugenstange oder Brezel",u:"Stk",a:"0.5"},{n:"Kartoffelmehl",u:"TL",a:"1"},{n:"Muskat",u:"",a:""},{n:"Wasser",u:"etw.",a:""},{n:"Honig/ Zucker",u:"EL",a:"1"},{n:"Butter",u:"EL",a:"2"},{n:"Öl",u:"EL",a:"3"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Brühe",u:"Tl",a:"2"}],st:[{s:1,n:"Kartoffeln zubereiten",d:"Die Kartoffeln schälen, abwaschen und in Scheiben schneiden. Einen Topf mit 2 EL Butter erhitzen. Sobald diese flüssig geworden ist, Mehl darüberstreuen und einrühren. Nun werden nach und nach Wasser hinzu gegossen 2 TL Brühe dazu gegeben. Kurz aufkochen lassen und die in Scheiben geschnittenen Kartoffeln für ca. 15 Min. bei geschlossenem Deckel und leicht reduzierter Hitze garen lassen."},{s:2,n:"Sauerkraut vorbereiten und Fleischwürfel anbraten",d:"Das Sauerkraut in ein Sieb geben und abtropfen lassen. Kurzer Geschmackstest, wie sauer das Kraut ist. Dies ist wichtig, für die spätere Würze durch Honig oder Zucker. Schließlich sollte das Kraut später nicht zu sauer, aber auch nicht zu süss schmecken. Das Kassler abwaschen, trockentupfen und in Würfel schneiden. Danach eine Pfanne mit 2 EL Öl erhitzen und das Fleisch darin portionsweise anbraten. Herausnehmen und in einer Schüssel zur Seite stellen."},{s:2,n:"Sauerkraut vorbereiten und Fleischwürfel anbraten",d:"Das Sauerkraut in ein Sieb geben und abtropfen lassen. Kurzer Geschmackstest, wie sauer das Kraut ist. Dies ist wichtig, für die spätere Würze durch Honig oder Zucker. Schließlich sollte das Kraut später nicht zu sauer, aber auch nicht zu süss schmecken. Das Kassler abwaschen, trockentupfen und in Würfel schneiden. Danach eine Pfanne mit 2 EL Öl erhitzen und das Fleisch darin portionsweise anbraten. Herausnehmen und in einer Schüssel zur Seite stellen."},{s:3,n:"Sauerkraut anbraten und Kartoffeln abschmecken",d:"In der gleichen Pfanne wird nun das Sauerkraut angebraten. Evtl. muß noch etwas Öl hinzugegeben werden. Später sollte das Sauerkraut mit Salz, Pfeffer, Honig oder Zucker gewürzt werden. Evtl. kann noch etwas Wasser hinzugegossen werden, sodaß das Sauerkraut für etwa 30 Min. leicht vor sich hin schmoren kann. Zu den Kartoffeln kann nun 200 ml Sahne, Salz, Pfeffer und Muskatnuss hinzugefügt werden. Noch einmal kurz einkochen lassen und schließlich vom Herd nehmen. Ca. 5 Min bevor das Sauerkraut fertig geschmorrt ist, wird der Ofen auf ca. 200 Grad vorgeheizt. Jetzt hat man noch etwas Zeit die restlichen Zutaten vorzubereiten."},{s:3,n:"Sauerkraut anbraten und Kartoffeln abschmecken",d:"In der gleichen Pfanne wird nun das Sauerkraut angebraten. Evtl. muß noch etwas Öl hinzugegeben werden. Später sollte das Sauerkraut mit Salz, Pfeffer, Honig oder Zucker gewürzt werden. Evtl. kann noch etwas Wasser hinzugegossen werden, sodaß das Sauerkraut für etwa 30 Min. leicht vor sich hin schmoren kann. Zu den Kartoffeln kann nun 200 ml Sahne, Salz, Pfeffer und Muskatnuss hinzugefügt werden. Noch einmal kurz einkochen lassen und schließlich vom Herd nehmen. Ca. 5 Min bevor das Sauerkraut fertig geschmorrt ist, wird der Ofen auf ca. 200 Grad vorgeheizt. Jetzt hat man noch etwas Zeit die restlichen Zutaten vorzubereiten."},{s:4,n:"Lauch schneiden und Laugenmasse zubereiten",d:"Dafür wird von dem Zwiebellauch die Wurzel und der obere Rand vom Grün entfernt. Den Rest schneidet man in Ringe. Die 1/2 Brezel bzw. Laugenstange wird in einer Küchenmaschine kleingehäckselt und in eine Schüssel gegeben. Die Petersilie abwaschen, trockenschütteln, kleinhacken und ebenso in die Schüssel geben. Alles zusammen wird nun mit 2 EL Butter verknetet."},{s:4,n:"Lauch schneiden und Laugenmasse zubereiten",d:"Dafür wird von dem Zwiebellauch die Wurzel und der obere Rand vom Grün entfernt. Den Rest schneidet man in Ringe. Die 1/2 Brezel bzw. Laugenstange wird in einer Küchenmaschine kleingehäckselt und in eine Schüssel gegeben. Die Petersilie abwaschen, trockenschütteln, kleinhacken und ebenso in die Schüssel geben. Alles zusammen wird nun mit 2 EL Butter verknetet."},{s:5,n:"Sauerkraut abschmecken, Auflaufform schichten und ab in den Ofen",d:"Das Sauerkraut dürfte nun auch fertig geschmorrt sein. Nochmals mit Salz, Pfeffer und Honig abschmecken. 1 TL Kartoffelmehl einrühren. Die Kasslerwürfel sowie die Zwiebellauchringe unterrühren. In die vorbereitete Auflaufform schichtet man nun die Kartoffeln und das Kassler-Sauerkraut abwechselnd auf. Die Bechamelsoße wird noch dezent darüber gegossen. Brösel darüber verteilen und alles für ca. 15 Min in den vorgeheizten Ofen. Fertig ist ein zünftiger bayerischer Auflauf welcher mit einem Glas Bier regelkonform abgerundet werden darf. Guten Appetit"},{s:5,n:"Sauerkraut abschmecken, Auflaufform schichten und ab in den Ofen",d:"Das Sauerkraut dürfte nun auch fertig geschmorrt sein. Nochmals mit Salz, Pfeffer und Honig abschmecken. 1 TL Kartoffelmehl einrühren. Die Kasslerwürfel sowie die Zwiebellauchringe unterrühren. In die vorbereitete Auflaufform schichtet man nun die Kartoffeln und das Kassler-Sauerkraut abwechselnd auf. Die Bechamelsoße wird noch dezent darüber gegossen. Brösel darüber verteilen und alles für ca. 15 Min in den vorgeheizten Ofen. Fertig ist ein zünftiger bayerischer Auflauf welcher mit einem Glas Bier regelkonform abgerundet werden darf. Guten Appetit"}],p:"00:40",c:"00:15",tot:65,srv:"5",cats:["Fleisch"]},{id:2300,t:"Gruner Salat Mit Entenbrust In Orangendressing",i:[{n:"Entenbrust",u:"g",a:"400"},{n:"Weißbrot",u:"Scheiben",a:"3"},{n:"Orangensaft",u:"ml",a:"10"},{n:"Radieschen",u:"Bund",a:"1"},{n:"Weinessig",u:"EL",a:"2"},{n:"Öl",u:"",a:""},{n:"Salatmix",u:"Beutel",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Ofen vorheizen und CroÃ»tons herstellen",d:"Den Ofen auf 200 Grad vorheizen. Das Weißbrot in kleine Würfel schneiden, auf einem mit Backpapier ausgelegtem Backblech verteilen, mit Öl beträufeln und salzen. Nun kann alles für ca. 10 Min in den Ofen. Sobald die Weißbrotwürfel kross genug gebacken sind, herausnehmen und in einer Schüssel zur Seite stellen."},{s:2,n:"Entenbrust zubereiten",d:"Die Entenbrust gut mit kaltem Wasser abspülen und die Haut mit einem scharfen Messer rautenförmig einritzen. Eine Pfanne mit wenig Öl erhitzen und die Entenbrust mit der Haut nach unten 5 Min. kross anbraten. Danach wenden und die Seite mit dem Entenfleisch kurz 2-3 Min. ebenso anbraten. Nun wird die Entenbrust mit Salz und Pfeffer gewürzt. Herausnehmen und für ca. 10 Min in den auf 200 Grad vorgeheizten Ofen geben. ( Das Bratenfett bitte aufbewahren)Nach den 10 Min wird die Entenbrust herausgenommen, mit Alufolie umwickelt und ruhen gelassen. Während die Entenbrust im Ofen liegt, kann der Salat und das Dressing vorbereitet werden."},{s:3,n:"Salat und Dressing zubereiten",d:"Während die Entenbrust im Ofen liegt, kann der Salat und das Dressing vorbereitet werden. Dafür werden die Radieschen geputzt, geviertelt und in eine große Schüssel geben. Der Salatmix wird abgewaschen, trockengeschüttelt und ebenso in die Schüssel gegeben. Für das Salatdressing nimmt man eine kleine Schüssel, gibt ca. 0,1 ml Orangensaft, 2 EL Weinessig sowie das Bratenfett hinzu. Vermischen und mit Salz und Pfeffer abschmecken. Das Dressing wird nun zum Salat in die Schüssel gegeben und mit diesem vermischt."},{s:4,n:"Anrichten und servieren",d:"So nun ist alles vorbereitet. Für den Verzehr richtet man den Salat nett auf einem tiefen Teller oder einer großen Schüssel an. Dafür gibt man den Salat hinein, schneidet die Entenbrust in dünne Scheiben und verteilt die krossen Weißbrotwürfel darüber. Eine leichte Mahlzeit für den kleinen Hunger. Guten Appetit."}],p:"00:10",c:"00:18",tot:40,srv:"4",cats:["Geflügel","Salate"]},{id:2304,t:"Gefullte Tomaten",i:[{n:"große Fleischtomaten",u:"Stk",a:"4"},{n:"große Champignons",u:"Stk",a:"9"},{n:"kleine Zwiebeln",u:"Stk",a:"2"},{n:"Kochschinken",u:"Pck",a:"1"},{n:"Sahne",u:"ml",a:"200"},{n:"Rosmarin",u:"Zweig",a:"1"},{n:"Basilikum",u:"Stiele",a:"4"},{n:"Parmesankäse",u:"",a:""},{n:"Butter",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Tomaten vorbereiten",d:"Die Tomaten gründlich abwaschen, abtrocknen und einen Deckel abschneiden. Mit einem kleinen Messer das Tomateninnere vorsichtig ausschneiden und mit einem kleinen Löffel herauskratzen. Das Innere der Tomaten in ein Sieb geben, das verbleibende Tomatenfleisch kleinschneiden und in einer Schüssel zur Seite stellen."},{s:2,n:"Gemüse putzen und Kochschinken würfeln",d:"Die Champignons putzen, den Stiel entfernen und den Pilzkopf fein hacken. Die Zwiebeln schälen und kleinschneiden. Den Kochschinken in klein würfeln. Die Kräuter abwaschen und trocken schütteln. Die Rosmarinnadeln vom Stiel entfernen und zusammen mit den Basilikumblättern sehr fein hacken."},{s:2,n:"Gemüse putzen und Kochschinken würfeln",d:"Die Champignons putzen, den Stiel entfernen und den Pilzkopf fein hacken. Die Zwiebeln schälen und kleinschneiden. Den Kochschinken in klein würfeln. Die Kräuter abwaschen und trocken schütteln. Die Rosmarinnadeln vom Stiel entfernen und zusammen mit den Basilikumblättern sehr fein hacken."},{s:3,n:"Ofen vorheizen und Gemüse, Schinken anbraten",d:"Den Ofen auf 200 Grad vorheizen. Nun wird eine Pfanne mit 2 EL Butter erhitzt und die Champignons darin mit Salz, Pfeffer, Estragon und ein wenig Majoran angebraten. Nach ca. 5 Min. werden die Zwiebeln, der Schinken sowie das gehackte Tomatenfleisch in die Pfanne gegeben. Kurz anbraten und einköcheln lassen. Danach rührt man den Frischkäse und die Kräuter hinein. Alles gut verrühren und mit Salz und Pfeffer kräftig abschmecken."},{s:3,n:"Ofen vorheizen und Gemüse, Schinken anbraten",d:"Den Ofen auf 200 Grad vorheizen. Nun wird eine Pfanne mit 2 EL Butter erhitzt und die Champignons darin mit Salz, Pfeffer, Estragon und ein wenig Majoran angebraten. Nach ca. 5 Min. werden die Zwiebeln, der Schinken sowie das gehackte Tomatenfleisch in die Pfanne gegeben. Kurz anbraten und einköcheln lassen. Danach rührt man den Frischkäse und die Kräuter hinein. Alles gut verrühren und mit Salz und Pfeffer kräftig abschmecken."},{s:4,n:"Soße zubereiten, Auflauf schichten und ab in den Ofen",d:"Nun wird in einer Schüssel die Sahne mit Brühe und Pfeffer gewürzt. In die Auflaufform gibt man nun die ausgehöhlten Tomaten, befüllt diese mit dem Gemüse, reibt Parmesankäse darüber und gießt die Sahne hinein. Nun darf alles zusammen für ca. 20 Min in den vorgeheizten Ofen gegeben und später sofort heiß serviert werden. Ein leichtes vegetarisches Gericht. Guten Appetit."},{s:4,n:"Soße zubereiten, Auflauf schichten und ab in den Ofen",d:"Nun wird in einer Schüssel die Sahne mit Brühe und Pfeffer gewürzt. In die Auflaufform gibt man nun die ausgehöhlten Tomaten, befüllt diese mit dem Gemüse, reibt Parmesankäse darüber und gießt die Sahne hinein. Nun darf alles zusammen für ca. 20 Min in den vorgeheizten Ofen gegeben und später sofort heiß serviert werden. Ein leichtes vegetarisches Gericht. Guten Appetit."}],p:"00:30",c:"00:20",tot:60,srv:"4",cats:["Sonstiges"]},{id:2309,t:"Grune Bohnensuppe Mit Kassler",i:[{n:"lange Bohnen (oder gefrorene Brechbohnen)",u:"g",a:"500"},{n:"Kartoffeln",u:"g",a:"500"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"Möhren",u:"Stk",a:"4"},{n:"Kassler",u:"g",a:"500"},{n:"Gemüsefond",u:"ml",a:"800"},{n:"Bohnenkraut",u:"",a:""},{n:"Petersilie",u:"",a:""},{n:"Öl",u:"",a:""}],st:[{s:1,n:"Grüne Bohnen putzen und garen",d:"Bohnen abwaschen, Stielenden entfernen und in 2-3 cm lange Stücke schneiden. Einen Topf mit Wasser erhitzen und die Bohnen mit Salz und Bohnenkraut ca. 15 Min garen."},{s:2,n:"Kassler in Würfel schneiden und Gemüse vorbereiten",d:"Währenddessen das Kassler mit klarem Wasser abspülen, trockentupfen und in Würfel schneiden. Zwiebeln schälen und in Spalten schneiden. Kartoffeln schälen und in grobe Würfel, sowie die Möhren schälen und in Scheiben schneiden."},{s:3,n:"Topf erhitzen und Zutaten hinzufügen",d:"Nun wird ein großer Topf mit etwas Öl erhitzt, sodass das Fleisch darin rundherum angebraten werden kann. Sobald dies geschehen ist, herausnehmen und in einer Schüssel zur Seite stellen. In den gleichen Topf Zwiebeln sowie die Kartoffeln hineingeben und diese ca. 5 Min anbraten. Mit dem Gemüsefonds ablöschen, aufkochen und ca. 15 Min. garen lassen. Nach ca. 5 Min Garzeit folgen die Möhren."},{s:4,n:"Bohnen in den Topf geben",d:"Die Bohnen sollten nun auch fertig sein. Die Bohnen werden in ein Sieb gegeben. Das Bohnenwasser wird in einer Schüssel aufgefangen und in den Topf mit dem Gemüsefond gegeben. Nach den 15 Min das Fleisch sowie die Bohnen in den Topf geben. Kurz aufkochen lassen und zum Schluss mit Salz und Pfeffer kräftig abschmecken."},{s:5,n:"Anrichten und servieren",d:"Alles zusammen nett auf einem tiefen Teller oder einer Schüssel anrichten. Petersilie darüber streuen und schmecken lassen."}],p:"00:20",c:"00:30",tot:60,srv:"6",cats:["Fleisch","Suppen & Eintöpfe"]},{id:2315,t:"Linguine Mit Sardellensauce",i:[{n:"Sardellenfilets",u:"Stk",a:"8"},{n:"mittelgroße Tomaten",u:"Stk",a:"2"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"frische Chili",u:"Stk",a:"0.5"},{n:"Basilikum",u:"Bd",a:"1"},{n:"Öl",u:"",a:""},{n:"Butter",u:"TL",a:"1"},{n:"Weißwein",u:"ml",a:"100"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Nudelwasser aufsetzen und Gemüse sowie Sardellen kleinschneiden",d:"Wasser für die Nudeln aufsetzen. Die Sardellen mit einer Gabel sehr fein zerdrücken. Die Zwiebel schälen und sehr fein würfeln. Die halbe kleine frische Chili kleinhacken. Die Knoblauchzehe schälen und in feine Scheiben schneiden. 2 mittelgroße Tomaten halbieren, vom Strunk befreien, Kerne entfernen und den Rest in Würfel schneiden. Die Basilikumblätter feinhacken und zusammen mit den Tomatenwürfeln mit Salz, Pfeffer und Oregano mischen."},{s:2,n:"Nudeln kochen",d:"Die Nudeln in den Topf geben und bissfest kochen."},{s:3,n:"Gemüse und Sardellen dünsten, Soße abschmecken und servieren",d:"Eine Pfanne mit Öl erhitzen und die Zwiebel, die Chilie sowie den Koblauch glasig dünsten. Nun die Sardellen hinzugeben, kurz mitbraten lassen und mit Weißwein ablöschen. Sobald ein Großteil verkocht ist, gibt man die Tomaten für ca. 1 Minute hinzu. Mit Salz und Pfeffer und einem TL Butter abschmecken. Alles zusammen mit den Nudeln appetitlich anrichten und schmecken lassen. Wer mag streut noch etwas Parmesan darüber. Guten Appetit"}],p:"00:10",c:"00:20",tot:35,srv:"2",cats:["Fisch & Meeresfrüchte","Pasta & Nudeln"]},{id:2320,t:"Linguine Und Garnelen In Alufolie",i:[{n:"Linguine",u:"g",a:"400"},{n:"Garnelen",u:"g",a:"200"},{n:"geräucherter Schinken",u:"Scheiben",a:"3"},{n:"gefrostete Erbsen",u:"g",a:"200"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Weißwein",u:"ml",a:"100"},{n:"Olivenöl",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Nudeln kochen",d:"Die Nudeln in reichlich Salzwasser bissfest kochen, abgießen und mit einigen Tropfen Öl beträufelt in eine Schüssel zur Seite stellen."},{s:2,n:"Garnelen vorbereiten",d:"Ich nehme wie immer gefrostete Garnelen. Da diese in der Regel nicht die Zeit haben in Ruhe aufzutauen, wasche ich diese in heißem Wasser gründlich sauber und lasse sie noch für ein paar Minuten im warmen Wasser stehen. Bis zur Zubereitung sind die Garnelen dann aufgetaut."},{s:3,n:"Zwiebel und Schinken würfeln, Erbsen vorbereiten",d:"Nun wird die Zwiebel geschält und ebenso wie der geräucherte Schinken in feine Würfel geschnitten. Die Erbsen gibt man noch kurz in warmes Wasser, sodaß auch diese auftauen können."},{s:4,n:"Ofen vorheizen und Garnelen dünsten",d:"Den Ofen auf 180 Grad vorheizen. Eine Pfanne mit Öl erhitzen und die Garnelen mit Salz und Pfeffer dünsten und späte mit Weißwein ablöschen und einkochen lassen. Garnelen danach herausnehmen und zu den Nudeln in die Schüssel geben."},{s:4,n:"Ofen vorheizen und Garnelen dünsten",d:"Den Ofen auf 180 Grad vorheizen. Eine Pfanne mit Öl erhitzen und die Garnelen mit Salz und Pfeffer dünsten und späte mit Weißwein ablöschen und einkochen lassen. Garnelen danach herausnehmen und zu den Nudeln in die Schüssel geben."},{s:5,n:"Gemüse dünsten und Schüsseln aus Alufolie formen",d:"Die in Würfel geschnittene Zwiebel im Weinsud mit ein wenig Öl andünsten, den Schinken hinzufügen sowie die Erbsen zugeben. Ab und zu heißes Wasser hinzugießen und einkochen lassen. Mit Salz und Pfeffer abschmecken. Nun formt man mit Alufolie mehrere kleine oder eine größere Schüssel."},{s:5,n:"Gemüse dünsten und Schüsseln aus Alufolie formen",d:"Die in Würfel geschnittene Zwiebel im Weinsud mit ein wenig Öl andünsten, den Schinken hinzufügen sowie die Erbsen zugeben. Ab und zu heißes Wasser hinzugießen und einkochen lassen. Mit Salz und Pfeffer abschmecken. Nun formt man mit Alufolie mehrere kleine oder eine größere Schüssel."},{s:6,n:"Vermengen und im Ofen schmoren lassen",d:"Das gedünstete Gemüse aus der Pfanne gibt man nun zu den Nudeln in die Schüsel und vermengt alls miteinander. Nun wird dies portionsweise in die Alufolienförmchen gebeben. \\Deckel\\ drauf und für ca. 10 Min in dem vorgeheizten Ofen schmoren lassen. Danach kann das Gericht sofort serviert werden. Guten Appetit"},{s:6,n:"Vermengen und im Ofen schmoren lassen",d:"Das gedünstete Gemüse aus der Pfanne gibt man nun zu den Nudeln in die Schüsel und vermengt alls miteinander. Nun wird dies portionsweise in die Alufolienförmchen gebeben. \\Deckel\\ drauf und für ca. 10 Min in dem vorgeheizten Ofen schmoren lassen. Danach kann das Gericht sofort serviert werden. Guten Appetit"}],p:"00:10",c:"00:10",tot:35,srv:"4",cats:["Fisch & Meeresfrüchte","Pasta & Nudeln"]},{id:2327,t:"Bratwurst Mit Sauerkraut Und KartoffelpüRee   Herdzeit.De",i:[{n:"Bratwürste",u:"Stk",a:"4"},{n:"Sauerkraut",u:"g",a:"500"},{n:"Speck oder geräucherter Schinken",u:"g",a:"50"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"mehligkochende Kartoffeln",u:"g",a:"600"},{n:"Milch",u:"ml",a:"250"},{n:"Butter",u:"EL",a:"3"},{n:"Salz",u:"",a:""},{n:"Butter",u:"EL",a:"2"},{n:"Mehl",u:"EL",a:"1"},{n:"heißes Wasser",u:"ml",a:"300"},{n:"gerebelter Majoran",u:"TL",a:"15"},{n:"gerebelter Thymian",u:"TL",a:"1"},{n:"Dijonsenf",u:"Tl",a:"2"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Honig für das Sauerkraut",u:"EL",a:"1"}],st:[{s:1,n:"Kartoffelpüree zubereiten",d:"Kartoffeln schälen, grob schneiden und in einem Topf mit Wasser ca. 20 Minuten garen. Danach das Wasser in einem Behälter für die spätere Soße auffangen. In den Topf mit Kartoffeln Butter, Milch und Salz geben und alles zusammen zu einer geschmeidigen Masse pürieren."},{s:2,n:"Sauerkraut zubereiten",d:"Das Sauerkraut in einem Sieb abtropfen lassen. Eine Zwiebel schälen und klein schneiden. Wenn vorhanden, etwas Speck oder geräucherter Schinken in Würfel schneiden. Eine Pfanne mit etwas Öl erhitzen und erst den Speck und 3 Min. später die Zwiebeln anbraten. Danach das Sauerkraut hinzugeben und noch ca. 5 Min. anbraten."},{s:3,n:"Sauerkraut köcheln lassen",d:"Währenddessen etwas Wasser in einem Wasserkocher vorbereiten und zu dem Sauerkraut in die Pfanne geben. Bei verminderter Hitze das Kraut nun 30 Min. leicht vor sich hinköcheln. Dabei wird das Sauerkraut mit Salz, Pfeffer und Honig gewürzt. Entsprechend der jeweiligen geschmacklichen Vorlieben mehr oder weniger Honig hinzugeben. Zu sauer sollte es nun auch nicht schmecken."},{s:4,n:"Soße vorbereiten",d:"In einer weiteren Pfanne die Soße zubereiten. Eine klassische Mehlschwitze vorbereiten. Etwas Butter in der Pfanne erhitzen und Mehl hinzugeben, wenn sie geschmolzen ist. Alles zusammen mit einem Schneebesen glatt rühren. Das ist wichtig, um später keine Mehlklümpchen aus der Soße zu fischen. Sobald das Mehl gut verrührt ist, Kartoffelwasser unter ständigem Rühren hinzugeben. Soße mit Majoran, Thymian, Dijon-Senf, Salz und Pfeffer würzen und noch ca. 11 Min köcheln. Erst danach dürfte der Mehlgeschmack den Gewürzen gewichen sein. Zum Schluss noch einmal abschmecken und je nach Wunsch nachwürzen."},{s:5,n:"Bratwurst braten",d:"Das Sauerkraut ist fertig und kann in einer Schüssel zur Seite gestellt werden. In der nun freigewordenen Pfanne die Bratwürste braten. Fertig ist ein deftiges Gericht aus der Rubrik Hausmannskost!"}],p:"00:15",c:"00:45",tot:65,srv:"4",cats:["Fleisch"]},{id:2342,t:"Lachsfilet Auf Schmorkartoffeln",i:[{n:"Lachsfilet",u:"g",a:"600"},{n:"Kartoffeln",u:"g",a:"600"},{n:"Zwiebellauch",u:"Bd",a:"1"},{n:"Butterschmalz",u:"",a:""},{n:"Butter",u:"g",a:"200"},{n:"Sahnejoghurt",u:"g",a:"150"},{n:"Dijonsenf",u:"g",a:"100"},{n:"Zucker",u:"Prise",a:"1"},{n:"Eigelb",u:"Stk",a:"2"},{n:"Zitronensaft",u:"",a:""},{n:"Worchestersauce",u:"",a:""},{n:"Salz/Pfefer",u:"",a:""}],st:[{s:1,n:"Lachsfilet in Streifen schneiden und marinieren",d:"Das Lachsfilet mit kaltem Wasser abwaschen, mit Küchenpapier trocken tupfen und in ca. 4 cm breite Streifen schneiden. Diese werden nun mit Zitronensaft, ein paar Trofpen Worchestersauce, Salz und Pfeffer in einer Schüssel gewürzt und für ca. 15 Min. im Kühlschrank mariniert."},{s:2,n:"Kartoffeln und Lauchzwiebeln zubereiten",d:"Nun schält man die Kartoffeln und viertelt oder halbiert diese je nach Größe und brät diese für ca. 10 Minuten in Butterschmalz mit Salz und Pfeffer goldbraun an. Während dessen werden die Lauchzwiebeln geputzt und das Weiße in 3 cm lange Streifen geschnitten. Das Grün in dünne Ringe schneiden und in einer Schüssel zur Seite stellen. Für die Zubereitung der Schmorkartoffeln wird heißes Wasser auf 2 Tl Brühe gegossen und zu den Kartoffeln in die Pfanne gegeben. Die weißen Zwiebelstreifen hinzufügen und alles zusammen ca. 10 Min bei verminderter Hitze leicht schmoren lassen"},{s:2,n:"Kartoffeln und Lauchzwiebeln zubereiten",d:"Nun schält man die Kartoffeln und viertelt oder halbiert diese je nach Größe und brät diese für ca. 10 Minuten in Butterschmalz mit Salz und Pfeffer goldbraun an. Während dessen werden die Lauchzwiebeln geputzt und das Weiße in 3 cm lange Streifen geschnitten. Das Grün in dünne Ringe schneiden und in einer Schüssel zur Seite stellen. Für die Zubereitung der Schmorkartoffeln wird heißes Wasser auf 2 Tl Brühe gegossen und zu den Kartoffeln in die Pfanne gegeben. Die weißen Zwiebelstreifen hinzufügen und alles zusammen ca. 10 Min bei verminderter Hitze leicht schmoren lassen"},{s:3,n:"Ofen vorheizen und Kartoffeln warmhalten",d:"Der Ofen wird nun auf ca. 70 Grad vorgeheizt. Sobald die Kartoffleln fertig gegart sind, werden diese mit einer Siebkelle herausgenommen, in einer Auflaufform gegeben und im Ofen warmgehalten."},{s:3,n:"Ofen vorheizen und Kartoffeln warmhalten",d:"Der Ofen wird nun auf ca. 70 Grad vorgeheizt. Sobald die Kartoffleln fertig gegart sind, werden diese mit einer Siebkelle herausgenommen, in einer Auflaufform gegeben und im Ofen warmgehalten."},{s:4,n:"Soße zubereiten, Fisch glasig braten und anrichten",d:"In einem kleinen Topf 200 g Butter schmelzen, Senf und Eigelb unterrühren und langsam erhitzen. Sobald die Mischung dickt, Joghurt unterrühren, mit Salz, Pfeffer und Zucker abschmecken. Der Fisch wird nun für ca. 3 Minuten in Butter gebraten. Über die Kartoffeln kann man nun die Joghurtsoße geben, den Fisch darauf legen und mit dem grünen Zwiebellauch garnieren. Guten Appetit"},{s:4,n:"Soße zubereiten, Fisch glasig braten und anrichten",d:"In einem kleinen Topf 200 g Butter schmelzen, Senf und Eigelb unterrühren und langsam erhitzen. Sobald die Mischung dickt, Joghurt unterrühren, mit Salz, Pfeffer und Zucker abschmecken. Der Fisch wird nun für ca. 3 Minuten in Butter gebraten. Über die Kartoffeln kann man nun die Joghurtsoße geben, den Fisch darauf legen und mit dem grünen Zwiebellauch garnieren. Guten Appetit"}],p:"00:25",c:"00:30",tot:60,srv:"5",cats:["Fisch & Meeresfrüchte"]},{id:2354,t:"China Eiernudeln Mit Huhn",i:[{n:"chinesische Eiernudeln",u:"g",a:"250"},{n:"Hühnerbrustfilet",u:"g",a:"400"},{n:"Ingwerwurzel (groß)",u:"cm",a:"6"},{n:"Brokkoli",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Maiskeimöl",u:"EL",a:"4"},{n:"dunkle Sojasauce",u:"EL",a:"4"},{n:"Zwiebellauch",u:"Stangen",a:"4"}],st:[{s:1,n:"Eiernudeln kochen",d:"Die Eiernudeln in reichlich kochendem Salzwasser bissfest garen. In einem Sieb abgießen, kalt abschrecken und abtropfen lassen."},{s:2,n:"Brokkoli garen",d:"Den Brokkoli abwaschen und in kleine Röschen schneiden. Einen Topf mit Salzwasser erhitzen und die Brokkoliröschen für ca. 2-3 Minuten in das kochende Wasser geben. Danach sofort herausnehmen und mit kaltem Wasser abschrecken. Dabei gart der Brokkoli nicht nach und bleibt somit bissfest und behält die frische grüne Farbe. Da vermutlich nicht der ganze Brokkoli gebraucht wird, erhitzt man noch schnell einen kleinen Topf mit 3 EL Butter. Fügt eine Prise Salz sowie 2 EL Paniermehl hinzu und röstet dies alles kurz an. Danach gießt man es über die verbliebenen Brokkoliröschen. Als kleiner Snack für den kleinen Hunger ideal geeignet."},{s:3,n:"Lauch und Knoblauch vorbereiten",d:"Nun aber wieder zurück zum Gericht. Den Zwiebellauch waschen, putzen und in 3 cm lange Streifen schneiden. Den Knoblauch sowie den Ingwer schälen und fein hacken."},{s:4,n:"Hühnerbrustfilet in Streifen schneiden und zusammen mit dem Gemüse anbraten",d:"Das Hühnerbrustfilet kalt abwaschen, trockentupfen und in kurze dünne Streifen schneiden. Den Wok erhitzen, das Öl hineingeben und sehr heiß werden lassen. Nun werden die vorbereiteten Zutaten Schritt für Schritt angebraten. Zuerst das Fleisch hineingeben und scharf anbraten. Es folgen die Zwiebellauchstreifen, der Knoblauch sowie der Ingwer. Nach weiteren 3 Minuten die Nudeln und die Sojasauce locker miteinander vermischen. Ganz zum Schluss können nun die Brokkoliröschen untergehoben werden. Nochmals mit Sojasauce abschmecken. Das Mahl kann sofort serviert werden. Guten Appetit."}],p:"00:15",c:"00:10",tot:35,srv:"4",cats:["Geflügel","Pasta & Nudeln","Asiatisch"]},{id:2369,t:"Huhnerbrust Auf Kartoffeln Und Leipziger Allerlei",i:[{n:"Hühnerbrustfilets (4 Teile)",u:"Stk",a:"2"},{n:"festkochende Kartoffeln",u:"g",a:"400"},{n:"mittelgroße Möhren",u:"Stk",a:"3"},{n:"Morcheln",u:"Hand",a:"1"},{n:"gefrorene Erbsen",u:"g",a:"150"},{n:"Blumenkohl",u:"Stk",a:"1"},{n:"Milch",u:"ml",a:"150"},{n:"Gemüsefond",u:"ml",a:"300"},{n:"Butter",u:"EL",a:"2"},{n:"Butterschmalz",u:"EL",a:"1"},{n:"Mehl",u:"EL",a:"1"},{n:"einige spritzer Zitrone",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Morcheln einweichen und Kartoffeln kochen",d:"Die getrockneten Morcheln werden für ca. 30 Min. in eine kleine Schüssel mit Wasser gegeben. Einen Topf mit Wasser für die Kartoffeln aufsetzen und ca. 20 Min kochen lassen."},{s:2,n:"Blumenkohl zubereiten und Möhren schneiden",d:"Einen mittleren Topf mit Salzwasser aufsetzen. Während dessen wird der Blumenkohl vom Strunk befreit und kleine Blumenkohlröschen herausgeschnitten. Da man nicht den ganzen Blumenkohlkopf benötigt, werden die restlichen Röschen mit leicht gesalzener Butter übergossen und können gern nebenbei gegessen werden. Sobald das Wasser kocht, wird der Blumenkohl für ca. 3 Min. in den Topf gegeben. Jetzt schält man 3 mittelgroße Mohrrüben und schneidet diese in Ringe. Den gegarten Blumenkohl entnimmt man dem Topf mit einer Siebkelle und gibt ihn in eine Schüssel mit Eiswasser, damit das Gemüse nicht nachgaren und somit bissfest bleiben kann. Dies wiederholt man später mit den Mohrrüben und den Erbsen."},{s:2,n:"Blumenkohl zubereiten und Möhren schneiden",d:"Einen mittleren Topf mit Salzwasser aufsetzen. Während dessen wird der Blumenkohl vom Strunk befreit und kleine Blumenkohlröschen herausgeschnitten. Da man nicht den ganzen Blumenkohlkopf benötigt, werden die restlichen Röschen mit leicht gesalzener Butter übergossen und können gern nebenbei gegessen werden. Sobald das Wasser kocht, wird der Blumenkohl für ca. 3 Min. in den Topf gegeben. Jetzt schält man 3 mittelgroße Mohrrüben und schneidet diese in Ringe. Den gegarten Blumenkohl entnimmt man dem Topf mit einer Siebkelle und gibt ihn in eine Schüssel mit Eiswasser, damit das Gemüse nicht nachgaren und somit bissfest bleiben kann. Dies wiederholt man später mit den Mohrrüben und den Erbsen."},{s:3,n:"Gemüse garen und Mehlschwitze zubereiten",d:"Die Mohrrüben kommen nun auch für ca. 4 Min in den Topf. Danach folgen die Erbsen für weitere 4 Min. Das Gemüse wird immer wieder mit einer Siebkelle entnommen und in eine Schüssel mit Eiswasser gegeben. Nun wird ein weiterer Topf mit 2 EL Butter erhitzt und Mehl darüber gestreut. Gut einrühen, sodaß keine Klümpchen mehr vorhanden sind. Nun gibt man die Milch sowie den Gemüsefond unter ständigem rühren hinzu. 5 Min einkochen lassen und bei reduzierter Hitze mit Salz, Pfeffer, und Zitrone gewürzt köcheln lassen. Die Kartoffeln dürften nun auch fertig gegart sein und werden entweder im Ofen oder auf dem Herd warm gehalten."},{s:3,n:"Gemüse garen und Mehlschwitze zubereiten",d:"Die Mohrrüben kommen nun auch für ca. 4 Min in den Topf. Danach folgen die Erbsen für weitere 4 Min. Das Gemüse wird immer wieder mit einer Siebkelle entnommen und in eine Schüssel mit Eiswasser gegeben. Nun wird ein weiterer Topf mit 2 EL Butter erhitzt und Mehl darüber gestreut. Gut einrühen, sodaß keine Klümpchen mehr vorhanden sind. Nun gibt man die Milch sowie den Gemüsefond unter ständigem rühren hinzu. 5 Min einkochen lassen und bei reduzierter Hitze mit Salz, Pfeffer, und Zitrone gewürzt köcheln lassen. Die Kartoffeln dürften nun auch fertig gegart sein und werden entweder im Ofen oder auf dem Herd warm gehalten."},{s:4,n:"Hühnerbrustfilets anbraten und alles abschmecken",d:"Die Hühnerbrustfilets waschen, trockentupfen und vom Knochen lösen. Von allen Seiten gut salzen und in eine mit Butterschmalz erhitzte Pfanne geben und ca. 10 Min von allen Seiten schön braun anbraten. Während die Hühnerbrustfilets braten, wird das vorbereitete Leipziger Allerlei sowie die Morcheln in die Soße gegeben und erwärmt. Evtl. sollte die Soße nochmals mit Salz, Pfeffer und Zitrone abgeschmeckt werden. Nun wird alles zusammen nett auf einem großen Teller angerichtet. Fertig ist ein leicht bekömmliches Gericht für die schlanke Linie :-) Guten Appetit."},{s:4,n:"Hühnerbrustfilets anbraten und alles abschmecken",d:"Die Hühnerbrustfilets waschen, trockentupfen und vom Knochen lösen. Von allen Seiten gut salzen und in eine mit Butterschmalz erhitzte Pfanne geben und ca. 10 Min von allen Seiten schön braun anbraten. Während die Hühnerbrustfilets braten, wird das vorbereitete Leipziger Allerlei sowie die Morcheln in die Soße gegeben und erwärmt. Evtl. sollte die Soße nochmals mit Salz, Pfeffer und Zitrone abgeschmeckt werden. Nun wird alles zusammen nett auf einem großen Teller angerichtet. Fertig ist ein leicht bekömmliches Gericht für die schlanke Linie :-) Guten Appetit."}],p:"00:30",c:"00:30",tot:65,srv:"4",cats:["Geflügel"]},{id:2375,t:"Kasesuppe",i:[{n:"Kartoffeln",u:"g",a:"500"},{n:"Rinderhack",u:"g",a:"500"},{n:"Porreestangen",u:"Stk",a:"2"},{n:"Schmelzkäse (natur + Kräuter)",u:"Pck",a:"2"},{n:"Creme Fraiche",u:"Becher",a:"1"},{n:"Schinkenwürfel",u:"Pck",a:"1"},{n:"Gemüsebrühe",u:"l",a:"1"},{n:"Muskat",u:"Tl",a:"0.5"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Knoblauchzehen",u:"Stk",a:"3"}],st:[{s:1,n:"Kartoffeln und Porree vorbereiten",d:"Kartoffeln schälen und in kleine Würfel schneiden. Den Porree abwaschen und in Ringe schneiden. Dabei den Sand zwischen den Blättern gründlich auswaschen."},{s:2,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/JwsB5WhgI98\\ width=\\480\\ height=\\360\\]"},{s:3,n:"Rinderhack anbraten und Knoblauch pressen",d:"Das Rinderhack in einem Topf mit Salz und Pfeffer scharf anbraten. Währenddessen das Hack mit einem Löffel immer wieder zerteilen. Nachdem das Hack angebraten ist, fügt man nun die Porreeringe hinzu und brät auch diese an. Nun werden 3 Knoblauchzehen geschält und durch eine Knoblauchpresse in den Topf geben. Jetzt fügt man Gemüsefond hinzu. Sollte dieser nicht zur Verfügung stehen, kann man auch normales Brühepulver oder Würfel mit heißem Wasser hinzufügen."},{s:4,n:"Kartoffeln kochen und Käse in Suppe geben",d:"Die Kartoffeln in den Topf geben. Kurz aufkochen lassen und weitere 10 Min köcheln lassen. Nun den Schmelzkäse einrühren und kurz einkochen lassen. Creme Fraiche hinzugeben und aufkochen lassen. Nun alles kräftig mit Salz, Pfeffer und Muskat abgeschmecken und 5 Min. ziehen lassen."},{s:5,n:"Schinkenwürfel anbraten, Suppe abschmecken und servieren",d:"Währenddessen brät man in einer Pfanne Schinkenwürfel kross an und gibt diese ganz zum Schluss in die Käsesuppe. Fertig ist eine sehr schmackhafte Käsesuppe, die auch auf Vorrat gekocht werden kann. Guten Appetit [su_slider source=\\media: 5411,5407,5404,5408,5405,5406,5400,5403,5409,5401,5410,5402\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"}],p:"00:10",c:"00:20",tot:40,srv:"4",cats:["Suppen & Eintöpfe"]},{id:2411,t:"Schweinegulasch",i:[{n:"Schweinegulasch",u:"kg",a:"1.5"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Wasser",u:"l",a:"1.7"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"edelsüsses Paprikapulver",u:"EL",a:"2"},{n:"Öl",u:"EL",a:"2"},{n:"Brühe",u:"EL",a:"1"},{n:"Becher Sahne",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch würfeln",d:"Das Fleisch mit kaltem Wasser abwaschen, trockentupfen und je nach Belieben in mittelgroße oder kleine Würfel schneiden."},{s:2,n:"Gemüse vorbereiten und Fleischwürfel anbraten",d:"Den Knoblauch sowie die Zwiebeln schälen und kleinschneiden, wobei der Knoblauch zusätzlich noch sehr klein gehackt wird. Die Champignons vom groben Sand befreien, halbieren und in Scheiben schneiden. Nun wird ein großer Topf mit Öl erhitzt und das Fleisch portionsweise jeweils für 5 Min. scharf angebraten. Dabei darf schon mit Salz und Pfeffer gewürzt werden. Den austretenden Bratensaft auffangen, da dieser später wieder der Soße zugefügt wird. Währenddessen wird ausreichend Wasser in einem Wasserkocher erhitzt."},{s:3,n:"Gemüse und Gewürze hinzufügen",d:"Nachdem das Fleisch angebraten worden ist, fügt man nun die Pilze, die Zwiebeln sowie den Knoblauch für ca. 5 Min. hinzu. Jetzt gibt man noch einen EL Tomatenmark sowie 1-2 EL edelsüssen Paprika hinzu. Gut miteinander vermengen, kurz anrösten und letztendlich mit dem heißen Wasser bedeckt auffüllen, einkochen und wieder auffüllen. Dies wiederholt man etwa 1-2 mal bis dann letztendlich genügend Wasser in den Topf gegeben wurde. Nun darf der Gulasch ca. 1,5-2 Stunden bei leichter Flamme schmoren."},{s:4,n:"Soße andicken",d:"In dem sich das Fleisch mit einem Löffel leicht zerdrücken lässt, kann man feststellen, ob der Gulasch soweit fertig geworden ist. Jetzt rührt man 2 TL Mehl und 0,1 l kaltes Wasser glatt und ergänzt dies zum Schluss noch mit einem Becher Sahne. Dies zusammen gießt man nun in den Topf zu dem Gulasch. Umrühren nochmals kräftig mit Salz und Pfeffer abschmecken. Fertig ist ein sehr einfacher Schweinegulasch ideal geeignet für die kalte Jahreszeit. Da man den Gulasch ebenso in großen Mengen zubereiten kann, eignet er sich ebenso für Feiern oder kleinen Feiern unter Freunden."}],p:"00:15",c:"2:00",tot:140,srv:"8",cats:["Fleisch"]},{id:2416,t:"Glasnudeln Mit Gebratenem Gemuse Und Sesam",i:[{n:"Glasnudeln",u:"g",a:"200"},{n:"Möhren",u:"Stk",a:"2"},{n:"rote Paprikaschote",u:"Stk",a:"1"},{n:"mittelgroße Zucchini",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Glas Sojabohnensprossen",u:"Stk",a:"1"},{n:"Sesamsamen",u:"EL",a:"1"},{n:"Sesamöl",u:"EL",a:"4"},{n:"helle Sojasauce",u:"EL",a:"2"},{n:"Austernsauce",u:"EL",a:"1"},{n:"gehackter Koriander",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Glasnudeln zubereiten",d:"Die Glasnudeln läßt man in einer Schüssel mit heißem Wasser ca. 15 Min. quellen."},{s:2,n:"Gemüse vorbereiten",d:"Die Parpika halbieren, Stiel und Kerne entfernen und den Rest in sehr dünne Streifen schneiden. Die Möhren schälen und in ca. 5 cm dünne Sticks schneiden. Die Zucchini waschen, Enden entfernen, je nach Größe quer halbieren oder dritteln und ebenso in dünne Streifen schneiden. Zwei Knoblauchzehen schälen und kleinhacken. Die Sojabohnensprossen in ein Sieb geben, heiß abbrausen und abtropfen lassen."},{s:2,n:"Gemüse vorbereiten",d:"Die Parpika halbieren, Stiel und Kerne entfernen und den Rest in sehr dünne Streifen schneiden. Die Möhren schälen und in ca. 5 cm dünne Sticks schneiden. Die Zucchini waschen, Enden entfernen, je nach Größe quer halbieren oder dritteln und ebenso in dünne Streifen schneiden. Zwei Knoblauchzehen schälen und kleinhacken. Die Sojabohnensprossen in ein Sieb geben, heiß abbrausen und abtropfen lassen."},{s:3,n:"Gemüse im Wok anbraten",d:"Nun wird ein Wok mit 3 EL Sesamöl erhitzt und der Knoblauch angebraten. Das Gemüse unter Rühren darin anbraten, jedoch nicht bräunen. Mit Salz und Pfeffer würzen."},{s:3,n:"Gemüse im Wok anbraten",d:"Nun wird ein Wok mit 3 EL Sesamöl erhitzt und der Knoblauch angebraten. Das Gemüse unter Rühren darin anbraten, jedoch nicht bräunen. Mit Salz und Pfeffer würzen."},{s:4,n:"Glasnudeln abgießen und abschmecken",d:"Die Glasnudeln in einem Sieb abtropfen lassen, evtl. mit einer Schere in Stücke schneiden und in den Wok zu dem Gemüse unterheben. Die Sojabohnensprossen, 2 EL helle Sojasoße, 1 EL Austernsoße, etwas Limetten- oder Zitronensaft und das restliche Öl hinzugeben und miteinander vermengen. Der Wok kann nun vom Herd genommen werden."},{s:4,n:"Glasnudeln abgießen und abschmecken",d:"Die Glasnudeln in einem Sieb abtropfen lassen, evtl. mit einer Schere in Stücke schneiden und in den Wok zu dem Gemüse unterheben. Die Sojabohnensprossen, 2 EL helle Sojasoße, 1 EL Austernsoße, etwas Limetten- oder Zitronensaft und das restliche Öl hinzugeben und miteinander vermengen. Der Wok kann nun vom Herd genommen werden."},{s:5,n:"Glasnudelsalat mit Koriander und Sesamkörner verfeinern",d:"Den Koriander für etwa 1 EL kleinhacken. In eine große Schüssel gibt man nun den Glasnudelsalat mit dem Gemüse und hebt einen EL Sesamkörner sowie den Koriander drunter. Diesen Salat kann man sowohl warm als auch kalt servieren. Passend als Beilage für jede Feier geeignet. Guten Appetit."},{s:5,n:"Glasnudelsalat mit Koriander und Sesamkörner verfeinern",d:"Den Koriander für etwa 1 EL kleinhacken. In eine große Schüssel gibt man nun den Glasnudelsalat mit dem Gemüse und hebt einen EL Sesamkörner sowie den Koriander drunter. Diesen Salat kann man sowohl warm als auch kalt servieren. Passend als Beilage für jede Feier geeignet. Guten Appetit."}],p:"00:15",c:"00:10",tot:30,srv:"4",cats:["Pasta & Nudeln","Asiatisch"]},{id:2419,t:"Glasnudelsalat Mit Huhnerbrust Und Fenchel",i:[{n:"Glasnudeln",u:"g",a:"250"},{n:"mittelgroße Zucchini",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"2"},{n:"Paprika (gelb, rot)",u:"Stk",a:"1"},{n:"Cocktailtomaten",u:"Stk",a:"9"},{n:"Fenchelknolle",u:"Stk",a:"0.5"},{n:"Champignons (Morcheln sind auch geeignet)",u:"g",a:"150"},{n:"Hühnerbrustfilet",u:"g",a:"300"},{n:"Sesamöl",u:"EL",a:"3"},{n:"helle Sojasauce",u:"EL",a:"5"},{n:"Fischsauce",u:"EL",a:"2"},{n:"cm frische Chilischote",u:"",a:"2"},{n:"brauner Zucker (weiß ist auch möglich)",u:"EL",a:"1"},{n:"Limettensaft",u:"EL",a:"1"}],st:[{s:1,n:"Glasnudeln zubereiten",d:"Einen Wasserkocher erhitzen und die Glasnudeln in einer Schüssel damit übergießen. Etwa 10 Min quellen und abkühlen lassen."},{s:2,n:"Fleisch in Streifen schneiden und Pilze, Fenchel putzen",d:"Die Hühnerbrust mit kaltem Wasser abwaschen, trockentupfen und zuerst in sehr schmale Streifen, dann in etwa 1 cm große Stücke schneiden. Die Champignons vom Sand befreien, halbieren und in Scheiben schneiden. Den Fenchel in kleine Würfel schneiden."},{s:3,n:"Fleisch und Gemüse anbraten",d:"Einen Wok mit Sesamöl erhitzen und das Fleisch rundherum unter ständigem Rühren anbraten, jedoch nicht braun werden lassen. Fleisch herausnehmen und in einer Schüssel zur Seite stellen. Die Pilze werden in dem verbliebenen Bratensaft ebenso unter permantenten Rühren ca. 1-2 Min. angebraten und zu dem Fleisch in die Schüssel gegeben. Den Fenchel etwa 1 Min anbraten. Nun werden in einer kleinen Schüssel 3 EL helle Sojasauce sowie 1,5 EL Fischsauce angerührt und zu dem Fleisch und den Pilzen gegeben. Gut verrühren und etwa 20 Min. marinieren lassen. Gelgentlich umrühren."},{s:4,n:"restliches Gemüse vorbereiten",d:"Währenddessen kann das restliche Gemüse vorbereitet werden. Dafür werden eine rote und eine halbe gelbe Paprikaschote vom Stiel und den Kernen befreit, in sehr dünne Streifen geschnitten, welche zum Schluss nochmals quer halbiert werden. Die Zucchini abwaschen, die Enden entfernen und ebenso in sehr dünne Sticks schneiden. Länge sollte in etwa 2 cm betragen. Die Möhren schälen und Sticks daraus schnippeln. Die Cocktailtomaten abwaschen, den Strunk entfernen und abhängig von der Größe vierteln oder achteln."},{s:5,n:"Marinade anrühren",d:"In einer weiteren kleinen Schüssel wird nun die Marinade angerührt, welche die dezente Frische des Salates ausmacht, angerührt. Dafür vermischt man 2 EL braunen Zucker, 1,5 EL Limetten- oder Zitronensaft, 2 EL helle Sojasauce und 1 EL Fischsauce miteinander. Es darf noch dezent säuerlich schmecken. Von einer frischen Chilischote werden etwa 2 cm. von der Spitze abgeschnitten. Evtl. entkernen und sehr fein schneiden oder hacken. Die kleingeschnittene Chilischote gibt man nun noch zur Marinade."},{s:6,n:"Salat anrichten und servieren",d:"Die Glasnudeln dürften nun auch fertig sein. Das Wasser abgießen, evtl. mit kaltem Wasser abrausen und je nach Belieben mit der Schere in die gewünschte Länge schneiden. Nachdem nun alle Zutaten vorbereitet wurden, können diese miteinander vermengt werden. Wer mag darf noch gern einen EL gehackten Koriander und Sesamsamen unterrühren. Dieser Salat ist sofort servierfertig. Wenn möglich darf wie jeder andere Salat auch, noch ein paar minuten ziehen. Dieses Gericht kommt gänzlich ohne Salz und Pfeffer aus. Absolut lecker und erfrischend. Dazu ein Baguette. Guten Appetit."}],p:"00:35",c:"00:10",tot:50,srv:"6",cats:["Geflügel","Pasta & Nudeln","Salate","Asiatisch"]},{id:2429,t:"Schweinefleisch Mit Gemuse Aus Dem Wok",i:[{n:"Zuckerschoten",u:"g",a:"100"},{n:"Schweinefleischscheiben",u:"g",a:"250"},{n:"Möhren",u:"Stk",a:"2"},{n:"Champignons",u:"Stk",a:"6"},{n:"rote Zwiebel",u:"Stk",a:"0.5"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"rote sowie 1/2 gelbe Paprikaschote",u:"Stk",a:"0.5"},{n:"Sojasauce",u:"EL",a:"1"},{n:"Austernsauce",u:"EL",a:"1"},{n:"Tabascosauce",u:"",a:""}],st:[{s:1,n:"Gemüse vorbereiten",d:"Die Zuckerschoten abwaschen. Die rote Zwiebel schälen und in Streifen schneiden. Jeweils eine halbe gelbe, sowie eine halbe rote Paprikaschote entkernen und in schmale Streifen schneiden. Die Möhren schälen und in 3 cm lange sehr dünne Sticks schneiden. Die Champignons vom Sand befreien, halbieren und in Scheiben schneiden. Das Schweinefleisch mit kaltem Wasser abbrausen, trockentupfen und zuerst in schmale Streifen und danach in 2cm lange Stücke schneiden."},{s:2,n:"Wasser kochen und Knoblauch feinhacken",d:"Wasser in einem Wasserkocher erhitzen. Die Knoblauchzehe schälen und feinhacken."},{s:3,n:"Fleisch und Gemüse im Wok anbraten",d:"Nun wird in einem Wok 2 EL Sesamöl erhitzt und das Fleisch darin rundherum 5 Min angebraten. Herausnehmen und das Gemüse mit 1 EL Sesamöl ebenso 4 Min. anbraten. Das Fleisch wieder hinzufügen, mit dem Gemüse vermengen, mit 1,5 EL heller Sojasauce, ein paar Spritzer Tabascosauce sowie 1 EL Austernsauce würzen und zum Schluss mit etwa 0,3 l heißem Wasser aufkochen."},{s:4,n:"Servieren",d:"Letztendlich noch einmal abschmecken, evtl. noch nachwürzen und sodann sofort servieren. Dazu können Reis oder Chinanudeln serviert werden. Guten Appetit."}],p:"00:15",c:"00:15",tot:35,srv:"3",cats:["Fleisch","Asiatisch"]},{id:2443,t:"Rezept 2443",i:[{n:"Ente mit Innerein",u:"kg",a:"3.2"},{n:"Sellerieknolle",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"7"},{n:"Schalotten",u:"Stk",a:"8"},{n:"Orangen",u:"Stk",a:"1"},{n:"Boskopäpfel",u:"Stk",a:"2"},{n:"Rotwein",u:"ml",a:"300"},{n:"Ingwerwurzel",u:"cm",a:"3"},{n:"Rosmarinzweige",u:"Stgl",a:"2"},{n:"Thymianzweige",u:"Stgl",a:"8"},{n:"Majoran",u:"El",a:"5"},{n:"Sonnenblumenöl",u:"EL",a:"2"},{n:"Zucker",u:"EL",a:"2"},{n:"Salz",u:"",a:""},{n:"Wasser",u:"l",a:"1"}],st:[{s:1,n:"Ente vorbereiten und Gemüse schneiden",d:"Die Innerein herausnehmen und die Ente innen und außen ordentlich mit kaltem Wasser abwaschen, abtupfen, das Fett am Hintern entfernen und aufbewahren. Etwa 1/3 vom Sellerie, 3 Möhren, einen Bosskopfapfel, eine Orange, 3 Schalotten sowie 3 cm Ingwer jeweils schälen, in Würfel kleinschneiden und mit Salz und gerebelten Majoran würzen."},{s:2,n:"Ofen heizen und Ente innen würzen",d:"Den Ofen auf 200-220 Grad vorheizen. Die Ente innen kräftig mit Salz einreiben und mit 2 Rosmarinzweigen belegen."},{s:2,n:"Ofen heizen und Ente innen würzen",d:"Den Ofen auf 200-220 Grad vorheizen. Die Ente innen kräftig mit Salz einreiben und mit 2 Rosmarinzweigen belegen."},{s:3,n:"Den Hals verschließen",d:"Mit Küchengarn und einer großen Nadel oder einer Rouladennadel (wobei man hier dar Ende der Öse flachdrücken sollte, da sonst die Haut beim durchziehen der Nadel reißen könnte) das Halsende zuschnüren. Ente vor dem Füllen auf einer Seite zunähen"},{s:4,n:"Die Ente mit Gemüse befüllen und verschließen",d:"Die Ente mit dem Gemüse befüllen. Dafür die Ente auf den verschlossenen Hals stellen und von oben das Gemüse hineingeben. Vorsichtig stopfen. Zum Schluss wird die andere Seite verschlossen. Mit ein wenig Übung gelingt das Nähen sehr einfach. Man kann dies durchaus vorher mit einer Nadel und einem Faden an einem eingerissenem Stück Stoff kurz üben. Ich hatte das früher noch im Unterrichtsfach \\Werken\\... Ist das lange her ;-) Hinweis: Nachdem der Hals und der Hintern verschlossen sind, sollten noch die Beine und Flügel eng an die Ente angelegt und zusammengebunden werden. So bleiben sie schön saftig und kann beim braten im Ofen nicht so schnell austrocknen."},{s:5,n:"Ente von aussen einreiben und Bräter vorbereiten",d:"Nun wird die Ente mit Sonnenblumenöl eingerieben und kräftig mit Salz und gerebelten Majoran gewürzt. Den Bräter mit weiteren 1/3 des grobgeschnittenem Selleries, 3 Möhren, 4 Schalotten, einem Bosskopfapfel, Thymianzweigen sowie 300-500 ml Wasser befüllen und die Ente mit der Brust nach unten rauflegen."},{s:5,n:"Ente von aussen einreiben und Bräter vorbereiten",d:"Nun wird die Ente mit Sonnenblumenöl eingerieben und kräftig mit Salz und gerebelten Majoran gewürzt. Den Bräter mit weiteren 1/3 des grobgeschnittenem Selleries, 3 Möhren, 4 Schalotten, einem Bosskopfapfel, Thymianzweigen sowie 300-500 ml Wasser befüllen und die Ente mit der Brust nach unten rauflegen."},{s:6,n:"braten, begießen, braten, begießen...",d:"Die Ente darf das erste mal nach etwa einer halben Stunde gewendet werden. In den kommenden 1,5-2 Stunden immer wieder mit dem Sud aus dem Bräter übergießen und noch ein oder zwei mal wenden. Nachdem die Ente gebraten wurde, herausnehmen und etwa 10 Min ruhen lassen."},{s:6,n:"braten, begießen, braten, begießen...",d:"Die Ente darf das erste mal nach etwa einer halben Stunde gewendet werden. In den kommenden 1,5-2 Stunden immer wieder mit dem Sud aus dem Bräter übergießen und noch ein oder zwei mal wenden. Nachdem die Ente gebraten wurde, herausnehmen und etwa 10 Min ruhen lassen."},{s:7,n:"Entensoße zubereiten",d:"Nachdem die Ente etwa 1 Stunde im Ofen gebraten ist, wird die Soße zubereitet. Dafür nimmt man einen großen Topf und fügt das restliche Drittel grob geschnittenen Selleries, ein paar Schalotten und die Innerein (also das Herz, die Nieren und den Hals) hinein und brät dies etwa 5 Minuten an. Die Leber ist aufgrund des intensiven Eigengeschmacks dafür nicht geeignet. Diese können Liebhaber von Lebergerichten jedoch gern extra anbraten und würzen. Als Snack beim Kochen sicherlich eine gute Alternative. Mit Rotwein ablöschen, einkochen lassen, bis der typische Alkoholgeruch verschwunden ist und zum Schluss mit etwa 300 ml heißem Wasser auffüllen. Die Hitze reduzieren und gemütlich vor sich hin köcheln lassen."},{s:7,n:"Entensoße zubereiten",d:"Nachdem die Ente etwa 1 Stunde im Ofen gebraten ist, wird die Soße zubereitet. Dafür nimmt man einen großen Topf und fügt das restliche Drittel grob geschnittenen Selleries, ein paar Schalotten und die Innerein (also das Herz, die Nieren und den Hals) hinein und brät dies etwa 5 Minuten an. Die Leber ist aufgrund des intensiven Eigengeschmacks dafür nicht geeignet. Diese können Liebhaber von Lebergerichten jedoch gern extra anbraten und würzen. Als Snack beim Kochen sicherlich eine gute Alternative. Mit Rotwein ablöschen, einkochen lassen, bis der typische Alkoholgeruch verschwunden ist und zum Schluss mit etwa 300 ml heißem Wasser auffüllen. Die Hitze reduzieren und gemütlich vor sich hin köcheln lassen."},{s:8,n:"Gemüse der Ente und vom Bräter hinzufügen",d:"Nachdem die Ente herausgenommen wurde, fügt man den Gemüsesud und das Gemüse ebenso in den Topf. Sobald die Ente aufgeschnitten ist, fügt man auch das Gemüse aus der Ente in den Topf. Evtl. nochmal mit Wasser auffüllen. Dies darf nun nochmals etwa 30 min köcheln. Dies ist die Zeit, bei der die Soße ihren eigenen Geschmack entwickelt."},{s:8,n:"Gemüse der Ente und vom Bräter hinzufügen",d:"Nachdem die Ente herausgenommen wurde, fügt man den Gemüsesud und das Gemüse ebenso in den Topf. Sobald die Ente aufgeschnitten ist, fügt man auch das Gemüse aus der Ente in den Topf. Evtl. nochmal mit Wasser auffüllen. Dies darf nun nochmals etwa 30 min köcheln. Dies ist die Zeit, bei der die Soße ihren eigenen Geschmack entwickelt."},{s:9,n:"Soße durch eine Sieb passieren und abschmecken",d:"Nun wird die Soße durch ein feines Sieb in einen anderen Topf passiert. Dabei drückt man mit dem Löffel vorsichtig das Gemüse an das Sieb, sodaß all die Flüssigkeit auch aus dem Gemüse herausgedrückt wird. Also alles schön in einem Topf auffangen. Nun wird die Soße nochmals aufgekocht und evtl. mit Salz und Zucker abgeschmeckt. Mit Zucker deshalb, da der Geschmack der Soße evtl. noch etwas säuerlich aufgrund der Bosskopäpfel sein könnte. Sollte die Soße noch zu dünn sein, so rührt man in einer kleinen Schüssel etwa 1 TL Kartoffelmehl mit etwas kaltem Wasser an, glattrühren und zur Soße geben. Fertig ist eine wahrlich leckere Soße, die den Geschmack der Ente kräftig unterstreicht. Dazu dürfen Kartoffeln, Rosenkohl, Rotkraut oder Grünkohl serviert werden."},{s:9,n:"Soße durch eine Sieb passieren und abschmecken",d:"Nun wird die Soße durch ein feines Sieb in einen anderen Topf passiert. Dabei drückt man mit dem Löffel vorsichtig das Gemüse an das Sieb, sodaß all die Flüssigkeit auch aus dem Gemüse herausgedrückt wird. Also alles schön in einem Topf auffangen. Nun wird die Soße nochmals aufgekocht und evtl. mit Salz und Zucker abgeschmeckt. Mit Zucker deshalb, da der Geschmack der Soße evtl. noch etwas säuerlich aufgrund der Bosskopäpfel sein könnte. Sollte die Soße noch zu dünn sein, so rührt man in einer kleinen Schüssel etwa 1 TL Kartoffelmehl mit etwas kaltem Wasser an, glattrühren und zur Soße geben. Fertig ist eine wahrlich leckere Soße, die den Geschmack der Ente kräftig unterstreicht. Dazu dürfen Kartoffeln, Rosenkohl, Rotkraut oder Grünkohl serviert werden."}],p:"1:00",c:"3:00",tot:250,srv:"6",cats:["Sonstiges"]},{id:2458,t:"Gebratene Leber Mit Zwiebeln   Herdzeit.De",i:[{n:"Leber",u:"Stk",a:"2"},{n:"große Zwiebel",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Butterschmalz oder Butter",u:"EL",a:"2"}],st:[{s:1,n:"Leber waschen und Zwiebel schneiden",d:"Die Leber mit kaltem Wasser abspülen, trockentupfen und zur Seite stellen. Eine große Zwiebel schälen und in Ringe schneiden. Den Ofen auf etwa 80 Grad vorheizen."},{s:2,n:"Leber braten",d:"Eine Pfanne mit Butterschmalz erhitzen und die Leber etwa 3 Minuten auf beiden Seiten scharf anbraten. Danach die Hitze auf die Hälfte runterregulieren und nochmals etwa 3 Minuten braten. Die fertige Leber zum warmhalten in den Ofen geben."},{s:3,n:"Zwiebelringe braten",d:"Die Zwiebelringe werden nun in der gleichen Pfanne im Bratensaft goldbraun angebraten. Dafür gebt Ihr ein Stück Butter in die Pfanne und erst wenn diese richtig heiß geworden ist, werden die Zwiebelringe scharf für ca. 1 Minute angebraten. Danach die Hitze auf die Hälfte reduzieren und bei geschlossenem Deckel weitere 4-5 Minuten schmoren. Gelegentlich umrühren. Mit Salz würzen und abschmecken."},{s:4,n:"Tipp",d:"Besonders lecker wird es, indem man in einer weiteren Pfanne dünne Apfelscheiben hinzufügt und diese mit etwas Honig karamelisiert. Das gibt dem Gericht noch das gewisse Extra an Geschmack. Probiert doch mal das Kalbsleberrezept mit karamelisiertem Gemüse."}],p:"00:20",c:"00:40",tot:20,srv:"2",cats:["Fleisch"]},{id:2463,t:"Hirschgulasch Mit Sellerie Kartoffelpuree",i:[{n:"Hirsch",u:"g",a:"500"},{n:"kleine Zwiebeln",u:"Stk",a:"3"},{n:"mehligkochende Kartoffeln",u:"g",a:"500"},{n:"Sellerieknolle",u:"Stk",a:"0.5"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"edelsüsses Paprikapulver",u:"TL",a:"1"},{n:"Thymian",u:"TL",a:"1"},{n:"Bratenfond oder Brühe",u:"ml",a:"400"},{n:"Milch",u:"ml",a:"100"},{n:"Butterschmalz",u:"",a:""},{n:"Butter",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Champignons",u:"Stk",a:"5"}],st:[{s:1,n:"Fleisch vorbereiten und Gemüse kleinschneiden",d:"Die Fleischstücke vom Hirsch mit kaltem Wasser abwaschen, trockentupfen und in mundgerechte Stücke schneiden. 3 kleine Zwiebeln schälen und würfeln. 2 Knoblauchzehen kleinhacken. Von der Jahreszeit abhängig, können nun selbst gesammelte Pilze oder Champignons in Scheiben geschnitten werden. Vorher den Sand abputzen."},{s:2,n:"Fleisch anbraten, Bratensaft auffangen und Gemüse garen",d:"Eine Topf mit Butterschmalz erhitzen und das Fleisch darin rundherum anbraten. Austretenden Bratensaft in eine kleine Schüssel abgießen und zur Seite stellen. Nach etwa 5 Minuten fügt man nun die Zwiebelwürfel, den Knoblauch sowie die Pilze hinzu und brät auch diese kurz an."},{s:2,n:"Fleisch anbraten, Bratensaft auffangen und Gemüse garen",d:"Eine Topf mit Butterschmalz erhitzen und das Fleisch darin rundherum anbraten. Austretenden Bratensaft in eine kleine Schüssel abgießen und zur Seite stellen. Nach etwa 5 Minuten fügt man nun die Zwiebelwürfel, den Knoblauch sowie die Pilze hinzu und brät auch diese kurz an."},{s:3,n:"Bratensoße zubereiten",d:"Einen Wasserkocher mit etwa 500 ml Wasser ansetzen. Jetzt gibt man einen EL Tomatenmark und einen TL edelsüsses Paprikapulver hinzu. Einrühren, anrösten, mit 0,1 l Rotwein ablöschen und einkochen. Nun wird der Bratenfond und der aufgefangene Bratensaft in den Topf gegeben. Wer gerade keinen Bratenfond zur Verfügung hat, kann auch etwa 400 ml Brühe anrühren und in den Topf geben. Ab und zu etwas Wasser in den Topf geben und einkochen lassen. Mit Thymian, Salz und Pfeffer würzen. Bei reduzierter Hitze etwa 1 Stunde köcheln lassen."},{s:3,n:"Bratensoße zubereiten",d:"Einen Wasserkocher mit etwa 500 ml Wasser ansetzen. Jetzt gibt man einen EL Tomatenmark und einen TL edelsüsses Paprikapulver hinzu. Einrühren, anrösten, mit 0,1 l Rotwein ablöschen und einkochen. Nun wird der Bratenfond und der aufgefangene Bratensaft in den Topf gegeben. Wer gerade keinen Bratenfond zur Verfügung hat, kann auch etwa 400 ml Brühe anrühren und in den Topf geben. Ab und zu etwas Wasser in den Topf geben und einkochen lassen. Mit Thymian, Salz und Pfeffer würzen. Bei reduzierter Hitze etwa 1 Stunde köcheln lassen."},{s:4,n:"Kartoffelpüree zubereiten",d:"Zubereitung des Kartoffelpürees: Die Kartoffeln schälen und in grobe Würfel schneiden. Eine halbe Sellerieknolle schälen und ebenso in grobe Würfel schneiden. Einen Topf mit Wasser aufsetzen und das Gemüse hineingeben. Das ganze darf dann etwa 20-30 Minuten köcheln. Danach das Kartoffelwasser abgießen und in einer Schüssel auffangen. Das Kartoffelwasser kann man dezent dem Hirschgulasch beimengen und einköcheln lassen. In den Topf mit dem Gemüse gibt man nun etwas Milch, 2 EL Butter und eine Prise Salz. Mit einem Handmixer pürieren oder mit einem Kartoffelstampfer zerdrücken."},{s:4,n:"Kartoffelpüree zubereiten",d:"Zubereitung des Kartoffelpürees: Die Kartoffeln schälen und in grobe Würfel schneiden. Eine halbe Sellerieknolle schälen und ebenso in grobe Würfel schneiden. Einen Topf mit Wasser aufsetzen und das Gemüse hineingeben. Das ganze darf dann etwa 20-30 Minuten köcheln. Danach das Kartoffelwasser abgießen und in einer Schüssel auffangen. Das Kartoffelwasser kann man dezent dem Hirschgulasch beimengen und einköcheln lassen. In den Topf mit dem Gemüse gibt man nun etwas Milch, 2 EL Butter und eine Prise Salz. Mit einem Handmixer pürieren oder mit einem Kartoffelstampfer zerdrücken."},{s:5,n:"Gulasch abschmecken und servieren",d:"Der Gulasch dürfte nun fertig sein. Gegebenenfalls nochmal mit Salz und Pfeffer abschmecken. Sollte dieser aufgrund des Tomatenmarks noch etwas säuerlich schmecken, so wird noch ein wenig Zucker eingerührt. Fertig ist ein schmackhafter Hirschgulasch. Guten Appetit."},{s:5,n:"Gulasch abschmecken und servieren",d:"Der Gulasch dürfte nun fertig sein. Gegebenenfalls nochmal mit Salz und Pfeffer abschmecken. Sollte dieser aufgrund des Tomatenmarks noch etwas säuerlich schmecken, so wird noch ein wenig Zucker eingerührt. Fertig ist ein schmackhafter Hirschgulasch. Guten Appetit."}],p:"00:15",c:"1:15",tot:100,srv:"4",cats:["Fleisch"]},{id:2467,t:"Linseneintopf Mit Gemuse",i:[{n:"festkochende Kartoffeln",u:"g",a:"400"},{n:"Sellerieknolle",u:"Stk",a:"0.5"},{n:"Selleriestangen",u:"Stk",a:"4"},{n:"große Möhren",u:"Stk",a:"4"},{n:"Linsen (kochfertig)",u:"g",a:"400"},{n:"Brühe",u:"l",a:"2"},{n:"Fenchelsamen",u:"TL",a:"3"},{n:"Kümmel",u:"TL",a:"1"},{n:"Lorbeerblätter",u:"Stk",a:"3"},{n:"Kartoffelmehl",u:"TL",a:"1"},{n:"Butterschmalz",u:"",a:""},{n:"Wiener oder Knacker",u:"",a:""},{n:"8 Kräuter (Tiefkühlabteilung)",u:"Pck",a:"0.5"},{n:"Essig/Zucker",u:"",a:""}],st:[{s:1,n:"Gemüse putzen und Brühe ansetzen",d:"Die Kartoffeln sowie eine halbe Sellerieknolle schälen und in Würfel schneiden. Die Möhren ebenso schälen, längs halbieren und in grobe Stücke schneiden. 4 Selleriestangen jeweils die Enden abschneiden, abwaschen, längs halbieren und kleinschneiden. Einen Wasserkocher mit 1,5-2 L Wasser erhitzen und eine Brühe ansetzen. Ein Tee-Ei mit 3 TL Fenchelsamen, 1 TL Kümmel und 3 Lorbeerblättern füllen und verschließen."},{s:2,n:"Butter zerlassen, Gemüse anbraten und Brühe einreduzieren lassen",d:"Einen Topf mit Butterschmalz erhitzen und den Sellerie sowie die Möhren darin etwa 5 Minuten anbraten. Danach die Brühe hinzugießen, aufkochen lassen, Hitze reduzieren und das Tee-Ei mit den Gewürzen hineingeben. Nach etwa 10 Minuten fügt man nun die Kartoffeln sowie die Linsen hinzu. Bei reduzierter Hitze etwa 30 Minuten köcheln lassen. Evtl. muß noch einmal etwas Wasser hinzugegeben werden."},{s:3,n:"Eintopf kräftig abschmecken",d:"Zum Schluss den Eintopf mit Salz, Pfeffer und den Kräutern kräftig abschmecken."},{s:4,n:"Tipp",d:"Sollte der Eintopf in der Konsistenz noch etwas dünn sein, dann wird in einer Schüssel 1 TL Kartoffelmehl in etwas Wasser glattgerührt und in den Topf gegeben. Dazu dürfen Wiener oder Knacker gereicht werden. Fertig. Für die kalte Jahreszeit ideal geeignet. Ein kleiner Tipp zum Schluss. Der Linseneintopf darf auf dem Teller noch individuell mit etwas Essig und Zucker verfeinert werden. Schmeckt lecker. Guten Appetit"}],p:"00:20",c:"00:40",tot:65,srv:"10",cats:["Suppen & Eintöpfe"]},{id:2496,t:"Gemusepfanne Mit Rindfleisch Aus Dem Wok",i:[{n:"Rindfleisch",u:"g",a:"300"},{n:"Paprika (gelb, grün)",u:"Stk",a:"2"},{n:"frische Champignons",u:"Stk",a:"5"},{n:"Fenchelknolle",u:"Stk",a:"0.5"},{n:"Ingwer",u:"cm",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"1"},{n:"Petersilie und Koriander",u:"",a:""},{n:"Sesamöl",u:"EL",a:"3"},{n:"dunkle Sojasoße",u:"EL",a:"1"},{n:"Worchestersauce",u:"EL",a:"1"},{n:"Fischsauce",u:"EL",a:"0.5"},{n:"Kartoffelmehl",u:"TL",a:"0.5"},{n:"von einer frischen Chilischote",u:"cm",a:"1"},{n:"Wasser",u:"ml",a:"200"}],st:[{s:1,n:"Fleisch, Gemüse kleinschneiden und würzen",d:"Das Rindfleisch mit kaltem Wasser abwaschen, trockentupfen und in kleine mundgerechte Stücke oder schmale Streifen schneiden. Etwa 3 cm von einer Ingwerwurzel sowie 2 Knoblauchzehen schälen und mit etwas frischem Chili kleinhacken. Dies zusammen mit einem EL Sesamöl, 1 EL Worchestersauce und einer Prise Salz in einem Mörser zerstoßen. Die breiige Masse wird nun zu dem Rindfleisch in eine Schüssel gegeben, gut miteinander vermengt und für etwa 20 Minuten abgedeckt in den Kühlschrank gestellt.."},{s:2,n:"restliches Gemüse putzen und Wasser kochen",d:"Währenddessen wird eine gelbe und grüne Paprikaschote entkernt, abgewaschen und in grobe Stücke geschnitten. Die frischen Champignons vom Sand befreien, halbieren und in Scheiben schneiden. Eine halbe Fenchelknolle in kleine Würfel schneiden. Zum Schluss ein paar Blätter glatte Petersilie und Koriander fein hacken. Den Wasserkocher mit etwa 300 ml Wasser erhitzen. Vom marinierten Rindfleisch wird überflüssiger Ingwer und Knoblauch entfernt."},{s:3,n:"Fleisch und Gemüse anbraten",d:"In einem Wok wird nun etwa 3 EL Sesamöl erhitzt und das Fleisch etwa 4 Minuten scharf angebraten. Danach gibt man das Gemüse hinzu und brät auch dieses unter gelegentlichem Rühren an.');"},{s:4,n:"Soße zubereiten und servieren",d:"Das heiße Wasser aus dem Wasserkocher gibt man nun in eine Schüssel und fügt noch einen EL Sojasoße, 1/2 EL Fischsauce sowie einen halben TL Kartoffelmehl hinzu. Gut verrühren und in den Wok geben, kurz aufkochen lassen und die kleingehackten Kräuter unterheben. Letztendlich heiß servieren. Dazu gab es bei uns ganz klassisch Reis. Guten Appetit"}],p:"00:20",c:"00:10",tot:35,srv:"3",cats:["Fleisch","Asiatisch"]},{id:2499,t:"Chinakohlrouladen In Tomatensose",i:[{n:"Hackfleisch",u:"g",a:"200"},{n:"Reis",u:"Tasse",a:"1"},{n:"Chinakohl (10-12 Blätter)",u:"Stk",a:"1"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"stückige Tomaten",u:"g",a:"500"},{n:"Brühe",u:"ml",a:"250"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Öl",u:"EL",a:"3"},{n:"Oregano",u:"TL",a:"1"},{n:"edelsüßer Paprika",u:"TL",a:"1"},{n:"geriebener Goudakäse",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Töpfe mit Wasser aufsetzen",d:"Einen Topf mit Reis aufsetzen und etwa 15-20 Minuten quellen lassen. Einen weiteren großen Topf mit Brühe zum kochen bringen."},{s:2,n:"Chinakohl putzen und Blätter blanchieren",d:"Vom Chinakohl wird etwa ein halber Zentimeter vom Strunk abgeschnitten. Dadurch lassen sich die Blätter leichter lösen. Nun entnimmt man vorsichtig 10-12 einzelne Blätter auseinander. Dabei dürfen diese nicht zerreißen. Die Blätter werden nun in das kochende Wasser gegeben und für etwa 1-2 Minuten blanchiert. Vorsichtig mit einer Siebkelle herausnehmen und auf Küchenpapier abtropfen und abkühlen lassen."},{s:2,n:"Chinakohl putzen und Blätter blanchieren",d:"Vom Chinakohl wird etwa ein halber Zentimeter vom Strunk abgeschnitten. Dadurch lassen sich die Blätter leichter lösen. Nun entnimmt man vorsichtig 10-12 einzelne Blätter auseinander. Dabei dürfen diese nicht zerreißen. Die Blätter werden nun in das kochende Wasser gegeben und für etwa 1-2 Minuten blanchiert. Vorsichtig mit einer Siebkelle herausnehmen und auf Küchenpapier abtropfen und abkühlen lassen."},{s:3,n:"Gemüse kleinschneiden und Hackfleisch anbraten",d:"Eine mittelgroße Zwiebel sowie 2 Knoblauchzehen schälen und sehr fein schneiden. Einen EL Öl in einer Pfanne erhitzen, das Hackfleisch hineinbröseln, anbraten und die Hälfte der Zwiebeln und des Knoblauchs hinzufügen und untermengen. Mit Salz und Pfeffer würzen. Danach den Reis unterheben und mit dem Hack vermengen."},{s:3,n:"Gemüse kleinschneiden und Hackfleisch anbraten",d:"Eine mittelgroße Zwiebel sowie 2 Knoblauchzehen schälen und sehr fein schneiden. Einen EL Öl in einer Pfanne erhitzen, das Hackfleisch hineinbröseln, anbraten und die Hälfte der Zwiebeln und des Knoblauchs hinzufügen und untermengen. Mit Salz und Pfeffer würzen. Danach den Reis unterheben und mit dem Hack vermengen."},{s:4,n:"Rouladen wickeln und Ofen vorheizen",d:"Die Chinakohlblätter auf einer Arbeitsfläche vorsichtig ausbreiten und etwa 1,5-2 EL von dem Reis-Hackfleisch Gemisch in die Mitte der Blätter geben. Die Kanten umklappen und vorsichtig von der Blattspitze beginnend aufrollen. Mit einem Holz- oder Rouladenspieß fixieren. Den Ofen auf 175 Grad vorheizen."},{s:4,n:"Rouladen wickeln und Ofen vorheizen",d:"Die Chinakohlblätter auf einer Arbeitsfläche vorsichtig ausbreiten und etwa 1,5-2 EL von dem Reis-Hackfleisch Gemisch in die Mitte der Blätter geben. Die Kanten umklappen und vorsichtig von der Blattspitze beginnend aufrollen. Mit einem Holz- oder Rouladenspieß fixieren. Den Ofen auf 175 Grad vorheizen."},{s:5,n:"Tomatensoße zubereiten",d:"Die Kirschtomaten waschen, den Strunk entfernen und halbieren. In einer Pfanne die zweite Hälfte der Zwiebeln und des Knoblauchs und nach 2 Minuten die Tomaten kurz anschwitzen. Mit stückigen Tomaten und einer Tasse heißem Wasser ablöschen und einkochen. Mit Salz, Pfeffer, Oregano, Paprika und etwas Zucker würzen und abschmecken."},{s:5,n:"Tomatensoße zubereiten",d:"Die Kirschtomaten waschen, den Strunk entfernen und halbieren. In einer Pfanne die zweite Hälfte der Zwiebeln und des Knoblauchs und nach 2 Minuten die Tomaten kurz anschwitzen. Mit stückigen Tomaten und einer Tasse heißem Wasser ablöschen und einkochen. Mit Salz, Pfeffer, Oregano, Paprika und etwas Zucker würzen und abschmecken."},{s:6,n:"Chinakohlrouladen im Ofen backen",d:"In die Auflaufform gibt man nun die heiße Tomatensoße und legt die Chinakohlrouladen hinein. Mit dem Goudakäse bestreuen und für etwa 20 Minuten in den Ofen geben. Danach darf sofort serviert werden."},{s:6,n:"Chinakohlrouladen im Ofen backen",d:"In die Auflaufform gibt man nun die heiße Tomatensoße und legt die Chinakohlrouladen hinein. Mit dem Goudakäse bestreuen und für etwa 20 Minuten in den Ofen geben. Danach darf sofort serviert werden."}],p:"00:25",c:"00:35",tot:75,srv:"4",cats:["Fleisch","Vegetarisch","Asiatisch"]},{id:2507,t:"Rollbraten Mit Schinken Und Ricotta Fullung 2",i:[{n:"Schweinefleisch",u:"kg",a:"1.3"},{n:"Champignons",u:"g",a:"200"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Ricotta-Käse",u:"Pck",a:"3"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Möhren",u:"Stk",a:"2"},{n:"Parmaschinken",u:"Pck",a:"1"},{n:"Salbeiblätter",u:"",a:""},{n:"Kartoffelmehl",u:"",a:""},{n:"Brühe",u:"ml",a:"300"},{n:"Eigelb",u:"Stk",a:"2"},{n:"Muskatpulver",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fleisch vorbereiten, Gemüse putzen und dünsten",d:"Das Schweinefleisch am besten schon beim Fleischer zu einem Rollbraten zurechtschneiden lassen. Vor dem Zubereiten das Schweinefleisch mit kaltem Wasser abbrausen, mit einem Küchentuch trockentupfen und auf der Arbeitsfläche ausbreiten. Die Champignons putzen und die Hälfte davon kleinhacken. Die Knoblauchzehen schälen und ebenso kleinschneiden. Eine Pfanne mit Öl erhitzen und den Knoblauch darin andünsten. Nach 2 Minuten die klein gehackten Pilze hinzugeben und anbraten. Danach die Pfanne vom Herd nehmen."},{s:2,n:"Ricotta-Creme zubereiten und Ofen vorheizen",d:"In einer Schüssel den Ricotta-Käse, 2 Eigelb, Salz, Pfeffer und geriebenen Muskat einrühren. Die angebratenen Champignons hinzugeben und unterheben. Den Ofen auf 200 Grad vorheizen."},{s:3,n:"Fleisch füllen",d:"Das Fleisch wird nun mit Salbeiblättern und Parmaschinken belegt. Darauf die Pilz-Ricotta-Masse streichen und einen breiten Rand freilassen. Durch das Aufrollen, würde sonst die Füllung wieder rausgedrückt werden. Nun das Fleisch aufrollen und mit Küchengarn zusammenbinden."},{s:4,n:"restliches Gemüse putzen, Fleisch anbraten und Brühe ansetzen",d:"Die Möhren, die restlichen Pilze und die Zwiebel putzen und grob schneiden. In einem Bräter 3 EL Öl erhitzen und das Fleisch rundherum scharf anbraten, herausnehmen, salzen und pfeffern. Den Wasserkocher erhitzen und etwa 300-400 ml Brühe vorbereiten."},{s:5,n:"Gemüse, Fleisch schmoren und Soße zubereiten",d:"Das grob geschnittene Gemüse in den Bräter geben und ebenso im Bratenfett scharf anbraten. Mit Weißwein ablöschen, einkochen, die Brühe hinzugeben, kurz aufkochen lassen und das Fleisch hineingeben. Das Ganze kommt nun für etwa 60 Minuten in den vorgeheizten Ofen. Etwa 10 Minuten vor dem Ende können das Beilagengemüse und die Kartoffeln angesetzt werden. Den Bräter aus dem Ofen nehmen, das Fleisch auf einem Teller im Ofen bei etwa 75 Grad warm halten. Währenddessen den Fonds aus dem Bräter nochmals auf und ein wenig einkochen lassen. Nach etwa 8 Minuten wird alles durch ein Sieb passiert und die verbliebene Flüssigkeit mit einem Löffel vorsichtig aus dem Gemüse gedrückt. Hier versteckt sich der Geschmack der Soße. ;-) Nun wird die Soße in einen kleinen Topf geben. Aufkochen, mit Salz und Pfeffer abschmecken. In einer kleinen Schüssel wird ein TL Kartoffelmehl und kaltes Wasser glattgerührt und zur Bratensoße gegeben. Fertig."},{s:6,n:"Servieren",d:"Das Fleisch in schmale Scheiben schneiden und zusammen mit dem Gemüse und der Soße nett auf einem Teller anrichten. Guten Appetit."}],p:"00:35",c:"1:00",tot:115,srv:"7",cats:["Fleisch"]},{id:2512,t:"Blumenkohl Mit Brauner Butter",i:[{n:"Blumenkohl",u:"Stk",a:"1"},{n:"Butter",u:"EL",a:"5"},{n:"Semmelbrösel",u:"EL",a:"4"},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Blumenkohl vorbereiten",d:"Die äußeren Blätter entfernen. Braune Stellen ausschneiden und ca. 1 cm vom Strunkende abschneiden. Die Röschen am Stielansatz abschneiden. Ggfs. den dicken Strunk schälen und in ca. 1 cm dünne Scheiben schneiden. Gründlich mit kaltem Wasser abwaschen. Große Röschen evtl. halbieren"},{s:2,n:"Blumenkohl kochen",d:"Einen großen Topf mit Salzwasser aufkochen lassen. Die Röschen hinzugeben und ca. 10 Minuten bei geschlossenem Deckel kochen lassen. Evtl. eine Kostprobe nehmen. Der Kohl sollte bissfest sein."},{s:3,n:"Braune Butter mit Semmelbrösel zubereiten",d:"Etwa 4 Minuten vor dem Ende der Garzeit des Blumenkohls, einen kleinen Topf mit 5 EL Butter erhitzen. Kurz aufschäumen lassen und danach die Semmelbrösel sowie etwas Salz hinzugeben. Die Brösel goldbraun anbraten."},{s:4,n:"Servieren",d:"Den Blumenkohl mit einer Siebkelle herausnehmen. Auf die Teller oder in eine Schüssel servieren. Die heiße braune Butter gleichmäßig mit einem Löffel oder direkt aus dem Topf gleichmäßig verteilen."}],p:"00:3",c:"00:10",tot:20,srv:"2",cats:["Vegetarisch"]},{id:2516,t:"Kartoffelgratin Mit Schweinefilet",i:[{n:"festkochende Kartoffeln",u:"g",a:"500"},{n:"Schweinefilet",u:"g",a:"500"},{n:"Schinkenwürfel",u:"g",a:"100"},{n:"geriebener Käse",u:"Pck",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"stückige Tomaten",u:"g",a:"500"},{n:"Brühe",u:"ml",a:"200"},{n:"Sahne",u:"ml",a:"100"},{n:"Rosmarin",u:"Zweige",a:"2"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen",d:"Einen großen Topf mit Wasser aufsetzen. Ein paar mittelgroße festkochende Kartoffeln abwaschen und später in das kochende Wasser geben. Ca. 20 Minuten garen, dann abkühlen lassen und später die Haut abpellen und in dünne Scheiben schneiden."},{s:2,n:"Fleisch filetieren und anbraten",d:"Das Schweinefilet mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen, Sehnen und Fett vorsichtig entfernen und in ca. 1 cm dicke Scheiben schneiden. Eine Pfanne mit 2 EL Öl erhitzen und die Filetscheiben rundherum etwa 5 Minuten scharf anbraten. Nicht zu lange braten, da das Fleisch nicht austrocknen soll. Des weiteren gart es später im Ofen noch etwa 20 Minuten nach. Das Fleisch aus der Pfanne nehmen, mit Salz und Pfeffer würzen und zur Seite stellen."},{s:2,n:"Fleisch filetieren und anbraten",d:"Das Schweinefilet mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen, Sehnen und Fett vorsichtig entfernen und in ca. 1 cm dicke Scheiben schneiden. Eine Pfanne mit 2 EL Öl erhitzen und die Filetscheiben rundherum etwa 5 Minuten scharf anbraten. Nicht zu lange braten, da das Fleisch nicht austrocknen soll. Des weiteren gart es später im Ofen noch etwa 20 Minuten nach. Das Fleisch aus der Pfanne nehmen, mit Salz und Pfeffer würzen und zur Seite stellen."},{s:3,n:"Brühe ansetzen",d:"Während die Kartoffeln kochen und das Fleisch bruzzelt, 200 ml Wasser in einem Wasserkocher erhitzen und eine Brühe vorbereiten. Eine mittelgroße Zwiebel schälen und würfeln."},{s:3,n:"Brühe ansetzen",d:"Während die Kartoffeln kochen und das Fleisch bruzzelt, 200 ml Wasser in einem Wasserkocher erhitzen und eine Brühe vorbereiten. Eine mittelgroße Zwiebel schälen und würfeln."},{s:4,n:"Soße zubereiten und Ofen vorheizen",d:"Nachdem das Fleisch zur Seite gestellt wurde, werden in der gleichen Pfanne die Schinkenwürfel langsam ausgelassen. Etwa 1/3 von den krossgebratenen Würfeln herausnehmen und ebenso zur Seite stellen. Nun werden die Zwiebelwürfel glasig angebraten, mit Tomatenmark und Kräutern verfeinert um 2 Minuten später mit Brühe, stückigen Tomaten und Sahne abgelöscht zu werden. Mit Salz, Pfeffer und Paprika würzen und abschmecken. Der Ofen darf nun auf 200 Grad vorgeheizt werden."},{s:4,n:"Soße zubereiten und Ofen vorheizen",d:"Nachdem das Fleisch zur Seite gestellt wurde, werden in der gleichen Pfanne die Schinkenwürfel langsam ausgelassen. Etwa 1/3 von den krossgebratenen Würfeln herausnehmen und ebenso zur Seite stellen. Nun werden die Zwiebelwürfel glasig angebraten, mit Tomatenmark und Kräutern verfeinert um 2 Minuten später mit Brühe, stückigen Tomaten und Sahne abgelöscht zu werden. Mit Salz, Pfeffer und Paprika würzen und abschmecken. Der Ofen darf nun auf 200 Grad vorgeheizt werden."},{s:5,n:"Auflauf schichten und ab in den Ofen",d:"Eine Auflaufform einfetten, den Boden mit 1/3 der in Scheiben geschnittenen Kartoffeln belegen. Den Rest rundherum am Rand verteilen. In die nun entstandene Mitte legt man die angebratenen Schweinefiletscheiben. Vorsichtig die Soße über alles verteilen. Den geriebenen Käse darüber streuen. Mit abgewaschenen und Nadeln vom Rosmarin und den restlichen Schinkenwürfeln bestreuen. Alles zusammen kommt nun für etwa 25 Minuten in den vorgeheizten Ofen. Danach darf sofort serviert werden. Guten Appetit"},{s:5,n:"Auflauf schichten und ab in den Ofen",d:"Eine Auflaufform einfetten, den Boden mit 1/3 der in Scheiben geschnittenen Kartoffeln belegen. Den Rest rundherum am Rand verteilen. In die nun entstandene Mitte legt man die angebratenen Schweinefiletscheiben. Vorsichtig die Soße über alles verteilen. Den geriebenen Käse darüber streuen. Mit abgewaschenen und Nadeln vom Rosmarin und den restlichen Schinkenwürfeln bestreuen. Alles zusammen kommt nun für etwa 25 Minuten in den vorgeheizten Ofen. Danach darf sofort serviert werden. Guten Appetit"}],p:"00:30",c:"00:25",tot:60,srv:"8",cats:["Fleisch","Vegetarisch"]},{id:2527,t:"Spaghetti Mit Klosschensauce",i:[{n:"Rinderhackfleisch",u:"g",a:"300"},{n:"Zwiebeln",u:"Stk",a:"2"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Tomatenwürfel (500 g)",u:"Dose",a:"1"},{n:"Paniermehl",u:"EL",a:"2"},{n:"Senf",u:"TL",a:"1"},{n:"Ei",u:"Stk",a:"1"},{n:"Erbsen",u:"g",a:"100"},{n:"Blätter Salbei",u:"Stk",a:"8"},{n:"Spaghetti",u:"g",a:"500"},{n:"Olivenöl",u:"EL",a:"1"},{n:"Schafskäse",u:"g",a:"100"},{n:"edelsüsses Paprikapulver",u:"TL",a:"1"}],st:[{s:1,n:"Gemüse vorbereiten und in Pfanne kurz garen",d:"Den Knoblauch und Zwiebeln schälen und in feine Würfel schneiden. Eine Pfanne mit Öl erhitzen und das Gemüse unter Rühren darin kurz anschwitzen. Die Dose mit den Tomatenwürfeln und der Flüssigkeit dazugeben und mit Salz, Pfeffer und Paprikapulver kräftig abschmecken. Die Sauce darf nun bei milder Hitze etwa 10"},{s:2,n:"Rinderhack zu Klößchen formen",d:"Währenddessen das Rinderhack mit Paniermehl, einem Ei, einem Tl Senf, Salz und Pfeffer verkneten, abschmecken und kleine Klößchen formen. Die fertigen Klößchen gibt man nun zu der Sauce und läßt diese ca. 10 Minuten garziehen."},{s:3,n:"Nudeln kochen und Erbsen garen",d:"In der Zwischenzeit die Spaghetti in kochendem Salzwasser bissfest garen. Die Erbsen werden ca. 5 Minuten vor dem Ende der Garzeit zu den Klößchen gegeben."},{s:4,n:"mit Salbei und Schafskäse garnieren",d:"Den Salbei waschen, trocken schütteln und fein hacken. Den Schafskäse in kleine Würfel schneiden. Beides darf zum Schluß über das Gericht gestreut werden."}],p:"00:20",c:"00:25",tot:50,srv:"4",cats:["Pasta & Nudeln"]},{id:2535,t:"Suppentopf",i:[{n:"Suppenfleisch vom Rind",u:"g",a:"500"},{n:"Wasser",u:"l",a:"1"},{n:"Tiefkühlgemüse",u:"g",a:"500"},{n:"Pfefferkörner",u:"Stk",a:"6"},{n:"kleine Zwiebeln",u:"Stk",a:"2"},{n:"Lorbeerblat",u:"Stk",a:"1"},{n:"Wacholderbeeren",u:"Stk",a:"4"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Creme Fraiche",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Rinderbrühe ansetzen",d:"Das Wasser in einen großen Topf gießen. Die Pfefferkörner, die geschälten und halbierten Zwiebeln, das Lorbeerblatt und die Wacholderbeeren zugeben und zum kochen bringen. Das Suppenfleisch abspülen. Das Wasser leicht salzen, das Suppenfleisch hineinlegen und zugedeckt bei reduzierter Hitze etwa 1,5 Stunden köcheln lassen."},{s:2,n:"Kartoffeln und Gemüse vorbereiten",d:"Während dessen die Kartoffeln schälen, waschen und in Würfel schneiden. Das gefrorene Gemüse aus der Verpackung nehmen und in einer Schüssel zur Seite stellen."},{s:3,n:"Fleisch schneiden und restliche Zutaten in der Brühe kochen",d:"Nach 90 Minuten das Fleisch herausnehmen und in mundgerechte Würfel schneiden. Je nach Belieben das Fett entfernen. Zusammen mit den Kartoffelwürfeln wieder in die Brühe geben und weitere 10-15 Minuten garen. Das Gemüse dazugeben. Sobald die Suppe kocht, noch etwa 5 Minuten garen, sodaß das Gemüse den Biss behalten"},{s:4,n:"Suppe verfeinern",d:"In einer kleinen Schüssel Creme Fraiche und Tomatenmark mit ein wenig Wasser glattrühren und zusammen mit Salz und Pfeffer in den Topf geben und abschmecken. Es darf serviert werden."}],p:"00:5",c:"1:50",tot:120,srv:"4",cats:["Suppen & Eintöpfe"]},{id:2539,t:"Farfalle Mit Frischen Tomaten",i:[{n:"kleine Tomaten",u:"g",a:"380"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"frischer Basilikum",u:"gr. Blätter",a:"8"},{n:"Olivenöl",u:"EL",a:"5"},{n:"dunkler Balsamico Essig",u:"EL",a:"3"},{n:"Mozzarellakäse",u:"g",a:"125"},{n:"Pinienkerne",u:"g",a:"50"},{n:"kleine Farfalle Nudeln",u:"g",a:"250"},{n:"Parmaschinken",u:"Pck.",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Tomaten, Knoblauch und Basilikum vorbereiten und vermengen",d:"Die Tomaten abwaschen, vierteln und die Kerne entfernen. Den Rest kleinschneiden. Den Knoblauch schälen und sehr feinhacken. 10 große Basilikumblätter abwaschen, trockenschütteln und in Streifen schneiden. In eine Schüssel gibt man nun die Tomaten, den Knoblauch, Basilikum, Öl, Balsamico und wer mag, Chiliflocken. Gut miteinander vermengen und 15 Minuten ziehen lassen."},{s:2,n:"Pinienkerne rösten und Mozzarella würfeln",d:"Die Pinienkerne in einer Pfanne unter permanenten Rühren braun anbraten. Hier sehr behutsam vorgehen, da diese schnell anbrennen und somit schwarz werden können. Den Mozzarellakäse in kleine Würfel schneiden und nach 15 Minuten unter die Sauce heben. Weitere 10 Minuten ziehen lassen."},{s:2,n:"Pinienkerne rösten und Mozzarella würfeln",d:"Die Pinienkerne in einer Pfanne unter permanenten Rühren braun anbraten. Hier sehr behutsam vorgehen, da diese schnell anbrennen und somit schwarz werden können. Den Mozzarellakäse in kleine Würfel schneiden und nach 15 Minuten unter die Sauce heben. Weitere 10 Minuten ziehen lassen."},{s:3,n:"Nudeln kochen",d:"Einen Topf mit Salzwasser ansetzen und die Farfalle Nudeln bissfest kochen. Sobald die Nudeln fertig gekocht sind, zusammen mit den angebratenen Pininenkernen sowei den klein geschnittenen Parmaschinken unter die Sauce heben und gut vermischen. Mit Salz und Pfeffer würzen und lauwarm servieren."},{s:3,n:"Nudeln kochen",d:"Einen Topf mit Salzwasser ansetzen und die Farfalle Nudeln bissfest kochen. Sobald die Nudeln fertig gekocht sind, zusammen mit den angebratenen Pininenkernen sowei den klein geschnittenen Parmaschinken unter die Sauce heben und gut vermischen. Mit Salz und Pfeffer würzen und lauwarm servieren."}],p:"00:15",c:"00:25",tot:45,srv:"4",cats:["Pasta & Nudeln"]},{id:2547,t:"Schweineschnitzel In Rosmarin Panade",i:[{n:"Schweineschnitzel",u:"Scheiben",a:"4"},{n:"Zitronen",u:"Stk",a:"2"},{n:"Mehl",u:"g",a:"300"},{n:"Eier",u:"Stk",a:"2"},{n:"Semmelbrösel",u:"g",a:"300"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Rosmarin",u:"EL",a:"1"},{n:"Öl zum braten",u:"ml",a:"100"},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Fleisch vorbereiten",d:"Die Schweineschnitzel läßt man sich schon beim Fleischer in 8 mm dünne Scheiben schneiden. Diese werden dann mit kaltem Wasser abgewaschen, trockengetupft und falls diese doch zu dick sein sollten mit einem Fleischhammer flachgeklopft."},{s:2,n:"Marinade zubereiten und Schnitzel marinieren",d:"Eine halbe Zitrone auspressen und den Saft auf den Schnitzelscheiben verteilen. Nun werden 3 Teller vorbereitet und jeweils mit Mehl, 2 Eiern sowie Semmelbröseln befüllt. In den Teller mit den Semmelbröseln mischt man nun 1 EL Majoran, 1 EL Rosmarin sowie einen TL Salz drunter. Nun werden die vorbereiteten Schnitzelscheiben nacheinander im Mehl, im Ei und letztendlich in den Semmelbröseln gewälzt. Überschüssiges Mehl wird kurz abgeklopft. Die Semmelbrösel leicht angedrückt. So kann die Panade leichte luftige Blasen bilden."},{s:3,n:"Schnitzel braten",d:"Eine Pfanne mit ausreichend Öl heißwerden lassen. Die Schnitzel werden jetzt nacheinander für etwa 2 Minuten im Ölbad gebruzzelt. Dabei einmal wenden und die Oberseite immer mal wieder mit dem heißen Öl übergießen."},{s:4,n:"Tipp",d:"Sollte eine große Menge an Schnitzel zubereitet werden, so erwärmt man den Ofen auf etwa 80 Grad, legt Küchenpapier auf das Rost und die fertig gebratenen Scheiben zum warmhalten darauf. Das überschüssige Öl kann auf dem Küchenpapier wunderbar abtropfen und die Panade bleibt dabei schön kross."}],p:"00:20",c:"00:10",tot:30,srv:"4",cats:["Fleisch"]},{id:2561,t:"Ddr Tomatensose",i:[{n:"Nudeln",u:"g",a:"500"},{n:"Jagdwurst",u:"g",a:"300"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"passierte Tomaten",u:"g",a:"400"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Mehl",u:"EL",a:"2"},{n:"Butter",u:"EL",a:"4"},{n:"edelsüsses Paprikapulver",u:"TL",a:"1"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Essig",u:"EL",a:"1"},{n:"Zucker nach Bedarf",u:"",a:""},{n:"heißes Wasser",u:"ml",a:"100"}],st:[{s:1,n:"Jagdwurst, Zwiebeln und Knoblauch zuschneiden und anbraten",d:"Die Jagdwurst, die Zwiebeln und die Knoblauchzehe in kleine Würfel schneiden. Einen Topf mit 2 EL Öl erhitzen und zuerst die Jagdwurstwürfel anbraten, herausnehmen und im gleichen Bratenfett die Zwiebeln andünsten. Alles in eine Schüssel geben und zur Seite stellen."},{s:2,n:"Nudeln kochen und Tomatensoße vorbereiten",d:"Nun können die Nudeln aufgesetzt und bissfest gekocht werden. In einer großen Tasse rüht man 2 EL Tomatenmark, 200 ml Wasser, 1 TL Salz und Pfeffer an."},{s:2,n:"Nudeln kochen und Tomatensoße vorbereiten",d:"Nun können die Nudeln aufgesetzt und bissfest gekocht werden. In einer großen Tasse rüht man 2 EL Tomatenmark, 200 ml Wasser, 1 TL Salz und Pfeffer an."},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/dilBD8RBHJg\\ width=\\480\\ height=\\360\\]"},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/dilBD8RBHJg\\ width=\\480\\ height=\\360\\]"},{s:4,n:"Mehlschwitze und Tomatensoße zubereiten",d:"n dem Topf, worin schon die Wurst angebraten wurde, bereitet man nun eine Mehlschwitze vor. Dafür werden 4 EL Butter verflüssigt und mit 2 EL Mehl bestreut. Mit einem Schneebesen gut miteinander vermengen, sodaß keine Klümpchen mehr vorhanden sind. Sobald dies geschehen ist, gießt man sowohl die passierten Tomaten als auch das vorbereitete Tomatenmark hinzu. Kurz aufkochen und evtl. noch mit heißem Wasser verdünnen. Jetzt gibt man die angebratene Jagdwurst und die Zwiebeln hinzu. Die Soße mit gerebelten Majoran, Paprikapulver,Salz, Pfeffer und Essig abschmecken. Aufkochen und noch etwa 10 Minuten köcheln lassen."},{s:4,n:"Mehlschwitze und Tomatensoße zubereiten",d:"n dem Topf, worin schon die Wurst angebraten wurde, bereitet man nun eine Mehlschwitze vor. Dafür werden 4 EL Butter verflüssigt und mit 2 EL Mehl bestreut. Mit einem Schneebesen gut miteinander vermengen, sodaß keine Klümpchen mehr vorhanden sind. Sobald dies geschehen ist, gießt man sowohl die passierten Tomaten als auch das vorbereitete Tomatenmark hinzu. Kurz aufkochen und evtl. noch mit heißem Wasser verdünnen. Jetzt gibt man die angebratene Jagdwurst und die Zwiebeln hinzu. Die Soße mit gerebelten Majoran, Paprikapulver,Salz, Pfeffer und Essig abschmecken. Aufkochen und noch etwa 10 Minuten köcheln lassen."},{s:5,n:"DDR Tomatensoße abschmecken",d:"Sollte die Soße noch etwas säuerlich schmecken, so fügt man einfach noch Zucker hinzu. Die Nudeln dürften nun auch al dente sein und können nun zusammen mit der Soße kredenzt werden. Ein Hauch von DDR-Kantinenessen holt man sich so in die eigenen 4 Wände. Nun noch die Wände in einem wunderschönen Mintgrün streichen, eine Kassette mit Kinderlärm einlegen und schon fühlt man sich 20 Jahre in der Zeit zurückversetzt. Ein Träumche, was die Soße angeht :-) [su_slider source=\\media: 5569,5568,5563,5566,5562,5564,5565,5567\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"},{s:5,n:"DDR Tomatensoße abschmecken",d:"Sollte die Soße noch etwas säuerlich schmecken, so fügt man einfach noch Zucker hinzu. Die Nudeln dürften nun auch al dente sein und können nun zusammen mit der Soße kredenzt werden. Ein Hauch von DDR-Kantinenessen holt man sich so in die eigenen 4 Wände. Nun noch die Wände in einem wunderschönen Mintgrün streichen, eine Kassette mit Kinderlärm einlegen und schon fühlt man sich 20 Jahre in der Zeit zurückversetzt. Ein Träumche, was die Soße angeht :-) [su_slider source=\\media: 5569,5568,5563,5566,5562,5564,5565,5567\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Vegetarisch"]},{id:2565,t:"Cevapcici Mit Kartoffel Sellerie Pureee",i:[{n:"Rinderhack",u:"kg",a:"1"},{n:"Silberzwiebeln (sauer eingelegt)",u:"Stk",a:"15"},{n:"Gewürzgurken",u:"Stk",a:"2"},{n:"rote Paprika",u:"Stk",a:"0.5"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Eier",u:"Stk",a:"2"},{n:"Semmelbrösel",u:"EL",a:"6"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"edelsüßes Paprikapulver",u:"EL",a:"1"},{n:"Salz",u:"TL",a:"2"},{n:"Pfeffer und Chiliflocken",u:"",a:""}],st:[{s:1,n:"Fleisch vorbereiten",d:"Das Rinderhack wird mit 2 Eiern, 6 EL Semmelbrösel in eine Schüssel gegeben. Wer eine entsprechend große Küchenmaschine hat, häckselt das Rinderhack sehr fein. Lammfleisch darf auch noch mit hinzu gefügt werden. Doch nicht jeder mag es, deswegen soll dieses Gericht einfach mit Rinderhack zubereitet werden."},{s:2,n:"Gemüse schneiden",d:"Nun schält man eine mittelgroße Möhre und schneidet diese wie auch eine halbe rote Paprika in kleine Würfel. Den Knoblauch schälen und ebenso kleinschneiden. 2 Gewürzgurken und die sauer eingelegten Silberzwiebeln ebenso kleinschneiden. Das Gemüse wird nun zusammen mit 1-2 TL Salz, Pfeffer, 1EL gerebelten Majoran, 1 EL edelsüßem Paprikapulver und ein paar Chiliflocken in einen Mixer gegeben und sehr fein gehäckselt. Die so entstandene Masse wird mit dem Rinderhack ca. 10 Minuten kräftig eingeknetet. Evtl. nochmals mit Salz und Pfeffer abschmecken. Zur Seite stellen und ca. 15 Minuten ziehen lassen"},{s:3,n:"Hackfleischröllchen formen und anbraten",d:"Danach kleine Hackfleischröllchen formen und rundherum zum braten in die Pfanne geben. Die Cevapcici dürfen auch in größeren Mengen vorbereitet werden, da diese auch roh eingefroren werden und als Vorrat für kochfaule Zeiten herhalten dürfen."},{s:4,n:"Tipp",d:"Dazu gab es bei uns Kartoffel-Sellerie Püree mit dezent gesalzener flüssiger Butter."}],p:"00:30",c:"00:15",tot:45,srv:"6",cats:["Fleisch"]},{id:2569,t:"Steinbeisserfilet Auf Mediterranem Gemuse",i:[{n:"Steinbeisserfilet",u:"g",a:"700"},{n:"mittelgroße Zucchini",u:"Stk",a:"2"},{n:"rote Paprika",u:"Stk",a:"1"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"gefrorene italienische Kräuter",u:"Pck",a:"1"},{n:"Zitronensaft",u:"",a:""},{n:"gerebelter Thymian",u:"TL",a:"1"},{n:"Chiliflocken",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Fisch portionieren und marinieren",d:"Das Fischfilet mit kaltem Wasser abspülen und trockentupfen. Nun 5 cm breite Portionen schneiden. Auf einen Teller legen, mit Zitronensaft und beträufeln und für ca. 15 Minuten in den Kühlschrank stellen."},{s:2,n:"Gemüse schneiden",d:"Während dessen die Zuchhini, Paprika und Tomaten abwaschen. Die Zucchini zunächst in Streifen und dann in Würfel schneiden. Die Paprika entkernen und ebenso in grobe Würfel schneiden. Die Kirschtomaten halbieren und den Strunk entfernen. Die Artischockenherzen, am besten von der Frischetheke, in einem Sieb abtropfen lassen und vierteln."},{s:3,n:"Gemüse und Fisch dünsten",d:"Eine Pfanne mit 1 EL Olivenöl erhitzen. Die Zucchiniwürfel etwa 2 Minuten darin dünsten. Danach die Tomaten, Paprika, Artischockenherzen und Kräuter zugeben. Mit Salz, Pfeffer und Thymian würzen. Die Fischfilets in der Pfanne auf dem Gemüse anrichten und bei geschlossenem Deckel ca. 8 Minuten dünsten. Vor dem Anrichten mit Salz und Pfeffer bestreuen.. Wer mag gibt noch ein paar Chiliflocken darauf. Es darf sofort serviert werden."}],p:"00:15",c:"00:10",tot:30,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2575,t:"Marinierte Hahnchenschenkel Auf Indischem Reis",i:[{n:"Hähnchenschenkel",u:"Pck",a:"3"},{n:"Strauchtomaten",u:"Stk",a:"2"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"getrocknete Soft-Aprikosen",u:"g",a:"100"},{n:"Reis",u:"g",a:"200"},{n:"Wallnussöl oder Sesamöl (am besten direkt aus einem asiatischen Lebensmittelmarkt)",u:"EL",a:"1"},{n:"edelsüsses Paprikapulver",u:"TL",a:"1"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Rosmarin",u:"TL",a:"1"},{n:"Salz",u:"TL",a:"2"},{n:"Sonnenblumenöl",u:"EL",a:"5"},{n:"Pfeffer",u:"",a:""}],st:[{s:1,n:"Ofen vorheizen und Hähnchenschenkel marinieren",d:"Den Ofen auf 200 Grad vorheizen. Die Hähnchenschenkel mit kaltem Wasser abwaschen und trockentupfen und in einer großen Schüssel zur Seite stellen. In einer Schüssel werden 1 EL Paprikapulver, 2 TL Salz, 1 EL Majoran, 1 TL Rosmarin, Pfeffer und etwa 5 EL Öl solange miteinander vermengt, bis eine sämige Masse entstanden ist. Diese fügt man nun zu den Schenkeln in die Schüssel und massiert diese vorsichtig ein."},{s:2,n:"Gemüse vorbereiten",d:"Die Zwiebeln und den Knoblauch schälen und kleinschneiden. Die Tomaten abwaschen, halbieren, den Strunk und die Kerne entfernen und ebenso wie die getrockneten Aprikosen in kleine Würfel schneiden."},{s:2,n:"Gemüse vorbereiten",d:"Die Zwiebeln und den Knoblauch schälen und kleinschneiden. Die Tomaten abwaschen, halbieren, den Strunk und die Kerne entfernen und ebenso wie die getrockneten Aprikosen in kleine Würfel schneiden."},{s:3,n:"Gemüse dünsten und Reis zubereiten",d:"Wallnuss- oder Sesamöl in einer Pfanne erhitzen und die Zwiebeln, Knoblauch sowie die Tomaten darin kurz andünsten. Den Reis dazugeben und ebenso kurz andünsten. Mit Curry-und Zimtpulver bestäuben. Die Aprikosen und 500 ml heißes Wasser hineingeben, umrühren, aufkochen und bei reduzierter Hitze bei geschlossenem Topf ca. 20 Minuten garen. Mit Salz würzen."},{s:3,n:"Gemüse dünsten und Reis zubereiten",d:"Wallnuss- oder Sesamöl in einer Pfanne erhitzen und die Zwiebeln, Knoblauch sowie die Tomaten darin kurz andünsten. Den Reis dazugeben und ebenso kurz andünsten. Mit Curry-und Zimtpulver bestäuben. Die Aprikosen und 500 ml heißes Wasser hineingeben, umrühren, aufkochen und bei reduzierter Hitze bei geschlossenem Topf ca. 20 Minuten garen. Mit Salz würzen."},{s:4,n:"Ab in den Ofen!",d:"Die Hähnchenschenkel im Ofen einmal wenden, sodaß diese von allen Seiten schön braun werden können. Nach etwa 60 Minuten darf sofort serviert werden."},{s:4,n:"Ab in den Ofen!",d:"Die Hähnchenschenkel im Ofen einmal wenden, sodaß diese von allen Seiten schön braun werden können. Nach etwa 60 Minuten darf sofort serviert werden."}],p:"00:10",c:"00:45",tot:60,srv:"4",cats:["Geflügel"]},{id:2580,t:"Hahnchen In Einem Speckmantel",i:[{n:"Hähnchen ca. 1,5 kg",u:"Stk",a:"1"},{n:"Baconstreifen",u:"Pck",a:"3"},{n:"getrocknete Pflaumen",u:"g",a:"100"},{n:"getrocknete Soft-Aprikosen",u:"g",a:"100"},{n:"Rosmarin",u:"Zweige",a:"4"},{n:"kleine Kartoffeln",u:"g",a:"500"},{n:"Äpfel",u:"",a:"2"},{n:"Sherry",u:"ml",a:"20"},{n:"Butter",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Getrocknetes Obst einweichen und Hähnchen würzen",d:"Die getrockneten Pflaumen und Aprikosen für etwa 30 Minuten im Wasser einweichen. Das Hähnchen mit kaltem Wasser innen und außen abbrausen, trockentupfen, mit Salz und Pfeffer innen und außen kräftig würzen."},{s:2,n:"Obst schneiden und Backofen vorheizen",d:"Die Äpfel schälen, das Kerngehäuse entfernen, in Würfel schneiden und in einer Schüssel zur Seite stellen. Etwa 3/4 der eingeweichten Trockenfrüchte herausnehmen, kleinschneiden und zu den Äpfeln in die Schüssel geben. Beides zusammen mit Sherry mischen. Die Rosmarinzweige abwaschen und trocken schütteln. Den Ofen auf 180 Grad vorheizen."},{s:3,n:"Hähnchen umwickeln und ab in den Ofen",d:"Das Hähnchen mit dem Speck umwickeln. Die Rosmarinzweige, die restlichen Pflaumen und Aprikosen vorsichtig unter die Speckscheiben stecken Eine Auflaufform einfetten und das umwickelte Hähnchen hineinsetzen. Butterflöckchen darauf verteilen und für etwa 80 Minuten in den Ofen geben. Dabei immer mal wieder mit dem austretenden Saft beträufeln."},{s:4,n:"Rosmarinkartoffeln zubereiten",d:"Etwa 30 Minuten vor dem Ende der Bratzeit, gibt man die Rosmarinkartoffeln hinzu. Dafür müssen die Kartoffeln vorher mit Wasser abgewaschen und je nach Größe halbiert oder geviertelt werden. In einer Schüssel vermengt man die Kartoffeln nun mit 2 EL Öl, Salz und gerebeltem Rosmarin miteinander. Es darf sofort heiß serviert werden."},{s:5,n:"Tipp",d:"Sollte der Speck im Ofen nicht zu dunkel geworden sein, so darf die Auflaufform mitsamt der Kartoffeln und Hähnchen nett auf dem Tisch präsentiert werden. Sonst schneidet man das Hähnchen in seine Einzelteile und richtet diese schön auf einem Teller an. Ein einfaches und köstliches Gericht."}],p:"00:30",c:"1:20",tot:120,srv:"4",cats:["Geflügel"]},{id:2584,t:"Omas Kasekuchen Ohne Boden",i:[{n:"Quark",u:"kg",a:"1"},{n:"Zucker",u:"g",a:"300"},{n:"Vanillezucke",u:"Pck",a:"1"},{n:"Backpulver",u:"Pck",a:"0.75"},{n:"Eier",u:"Stk",a:"5"},{n:"Grieß",u:"EL",a:"8"},{n:"Zitrone",u:"Stk",a:"1"},{n:"frisch gemahlene Mandeln",u:"g",a:"60"},{n:"Sanella",u:"g",a:"250"}],st:[{s:1,n:"Teig anrühren",d:"Dafür wird in eine große Schüssel 1 kg Quark gebeben und mit 300g Zucker, 1 Packung Vanillezucker, 3/4 Packung Backpulver, 5 Eiern, 8 EL Grieß, dem Saft einer Zitrone und 60 g frisch gemahlene Mandeln befüllt. Diese Mischung wird nun sehr lange mit einem Mixer gut miteinander verquirlt. Ich habe hier etwas weniger Zucker genommen, da mir dies beim ersten Versuch etwas zu süss gewesen ist. Jetzt gibt man noch 250 g Sanella in einen Topf und erwärmt dies bis es flüssig geworden ist. Diese Flüssigkeit hebt man nun unter die gemixte Masse."},{s:2,n:"Ofen vorheizen und Kuchenform einfetten",d:"Den Ofen auf 160 Grad vorheizen. In eine gefettete runde Kuchenform wird jetzt die Masse gegossen und für ca. 60 Minuten bei Mittelhize langsam gebacken. In den letzten 10 Minuten wird die Hitze noch auf 180 Grad erhöht."},{s:3,n:"Tipp",d:"Den Kuchen danach nicht sofort herausnehmen, sondern für weitere 60 Minuten bei abgeschaltetem geschlossenem Ofen abkühlen lassen. Dies hat den Effekt, daß er eben nicht sofort in sich zusammenfällt. Es kann vorkommen, daß der Kuchen auf der einen Seite noch nicht so braun geworden ist, wie im hinteren Teil des Ofens. Einfach den noch blassen Teil nach hinten drehen. So wird rein optisch ein gleichmäßig brauner Rand gezaubert. Das war es schon. Fertig ist ein Käsekuchen, der jeden Gaumen geschmacklich bereichern wird."}],p:"00:15",c:"2:00",tot:140,srv:"4",cats:["Backen & Desserts"]},{id:2589,t:"Apfelkuchen",i:[{n:"Butter",u:"g",a:"225"},{n:"Zucker",u:"g",a:"200"},{n:"Vanillezucker",u:"Pck",a:"1"},{n:"Eier",u:"Stk",a:"4"},{n:"Salz",u:"Prise",a:"1"},{n:"Mehl",u:"g",a:"400"},{n:"getrichene Teelöffel Backpulver",u:"",a:"3"},{n:"Äpfel",u:"kg",a:"1.5"},{n:"Zimt",u:"TL",a:"1"}],st:[{s:1,n:"Teig vorbereiten",d:"Die Butter in einem Topf erhitzen und in einer großen Schüssel mit Zucker und Vanillezucker schaumig rühren. Nach und nach Eier und Salz zufügen. In einer weiteren Schüssel das Mehl mit Backpulver vermischen und Esslöffelweise in die große Schüssel unterrühren. Den Teig auf ein gefettetes Backblech streichen."},{s:2,n:"Apfelspalten schneiden und Backofen vorheizen",d:"Die Äpfel schälen, entkernen und in schmale Spalten schneiden. Die Apfelspalten nun schuppenförmig auf dem Teig anordnen, mit Zimt bestäuben und in den vorgeheizten Backofen bei 175 Grad etwa 45 Minuten backen."},{s:2,n:"Apfelspalten schneiden und Backofen vorheizen",d:"Die Äpfel schälen, entkernen und in schmale Spalten schneiden. Die Apfelspalten nun schuppenförmig auf dem Teig anordnen, mit Zimt bestäuben und in den vorgeheizten Backofen bei 175 Grad etwa 45 Minuten backen."},{s:3,n:"Tipp",d:"Danach mit etwas Zucker bestäuben und auf dem Backblech abkühlen lassen. Wer mag, darf auch gern noch Rosinen oder Mandelplättchen darüber streuen."},{s:3,n:"Tipp",d:"Danach mit etwas Zucker bestäuben und auf dem Backblech abkühlen lassen. Wer mag, darf auch gern noch Rosinen oder Mandelplättchen darüber streuen."}],p:"00:20",c:"00:45",tot:80,srv:"8",cats:["Backen & Desserts"]},{id:2593,t:"Polnischer Sauerkrauteintopf",i:[{n:"braune mittelgroße Champignons",u:"Stk",a:"5"},{n:"Räucherspeck",u:"g",a:"130"},{n:"Schweinenacken",u:"g",a:"350"},{n:"Krakauer",u:"Stk",a:"2"},{n:"Weißkohl",u:"g",a:"500"},{n:"Backpflaumen",u:"g",a:"100"},{n:"Glas Rotwein",u:"",a:"1"},{n:"Zwiebeln",u:"Stk",a:"2"},{n:"braune mittelgroße Champignons",u:"Stk",a:"5"},{n:"Räucherspeck",u:"g",a:"130"},{n:"Schweinenacken",u:"g",a:"350"},{n:"Krakauer",u:"Stk",a:"2"},{n:"Weißkohl",u:"g",a:"500"},{n:"Backpflaumen",u:"g",a:"100"},{n:"Glas Rotwein",u:"",a:"1"},{n:"Zwiebeln",u:"Stk",a:"2"}],st:[{s:1,n:"Pilze putzen",d:"Die frischen Champignons vom Schmutz befreien, halbieren und in Scheiben schneiden. Sollte man getrocknete Pilze zu Hause haben, so können diese für etwa 30 Minuten in kaltem Wasser eingeweicht werden."},{s:2,n:"Sauerkraut vorbereiten und Speck würfeln",d:"Den Speck in feine Würfel schneiden. Den Schweinenacken abwaschen, trockentupfen und in grobe Würfel schneiden. Die Zwiebeln schälen und würfeln. Das Sauerkraut in einem Sieb abtropfen und leicht auseinander zupfen."},{s:3,n:"Weißkohl blanchieren",d:"Vom Weißkohl den Strunk abschneiden, die Blätter einzeln abnehmen, abwaschen, die dicken Blattrippen herausschneiden und den Kohl in schmale Streifen schneiden. Die Krakauer leicht schräg in Scheiben, die Pflaumen in kleine Stücke schneiden. Die Weißkohlstreifen in reichlich kochendes Wasser geben, etwa 2-3 Minuten blanchieren, abgießen, kalt abschrecken und in einem Sieb abtropfen lassen."},{s:4,n:"Fleisch anbraten",d:"Den Speck in einem großen Topf knusprig ausbraten. Das Schweinefleisch zugeben und rundherum anbraten. Die Würstchen und Zwiebeln dazugeben und mit Wasser oder Brühe ablöschen."},{s:5,n:"Alle Zutaten eine Weile schmoren lassen.",d:"Nun darf alles bei geschlossenem Deckel für etwa 30 Minuten bei reduzierter Hitze schmoren. Zwischendurch immer mal wieder mit Wasser auffüllen. Nach 30 Minuten den Weißkohl, die Pilze und die Pflaumen, das aufgelockerte Sauerkraut und den Rotwein zufügen und gut miteinander vermischen. Alles muß nun nochmals für 30 Minuten schmoren. Zum Schluss kräftig mit Salz, Pfeffer und Zucker abschmecken."},{s:6,n:"Tipp",d:"Diesen Eintopf sofort heiß servieren. Dazu eine frische Brotscheibe mit Butter, ein Glas Bier und als Absacker einen eiskalten Wodka."}],p:"00:15",c:"00:60",tot:80,srv:"8",cats:["Suppen & Eintöpfe"]},{id:2598,t:"Blumenkohlsalat",i:[{n:"kleiner Blumenkohl",u:"Stk",a:"1"},{n:"rote Paprikaschote",u:"Stk",a:"0.5"},{n:"grüne Oliven von der Frischetheke",u:"Stk",a:"7"},{n:"gesalzene Sardellenfilets",u:"Stk",a:"6"},{n:"mild eingelegte Peperoni",u:"Stk",a:"4"},{n:"Kapern",u:"EL",a:"1"},{n:"Weinessig",u:"EL",a:"3"},{n:"Öl",u:"EL",a:"5"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Blumenkohl zubereiten",d:"Den Blumenkohl putzen, in kleine mundgerechte Röschen teilen, waschen und in reichlich kochendem Salzwasser ca. 5 Minuten garen. Danach durch ein Sieb gießen, mit kaltem Wasser abschrecken und in einer Schüssel zur Seite stellen. Durch das Abschrecken garen die Röschen nicht nach und bleiben somit knackig."},{s:2,n:"Gemüse und Sardellen vorbereiten",d:"Die Paprika halbieren, entkernen, abwaschen, quer halbieren und in sehr feine Streifen schneiden. Die Oliven halbieren und in Halbringe schneiden. Die Sardellen in einem Sieb kalt abspülen, in sehr feine Streifen schneiden und nochmals halbieren. Die Peperoni längs aufschneiden, Kerne entfernen und in Ringe schneiden."},{s:3,n:"Zutaten vermengen",d:"Den Blumenkohl in eine Schüssel geben, mit Paprika, Oliven, Sardelln und Peperoni und Karper befüllen. Mit Salz, Pfeffer, Weinessig und Öl kräftig abschmecken und gut miteinander vermengen. Ich würde hier das Rapsöl empfehlen. Es schmeckt einfach nicht so vor, wie beispielsweise Olivenöl."},{s:4,n:"Tipp:",d:"Nun sollte der Salat noch eine Weile ca. 1-2 Stunden durchziehen. Besser noch über Nacht stehen lassen. Etwa 1 Stunde vor dem Servieren nochmals bei Zimmertemperatur durchziehen lassen. Für die etwas pikantere Variante darf man auch gern noch etwas Cayennepfeffer oder ein paar Chiliflocken daruntermischen."}],p:"00:15",c:"00:5",tot:20,srv:"6",cats:["Salate","Vegetarisch"]},{id:2604,t:"Raucherlachscreme",i:[{n:"Räucherlachs",u:"g",a:"200"},{n:"Creme Fraiche (ca. 1 Becher)",u:"EL",a:"4"},{n:"Saft einer Zitrone",u:"",a:""},{n:"Pfeffer",u:"",a:""}],st:[{s:1,n:"Zutaten vermengen",d:"Den Räucherlachs grob zerkleinern und zusammen mit Zitronensaft und Creme Fraiche in einem Mixer sehr fein pürieren. Je nach Geschmack mit Zitronensaft und Creme Fraiche nachwürzen. So kann man den Lachsgeschmack noch ein klein wenig abmildern."},{s:2,n:"Räucherlachscreme mit Kräutern verfeinern",d:"Nachdem so eine feine Creme entstanden ist, mit kleingehacktem Dill sowie Pfeffer abschmecken. Bei der Zubereitung kein Salz mehr verwenden, da der Räucherlachs bereits ausreichend gewürzt ist."}],p:"00:10",c:"00:00",tot:10,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2611,t:"Nudel Auflauf Auf Buntem Gemuse",i:[{n:"Nudeln",u:"g",a:"500"},{n:"Paprikaschoten (gelb und rot)",u:"Stk",a:"2"},{n:"mittelgroße Möhren",u:"Stk",a:"5"},{n:"Champignons",u:"Stk",a:"5"},{n:"Mais",u:"Dose",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"6"},{n:"Tomatenmark",u:"EL",a:"3"},{n:"gerebelter Oregano');",u:"TL",a:"1"},{n:"gerebelter Majoran",u:"TL",a:"1"},{n:"Zucker",u:"",a:""},{n:"Parmesankäse im Stück",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Nudeln kochen, Gemüse vorbereiten und Ofen vorheizen",d:"Die Nudeln werden in reichlich Wasser mit etwas Salz bissfest gekocht. Während die Nudeln kochen, wird das Gemüse kleingeschnitten. Dafür entkernt man die Paprika, schneidet diese in Streifen und dann in grobe Stücke. Von den Lauchzwiebeln schneidet man die Wurzeln und die oberen 2cm vom Grün ab, wäscht nun die Stangen vom Sand sauber und danach in Ringe. Die Champignons vom Sand befreien, halbieren und in Scheiben schneiden. Den Mais in einem Sieb abgießen. Die Möhren mit einem Spargelschäler schälen, längs halbieren und in schmale Streifen schneiden. Der Ofen darf jetzt auf ca. 180 Grad vorgeheizt werden. Zuletzt den Kochschinken in Würfel schneiden."},{s:2,n:"Tipp: Tomatenmark verwenden",d:"Eigentlich wollte ich für die Soße passierte Tomaten nehmen. Doch mußte ich während der Zubereitung feststellen, daß diese nicht mehr im Haushalt vorrätig hatte. Früher wäre ich in Panik geraten, hätte den Herd ausgestellt und wäre Essen gegangen. Heute weiß ich ,daß man manchmal auch ein klein wenig improvisieren muß. Diejenigen, welche viel zu Hause kochen, haben sich einen gewissen Vorrat an Zutaten zugelegt, die immer im Hause sein sollten. Dazu gehört unter anderem auf Tomatenmark. Dies war dann letztendlich meine Rettung. Aus dem Tomatenmark, kann man ein leckere Soße zaubern."},{s:2,n:"Tipp: Tomatenmark verwenden",d:"Eigentlich wollte ich für die Soße passierte Tomaten nehmen. Doch mußte ich während der Zubereitung feststellen, daß diese nicht mehr im Haushalt vorrätig hatte. Früher wäre ich in Panik geraten, hätte den Herd ausgestellt und wäre Essen gegangen. Heute weiß ich ,daß man manchmal auch ein klein wenig improvisieren muß. Diejenigen, welche viel zu Hause kochen, haben sich einen gewissen Vorrat an Zutaten zugelegt, die immer im Hause sein sollten. Dazu gehört unter anderem auf Tomatenmark. Dies war dann letztendlich meine Rettung. Aus dem Tomatenmark, kann man ein leckere Soße zaubern."},{s:3,n:"Tomatensoße zubereiten",d:"Dafür nimmt man 3 EL Tomatenmark, das Wasser der Nudeln, gerebelten Oregano, Majoran, Pfeffer, Zucker und Salz zum abschmecken. Dies rührt man nun in einer Schüssel glatt."},{s:3,n:"Tomatensoße zubereiten",d:"Dafür nimmt man 3 EL Tomatenmark, das Wasser der Nudeln, gerebelten Oregano, Majoran, Pfeffer, Zucker und Salz zum abschmecken. Dies rührt man nun in einer Schüssel glatt."},{s:4,n:"Gemüse dünsten und mit Tomatensoße vermengen",d:"In einer große Pfanne oder einem großen Topf Öl erhitzen, die Möhren, die Champignons sowie den Zwiebellauch ca. 5 Minuten darin dünsten. Danach den Paprika, den Mais und den Kochschinken hinzugeben, mit Salz und Pfeffer kräftig würzen und nochmals etwa 3 Minuten anbraten. Nun die angerührte Tomatensoße hineingeben und etwa 10 Minuten bei reduzierter Hitze köcheln lassen. Zum Schluß evtl. noch einmal nachwürzen."},{s:4,n:"Gemüse dünsten und mit Tomatensoße vermengen",d:"In einer große Pfanne oder einem großen Topf Öl erhitzen, die Möhren, die Champignons sowie den Zwiebellauch ca. 5 Minuten darin dünsten. Danach den Paprika, den Mais und den Kochschinken hinzugeben, mit Salz und Pfeffer kräftig würzen und nochmals etwa 3 Minuten anbraten. Nun die angerührte Tomatensoße hineingeben und etwa 10 Minuten bei reduzierter Hitze köcheln lassen. Zum Schluß evtl. noch einmal nachwürzen."},{s:5,n:"Ab in den Ofen!",d:"In eine Auflaufform gibt man nun die Nudeln und das Gemüse, vermengt dies miteinander und raspelt den Käse darüber. Alles zusammen für ca. 15 Minuten in den vorgeheizten Ofen geben."},{s:5,n:"Ab in den Ofen!",d:"In eine Auflaufform gibt man nun die Nudeln und das Gemüse, vermengt dies miteinander und raspelt den Käse darüber. Alles zusammen für ca. 15 Minuten in den vorgeheizten Ofen geben."}],p:"00:20",c:"00:35",tot:60,srv:"6",cats:["Pasta & Nudeln"]},{id:2617,t:"Eiersalat",i:[{n:"Eier",u:"Stk",a:"8"},{n:"Mayonnaise",u:"EL",a:"2"},{n:"Senf",u:"TL",a:"1"},{n:"Zucker",u:"Prise",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Eier kochen, abkühlen, schneiden und zerdrücken",d:"Die Eier ca. 15 Minuten hart kochen, abschrecken und abkühlen lassen. Danach abpellen und mit einer Eierharfe feinschneiden, in eine Schüssel geben und mit einer Gabel nochmals leicht zerdrücken."},{s:2,n:"Zubereitung der Mayonnaise für den Eiersalat",d:"Nun die Mayonnaise, Senf, Zucker, Salz und Pfeffer dazugeben und kräftig miteinander vermischen. Mit den Gewürzen abschmecken. Je nach Bedarf kann mehr oder weniger Mayonnaise dazugegeben werden. Mehr, wenn man den Eiersalat dünner mag, weniger wenn dieser dicker sein soll."},{s:3,n:"Eiersalat ziehen lassen",d:"Den Eiersalat läßt man jetzt noch ca. 30 Minuten im Kühlschrank ziehen und nimmt ihn spätestens eine halbe Stunde vor dem Verzehr wieder raus. Noch ein Gericht, welches die Auswahl auf dem Frühstückstisch erweitert. Wer mag, kann den Salat noch mit Kräutern verfeinern."}],p:"00:5",c:"00:15",tot:60,srv:"8",cats:["Salate","Frühstück & Eier"]},{id:2640,t:"Buletten",i:[{n:"Hackfleisch gemischt",u:"kg",a:"15"},{n:"Eier",u:"Stk",a:"2"},{n:"Dijonsenf",u:"TL",a:"2"},{n:"Semmelbrösel",u:"EL",a:"5"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"kleine Zwiebel",u:"Stk",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hackfleisch für die Buletten mit der Hand verkneten",d:"Das Hackfleisch wird zusammen mit 2 Eiern, 5-7 EL Semmelbrösel, 2 TL Dijonsenf, 1 EL gerebelten Majoran, einer sehr fein gewürfelten Zwiebel, Salz und Pfeffer in eine große Schüssel gegeben. Alles zusammen kräftig miteinander verkneten und abschmecken."},{s:2,n:"Buletten formen",d:"Je nach Belieben formt man in den Händen große oder kleine Buletten, drückt diese flach an und legt sie auf einem Teller zur Seite."},{s:3,n:"Buletten in der Pfanne braten",d:"Nun eine Pfanne mit Öl erhitzen und die Buletten von beiden Seiten etwa 5 Minuten anbraten. Bei großen Buletten am besten von beiden Seiten scharf anbraten, die Hitze auf die Hälfte runterregulieren und etwa 2-3 Minuten leicht durchbraten lassen."},{s:4,n:"Buletten nach Bedarf warm halten oder kalt servieren",d:"Sollte eine große Menge hergestellt werden, so können die bereits fertigen Frikadellen im Ofen bei 50 Grad warm gehalten werden. Sie eignen sich jedoch ebenso als Kaltspeise. Buletten können zu vielen Gerichten gereicht werden. Ob nun als vollwertige Mahlzeit zu Buletten mit Mischgemüse, als Fingerfood auf dem Partybuffet oder als kleine Klöschen in einer Suppe bzw. zu Spaghetti, es finden sich viele Gelegenheiten diese zu verspeisen. Mit leichten Variationen bei den Zutaten kann man den Geschmack verändern. Es kann ebenso Knoblauch hinzugefügt werden oder statt Majoran darf man auch mit Thymian experimentieren. Lecker ist es immer."}],p:"00:10",c:"00:15",tot:30,srv:"6",cats:["Fleisch"]},{id:2644,t:"Schweinefilet Auf Mohrengemuse",i:[{n:"Möhren",u:"g",a:"500"},{n:"Schweinefilet",u:"g",a:"600"},{n:"Äpfel",u:"Stk",a:"2"},{n:"Honig",u:"EL",a:"1"},{n:"Zitronensaft",u:"EL",a:"2"},{n:"Butterschmalz",u:"",a:""},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Sahne",u:"Becher",a:"1"},{n:"Brühe",u:"ml",a:"150"},{n:"Dijonsenf",u:"TL",a:"3"},{n:"gerebelter Estragon",u:"TL",a:"2"},{n:"Reis",u:"",a:""}],st:[{s:1,n:"Schweinefilet sowie Gemüse putzen und zuschneiden",d:"Einen Topf mit Salzwasser erhitzen. Das Schweinefilet mit kaltem Wasser abspülen, mit Küchenpapier abtupfen und die Sehnen mit einem scharfen Messer entfernen. Das Fleisch kann nun rundherum mit Salz und Pfeffer gewürzt werden. Die Zwiebel schälen und würfeln. Die Möhren mit einem Spargelschäler schälen und schräg in Scheiben schneiden. Die Äpfel schälen, entkernen und in sehr schmale Spalten schneiden. Die Apfelscheiben in eine Schüssel geben, mit Zitronensaft und Honig vermischen. Die Möhrenscheiben können nun in das kochende Wasser gegeben werden und etwa 2-3 Minuten dünsten lassen. Danach herausnehmen, unter kaltem Wasser abschrecken und zur Seite stellen. Den Backofen auf 200 Grad vorheizen."},{s:2,n:"Schweinefilet und Gemüse anbraten",d:"Das Schweinefilet in einem Topf rundherum etwa 10 Minuten anbraten, herausnehmen und zur Seite stellen. Die gewürfelten Zwiebeln im Bratfett glasig dünsten und später in einer Auflaufform geben. In einer Schüssel nun die Sahne, die Brühe, Senf und entweder klein gehackter frischer oder gerebelter Estragon, Salz und Pfeffer geben und miteinander vermischen. Die Möhren und Äpfel darauf schichten und mit der Sahne-Soße übergießen. Zum Schluss das Fleisch hineinlegen und für etwa 30 Minuten in den vorgeheizten Ofen geben. Während dessen den Reis nach Packungsangabe oder nach diesem Rezept garen. Zum Schluss das Fleisch herausnehmen, in Scheiben schneiden und anrichten. Das Gericht darf gern in der Auflaufform auf dem Tisch serviert werden. In eine weitere Schüssel wird der erwärmte Reis gegeben. So kann sich jeder nach Belieben seine Portionen auf den Teller geben. Ein Absolutes Muß ist das kräftige Abschmecken der Soße. Senf, Salz oder Estragon. Hier darf je nach Geschmäckle mehr oder weniger hinzugegeben werden."},{s:2,n:"Schweinefilet und Gemüse anbraten",d:"Das Schweinefilet in einem Topf rundherum etwa 10 Minuten anbraten, herausnehmen und zur Seite stellen. Die gewürfelten Zwiebeln im Bratfett glasig dünsten und später in einer Auflaufform geben. In einer Schüssel nun die Sahne, die Brühe, Senf und entweder klein gehackter frischer oder gerebelter Estragon, Salz und Pfeffer geben und miteinander vermischen. Die Möhren und Äpfel darauf schichten und mit der Sahne-Soße übergießen. Zum Schluss das Fleisch hineinlegen und für etwa 30 Minuten in den vorgeheizten Ofen geben. Während dessen den Reis nach Packungsangabe oder nach diesem Rezept garen. Zum Schluss das Fleisch herausnehmen, in Scheiben schneiden und anrichten. Das Gericht darf gern in der Auflaufform auf dem Tisch serviert werden. In eine weitere Schüssel wird der erwärmte Reis gegeben. So kann sich jeder nach Belieben seine Portionen auf den Teller geben. Ein Absolutes Muß ist das kräftige Abschmecken der Soße. Senf, Salz oder Estragon. Hier darf je nach Geschmäckle mehr oder weniger hinzugegeben werden."}],p:"00:20",c:"00:45",tot:75,srv:"4",cats:["Fleisch"]},{id:2648,t:"Ungarischer Rinderbraten",i:[{n:"Rinderbraten (aus der Schulter)",u:"kg",a:"15"},{n:"Knollensellerie",u:"Stk",a:"1"},{n:"Möhren",u:"g",a:"500"},{n:"Zwiebeln",u:"Stk",a:"2"},{n:"Rotwein",u:"ml",a:"500"},{n:"Stangen Zwiebellauch",u:"Stangen",a:"2"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Butterschmalz",u:"EL",a:"2"},{n:"Fleischbrühe (instant)",u:"l",a:"1"},{n:"Lorbeerblätter (frisch oder getrockner)",u:"Stk",a:"2"},{n:"Wacholderbeeren",u:"TL",a:"0.5"},{n:"Gewürznelken",u:"Stk",a:"2"},{n:"Pfefferkörner",u:"TL",a:"15"},{n:"kalte Butter",u:"EL",a:"2"}],st:[{s:1,n:"Gemüse putzen, Ofen heizen",d:"Das Gemüse putzen, waschen, evtl. schälen. Jeweils die Hälfte davon grob würfeln. Die andere Hälfte in feine Streifen schneiden und ggf. halbieren, sollten die Gemüsestreifen zu lang sein. Den Ofen auf 175 Grad vorheizen. Einen Wasserkocher für die Brühe erhitzen."},{s:2,n:"Rindfleisch vorbereiten",d:"Das Rindfleisch mit kaltem Wasser abspülen, mit Küchenpapier trockentupfen, rundherum salzen und pfeffern. Einen Bräter mit Butterschmalz erhitzen und das Fleisch von allen Seiten anbraten und herausnehmen. Das grob gewürfelte Gemüse und die Zwiebeln im gleichen Bratenfett rösten. Tomatenmark zugeben und mit Rotwein ablöschen. Die Brühe, die Gewürze (2 Lorbeerblätter, 1/2 TL Wacholderbeeren, 2 Gewürznelken, 1,5 TL Pfefferkörner) und das Fleisch in den Bräter geben. Alles zusammen bei 175 Grad im Ofen bei geschlossenem Deckel 1 Stunde schmoren. Danach den Deckel entfernen, das Fleisch wenden und eine weitere Stunde schmoren lassen."},{s:3,n:"Die Soße zubereiten",d:"Nach 2 Stunden den Braten herausnehmen und warmhalten. Die Sauce durch ein feines Sieb passieren, in einen Topf geben und etwa 15 Minuten kochen lassen. Kurz vor dem Servieren, kalte Butter hineingeben und mit einem Pürierstab untermixen."},{s:4,n:"Gemüse dünsten und würzen",d:"Während die Sauce köchelt, eine Pfanne mit Butter erhitzen und das in Streifen geschnittene Gemüse bissfest dünsten und mit Salz und Pfeffer abschmecken. Nun den Rinderbraten in Scheiben schneiden, auf einem großen Teller anrichten, Soße darüber geben, Gemüsestreifen daneben drappieren und auf dem Tisch servieren. Dazu gab es bei uns Kartoffeln. Ein traditionell geschmorter Rinderbraten in einer kräftigen Rotweinsauce, garniert mit knackigem Wurzelgemüse. Lecker."}],p:"00:30",c:"2:00",tot:160,srv:"6",cats:["Fleisch"]},{id:2655,t:"Schmorhuhn In Einer Bier Zwiebel Sose",i:[{n:"Hähnchenschenkel",u:"Stk",a:"8"},{n:"Zwiebeln",u:"kg",a:"1"},{n:"Malzbier",u:"ml",a:"500"},{n:"Brühe",u:"ml",a:"400"},{n:"Butter",u:"EL",a:"1"},{n:"braunen Zucker",u:"EL",a:"1"},{n:"Lorbeerblätter",u:"Stk",a:"4"},{n:"gerobelten Thymian",u:"TL",a:"2"},{n:"Dijonsenf",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hähnchenschenkel anbraten",d:"Zubereitung Schmorhuhn in einer Bier-Zwiebel-Soße Die Butter in einem großen Topf erhitzen und schmelzen lassen. Während dessen, die Hähnchenschenkel mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen und von allen Seiten kräftig mit Salz und Pfeffer würzen. Sobald die Butter heiß genug ist, werden die Hähchenschenkel in den Topf gegeben und von allen Seiten schön goldbraun angebraten. Während die Schenkel braten, werden die Zwiebeln geschält und in dünne Scheiben geschnitten."},{s:2,n:"Bier-zwiebelsoße zubereiten",d:"Nach dem Anbraten der Schenkel, werden diese herausgenommen und in einer Schüssel zur Seite gestellt. Die Zwiebeln werden nun ganz vorsichtig bei halber Hitze im gleichen Topf im Bratenfett glasig angebraten. Für die Süsse in den Zwiebeln, darf man gern noch etwas brauen Zucker hinzu geben. Häufig jedoch, sind die Speisezwiebeln im Geschmack süss genug, sodaß dies nicht undbeding notwendig sein muß. Die Zwiebeln gelegentlich umrühren. Nach etwa 15-20 Minuten die Lorbeerblätter, das Salz, den Thymian und das Malzbier zu den Zwiebeln geben. Gut umrühren und den Bratensatz vorsichtig mit einem Holzlöffel vom Boden kratzen"},{s:3,n:"Mit Wasser auffüllen und Hähnchenschenkel schmoren",d:"Wasser in einem Wasserkocher erhitzen, mit einem EL Brühe vermischen und zu dem Bierfonds in den Topf geben. Die Hähnchenschenkel vorsichtig hineinlegen und mit geschlossenem Deckel etwa 45 Minuten leicht simmen lassen. Nach 45 Minuten den Deckel abnehmen, Hitze etwas erhöhen und weitere 50 Minuten köcheln lassen. Dabei verdampft langsam etwas Flüssigkeit und übrig bleibt ein unglaublich kräftig schmackhafter Bier-Zwiebel Soßenfond."},{s:4,n:"Reis kochen und Bier-Zwiebelsoße abschmecken",d:"Zum Schluss mit Salz und frisch gemahlenem Pfeffer abschmecken. In den letzten 30 Minuten des Schmorens wird der Reis aufgesetzt. Letztendlich alles schön auf einem Teller anrichten und schmecken lassen."}],p:"00:15",c:"2:00",tot:140,srv:"4",cats:["Geflügel"]},{id:2660,t:"Grundrezept Senfsosse",i:[{n:"Zwiebel",u:"Stk",a:"1"},{n:"geriebener Muskat",u:"TL",a:"0.5"},{n:"Milch",u:"ml",a:"100"},{n:"Brühe",u:"ml",a:"200"},{n:"Dijonsenf",u:"EL",a:"4"},{n:"Butter",u:"EL",a:"1"},{n:"Mehl",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Vorbereitende Arbeiten für die Senfsosse",d:"Die Zwiebel schälen und in kleine Würfel schneiden. Wasser in einen Wasserkocher erhitzen und mit einem EL Brühe vermengen."},{s:2,n:"Senfsoße zubereiten",d:"Butter in einer Pfanne erhitzen und die Zwiebeln darin glasig andünsten. Mehl darüber streuen, gut umrühren, sodaß keine Klümpchen mehr vorhanden sind und mit Milch und Brühe ablöschen. Kurz aufkochen und andicken lassen. Die Sauce mit Salz, Pfeffer, Muskat und Senf abschmecken. Die Sauce sollte etwa 11 Minuten köcheln, sodaß der Mehlgeschmack verschwindet. Je nach Belieben darf hier mit mehr oder weniger Senf gearbeitet werden. Ich habe hier etwa 4-6 EL Senf dazu gegeben. Diese Senfsoße eignet sich besonders für das Gericht Senfeier mit Kartoffelpüree. Aber auch für Fischgerichte darf diese Grundsoße gern verwendet werden"},{s:2,n:"Senfsoße zubereiten",d:"Butter in einer Pfanne erhitzen und die Zwiebeln darin glasig andünsten. Mehl darüber streuen, gut umrühren, sodaß keine Klümpchen mehr vorhanden sind und mit Milch und Brühe ablöschen. Kurz aufkochen und andicken lassen. Die Sauce mit Salz, Pfeffer, Muskat und Senf abschmecken. Die Sauce sollte etwa 11 Minuten köcheln, sodaß der Mehlgeschmack verschwindet. Je nach Belieben darf hier mit mehr oder weniger Senf gearbeitet werden. Ich habe hier etwa 4-6 EL Senf dazu gegeben. Diese Senfsoße eignet sich besonders für das Gericht Senfeier mit Kartoffelpüree. Aber auch für Fischgerichte darf diese Grundsoße gern verwendet werden"}],p:"00:5",c:"00:15",tot:20,srv:"4",cats:["Vegetarisch"]},{id:2663,t:"Senfeier Mit Sellerie Kartoffelstampf",i:[{n:"mehligkochend Kartoffeln",u:"g",a:"500"},{n:"mehligkochend Kartoffeln",u:"g",a:"500"},{n:"Sellerieknolle",u:"Stk",a:"0.5"},{n:"Eier",u:"Stk",a:"8"},{n:"Petersilie",u:"",a:""},{n:"Milch",u:"ml",a:"200"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Butter",u:"EL",a:"5"},{n:"Mehl",u:"EL",a:"1"},{n:"Milch (Püree+Soße)",u:"ml",a:"300"},{n:"Brühe",u:"ml",a:"200"},{n:"geriebener Muskat",u:"TL",a:"0.5"},{n:"Dijonsenf",u:"EL",a:"4"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Die Eier kochen und abkühlen lassen",d:"Die Eier etwa 10 Minuten hart kochen. Abkühlen lassen, schälen und nach Belieben vierteln oder halbieren."},{s:2,n:"Senfsoße für Senfeier zubereiten",d:"Die Senfsoße nach dem Rezept auf meiner Seite zubereiten."},{s:3,n:"Sellerie-Kartoffelpüree zubereiten",d:"Für den Sellerie-Kartoffelpüree werden etwa 500 g mehlig kochende Kartoffeln geschält und in Würfel geschnitten. Eine halbe Sellerieknolle schälen und ebenso in Würfel schneiden. Einen Topf mit Wasser erhitzen und das Gemüse etwa 15-20 Minuten kochen lassen. Das Wasser abgießen, das gekochte Gemüse mit 3-4 EL Butter, 50-100 ml Milch sowie Salz stampfen."},{s:4,n:"Eier der Senfsoße hinzufügen",d:"Die Eier gibt man nun in die Senfsoße. Kurz darin warm werden lassen und alles zusammen auf einem Teller servieren. Etwas Petersilie darüber streuen. Die Kinder lieben es und wir Erwachsenen haben so ein leckeres Gericht schnell auf den Tisch gezaubert."}],p:"00:10",c:"00:25",tot:40,srv:"4",cats:["Frühstück & Eier"]},{id:2668,t:"Huhnergeschnetzeltes In Einer Bier Senf Sose",i:[{n:"Hühnerfleisch",u:"g",a:"350"},{n:"frische Champginons",u:"g",a:"150"},{n:"Becher Saure Sahne",u:"Stk",a:"1"},{n:"Brühe",u:"ml",a:"100"},{n:"Mehl",u:"EL",a:"15"},{n:"Mehl",u:"EL",a:"15"},{n:"Zitronensaft",u:"TL",a:"1"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Dijonsenf",u:"EL",a:"2"},{n:"Kümmel",u:"TL",a:"0.5"},{n:"gerebelter Thymian",u:"TL",a:"15"},{n:"edelsüsses Paprikapulver",u:"EL",a:"1"},{n:"Öl",u:"El",a:"6"}],st:[{s:1,n:"Vorbereitende Schnippelarbeiten",d:"Das Fleisch mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen, in 5 cm schmale Streifen schneiden und in eine große Schüssel geben. 1,5 Zwiebeln schälen und kleinschneiden. 3 Knoblauchzehen schälen und entweder in der Knoblauchpresse durchdrücken oder sehr feinwürfeln."},{s:2,n:"Fleischmarinade vorbereiten und mit dem Fleisch ziehen lassen",d:"In einer weiteren Schüssel werden nun das Öl, der Senf, Pfeffer, Kümmel, Paprikapulver, die Zwiebelwürfel, der Knoblauch und Thymian kräftig miteinander vermengt. Diese Marinade gibt man nun zu dem Fleisch in die Schüssel und vermischt alles sehr gut miteinander. Zum Schluss Bier bedeckt rüber gießen und unterheben. Abgedeckt für etwa 8-12 Stunden im Kühlschrank marinieren lassen."},{s:3,n:"Bier-Senfmarinade vom Fleisch abtropfen lassen und das Fleisch anbraten",d:"Danach das Fleisch in ein Sieb geben und die Flüssigkeit in eine Schüssel abtropfen lassen. Das Fleisch in einer Pfanne mit Öl anbraten, mit Mehl bestäuben und braun werden lassen"},{s:4,n:"Gemüse schneiden und dem Fleisch hinzufügen",d:"Während dessen die Champignons putzen, halbieren, in Scheiben schneiden und zusammen mit einer kleingeschnittenen Zwiebel zu dem Fleisch in die Pfanne geben. Kurz anrösten."},{s:5,n:"Bier-Senf-Soße verfeinern und abschmecken",d:"Mit Brühe ablöschen,Saure Sahne unterrühren und mit etwa der Hälfte der abgetropften Marinade sowie einigen Spritzern Zitrone abschmecken. Verrühren und etwa 30 Minuten köcheln lassen. Dazu gab es bei uns Reis. Eine würzige Bier-Senf Marinade für Fleisch aller Art. Es eignen sich ebenso Rind- oder Schweinefleisch dazu. Über Nacht ziehen so alle Gewürze in das Fleisch und heraus kommt eine kräftige Soße. Ich habe es noch nicht ausprobiert, doch kann ich mir gut vorstellen, daß man auch Grillfleisch so gut marinieren könnte. Probiert´s einfach aus."}],p:"12:00",c:"00:45",tot:770,srv:"6",cats:["Geflügel","Fleisch"]},{id:2675,t:"Feurige Spargelcremesuppe",i:[{n:"Spargel (auch Bruchspargel)",u:"kg",a:"1"},{n:"Butter",u:"EL",a:"2"},{n:"Mehl",u:"EL",a:"1"},{n:"Rapsöl",u:"EL",a:"2"},{n:"Sesamöl",u:"EL",a:"2"},{n:"Sahne",u:"Becher",a:"1"},{n:"Zitronenpfeffer",u:"",a:""},{n:"Zitrone",u:"Stk",a:"1"},{n:"Cayennepfeffer",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""},{n:"Chilischote und Petersilie als Garnitur",u:"Stk",a:"1"}],st:[{s:1,n:"Spargelenden und Schalen für die Spargelcremesuppe kochen",d:"Man nehme die Schalen und Enden von ca. 1 kg Spargel. Gibt diese in einen Topf und gießt 1 Liter Wasser hinzu. Mit Zucker und Salz würzen, aufkochen und etwa 30 Minuten bei stark reduzierter Hitze ziehen lassen."},{s:2,n:"Bruchspargel andünsten und mit Spargelfond ablöschen",d:"Etwa 2/3 der Spargelstangen in kleine Stücke schneiden. Wer hat, darf natürlich auch gern Bruchspargel dazu nehmen. Die Spargelstücken werden in einen Topf mit Butter gegeben, angedünstet und mit Mehl bestäubt. Nun wird der Spargelfond durch ein feines Sieb zu dem gedünsteten Spargel gegossen. Kurz aufkochen lassen, Hitze reduzieren und etwa eine viertel Stunde garen lassen."},{s:2,n:"Bruchspargel andünsten und mit Spargelfond ablöschen",d:"Etwa 2/3 der Spargelstangen in kleine Stücke schneiden. Wer hat, darf natürlich auch gern Bruchspargel dazu nehmen. Die Spargelstücken werden in einen Topf mit Butter gegeben, angedünstet und mit Mehl bestäubt. Nun wird der Spargelfond durch ein feines Sieb zu dem gedünsteten Spargel gegossen. Kurz aufkochen lassen, Hitze reduzieren und etwa eine viertel Stunde garen lassen."},{s:3,n:"Spargelscheiben schneiden und anbraten",d:"Während dessen schneidet man von einzelnen Spargelstangen leicht schräg dünne Scheiben ab. Diese Spargelscheiben werden in einer Pfanne mit Sesam- und Rapsöl, Salz und Pfeffer vorsichtig angebraten. Danach zur Seite stellen."},{s:4,n:"Die Spargelcremesuppe mit Sahne verfeinern",d:"Nach etwa 15 Minuten gibt man einen Becher Sahne in die Spargelsuppe und zerkleinert den Spargel mit einem Pürierstab. Nun wird die Suppe mit Salz, Zucker, Zitronenpfeffer, Cayennepfeffer und ein paar Spritzern Zitrone gewürzt. Mit dem Zitronenpfeffer vorsichtig würzen, da die Suppe sonst zu sehr danach schmecken würde. Eine leckere, leicht scharfe Variante einer Spargelcremsuppe, die zur Spargelsaison auf keinem Tisch fehlen darf."},{s:4,n:"Die Spargelcremesuppe mit Sahne verfeinern",d:"Nach etwa 15 Minuten gibt man einen Becher Sahne in die Spargelsuppe und zerkleinert den Spargel mit einem Pürierstab. Nun wird die Suppe mit Salz, Zucker, Zitronenpfeffer, Cayennepfeffer und ein paar Spritzern Zitrone gewürzt. Mit dem Zitronenpfeffer vorsichtig würzen, da die Suppe sonst zu sehr danach schmecken würde. Eine leckere, leicht scharfe Variante einer Spargelcremsuppe, die zur Spargelsaison auf keinem Tisch fehlen darf."},{s:5,n:"nun kommt das Feuer in die Spargelcremesuppe",d:"Zum Schluss alles schön anrichten. Dazu gibt man die Spargelcremesuppe vorsichtig auf einen Teller, häuft die angebratenen Spargelscheiben in der Mitte des Tellers auf, schneidet noch 2 dünne Scheiben einer frischen Chilischote hinein und garniert das ganze mit Petersilie."},{s:5,n:"nun kommt das Feuer in die Spargelcremesuppe",d:"Zum Schluss alles schön anrichten. Dazu gibt man die Spargelcremesuppe vorsichtig auf einen Teller, häuft die angebratenen Spargelscheiben in der Mitte des Tellers auf, schneidet noch 2 dünne Scheiben einer frischen Chilischote hinein und garniert das ganze mit Petersilie."}],p:"00:10",c:"00:45",tot:60,srv:"3",cats:["Suppen & Eintöpfe","Vegetarisch"]},{id:2679,t:"Spargel Mit Einer Kalten Krautersauce",i:[{n:"Spargel",u:"Kg",a:"2"},{n:"Spargel",u:"Kg",a:"2"},{n:"Butter",u:"EL",a:"2"},{n:"Zucker",u:"EL",a:"1"},{n:"große Gewürzgurke",u:"Stk",a:"1"},{n:"Zitrone",u:"Stk",a:"1"},{n:"Ei",u:"Stk",a:"1"},{n:"Basilikum",u:"Bd",a:"0.5"},{n:"Petersilie",u:"Bd",a:"0.5"},{n:"große Gewürzgurke",u:"Stk",a:"1"},{n:"Schalotten",u:"Stk",a:"2"},{n:"Kapern",u:"EL",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Sonnenblumenöl",u:"EL",a:"5"},{n:"Butter",u:"EL",a:"6"},{n:"Semmelbrösel",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Spargel schälen und bissfest kochen",d:"Einen großen Topf mit Wasser auffüllen. Sobald das Wasser kocht, werden 3 Stück Butter, 1 EL Zucker, 1 EL Zitrone und 1-2 TL Salz hinein gegeben. Während das Wasser erhitzt wird, kann der Spargel geschält werden. Die Schale und die Enden aufheben. Daraus läßt sich eine schmackhafte Spargelcremesuppe zaubern. Sobald das Wasser kocht, gibt man die geschälten Spargelstangen hinein."},{s:2,n:"Kalte Kräutersoße zubereiten",d:"Für die kalte Kräutersauce oder auch Salsa Verde genannt stellt man eine Schüssel bereit. Gleich zu Beginn kann man einen kleinen Topf mit Wasser erhitzen und ein Ei hart kochen. Danach abschrecken, abpellen und kleinhacken. Die Basilikumblätter, den Petersilie, die Kapern sehr fein hacken. Saure Gurken, die Schalotten sowie zwei Knoblauchzehen in sehr feine Würfel schneiden. Alles zusammen in eine Schüssel geben, mit Sonnenblumenöl, Zitronensaft, Salz und Pfeffer gut vermischen und kräftig abschmecken."},{s:3,n:"Braune Butter für den Spargel",d:"Wer mag, erhitzt noch schnell einen kleinen Topf mit Butter, Semmelbrösel und einer Prise Salz. Nun darf der Spargel auf einem Teller, zusammen mit der Salsa Verde und der braunen Butter serviert werden. Ich muß sagen, es war ein Experiment, ob man Spargel auch mit einer anderen Sauce als brauner Butter oder Sauce Hollandaise genießen kann. Man kann :-)"}],p:"00:15",c:"00:20",tot:40,srv:"4",cats:["Vegetarisch"]},{id:2689,t:"Gruner Spargel Mit Gebratenen Nudeln",i:[{n:"Grüner Spargel",u:"g",a:"300"},{n:"Weißer Spargel",u:"g",a:"300"},{n:"Nudeln",u:"g",a:"300"},{n:"Zwiebellauch",u:"Stangen",a:"3"},{n:"rote Chilischote",u:"Stk",a:"1"},{n:"Koriander",u:"",a:""},{n:"Ölivenöl",u:"EL",a:"4"},{n:"Ölivenöl",u:"EL",a:"4"},{n:"Sesamöl",u:"TL",a:"15"},{n:"helle Sojasauce",u:"EL",a:"5"},{n:"Honig",u:"EL",a:"1"},{n:"Butter",u:"EL",a:"1"}],st:[{s:1,n:"Nudeln kochen und Spargel schälen",d:"Die Nudeln in Wasser mit einem TL Salz bissfest kochen. Abgießen, in einem Sieb abtropfen lassen und zur Seite stellen. Den grünen sowie weißen Spargel schälen, die Enden entfernen und das untere Drittel der Spargelstangen schräg in schmale Scheiben schneiden. Die Chilischote abwaschen und ebenso in dünne Ringe schneiden. Den Koriander grob hacken."},{s:2,n:"Sojasoße Sesam Marinade vorbereiten und Spargel anbraten",d:"In einer kleinen Schüssel Sojasoße, Honig und Sesamöl gut vermischen. Einen Wok oder eine Pfanne mit Olivenöl erhitzen und den Spargel unter ständigem Rühren ca. 2-3 Minuten anbraten und mit Zucker und Salz würzen. Herausnehmen und zur Seite stellen."},{s:3,n:"Nudeln anbraten",d:"In der gleichen Pfanne werden nun die Nudeln mit dem Sesamöl ca. 3 Minuten angebraten. Das Soja,Honig, Sesamöl Gemisch hinzugeben und gut einkochen. Zum Schluss die Butter, das Gemüse und klein geschnittenen Zwiebellauch hinzugeben und unter Rühren etwa 2 Minuten braten. Alles zusammen nett auf einem Teller anrichten, mit dem grob gehackten Koriander bestreuen und servieren. Ungewöhnlich war für mich, hier den Spargel mit asiatischen Soßen und Kräutern zu würzen. Es hat sich jedoch gelohnt. Als Vorspeise gab es bei uns die feurige Spargelcremesuppe. Am besten eignet sich hierfür die helle Sojasauce. Das Gemüse und die Nudeln behalten dann ihre frische Farbe bei."}],p:"00:10",c:"00:15",tot:30,srv:"4",cats:["Pasta & Nudeln","Vegetarisch"]},{id:2699,t:"Rezept 2699",i:[{n:"mittelgroße festkochende Kartoffeln",u:"Stk",a:"3"},{n:"Hackfleisch gemischt",u:"g",a:"500"},{n:"Suppengrün",u:"Bd",a:"1"},{n:"edelsüsses Paprikapulver",u:"TL",a:"2"},{n:"Kümmel",u:"TL",a:"0.5"},{n:"Zimt",u:"TL",a:"0.5"},{n:"gerebelter Majoran",u:"TL",a:"3"},{n:"frischer Oregano",u:"Stängel",a:"2"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Tube Tomatenmark",u:"Stk",a:"0.5"},{n:"Wasser",u:"L",a:"1"},{n:"Zitronenpfeffer",u:"",a:""},{n:"Honig oder Zucker",u:"",a:""},{n:"Salz",u:"",a:""}],st:[{s:1,n:"Kartoffeln schälen",d:"Schritt für Schritt Zubereitung - unwiderstehliches Hackfleischgulasch Kartoffeln schälen und in mundgerechte Würfel schneiden. In einer Schüssel zur Seite stellen."},{s:2,n:"Suppengrün putzen",d:"Möhren schälen, vom Porree die Enden und das äußerste Blatt sowie vom Sellerie die braunen Stellen entfernen. Das Gemüse sehr klein schneiden. 2 Knoblauchzehen schälen und fein hacken."},{s:2,n:"Suppengrün putzen",d:"Möhren schälen, vom Porree die Enden und das äußerste Blatt sowie vom Sellerie die braunen Stellen entfernen. Das Gemüse sehr klein schneiden. 2 Knoblauchzehen schälen und fein hacken."},{s:3,n:"Hackfleisch anbraten",d:"Das Hackfleisch wird in einem mit Öl erhitzen Topf krümlig angebraten. Das Hackfleisch darf während dessen schon mit Salz, Pfeffer und 2 TL gerebeltem Majoran gewürzt werden. Danach herausnehmen und in einer Schüssel zur Seite stellen. In den Bratensud wird etwas Butter erhitzen und das Gemüse darin glasig anbraten."},{s:3,n:"Hackfleisch anbraten",d:"Das Hackfleisch wird in einem mit Öl erhitzen Topf krümlig angebraten. Das Hackfleisch darf während dessen schon mit Salz, Pfeffer und 2 TL gerebeltem Majoran gewürzt werden. Danach herausnehmen und in einer Schüssel zur Seite stellen. In den Bratensud wird etwas Butter erhitzen und das Gemüse darin glasig anbraten."},{s:4,n:"Hackfleisch und Gemüse vereinen",d:'Nach etwa 5 Minuten wieder Hackfleisch hinzugeben. 1/2 "“ 1 Tube Tomatenmark hineingeben. Anschließend 3 TL edelsüßes Paprikapulver, 1/2 TL Kümmel und 1/2 TL Zimt hinzufügen.'},{s:4,n:"Hackfleisch und Gemüse vereinen",d:'Nach etwa 5 Minuten wieder Hackfleisch hinzugeben. 1/2 "“ 1 Tube Tomatenmark hineingeben. Anschließend 3 TL edelsüßes Paprikapulver, 1/2 TL Kümmel und 1/2 TL Zimt hinzufügen.'},{s:5,n:"30 Minuten köcheln lassen",d:"]Alles etwa 2-3 Minuten anbraten und zum Schluss mit 1 1/2 l heißem Wasser auffüllen. Verrühren, mit dem Saft einer Zitrone würzen, kurz aufkochen lassen, die Kartoffeln hinzufügen und etwa 30 Minuten bei reduzierter Hitze und geschlossenem Topf köcheln lassen."},{s:5,n:"30 Minuten köcheln lassen",d:"]Alles etwa 2-3 Minuten anbraten und zum Schluss mit 1 1/2 l heißem Wasser auffüllen. Verrühren, mit dem Saft einer Zitrone würzen, kurz aufkochen lassen, die Kartoffeln hinzufügen und etwa 30 Minuten bei reduzierter Hitze und geschlossenem Topf köcheln lassen."},{s:6,n:"Abschmecken",d:"Zum Schluss kräftig mit Salz und Zitronenpfeffer abschmecken und servieren."},{s:6,n:"Abschmecken",d:"Zum Schluss kräftig mit Salz und Zitronenpfeffer abschmecken und servieren."}],p:"00:15",c:"00:50",tot:70,srv:"4",cats:["Sonstiges"]},{id:2707,t:"Steak Mit Rosmarinkartoffeln Und Krauterbutter",i:[{n:"große Scheiben Rind (können halbiert werden)",u:"Stk",a:"3"},{n:"Rosmarin",u:"Zweige",a:"4"},{n:"gerebelter Rosmarin",u:"EL",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"4"},{n:"Butter",u:"g",a:"100"},{n:"Butterschmalz",u:"EL",a:"1"},{n:"kleine Kartoffeln",u:"g",a:"600"},{n:"Öl",u:"TL",a:"1"},{n:"Kräuterbutter",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Rosmarinkartoffeln vorbereiten",d:"Den Ofen auf 180 Grad vorheizen. Ein Backblech mit Backpapier auslegen. Die kleinen Kartoffeln ordentlich abwaschen, halbieren und in eine Schüssel geben. Mit Salz, einem TL Öl und gerebeltem Rosmarin würzen und gut miteinander vermengen. Alles zusammen für etwa 30-40 Minuten in den Ofen auf das Backblech verteilen. Die Rosmarinzweige gut abspülen und trocken schütteln. Die Knoblauchzehen schälen und ggf. halbieren."},{s:2,n:"Steak anbraten und in den Ofen legen",d:"Etwa 15 Minuten nachdem man die Kartoffeln in den Ofen gegeben hat, wird eine Pfanne, wenn möglich gusseisern, mit Butterschmalz erhitzt. Sobald diese richtig heiß geworden ist, werden die Fleischstücken (mindestens 3 cm dick) in die Pfanne gegeben und etwa 2-3 Minuten kräftig von beiden Seiten angebraten. Die Poren sollen sich so schließen und den Saft im Fleisch behalten. Danach werden die angebratenen Fleischscheiben auf Alufolie in den Ofen gegeben. Je nachdem, ob man das Fleisch blutig, englisch, rosa, halbrosa oder durchgebraten mag, bleiben die Scheiben zwischen 5-15 Minuten im Ofen liegen. Danach herausnehmen und nochmals ca. 3 Minuten ruhen lassen."},{s:3,n:"Steaksoße einfach zubereitet",d:"Währenddessen wird die Pfanne nochmals erhitzt. Man gibt nun 2 Stück Butter, Salz, die Knoblauchzehen und den Rosmarin in die Pfanne. Sobald die Butter heiß und flüssig geworden ist, die Pfanne kurz schwenken, sodaß sich alles gut verteilt. Nun werden die Steakscheiben etwa 1 Minute von beiden Seiten nochmals kurz angebraten. Das Aroma aus Rosmarin und Knoblauch kann sich so gut auf dem Fleisch verteilen und die Oberfläche wird kross angebraten. Danach darf sofort serviert werden. Die Rosmarinkartoffeln dürften nun auch fertig gebacken sein. Das Fleisch, die Kartoffeln und den Rosmarin-Knoblauch-Butter Sud auf den Steaks verteilen, Pfeffer aus der Mühle darüber, Kräuterbutter daneben legen und schmecken lassen. Ein einfaches aber kräftig würziges Gericht, wenn der Appetit auf Fleisch überhand nimmt. Das nochmalige Anbraten der Steaks in dem Sud aus Rosmarin und Knoblauch gibt dem Fleisch den letzten Pfiff."}],p:"00:10",c:"00:40",tot:50,srv:"4",cats:["Fleisch"]},{id:2714,t:"Tomatensalat In Einer Balsamico Vinaigrette",i:[{n:"Kirschtomaten",u:"g",a:"750"},{n:"kleine Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Oregano",u:"TL",a:"2"},{n:"dunkler Balsamico Essig",u:"TL",a:"3"},{n:"Sonnenblumenöl",u:"TL",a:"4"},{n:"Ziegenkäse",u:"Pck",a:"1"}],st:[{s:1,n:"Tomaten, Knoblauch und Zwiebeln schneiden",d:"Die Tomaten abwaschen, halbieren und den Strunk entfernen. Dafür einfach vorsichtig V-förmig links und rechts vom Strunk einschneiden und herausnehmen. Danach die halbierten Tomaten in grobe Stücke schneiden. Die Knoblauchzehen schälen und sehr fein hacken. Die kleine Zwiebel ebenso schälen und sehr fein schneiden. Alles zusammen in eine Schüssel geben."},{s:2,n:"Balsamico-Vinaigrette zubereiten",d:"Für die Balsamico-Vinaigrette nimmt man eine kleine Schüssel und fügt, 3 EL dunklen Balsamico-Essig, 2 TL Oregano, gerebelt oder frisch (kleingehackt), ca. 1 TL Salz und Pfeffer aus der Mühle hinein und vermischt dies kräftig miteinander. Abschmecken und ggfs. nachwürzen. Sobald man den gewünschten Geschmack für die Vinaigrett gefunden hat, mit 4 EL Sonnenblumenöl vermengen. Mit einer Gabel unterschlagen oder in einem geschlossenen Gefäss kräftig schütteln."},{s:3,n:"Vinaigrette mit Tomaten vermengen",d:"Dies nun zu den Tomaten in die Schüssel geben, ordentlich miteinander vermengen und für ca. 15 Minuten zum ziehen in den Kühlschrank geben."},{s:4,n:"mit Ziegenkäse verfeinern",d:"Danach heraursnehmen und einen Ziegenkäse seiner wahl darüber bröseln."}],p:"00:15",c:"00:1",tot:30,srv:"4",cats:["Salate"]},{id:2720,t:"Rosmarin Pellkartoffeln Mit Einem Paprika Gurken Quark",i:[{n:"mittelgroße Kartoffeln (festkochend)",u:"Stk",a:"10"},{n:"Rosmarinzweige",u:"Stk",a:"2"},{n:"Sonnenblumenöl",u:"EL",a:"1"},{n:"Magerquark",u:"g",a:"250"},{n:"Sonnenblumenöl",u:"EL",a:"1"},{n:"Wasser mit Kohlensäure",u:"EL",a:"2"},{n:"8 Kräuter (gefroren)",u:"TL",a:"2"},{n:"rote Paprika",u:"Stk",a:"1"},{n:"Gurke",u:"Stk",a:"0.25"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen",d:"Die mittelgroßen Kartoffeln ordentlich abwaschen und etwa 20-25 Minuten kochen. Während dessen eine rote Paprikaschote entkernen, abwaschen und in kleine Würfel schneiden. Die Gurke ebenso in kleine Würfel schneiden. Nach etwa 15 Minuten den Ofen auf 180 Grad vorheizen."},{s:2,n:"Paprika - Gurken Quark zubereiten",d:"Zum Gemüse gibt man nun mit 250 g Magerquark, 2 EL Wasser mit Kohlensäure, 1 EL Sonnenblumenöl, 2 TL 8 Kräuter, Salz und Pfeffer und rührt alles glatt. Sollte der Quark noch zu fest sein, einfach noch etwas Wasser hinzufügen, glattrühren und bis zum servieren in den Kühlschrank geben."},{s:2,n:"Paprika - Gurken Quark zubereiten",d:"Zum Gemüse gibt man nun mit 250 g Magerquark, 2 EL Wasser mit Kohlensäure, 1 EL Sonnenblumenöl, 2 TL 8 Kräuter, Salz und Pfeffer und rührt alles glatt. Sollte der Quark noch zu fest sein, einfach noch etwas Wasser hinzufügen, glattrühren und bis zum servieren in den Kühlschrank geben."},{s:3,n:"Rosmarinkartoffeln in den Ofen geben",d:"Die Kartoffeln in kaltem Wasser kurz abschrecken. Mit einem Messer ein- jedoch nicht durchschneiden. Die Kartoffeln werden nun auf Alufolie gebettet, mit Rosmarinnadeln und grobem Meersalz bestreut. Die Kartoffeln in die Alufolie einwickeln und für etwa 8 Minuten in den vorgeheizten Ofen geben. Danach darf sofort serviert werden. Wer steht schon gern bei 38 Grad Aussentemperatur in der Küche neben der nächsten Wärmequelle. Da eignet sich diese Gericht hervorragend um ein einfaches leichtes Sommergericht auf den Tisch zu zaubern. Dazu gab es bei uns Butter und Matjes in Zwiebelsauce."},{s:3,n:"Rosmarinkartoffeln in den Ofen geben",d:"Die Kartoffeln in kaltem Wasser kurz abschrecken. Mit einem Messer ein- jedoch nicht durchschneiden. Die Kartoffeln werden nun auf Alufolie gebettet, mit Rosmarinnadeln und grobem Meersalz bestreut. Die Kartoffeln in die Alufolie einwickeln und für etwa 8 Minuten in den vorgeheizten Ofen geben. Danach darf sofort serviert werden. Wer steht schon gern bei 38 Grad Aussentemperatur in der Küche neben der nächsten Wärmequelle. Da eignet sich diese Gericht hervorragend um ein einfaches leichtes Sommergericht auf den Tisch zu zaubern. Dazu gab es bei uns Butter und Matjes in Zwiebelsauce."}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Vegetarisch"]},{id:2724,t:"Gemusepfanne Aus Dem Wok",i:[{n:"brauen Champignons",u:"Stk",a:"8"},{n:"frische Bohnen",u:"g",a:"150"},{n:"mittelgroße Möhren",u:"Stk",a:"2"},{n:"Kirschtomaten",u:"Stk",a:"10"},{n:"kleine Zucchini",u:"Stk",a:"0.5"},{n:"mittelgroße rote Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"rote und grüne Paprikaschote",u:"Stk",a:"0.5"},{n:"Ingwerwurzel",u:"cm",a:"2"},{n:"grüner Zwiebellauch",u:"Stk",a:"0.33"},{n:"Hühnerfleisch",u:"g",a:"350"},{n:"helle Sojasauce",u:"EL",a:"5"},{n:"Worchestersauce",u:"TL",a:"1"},{n:"Sesamöl",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hühnerfleisch schneiden und marinieren",d:"Das Hühnerfleisch abwaschen, mit Küchenpapier trockentupfen und in schmale 3 cm große Scheiben schneiden. In eine Schüssel geben, mit 3 EL heller Sojasauce, 1 TL Worchesterause und 1 Tl Sesamöl vermengen und für ca. 15 Minuten in den Kühlschrank geben. Einen kleinen Topf mit Wasser erhitzen."},{s:2,n:"Gemüse schneiden schneiden schneiden ... :-)",d:"Das Gemüse sollte selbstverständlich ordentlich abgewaschen werden. Die Champignons halbieren und ebenso wie die Möhren in Scheiben schneiden. Von den Bohnen die Enden entfernen und dritteln. Die Zucchini in Sticks, die grüne und rote Paprika in grobe Stücke scheiden. Die Kirschtomaten vierteln, die rote Zwiebel achteln und auseinander pulen. Zum Schluss den Zwiebellauch in Ringe schneiden und 2 Knoblauchzehen sowie eine 2 cm große Ingwerwurzel schälen und kleinhacken."},{s:3,n:"Grüne Bohnen garen",d:"Die Bohnen in dem Wassertopf mit etwas Salz ca. 5 Minuten garen. Danach mit kaltem Wasser abschrecken und zur Seite stellen."},{s:4,n:"Fleisch und Gemüse im Wok braten",d:"Nun darf ein Wok mit Sesamöl erhitzt werden. Sobald das Öl sehr heiß geworden ist, wird das Fleisch unter ständigem Rühren darin angebraten. Nach etwa 5 Minuten herausnehmen und in einer Schüssel zur Seite stellen.Ggfs. erhitzt man nochmals etwas Sesamöl und gibt nun zuerst den Knoblauch und den Ingwer hinein, etwa 1 Minute darin anbraten und schwenken. Nun folgen die Möhren, die Champignons, die roten Zwiebeln und der Paprika. Nach etwa 3-5 Minuten (abhängig von der Wokgröße) werden nun die vorgegarten Bohnen, die Tomaten als auch die Zucchinistreifen zusammen mit dem Fleisch in den Wok gegeben. Alle Zutaten vorsichtig miteinander vermengen und mit 2 EL heller Sojasauce, Pfeffer und ggfs. etwas Salz abschmecken. Zwiebellauch darüber streuen. Eigentlich sollte die Gemüsepfanne ausreichen um satt zu werden. Doch eignet sich dazu ebenso Reis bzw. ein frisches Baguette vom Bäcker. Ein perfektes Gericht für die Strandfigur........wenn das dann noch hilft ;-) Gemüse in dieser geballten Masse haben sogar unsere Kinder vertragen. Die helle Sojasauce eignet sich insbesondere für Gemüse oder hellem Fleisch. So bleiben die Farben der einzelnen Zutaten erhalten."}],p:"00:30",c:"00:15",tot:45,srv:"4",cats:["Asiatisch"]},{id:2730,t:"Charolais Steak Auf Bohnensalat Vinaigrette",i:[{n:"Rindfleisch (Charolais min. 3 cm dicke Scheiben)",u:"g",a:"700"},{n:"frische Bohnen",u:"g",a:"500"},{n:"große rote Zwiebeln",u:"Stk",a:"3"},{n:"scharfen Bautzener Senf",u:"EL",a:"3"},{n:"Estragron Essig",u:"EL",a:"4"},{n:"Sonnenblumenöl",u:"EL",a:"5"},{n:"Rosmarinzweige",u:"Stk",a:"3"},{n:"Knoblauchzehen",u:"Stk",a:"4"},{n:"Zucker",u:"Prise",a:"1"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Bohnen und restliches Gemüse zuschneiden",d:"Von den Bohnen die Enden abschneiden, abwaschen und in kochendem Salzwasser ca. 5-10 Minuten garen. Danach herausnehmen, sehr kalt abschrecken und zur Seite stellen. Knoblauch schälen und halbieren. 3 Rosmarinzweige abspülen und trockenschütteln. Drei große rote Zwiebeln schälen und in schmale Streifen schneiden. Dazu werden die Zwiebeln halbiert und quer zur Maserung geschnitten. Die Kirschtomaten abwaschen und je nach Größe halbieren oder vierteln. Den Ofen auf ca. 180 Grad vorheizen."},{s:2,n:"Charolais Steak scharf anbraten und in den Ofen geben",d:"Das Steak, sollte mindestens 3 cm dick sein, mit kaltem Wasser abspülen und mit Küchenpapier trocken tupfen. Eine gusseiserne Pfanne mit Öl erhitzen und das Fleisch etwa 3 Minuten von allen Seiten scharf anbraten. Danach werden die Steakscheiben für ca. 10-20 Minuten auf einer Alufolie in den Ofen gegeben. Die Zeit ist abhängig davon, wie durchgebraten das Fleisch sein soll."},{s:3,n:"Vinaigrette zubereiten und den Bohnen zufügen",d:"Während das Fleisch im Ofen liegt, bereitet man die Vinaigrette zu. Dafür verrührt man 2-3 EL scharfen Bautzener Senf, Estragonessig, Salz und eine Prise Zucker mit dem Stabmixer. Ich hatte in den Lebensmittelläden keinen Estragonessig gefunden. Dafür fand ich zu Hause noch etwas Kräuteressig und habe mir zudem noch ein paar Stängel frischen Estragon geholt. Ein paar davon in die Kräuteressig Flasche getan und über Nacht ziehen gelassen. Die Vinaigrette sollte kräftig gewürzt sein und noch einen leichten säuerlichen Geschmack aufweisen. Sobald das Fleisch aus dem Ofen genommen wurde, fügt man der Vinaigrette den ausgetretenen Fleischsaft hinzu und verrührt diesen. Die Vinaigrette gibt man nun zu den Bohnen und den Zwiebeln in eine Schüssel, vermengt alles miteinander und läßt dies kurz ziehen."},{s:4,n:"Charolais Steak herzhaft würzen",d:"Nun wird die Pfanne mit Butter, Salz, Knoblauch und den Rosmarinzweigen erhitzt. Das Fleisch wird nun nochmals 1 Minute von beiden Seiten kross angebraten. Herausnehmen und kurz zur Seite stellen. Die geviertelten Tomaten ebenso für etwa 1 Minute in dem Bratensud anbraten. Nun darf alles nett auf einem Teller angerichtet werden. Dazu legt man die Bohnen eng auf den Teller, legt das Fleisch darauf und verteilt die Tomaten darüber. Mit groben Meersalz und Pfeffer aus der Mühle würzen. Eine raffiniertes Gericht aus lauwarmen Bohnen und einem kräftig gewürztem Steak aus der Region Charolais. Ideal für lauwarme Sommertage geeignet."}],p:"00:25",c:"0:25",tot:60,srv:"4",cats:["Fleisch","Salate"]},{id:2734,t:"Fischfilet In Alufolie",i:[{n:"Fischfilet",u:"g",a:"800"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Thymianzweige",u:"Stk",a:"5"},{n:"Butter",u:"g",a:"100"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Baguette",u:"Stk",a:"1"}],st:[{s:1,n:"Fischfilet und Gemüse vorbreiten",d:"Den Ofen auf 180 Grad vorheizen. Das Fischfilet mit kaltem Wasser abspülen und mit Küchenpapier trocken tupfen. Kirschtomaten abwaschen und in grobe Stücke schneiden. Zwei mittelgroße Zwiebeln schälen und klein würfeln. 2 Knoblauchzehen schälen und in dünne Scheiben schneiden. Ein paar Thymianzweige abspülen und trocken schütteln."},{s:2,n:"Fischfilet und Gemüse in Alufolie verpacken",d:"Nun werden 4 Alufolien ausgelegt. Darauf verteilt man eine Hälfte der klein geschnittenen Zwiebelwürfel. Darauf wird der Fisch gelegt, Knoblauchscheiben, Tomatenwürfel, Thymianzweige und die restlichen Zwiebeln darauf verteilen. Butterflocken darüber geben und alles mit Salz und Pfeffer kräftig würzen. Die Alufolie samt Inhalt wird nun in kleine Päckchen zusammengefaltet und verschlossen."},{s:2,n:"Fischfilet und Gemüse in Alufolie verpacken",d:"Nun werden 4 Alufolien ausgelegt. Darauf verteilt man eine Hälfte der klein geschnittenen Zwiebelwürfel. Darauf wird der Fisch gelegt, Knoblauchscheiben, Tomatenwürfel, Thymianzweige und die restlichen Zwiebeln darauf verteilen. Butterflocken darüber geben und alles mit Salz und Pfeffer kräftig würzen. Die Alufolie samt Inhalt wird nun in kleine Päckchen zusammengefaltet und verschlossen."},{s:3,n:"Fischfilet im Ofen garen",d:"Die Päckchen gibt man nun für ca. 15-20 Minuten in den vorgeheizten Ofen. Nun gart der Fisch gemächlich vor sich hin und die Aromen können sich heir wunderbar verteilen. Danach darf sofort serviert werden. Bei uns gab es dazu Baguette. Ein leicht bekömmliches und schnell zubereitetes Gericht für die heiße Sommerzeit."}],p:"00:10",c:"00:20",tot:35,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2737,t:"Reissalat",i:[{n:"Reis",u:"g",a:"250"},{n:"Kirschtomaten",u:"g",a:"250"},{n:"Rucola",u:"g",a:"150"},{n:"eingelegte getrocknete Tomaten",u:"g",a:"100"},{n:"eingelegte Oliven (hier \\Athener Oliven\\)",u:"g",a:"100"},{n:"kleine Mozzarellakugeln",u:"g",a:"250"},{n:"heller Balsamico Essig",u:"EL",a:"5"},{n:"Sonnenblumenöl",u:"EL",a:"4"},{n:"Salz/Pfeffer und Zucker",u:"",a:""}],st:[{s:1,n:"Reis kochen",d:"Reis in kochendem Salzwasser bissfest garen, abgießen und abkühlen lassen."},{s:2,n:"Gemüse schneiden",d:"Kirschtomaten abwaschen, vierteln, halbieren und in eine Schüssel geben. Die Oliven halbieren. Die eingelegten, getrockneten Tomaten in schmale Streifen schneiden und ebenso in die Schüssel geben. Die Oliven und die eingelegten Tomaten bestenfalls von der Frischetheke im Supermarkt holen. Das Aroma ist herrlich intensiv."},{s:3,n:"Rucola putzen",d:"Rucola mit kaltem Wasser abwaschen. Stiele entfernen und Blätter in grobe Stücke schneiden. So gelingt die perfekte Vinaigrette zum Reissalat"},{s:4,n:"Vinaigrette verrühren für einen schmackhaften Reissalat",d:"Für die Vinaigrette den hellen Balsamico Essig, Sonnenblumenöl, Salz, Pfeffer und eine Prise Zucker verrühren. Den säuerlichen Geschmack des Essigs leicht vorschmecken."},{s:5,n:"Vinaigrette vermengen",d:"Die Vinaigrette in die Schüssel geben und alles miteinander vermengen."},{s:6,n:"Mozzarellakugeln unterheben",d:"Sobald der Reis abgekühlt ist, zusammen mit den kleinen Mozzarellakugeln unterheben. Reissalat vor dem Servieren kurz ziehen lassen."}],p:"00:10",c:"00:15",tot:30,srv:"4",cats:["Salate"]},{id:2744,t:"Meeresfruechteragout",i:[{n:"Meeresfrüchte (TK)",u:"g",a:"500"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"rote, 1 grüne Paprikaschote",u:"Stk",a:"1"},{n:"geschälte Tomaten",u:"gr. Dose",a:"1"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Kochschinken",u:"g",a:"100"},{n:"Oregano und 1 TL Basilikum",u:"TL",a:"1"},{n:"Gemüse- oder Fischbrühe",u:"ml",a:"250"},{n:"Rotwein",u:"Glas",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Olivenöl",u:"EL",a:"2"},{n:"Worchestersauce",u:"",a:""},{n:"Zitronensaft",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse und Schinken klein schneiden",d:"Die tiefgefrorenen Meeresfrüchte auftauen lassen. Die Knoblauchzehen grob zerkleinern und in einem Mörser mit einem TL Salz zerreiben. Eine mittelgroße Zwiebel schälen und klein würfeln. Die roten und grünen Paprikaschoten entkernen, abwaschen und ebenso wie den Kochschinken in sehr schmale Streifen schneiden."},{s:2,n:"Gemüse anbraten",d:"Eine Pfanne mit etwas Olivenöl erhitzen und sowohl die Zwiebeln als auch den zerriebenen Knoblauch glasig schwitzen. Danach den in Streifen geschnittenen Paprika dazugeben und kurz mitschwitzen. Den Kochschinken zum Gemüse geben, den Tomatenmark zusammen mit Oregano und Basilikum bestreuen, einrühren und anbraten. Hier darf man gern den gerebelten Oregano/Basilikum nehmen. Frische Kräuter entfalten Ihr Aroma noch etwas kräftiger."},{s:3,n:"Meeresfrüchte hinzufügen",d:"Nun dürfen die aufgetauten Meeresfrüchte zum Gemüse gegeben werden, mit Rotwein und Gemüsebrühe ablöschen. Wer hat, kann auch Fischbrühe hinzufügen. Die geschälten Tomaten aus der Dose hinzugeben und alles zusammen etwa 15-20 Minuten bei reduzierter Hitze leicht köcheln lassen. Zum Schluss das Ragout mit Salz, Pfeffer, Zitronensaft und Worchestersauce kräftig abschmecken und mit \\8 Kräutern\\ aus dem Tiefkühler bestreuen. Dazu serviert man Reis oder Baguette. Sehr lecker. Hierfür eignen sich ebenso Tintenfischringe. Die Soße sollte kräftig gewürzt werden. Laßt die Meeresfrüchte nicht zu lange köcheln, da diese sonst zu zäh werden könnten."}],p:"00:15",c:"00:20",tot:40,srv:"4",cats:["Fisch & Meeresfrüchte"]},{id:2762,t:"In Sesamteig Gebackenes Fleisch Und Gemuese Mit Dip",i:[{n:"Hühnerfleisch",u:"g",a:"400"},{n:"Rindfleisch",u:"g",a:"200"},{n:"mittelgroße frische braune Champignons",u:"Stk",a:"6"},{n:"Mehl",u:"g",a:"200"},{n:"kaltes Wasser",u:"ml",a:"100"},{n:"Backpulver",u:"Pck",a:"0.5"},{n:"helle Sojasoße",u:"El",a:"4"},{n:"Sesamsamen",u:"El",a:"2"},{n:"Salz Pfeffer",u:"",a:""},{n:"Ei",u:"Stk",a:"1"},{n:"Reis",u:"El",a:"1"},{n:"Reis",u:"El",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"2"},{n:"Koriander",u:"Sängel",a:"5"},{n:"Knablauchzehe",u:"Stk",a:"1"},{n:"Fischsauce",u:"El",a:"2"},{n:"Limettensaft",u:"",a:""},{n:"brauner Zucker",u:"El",a:"1"},{n:"eingelegte getrocknete Tomaten",u:"Stk",a:"3"},{n:"Öl zum Frittieren",u:"",a:""},{n:"helle Sojasoße",u:"EL",a:"4"},{n:"Ingwerwurzel",u:"cm",a:"3"},{n:"helle Sojasoße",u:"EL",a:"4"},{n:"dunkle Sojasoße",u:"EL",a:"3"}],st:[{s:1,n:"Zubereitung der Marinaden",d:"Das Fleisch mit kaltem Wasser abspülen, mit Küchenpapier abtupfen und in schmale Streifen schneiden. Die Champignons je nach Größe in mundgerechte Stücke vierteln oder halbieren. Für das Fleisch: Den Ingwer schälen und sehr fein schneiden bzw. hacken. Die Hälfte des Ingwers gibt man nun zusammen mit 4 EL heller Sojasoße zum Hühnerfleisch. Die andere Hälfte zusammen mit 4 El dunkler Sojasoße zum Rindfleisch. Für die Champignons: Die Chamignons erhalten ebenso 3-4 EL helle Sojasoße hinzu. Wer noch etwas experimentieren möchte, fügt etwas Worchestersauce oder andere Würzsoßen hinzu. Hier darf alles ausprobiert werden, was schmeckt. Alles jeweils gut miteinander vermengen und für etwa 30 Minuten im Kühlschrank marinieren lassen."},{s:2,n:"Den Teig vorbereiten",d:"Dafür löst man das das Eiweiß vom Eigelb und schlägt nur das Eiweis mit einem Schneebesen in einer Schüssel steif. Sobald Ihr die Schüssel umdrehen könnt und Euch das steif geschlagene Eiweis nicht entgegen fällt, seid Ihr damit fertig. Nun wird nach und nach 100-200 ml kaltes Wasser, 200 g Mehl, 3-4 EL helle Sojasoße, 1/2 Pck. Backpulver, Salz und Pfeffer untergerührt. Zum Schluss soll ein flüssiger Teig vorhanden sein. Diesen Teig läßt man nun etwa 30 Minuten ziehen. Kurz bevor das Fleisch darin eingetunkt wird, fügt man nach Belieben 2-3 EL Sesamsamen hinzu."},{s:3,n:"Den Dip zubereiten",d:"Hierfür mahlt man 1 EL Reis sehr fein, hackt Korianderblätter und Zwiebellauch klein, schält und zerkleinert eine Knoblauchzehe sowie 2-3 eingelegte getrocknete Tomaten und vermengt dies zusammen mit der Fischsauce, Limettensaft, und braunem Zucker. Je nachdem ob Ihr es etwas saurer oder süsser mögt, fügt man entsprechend etwas mehr oder weniger Limettensaft, Zucker oder andere Zutaten hinzu. Auch dies darf für ein paar Minuten im Kühlschrank marinieren.Der Dip entfaltet erst zusammen mt dem Fleisch und dem Gemüse seine geschmackliche Wirkung. :-)"},{s:4,n:"Fleisch und Gemüse frittieren",d:"Nun gibt man genug Öl in einen Wok oder einen Topf und erhitzt diesen. Das Fleisch sowie das Gemüse fügt man jetzt dem Sesamteig hinzu und sobald das Öl heiß genug ist, wird das Fleisch und das Gemüse etwa 2-3 Minuten frittiert. Danach herausnehmen und auf dem Küchenpapier das Öl abtropfen lassen. Je nach Menge und Dauer des Frittierens kann man die fertigen Teile bei 50 Grad im Ofen warm halten. Zum Schluss alles nett anrichten und servieren. In Teig gebackenes Gemüse oder Fleisch eignen sich für viele Arten von Gerichten. Ob als Snack, für die asiatische Küche oder auf dem Buffet, überall sind diese kleinen Häppchen nicht nur ein handwerkliches Highlight, sondern auch ein Genuss für den Gaumen. Je nach Belieben darf die Marinade oder der Teig mit eigenen Würzsaucen geschmacklich verändert und aufgewertet werden. Die hier beschriebene Variante hat meinen Kiddies so gut geschmeckt, daß sie dieses Rezept in die Rubrik für Kindergerichte erhoben haben. Mehr geht nicht :-)"}],p:"00:60",c:"00:15",tot:80,srv:"4",cats:["Asiatisch"]},{id:2767,t:"Rindergulasch Fuer Die Kalte Jahreszeit",i:[{n:"Rindfleisch",u:"kg",a:"12"},{n:"große Gemüsezwiebeln (ca. 1 kg)",u:"Stk",a:"2"},{n:"große Gemüsezwiebeln (ca. 1 kg)",u:"Stk",a:"2"},{n:"Lorbeerblätter",u:"Stk",a:"2"},{n:"Thymian",u:"Zweige",a:"5"},{n:"edelsüsses Paprikapulver",u:"EL",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"4"},{n:"Kümmel",u:"TL",a:"1"},{n:"Zitrone",u:"Stk",a:"1"},{n:"Kalbsfond",u:"L",a:"1"},{n:"Speisestärke",u:"TL",a:"1"}],st:[{s:1,n:"Rindfleisch vorbereiten",d:"Das Rindfleisch mit kaltem Wasser abrausen, mit Küchenpapier trocken tupfen und in mundgerechte Stücke schneiden."},{s:2,n:"Zwiebeln schneiden, Kalbsfond erwärmen",d:"Zwei große Gemüsezwiebeln schälen und in Würfel schneiden. Einen Topf mit dem Kalbsfond kurz aufkochen und warm halten."},{s:3,n:"Fleisch und Zwiebeln portionsweise anbraten",d:"Einen Topf mit Öl erhitzen und die Zwiebelwürfel darin goldbraun anbraten, herausnehmen und zur Seite stellen. Im gleichen Topf werden nun die Rindfleischstücke kurz scharf angebraten. Immer nur eine Lage, sodaß das Fleisch nicht gleich im eigenen Saft kocht. Je nach Fleischmenge diesen Vorgang wiederholen."},{s:4,n:"Rindergulasch schmoren lassen",d:"Nun darf der Rindergulasch bei geschlossenem Topf ca. 3-4 Stunden bei reduzierter Hitze garen."},{s:5,n:"Fleisch und Zwiebeln portionsweise anbraten",d:"Einen Topf mit Öl erhitzen und die Zwiebelwürfel darin goldbraun anbraten, herausnehmen und zur Seite stellen. Im gleichen Topf werden nun die Rindfleischstücke kurz scharf angebraten. Immer nur eine Lage, sodaß das Fleisch nicht gleich im eigenen Saft kocht. Je nach Fleischmenge diesen Vorgang wiederholen."},{s:6,n:"Rindergulasch schmoren lassen",d:"Nun darf der Rindergulasch bei geschlossenem Topf ca. 3-4 Stunden bei reduzierter Hitze garen."},{s:7,n:"Rindergulasch würzen",d:"Für die Gulaschwürze zermahlt man 4 Knoblauchzehen mit 1 TL Salz, 1 TL Kümmel, der Schale einer geriebenen Zitrone miteinandern, sodaß eine schöne Paste entsteht. Etwa die Hälfte des Gulaschgewürz gibt man etwa nach einer halben Stunde in den Topf, den Rest etwa 2,5-3 Stunden nach einer Garprobe hinzu. Evtl. weiter garen lassen."},{s:8,n:"Ist die Soße zu dünn - hier ein Tipp",d:"Es kann vorkommen, wenn auch selten, daß die Soße noch etwas zu dünnflüssig ist. Hier kann jedoch schnell gegengesteuert werden. [su_note class=\\text-block\\]1-2 TL Speisestärke in einem Becher mit kaltem Wasser gut verrühren bis sich alle Klümpchen aufgelöst haben. Danach sofort in die Soße geben, verrühren und nochmals kurz aufkochen lassen. Der Effekt tritt nahezu sofort ein und Ihr erhaltet eine schöne sämige Gulaschsoße ohne jedoch den Geschmack zu verändern.[/su_note]"}],p:"00:20",c:"3:20",tot:230,srv:"4",cats:["Fleisch"]},{id:2773,t:"Bunter Salat Mit Mozzarella Und Balsamico",i:[{n:"Kirschtomaten",u:"g",a:"250"},{n:"große Eiertomaten",u:"Stk",a:"3"},{n:"große Mozzarellakugeln",u:"Pck",a:"2"},{n:"kleine Mozzarellakugeln",u:"Pck",a:"1"},{n:"Ruccola",u:"Pck",a:"1"},{n:"Basilikum",u:"Stängel",a:"5"},{n:"Pinienkerne",u:"Pck",a:"1"},{n:"dunkler Balsamico Essig",u:"EL",a:"6"},{n:"Sonnenblumenöl",u:"EL",a:"6"},{n:"Senf",u:"TL",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Ahornsirup oder Honig",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Limette",u:"Stk",a:"1"}],st:[{s:1,n:"Kräuter, Tomaten und Pinienkerne vorbereiten",d:"Die Tomaten, den Ruccola sowie den Basilikum abwaschen und abtrocknen bzw. trocken schütteln. Die großen Tomaten sowie die großen Mozzarellakugeln in Scheiben schneiden. Die Basilikumblätter abzupfen, vom Ruccola die Stiele entfernen. Die Pinienkerne in einer Pfanne vorsichtig goldbraun anrösten."},{s:2,n:"Zubereitung der Balsamico Vinaigrette",d:"Dafür werden 1/3 der Basilikumblätter sowie 2 Knoblauchzehen geschält und kleingehackt. Dies gibt man nun zusammen mit 6 EL dunklem Balsamico Essig, 1 TL Senf, 1 EL Ahornsirup oder auch Honig, dem Saft einer Limette sowie Salz und Pfeffer in ein hohes Gefäß. Nun mit einer Küchenmaschine oder einem Stabmixer kräftig durchmixen. Bevor das Öl hinzugefügt wird, muß der Geschmack der Vinaigrette gefunden werden. Also ggfs. mit o.g. Zutaten nachwürzen und kräftig abschmecken. Sobald dies schmeckt, gibt man ca. 6-8 EL Öl hinzu und mixt auch dies kräftig durch. Nun wird der Geschmack eingeschlossen und die Vinaigrette ist dadurch ein paar Tage halbar."},{s:2,n:"Zubereitung der Balsamico Vinaigrette",d:"Dafür werden 1/3 der Basilikumblätter sowie 2 Knoblauchzehen geschält und kleingehackt. Dies gibt man nun zusammen mit 6 EL dunklem Balsamico Essig, 1 TL Senf, 1 EL Ahornsirup oder auch Honig, dem Saft einer Limette sowie Salz und Pfeffer in ein hohes Gefäß. Nun mit einer Küchenmaschine oder einem Stabmixer kräftig durchmixen. Bevor das Öl hinzugefügt wird, muß der Geschmack der Vinaigrette gefunden werden. Also ggfs. mit o.g. Zutaten nachwürzen und kräftig abschmecken. Sobald dies schmeckt, gibt man ca. 6-8 EL Öl hinzu und mixt auch dies kräftig durch. Nun wird der Geschmack eingeschlossen und die Vinaigrette ist dadurch ein paar Tage halbar."},{s:3,n:"Salat auf dem Teller anrichten",d:"Nun darf alles schön auf einem Teller angerichtet werden. Dafür verteilt man zuerst ein paar Ruccolablätter auf dem Teller, darauf baut man abwechselnd mit den Tomaten-/ und Mozzarellascheiben, den Basilikumblättern fächerförmig eine Pyramide auf. Diese wird mit einem kleinen Holzspieß aufrecht gehalten. Darum die Mozzarellakügelchen, die Kirschtomaten sowie die Pinienkerne locker drauf verteilen. Zum Schluss verteilt man mit einem Esslöffel die Balsamico-Vinaigrett darauf. Bei uns gab es dazu Baguette und Kräuterbutter. Ein schnelles Gericht, ein einfaches Gericht. Ideal für den kleinen Hunger. Das Herz dieses Salates ist natürlich die Vinaigrette. Die war der Hammer. Genau wie beim Italiener eignet sich die verbliebene Vinaigrette ideal dazu, mit dem Baguette aufgetunkt und vernascht zu werden:-)"},{s:3,n:"Salat auf dem Teller anrichten",d:"Nun darf alles schön auf einem Teller angerichtet werden. Dafür verteilt man zuerst ein paar Ruccolablätter auf dem Teller, darauf baut man abwechselnd mit den Tomaten-/ und Mozzarellascheiben, den Basilikumblättern fächerförmig eine Pyramide auf. Diese wird mit einem kleinen Holzspieß aufrecht gehalten. Darum die Mozzarellakügelchen, die Kirschtomaten sowie die Pinienkerne locker drauf verteilen. Zum Schluss verteilt man mit einem Esslöffel die Balsamico-Vinaigrett darauf. Bei uns gab es dazu Baguette und Kräuterbutter. Ein schnelles Gericht, ein einfaches Gericht. Ideal für den kleinen Hunger. Das Herz dieses Salates ist natürlich die Vinaigrette. Die war der Hammer. Genau wie beim Italiener eignet sich die verbliebene Vinaigrette ideal dazu, mit dem Baguette aufgetunkt und vernascht zu werden:-)"}],p:"00:15",c:"00:00",tot:20,srv:"4",cats:["Salate"]},{id:2778,t:"Linguine Mit Kirschtomaten Und Bueffelmozzarella 2",i:[{n:"Kirschtomaten",u:"g",a:"250"},{n:"Büffelmozzarella",u:"Pck",a:"1"},{n:"Linguine",u:"Pck",a:"1"},{n:"eingelegte getrocknete Tomaten",u:"Stk",a:"10"},{n:"grüne oder schwarze Oliven",u:"Stk",a:"10"},{n:"Estragon",u:"Stiele",a:"3"},{n:"Basilikum",u:"Bd",a:"1"},{n:"Lauchzwiebeln",u:"Stangen",a:"2"},{n:"Knoblauchzehen",u:"Stk",a:"1"},{n:"stückige Tomatensoße",u:"ml",a:"400"},{n:"Salz/Pfeffer und Zucker",u:"",a:""}],st:[{s:1,n:"Gemüse und restliche Zutaten putzen und schneiden",d:"Die Frühlingszwiebeln in Ringe und die Oliven in Scheiben schneiden. Für das Gericht können je nach Belieben schwarze oder grüne Oliven genommen werden. Ich mag die Grünen lieber, deswegen kommen sie hier zur Anwendung. Die Kirschtomaten abwaschen und je nach Größe halbieren oder vierteln. Den Knoblauch schälen und in feine Scheiben schneiden. Die Basilikumblätter abwaschen, trockenschütteln und in Streifen, sowie die eingelegten getrockneten Tomaten in Würfel schneiden. Den Estragon kleinhacken. Den Büffelmozzarella ebenso in grobe Stücke schneiden oder zupfen."},{s:2,n:"Ofen heizen und Nudeln kochen",d:"Den Ofen auf 90 Grad vorheizen. Einen Topf mit Salzwasser aufsetzen und die Linguine darin bissfest garen. Danach wird das Nudelwasser für die spätere Verwendung in einem Behältnis aufgefangen und die Nudeln werden in den Ofen zum warmhalten gegeben."},{s:3,n:"Gemüse anbraten und mit Nudelwasser auffüllen",d:"In einer Pfanne Öl erhitzen und die Frühlingszwiebeln, den Koblauch sowie die getrockneten Tomaten kurz glasig anschwitzen. Die Kirschtomaten und die Tomatensoße dazu geben, ggfs. mit dem Nudelwasser etwas auffüllen und aufkochen lassen. Nun wird der Basilikum sowie der klein gehackte Estragon dazu gegeben und durchgeschwenkt. Mit Salz und etwas Zucker würzen und abschmecken."},{s:4,n:"Abschmecken",d:"Nach etwa 3 Minuten gibt man einen Teil des Büffelmozzarellas sowie alle Olivenscheiben hinzu, vorsichtig unterheben und nochmals abschmecken. Durch die Tomatensoße kann hier noch eine dezent säuerliche Geschmacksnote vorhanden sein. Hier kann mit etwas Zucker der Geschmack verfeinert werden. Die Linguine mit der Tomatensoße anrichten, den restlichen Büffelmozzarella sowie mit ein paar halbierten Tomaten bestreuen und mit Basilikum garnieren. Die eingelegten getrockneten Tomaten tragen den Duft von Italienurlaub in das traute Heim. Der Büffelmozzarella garniert mit frischen Kräutern verleiht dem Gericht eine aromatische Note . Ein wunderbares Gericht, wenn man Nudeln mit Tomatensoße einen gewissen Piff verleihen möchte."}],p:"00:15",c:"00:15",tot:35,srv:"4",cats:["Pasta & Nudeln","Backen & Desserts"]},{id:2782,t:"HäHnchen SüßSauer   Herdzeit.De",i:[{n:"Reis",u:"Tassen",a:"2"},{n:"Hähnchenbrustfilet",u:"g",a:"400"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Zwiebellauch",u:"Stangen",a:"3"},{n:"frische Aprikosen oder aus der Dose",u:"g",a:"200"},{n:"rote Paprikaschoten",u:"Stk",a:"2"},{n:"rote Paprikaschoten",u:"Stk",a:"2"},{n:"Ingwer",u:"cm",a:"3"},{n:"helle Sojasauce",u:"EL",a:"6"},{n:"Weißweinessig",u:"EL",a:"2"},{n:"Honig",u:"TL",a:"2"},{n:"voller EL Tomatenmark",u:"Stk",a:"1"},{n:"Honig",u:"TL",a:"2"},{n:"Öl",u:"EL",a:"2"},{n:"Kartoffelmehl",u:"EL",a:"1"},{n:"Wasser",u:"ml",a:"150"}],st:[{s:1,n:"Reis kochen und Hähnchenfleisch marinieren",d:"Den Reis nach Packungsanweisung garen. Den Ingwer schälen und sehr fein hacken. Die Hähchenbrustfilets mit kaltem Wasser abwaschen, mit Küchenpapier trockentupfen und quer zur Faser in schmale Streifen schneiden. Den Ingwer zusammen mit der hellen Sojasauce, dem Weißweinessig verrühren und das Fleisch ca. 10 Minuten in der Hälfte der Marinade ziehen lassen."},{s:2,n:"Gemüse und Avocado schneiden",d:"Die Zwiebel schälen, halbieren und in halbe Ringe schneiden. Die rote Paprikaschote putzen, abwaschen und in grobe Stücke schneiden. Den Zwiebellauch ebenso putzen und das Weiße in etwa 2 cm lange Stücke und das Grüne in Ringe schneiden. Die Aprikosen, im Sommer frisch vom Markt, sonst aus der Dose in schmale Spalten schneiden. Die restliche Marinade wird zusammen mit Tomatenmark, Honig und 150 ml Wasser verrührt."},{s:2,n:"Gemüse und Avocado schneiden",d:"Die Zwiebel schälen, halbieren und in halbe Ringe schneiden. Die rote Paprikaschote putzen, abwaschen und in grobe Stücke schneiden. Den Zwiebellauch ebenso putzen und das Weiße in etwa 2 cm lange Stücke und das Grüne in Ringe schneiden. Die Aprikosen, im Sommer frisch vom Markt, sonst aus der Dose in schmale Spalten schneiden. Die restliche Marinade wird zusammen mit Tomatenmark, Honig und 150 ml Wasser verrührt."},{s:3,n:"Hähnchenfleisch scharf anbraten und Gemüse dünsten",d:"Nun wird ein Wok mit Öl erhitzt und das Fleisch je nach Menge im Ganzen oder portionsweise scharf angebraten. Danach herausnehmen und in einer Schüssel zur Seite stellen. Die Zwiebeln, die Paprika, das Weiße des Zwiebellauchs in den Wok geben und 2 Minuten bei mittlerer Hitze dünsten. Die Aprikosen zusammen mit der süßsauren Soße in den Wok geben, verrühren und etwas 5 Minuten köcheln lassen. Nun das Fleisch vorsichtig untermischen. Die süßsauren Hähnchen auf einem warmen Teller anrichten und mit den grünen Zwiebelringen bestreuen. Daneben eine Schüssel Reis platzieren. Fertig. Mit diesem Gericht habe ich offensichtlich die richtigen Geschmacksnerven meiner Kiddies getroffen. Sie wollten doch tatsächlich Nachschlag ;-) Dies hat mir sogar geschmeckt, obwohl ich nicht unbedingt ein Freund von süssauren Soßen bin. Insofern man hier mit dem Honig dezent arbeitet, dürfte dieses Gericht neue Freunde finden. Probiert´s aus."},{s:3,n:"Hähnchenfleisch scharf anbraten und Gemüse dünsten",d:"Nun wird ein Wok mit Öl erhitzt und das Fleisch je nach Menge im Ganzen oder portionsweise scharf angebraten. Danach herausnehmen und in einer Schüssel zur Seite stellen. Die Zwiebeln, die Paprika, das Weiße des Zwiebellauchs in den Wok geben und 2 Minuten bei mittlerer Hitze dünsten. Die Aprikosen zusammen mit der süßsauren Soße in den Wok geben, verrühren und etwas 5 Minuten köcheln lassen. Nun das Fleisch vorsichtig untermischen. Die süßsauren Hähnchen auf einem warmen Teller anrichten und mit den grünen Zwiebelringen bestreuen. Daneben eine Schüssel Reis platzieren. Fertig. Mit diesem Gericht habe ich offensichtlich die richtigen Geschmacksnerven meiner Kiddies getroffen. Sie wollten doch tatsächlich Nachschlag ;-) Dies hat mir sogar geschmeckt, obwohl ich nicht unbedingt ein Freund von süssauren Soßen bin. Insofern man hier mit dem Honig dezent arbeitet, dürfte dieses Gericht neue Freunde finden. Probiert´s aus."}],p:"00:20",c:"00:15",tot:40,srv:"4",cats:["Geflügel"]},{id:2786,t:"Schupfnudeln Mit Hackfleischbaellchen Aus Dem Wok",i:[{n:"Rinderhackfleisch",u:"g",a:"400"},{n:"Ei",u:"Stk",a:"1"},{n:"Semmelbrösel",u:"EL",a:"2"},{n:"Senf",u:"TL",a:"1"},{n:"kleine Zwiebel",u:"Stk",a:"1"},{n:"gerebelter Majoran",u:"TL",a:"1"},{n:"Wirsingkohl",u:"g",a:"700"},{n:"Schupfnudeln aus dem Kühlregal",u:"g",a:"700"},{n:"Creme Fraiche",u:"Becher",a:"1"},{n:"Fleischfond",u:"ml",a:"400"},{n:"gehackte Petersilie",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hackfleischbällchen zubereiten",d:"Die Hackfleischbällchen werden einfach nach dem Rezept für die Buletten zubereitet und in kleine Kugeln geformt."},{s:2,n:"Wirsingkohl Blätter vorbereiten",d:"Vom Wirsingkohl werden die Blätter einzeln entfernt, abgewaschen und trocken geschüttelt. Den dicken Strunk vom Blatt abschneiden und die verbliebenen Blätter in 2 cm breite Streifen schneiden"},{s:3,n:"Fleischfond vorbereiten",d:"Einen kleinen Topf mit dem Fleischfond kurz aufkochen und warm halten. Einen Becher Creme Fraiche hineingeben und verrühren, sodaß keine Klümpchen mehr vorhanden sind."},{s:4,n:"Hackfleischbällchen, Schupfnudeln und Wirsingkohl anbraten",d:"Die Hackbällchen in einen großen Wok geben und in etwas Öl ca. 3 Minuten rundherum anbraten. Danach die Schupfnudeln hinzugeben und weitere 5 Minuten bei mittlerer Hitze mitbraten. Zum Schluss herausnehmen und den in Streifen geschnittenen Wirsing mit etwas Öl in den Wok geben und 5 Minuten anbraten. Die Wirsingkohlblätter gelegentlich wenden und umrühren und dezent mit Salz und Pfeffer würzen."},{s:5,n:"Fond und und restlichen Zutaten zusammenfügen",d:"Nun werden die Schupfnudeln zusammen mit den Hackfleischbällchen vorsichtig unter die Wirsingkohlblätter gehoben. Jetzt den warmgehaltenen und mit Creme Fraiche verrührten Fleischfond hinzugeben und zugedeckt bei mittlerer Hitze etwa 5-8 Minuten köcheln lassen. Zum Schluss alles zusammen mit Salz und Pfeffer abschmecken. Petersilie klein hacken. Alles zusammen auf einem Teller anrichten und mit Petersilie bestreuen. Der Wirsingkohl hat zum ersten mal Einzug in meine Küche gehalten und ich war begeistert. Sehr schmackhaft und vorallem bissfesst, insofern die Blätter nicht zu lange geköchelt haben. Dieses Gericht war sehr schnell zubereitet und und hat wenig Aufwand bereitet. Ideal um während der Woche mal schnell was Schmackhaftes und leicht bekömmliches auf den Tisch zu zaubern."}],p:"00:20",c:"00:20",tot:45,srv:"4",cats:["Fleisch","Pasta & Nudeln","Asiatisch"]},{id:2797,t:"Bunter Rindfleischeintopf",i:[{n:"abgehangenes Roastbeef",u:"kg",a:"1"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"5"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Tomaten",u:"Stk",a:"5"},{n:"Möhren",u:"Stk",a:"2"},{n:"rote Paprikaschoten",u:"Stk",a:"2"},{n:"festkochende Kartoffeln",u:"g",a:"300"},{n:"Mehl",u:"EL",a:"2"},{n:"Mehl",u:"EL",a:"2"},{n:"edelsüsses Paprikapulver",u:"EL",a:"1"},{n:"Nelken",u:"Stk",a:"5"},{n:"Lorbeerblätter",u:"Stk",a:"3"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Rotwein",u:"ml",a:"300"},{n:"Wasser",u:"ml",a:"100"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Welches Fleisch für den Rindfleischeintopf?",d:"Ich habe für diesen schmackhaften Rindereintopf ein gutes Stück abgehangenes Roastbeef genommen. Das sieht manchmal nicht so appetitlich aus, läßt sich jedoch wunderbar kurz schmoren. Gutes abgehangenes Rindfleisch kann man unter anderem an der dunklen roten Farbe erkennen."},{s:2,n:"Rindfleisch abspülen und in große Würfel schneiden",d:"Nun, ich habe das Stück Fleisch unter kaltem Wasser abgewaschen und mit Küchenpapier trocken getupft. Wer mag kann sich schon beim Fleischer grobe 2 cm große Würfel schneiden lassen."},{s:2,n:"Rindfleisch abspülen und in große Würfel schneiden",d:"Nun, ich habe das Stück Fleisch unter kaltem Wasser abgewaschen und mit Küchenpapier trocken getupft. Wer mag kann sich schon beim Fleischer grobe 2 cm große Würfel schneiden lassen."},{s:3,n:"Gemüse schneiden und Rinderfond aufkochen",d:"5 mittelgroße Zwiebeln schälen und in grobe Würfel schneiden. 3 Knoblauchzehen schälen und sehr fein hacken. Wer Knoblauch nicht mag, kann diesen auch getrost weglassen. In einen kleinen Topf gibt man 400 ml Gemüse und 400 ml Rinderfond. Kurz aufkochen lassen und warm halten."},{s:3,n:"Gemüse schneiden und Rinderfond aufkochen",d:"5 mittelgroße Zwiebeln schälen und in grobe Würfel schneiden. 3 Knoblauchzehen schälen und sehr fein hacken. Wer Knoblauch nicht mag, kann diesen auch getrost weglassen. In einen kleinen Topf gibt man 400 ml Gemüse und 400 ml Rinderfond. Kurz aufkochen lassen und warm halten."},{s:4,n:"Rindfleisch und Gemüse anbraten und Soße ansetzen",d:"In einem großen Topf wird nun 2 EL Butterschmalz erhitzt und das Fleisch, je nach Menge portionsweise scharf angebraten. Den klein gehackten Knoblauch hinzugeben. Nachdem dies geschehen ist, fügt man die grob geschnittenen Zwiebeln hinzu und schwitzt sie glasig an. Nach weiteren 5-7 Minuten mit 2 EL Mehl, 1 EL edelsüssem Paprikapulver, Salz, Pfeffer und 2 EL Tomatenmark würzen, 2 Minuten rösten und mit 300 ml Rotwein ablöschen. Alles 5 Minuten einköcheln und mit dem warmgehaltenen Fond aufgießen. Hitze reduzieren, 6 Nelken, sowie 3 Lorbeerblätter hinzugeben und ca. 30 Minuten bei geschlossenem Deckel schmoren lassen"},{s:4,n:"Rindfleisch und Gemüse anbraten und Soße ansetzen",d:"In einem großen Topf wird nun 2 EL Butterschmalz erhitzt und das Fleisch, je nach Menge portionsweise scharf angebraten. Den klein gehackten Knoblauch hinzugeben. Nachdem dies geschehen ist, fügt man die grob geschnittenen Zwiebeln hinzu und schwitzt sie glasig an. Nach weiteren 5-7 Minuten mit 2 EL Mehl, 1 EL edelsüssem Paprikapulver, Salz, Pfeffer und 2 EL Tomatenmark würzen, 2 Minuten rösten und mit 300 ml Rotwein ablöschen. Alles 5 Minuten einköcheln und mit dem warmgehaltenen Fond aufgießen. Hitze reduzieren, 6 Nelken, sowie 3 Lorbeerblätter hinzugeben und ca. 30 Minuten bei geschlossenem Deckel schmoren lassen"},{s:5,n:"Gemüse hinzufügen und Tomatensoße ansetzen",d:"Währenddessen werden die Kartoffeln geschält, der Paprika sowie die Möhren geputzt und alles zusammen in grobe Würfel geschnitten. Die Tomaten oben anritzen und mit heißem Wasser abbrühen. Die Haut entfernen und das Fruchtfleisch achteln. Nach etwa 30 Minuten wird das Gemüse in den Topf gegeben und ggfs. mit heißem Wasser aufgegossen, sodaß alles schön bedeckt ist. Weitere 10-15 Minuten köcheln lassen. Zum Schluss werden die Tomaten für weitere 5 Minuten hinein gegeben. Den Rindereintopf mit Salz und Pfeffer abschmecken und servieren. Ein kräftiger Rindereintopf garniert mit Gemüse eignet sich sehr für die kalten Herbst- und Wintertage. Wenn man die Zutatenmenge etwas erhöht, reicht der Eintopf auch für 2 Tage. Laßt es Euch schmecken."}],p:"00:20",c:"1:00",tot:85,srv:"4",cats:["Fleisch","Suppen & Eintöpfe"]},{id:2800,t:"Speck Ummantelte Rosmarinkartoffeln Mit Kraeuterquark",i:[{n:"festkochende kleine Kartoffeln (Drillinge)",u:"Stk",a:"10"},{n:"Baconspeck",u:"Pck",a:"2"},{n:"Rosmarin",u:"Stängel",a:"3"},{n:"Petersilie",u:"Bd",a:"0.5"},{n:"Magerquark",u:"g",a:"500"},{n:"Dill",u:"Bd",a:"0.5"},{n:"Petersilie",u:"Bd",a:"0.5"},{n:"Dill",u:"Bd",a:"0.33"},{n:"Wasser",u:"EL",a:"3"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Kartoffeln kochen und abpellen",d:"Die kleinen Kartoffeln ordentlich abwaschen und in einem Topf mit Wasser ca. 15-20 Minuten garen. Danach herausnehmen und die Schale abpellen. Während die Kartoffeln kochen, den Speck oder Bacon auf einem Brett auslegen."},{s:2,n:"Kräuterquark zubereiten",d:"Für den Kräuterquark gibt man 500 g in eine Schüssel, fügt 3 EL Wasser hinzu, schneidet einen halben Bund Schnittlauch in kleine Röllchen, einen halben Bund Petersilie sowie Dill kleinhacken und zusammen mit Salz und Pfeffer zum Quark geben und kräftig verrühren. 3 Rosmarinstängel abwaschen, trockenschütteln und die Nadeln abtrennen. Diese werden nun kleingehackt."},{s:3,n:"Kartoffeln mit Baconscheiben einwickeln und anbraten",d:"Die abgepellten kleinen Kartoffeln in die Baconscheiben einrollen. Eine Pfanne mit etwas Öl erhitzen und die ummantelten Kartoffeln mit der Naht nach unten anbraten und gelegentlich wenden, sodaß diese schön von allen Seiten angebraten wird."},{s:4,n:"Mit Rosmarin würzen",d:"Zum Schluss den kleingehackten Rosmarin drüberstreuen und ganz kurz mitrösten, damit sich das Aroma verbreiten kann. Nun darf alles nett angerichtet und serviert werden. Eine leckere Variante von Pellkartoffeln mit Kräuterquark. Für den kleinen Hunger und eine schnelle Zubereitung."}],p:"00:10",c:"00:20",tot:30,srv:"4",cats:["Vegetarisch"]},{id:2804,t:"Mariniertes Haehnchenbrustfilet Mit Einem Glasnudelsalat",i:[{n:"Glasnudeln",u:"g",a:"100"},{n:"Hähnchenbrustfilet",u:"g",a:"500"},{n:"Spieße",u:"Stk",a:"10"},{n:"rote Paprika",u:"Stk",a:"1"},{n:"Möhre",u:"Stk",a:"1"},{n:"Korianderblätter",u:"Stk",a:"5"},{n:"helle Sojasauce",u:"EL",a:"6"},{n:"Ingwer",u:"cm",a:"4"},{n:"helle Sojasauce",u:"EL",a:"6"},{n:"Tabascosauce",u:"Tropfen",a:"4"},{n:"Worchestersauce",u:"EL",a:"1"},{n:"Honig",u:"EL",a:"1"},{n:"Öl",u:"EL",a:"2"}],st:[{s:1,n:"Glasnudeln für den Salat aufweichen",d:"Wasser in einem Wasserkocher erhitzen. Etwa 100 g Glasnudeln in eine Schüssel geben und später das heiße Wasser darüber gießen. 10 Minuten ziehen lassen. Danach die Nudeln durch ein Sieb geben und abkühlen lassen."},{s:2,n:"Hähnchenbrustfilet Spieße marinieren",d:"Die Hähnchenbrustfilets abwaschen, trockentupfen, in 2 schmale Streifen schneiden und auf Spieße stecken. 4 cm einer Ingwerwurzel schälen und kleinraspeln. In einer Schüssel werden nun 7 EL helle Sojasoße, 4 Tropfen Tabascosauce, 1 EL Worchestersauce, der geraspelte Ingwer sowie 1 EL Honig miteinander verrührt. Die Hähnchenbrustspieße in eine flache Schale legen und die Marinade darüber geben. Dies darf nun ca. 10 Minuten im Kühlschrank marinieren."},{s:2,n:"Hähnchenbrustfilet Spieße marinieren",d:"Die Hähnchenbrustfilets abwaschen, trockentupfen, in 2 schmale Streifen schneiden und auf Spieße stecken. 4 cm einer Ingwerwurzel schälen und kleinraspeln. In einer Schüssel werden nun 7 EL helle Sojasoße, 4 Tropfen Tabascosauce, 1 EL Worchestersauce, der geraspelte Ingwer sowie 1 EL Honig miteinander verrührt. Die Hähnchenbrustspieße in eine flache Schale legen und die Marinade darüber geben. Dies darf nun ca. 10 Minuten im Kühlschrank marinieren."},{s:3,n:"restliches Gemüse putzen",d:"Jetzt hat man Zeit den Paprika zu putzen, die Möhren zu schälen und alles zusammen in feine Streifen zu schneiden. Je nachdem ob man Koriander mag, hackt man noch etwa 5-10 Blätter Koriander klein."},{s:3,n:"restliches Gemüse putzen",d:"Jetzt hat man Zeit den Paprika zu putzen, die Möhren zu schälen und alles zusammen in feine Streifen zu schneiden. Je nachdem ob man Koriander mag, hackt man noch etwa 5-10 Blätter Koriander klein."},{s:4,n:"Hähnchenspieße anbraten und Glasnudeln marinieren",d:"Nun wird eine Pfanne mit etwas Öl erhitzt und die marinierten Hähnchenspieße ca. 2-3 Minuten darin unter gelegentlichem Wenden kross anbraten. Zum Schluss kurz die Marinade in die Pfanne geben und aufkochen lassen. Die heiße Marinade in die Schüssel mit den Glasnudeln geben und zusammen mit dem kleingeschnittenem Gemüse und dem Saft einer Limette vermengen. Kurz ziehen lassen. Nun darf alles auf einem Teller angerichtet werden. Ein geschmacklich sehr intensives Gericht, wo sich die heißen Hähnchenspieße mit dem kalten Glasnudelsalat einen wunderbaren Kontrast bilden."},{s:4,n:"Hähnchenspieße anbraten und Glasnudeln marinieren",d:"Nun wird eine Pfanne mit etwas Öl erhitzt und die marinierten Hähnchenspieße ca. 2-3 Minuten darin unter gelegentlichem Wenden kross anbraten. Zum Schluss kurz die Marinade in die Pfanne geben und aufkochen lassen. Die heiße Marinade in die Schüssel mit den Glasnudeln geben und zusammen mit dem kleingeschnittenem Gemüse und dem Saft einer Limette vermengen. Kurz ziehen lassen. Nun darf alles auf einem Teller angerichtet werden. Ein geschmacklich sehr intensives Gericht, wo sich die heißen Hähnchenspieße mit dem kalten Glasnudelsalat einen wunderbaren Kontrast bilden."}],p:"00:20",c:"00:10",tot:30,srv:"4",cats:["Geflügel","Pasta & Nudeln","Salate","Asiatisch"]},{id:2809,t:"Geschmorte Putenbrust",i:[{n:"Putenbrust",u:"g",a:"900"},{n:"Champignons",u:"g",a:"400"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"3"},{n:"rote Paprikaschoten (spitz)",u:"Stk",a:"2"},{n:"Rosmarinstängel",u:"Stk",a:"3"},{n:"Öl",u:"EL",a:"2"},{n:"Gemüsefond",u:"mal",a:"400"},{n:"Sojasauce",u:"mal",a:"50"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Putenbrust und Gemüse grob in Würfel schneiden",d:"Die Putenbrust abwaschen, trocken tupfen und in grobe Stücke schneiden. Die Paprikaschoten abwaschen, putzen und ebenso in Grobe Stücke schneiden. Zwiebeln schälen halbieren und Streifen schneiden. Die Champignons vom Sand befreien und klein schneiden. Drei Rosmarinstängel abspülen und klein hacken."},{s:2,n:"Gemüsefond vorbereiten",d:"Einen kleinen Topf mit dem Gemüsefond aufkochen und warm halten. 50ml mit 2Tl Kartoffelstärke darin verrühren."},{s:3,n:"Putenbrust und Gemüse schmoren lassen",d:"Einen großen Topf mit Öl erhitzen und die Putenbrust Stücke darin portionsweise scharf anbraten und herausnehmen. Jetzt werden im gleichen Topf die Champignons 5 Minuten angebraten. Danach das Gemüse für weitere 5 Minuten hinzugeben. Den kleingehackten Rosmarin untergehen. Nun die Putenbrust Stücke hinzugeben, den Gemüsefond zufügen und bei geschlossenem Deckel 15 Minuten schmoren lassen. Zum Schluss ggfs. mit Salz und Pfeffer abschmecken. Wenn es mal wieder schnell gehen soll, ist dies das perfekte Gericht."}],p:"00:10",c:"00:30",tot:45,srv:"4",cats:["Geflügel"]},{id:2816,t:"Rezept 2816",i:[{n:"große rote Paprikaschoten",u:"Stk",a:"5"},{n:"große rote Paprikaschoten",u:"Stk",a:"5"},{n:"Hackfleisch (gemischt)",u:"kg",a:"1"},{n:"Eier",u:"Stk",a:"2"},{n:"Brötchen",u:"Stk",a:"1"},{n:"Senf",u:"TL",a:"2"},{n:"Zwiebeln",u:"Stk",a:"2"},{n:"Möhre",u:"Stk",a:"1"},{n:"gerebelter Majoran",u:"EL",a:"1"},{n:"Oregano",u:"EL",a:"1"},{n:"Reis",u:"Tasse",a:"0.5"},{n:"Thymian",u:"TL",a:"1"},{n:"Tomatenmark",u:"EL",a:"3"},{n:"edelsüsses Paprikapulver",u:"TL",a:"1"},{n:"Tomatenmark",u:"EL",a:"3"},{n:"passierte Tomaten",u:"kl. Pck",a:"1"},{n:"Wasser",u:"ml",a:"299"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Reis kochen",d:'Gefüllte Paprikaschoten mit Hackfleisch "“ ein Klassiker der Küche Einen kleinen Topf mit Wasser aufsetzen und eine Handvoll Reis bissfest garen. Währenddessen die Füllung aus Hackfleisch vorbereiten.'},{s:2,n:"Hackfleisch Füllung vorbereiten",d:"1 kg gemischtes Hackfleisch mit 2 Eiern, 1 sehr klein geschnittenen Zwiebel, 2 Tl Senf, einem aufgeweichten Brötchen, 2 Tl gerebeltem Majoran, 1/2 TL Thymian, 1 TL Oregano, 1/2 sehr fein geschnittenen Möhre und dem gekochten Reis gut miteinander vermischen."},{s:2,n:"Hackfleisch Füllung vorbereiten",d:"1 kg gemischtes Hackfleisch mit 2 Eiern, 1 sehr klein geschnittenen Zwiebel, 2 Tl Senf, einem aufgeweichten Brötchen, 2 Tl gerebeltem Majoran, 1/2 TL Thymian, 1 TL Oregano, 1/2 sehr fein geschnittenen Möhre und dem gekochten Reis gut miteinander vermischen."},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/9EMSCXyr9F4\\ width=\\480\\ height=\\360\\]"},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/9EMSCXyr9F4\\ width=\\480\\ height=\\360\\]"},{s:4,n:"Paprikaschoten putzen",d:"Von den Paprikaschoten auf der Stielseite den Kopf so abschneiden, dass man diesen später als Deckel auf die Schote setzen kann. Die Kerne entfernen und die Schoten innen sowie außen gut abwaschen. Paprikaschoten mit der Hackfleischmischung gut füllen. Dabei vorsichtig andrücken. Zum Schluss sollte noch etwa 250 g Hackfleisch für die Zubereitung der Soße übrig bleiben."},{s:4,n:"Paprikaschoten putzen",d:"Von den Paprikaschoten auf der Stielseite den Kopf so abschneiden, dass man diesen später als Deckel auf die Schote setzen kann. Die Kerne entfernen und die Schoten innen sowie außen gut abwaschen. Paprikaschoten mit der Hackfleischmischung gut füllen. Dabei vorsichtig andrücken. Zum Schluss sollte noch etwa 250 g Hackfleisch für die Zubereitung der Soße übrig bleiben."},{s:5,n:"Gefüllte Paprikaschoten anbraten",d:"Nun wird ein großer Topf mit etwas Öl erhitzt und die Paprikaschoten mit der offenen Seite ca. 5 Minuten scharf angebraten. Danach die Hitze auf die Hälfte reduzieren und weitere 5 Minuten sanft anbraten. Herausnehmen und zur Seite stellen.Während die Schoten braten, eine weitere Zwiebel und die andere Hälfte der Möhre sowie eine Knoblauchzehe und eine Paprikaschote in kleine Würfel schneiden."},{s:5,n:"Gefüllte Paprikaschoten anbraten",d:"Nun wird ein großer Topf mit etwas Öl erhitzt und die Paprikaschoten mit der offenen Seite ca. 5 Minuten scharf angebraten. Danach die Hitze auf die Hälfte reduzieren und weitere 5 Minuten sanft anbraten. Herausnehmen und zur Seite stellen.Während die Schoten braten, eine weitere Zwiebel und die andere Hälfte der Möhre sowie eine Knoblauchzehe und eine Paprikaschote in kleine Würfel schneiden."},{s:6,n:"Tomatensoße für gefüllte Paprikaschoten vorbereiten",d:"500 ml Wasser im Wasserkocher erhitzen. In einer großen Schüssel eine kleine Packung passierte Tomaten, 3 EL Tomatenmark, das Wasser, 1 EL gerebelter Oregano, 1 EL Majoran, 1TL edelsüßes Paprikapulver, Pfeffer und Salz miteinander vermengen. Kräftig abschmecken."},{s:6,n:"Tomatensoße für gefüllte Paprikaschoten vorbereiten",d:"500 ml Wasser im Wasserkocher erhitzen. In einer großen Schüssel eine kleine Packung passierte Tomaten, 3 EL Tomatenmark, das Wasser, 1 EL gerebelter Oregano, 1 EL Majoran, 1TL edelsüßes Paprikapulver, Pfeffer und Salz miteinander vermengen. Kräftig abschmecken."},{s:7,n:"tomatensoße zubereiten",d:"In den Bratensud der angebratenen Schoten das übrige Hackfleisch geben und es krümelig anbraten. Das klein geschnittene Gemüse hinzufügen. 2 Minuten mitbraten und mit der vorbereiteten Tomatensoße ablöschen. Aufkochen und die angebratenen Paprikaschoten mit der offenen Seite nach oben hinzugeben. Hitze auf die Hälfte herunter reduzieren und bei geschlossenem Topf ca. 40 Minuten köcheln. Gelegentlich die gefüllten Paprikaschoten mit der Tomatensoße übergießen. [su_slider source=\\media: 5576,5575,5572,5571,5574,5579,5573,5577,5580,5578,5570\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"},{s:7,n:"tomatensoße zubereiten",d:"In den Bratensud der angebratenen Schoten das übrige Hackfleisch geben und es krümelig anbraten. Das klein geschnittene Gemüse hinzufügen. 2 Minuten mitbraten und mit der vorbereiteten Tomatensoße ablöschen. Aufkochen und die angebratenen Paprikaschoten mit der offenen Seite nach oben hinzugeben. Hitze auf die Hälfte herunter reduzieren und bei geschlossenem Topf ca. 40 Minuten köcheln. Gelegentlich die gefüllten Paprikaschoten mit der Tomatensoße übergießen. [su_slider source=\\media: 5576,5575,5572,5571,5574,5579,5573,5577,5580,5578,5570\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"}],p:"00:20",c:"00:50",tot:75,srv:"4",cats:["Sonstiges"]},{id:2820,t:"Klassische Kohlrouladen   Herdzeit.De",i:[{n:"Weißkohlkopf",u:"Stk",a:"1"},{n:"Hackfleisch gemischt",u:"kg",a:"1"},{n:"Hackfleisch gemischt",u:"kg",a:"1"},{n:"handvoll Reis",u:"Stk",a:"1"},{n:"Eier",u:"Stk",a:"2"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"2"},{n:"gerebelter Majoran",u:"TL",a:"2"},{n:"Thymian",u:"TL",a:"0.5"},{n:"Oregano",u:"TL",a:"1"},{n:"Möhre",u:"Stk",a:"1"},{n:"Paniermehl",u:"",a:""},{n:"Senf",u:"TL",a:"2"},{n:"Rotwein",u:"ml",a:"300"},{n:"Butterschmalz",u:"EL",a:"1"},{n:"Speck",u:"g",a:"100"},{n:"Tomatenmark",u:"EL",a:"2"},{n:"Rotwein",u:"ml",a:"300"},{n:"Kartoffelmehl",u:"TL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Reis kochen",d:"Eine kleinen Topf mit Wasser aufsetzen. Reis bissfest garen. Durch ein Sieb geben. Zur Seite stellen und abkühlen lassen."},{s:2,n:"Weißkohlblätter vorbereiten",d:"Einen großen Topf mit Salzwasser zum kochen bringen. Vom Weißkohl den Strunk trichterförmig rausscheiden. Kohl im Ganzen in das kochende Salzwasser geben. Die äußeren Blätter nach jeweils ca. 4 Minuten mit einer Schaumkelle vorsichtig lösen, den dicken Strunk entlang der Rippe keilförmig ausschneiden und zur Seite legen."},{s:3,n:"Hackfleischfüllung für Kohlrouladen zubereiten",d:"1 kg gemischtes Hackfleisch mit 2 Eiern, 1 sehr klein geschnittene Zwiebel, 2 TL Senf, einem im Wasser aufgeweichten Brötchen, 2 TL gerebelten Majoran, ½ TL Thymian, 1 TL Oregano, ½ sehr fein geschnittenen Möhre und dem gekochten Reis gut miteinander vermischen. Abschmecken und ggfs. nachwürzen."},{s:4,n:"Kohlrouladen wickeln",d:"Küchengarn für 8 Kohlrouladen in 50 cm lange Stücke schneiden. 2 Blätter versetzt aufeinander legen. Eine handvoll Hackfleisch in die Mitte platzieren und einwickeln. Mit Küchengarn fixieren."},{s:5,n:"Kohlrouladen anbraten",d:"Einen großen Topf mit Butterschmalz erhitzen. Die Kohlrouladen ca. 5-8 Minuten rundherum anbraten. Herausnehmen und zur Seite stellen."},{s:6,n:"Soße zubereiten",d:"Im gleichen Topf Butterschmalz, Speck und eine kleingeschnittene Zwiebel anbraten. Nach ca. 5 Minuten die klein geschnittenen Kohlstücke hinzugeben. Kurz mitbraten. Tomatenmark kurz einrühren. Mit Rotwein ablöschen. Einkochen bis ein sämiger Sud entsteht. Das Kohlwasser hinzugießen. Aufkochen und Kohlrouladen rein legen."},{s:7,n:"Kohlrouladen schmoren",d:"Die Kohlrouladen sollten nun ca. 45 Minuten bei reduzierter Hitze und geschlossenem Deckel schmoren."},{s:8,n:"Soße verfeinern",d:"Die Kohlrouladen herausnehmen. Soße ggfs. mit Wasser verlängern. Ist sie zu dünnflüssig, mit in kaltem Wasser aufgelöstem Kartoffelmehl vermischen und aufkochen lassen. Evtl. nochmals mit Salz abschmecken. Kartoffeln kochen."}],p:"00:45",c:"00:45",tot:100,srv:"8",cats:["Fleisch"]},{id:2825,t:"Klassischer Rinderbraten",i:[{n:"Rinderbraten (z.b. Tafelspitz)",u:"kg",a:"2"},{n:"Porreestange",u:"Stk",a:"1"},{n:"Porreestange",u:"Stk",a:"1"},{n:"Knollensellerie",u:"Stk",a:"0.5"},{n:"Möhren",u:"Stk",a:"3"},{n:"mittelgroße Zwiebeln",u:"Stk",a:"3"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Johannisbeergelee",u:"EL",a:"2"},{n:"Senf",u:"EL",a:"3"},{n:"Tomatenmark",u:"EL",a:"3"},{n:"gerebelter Majoran",u:"TL",a:"3"},{n:"Thymian",u:"TL",a:"2"},{n:"Butterschmalz",u:"EL",a:"3"},{n:"dunkle Sojasauce",u:"ml",a:"150"},{n:"Malzbier (je 500 ml)",u:"Flaschen",a:"2"},{n:"Glühweingewürz",u:"Beutel",a:"1"},{n:"Vanilleschote",u:"cm",a:"4"},{n:"Wacholderbeeren",u:"Stk",a:"10"},{n:"Lorbeerblätter",u:"Stk",a:"2"},{n:"Brühe",u:"TL",a:"4"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Kartoffelmehl",u:"TL",a:"1"}],st:[{s:1,n:"Rindfleisch bei Zimmertemperatur ruhen lassen",d:"Das Fleisch ca. 2h vor der Verarbeitung aus dem Kühlschrank nehmen und bei Zimmertemperatur ruhen lassen. Danach mit kaltem Wasser abspülen, mit Küchenpapier trocken tupfen sowie Sehnen und ggfs. Fett mit einem scharfen Messer entfernen."},{s:2,n:"Gemüse für Rinderbraten grob würfeln und anbraten",d:"Den Porree, die Möhren, den Knollensellerie sowie die Zwiebeln putzen und grob würfeln. Die Knoblauchzehen schälen und leicht andrücken. Der Bräter sollte nicht viel größer sein als das Fleisch, jedoch höher. Den Topf mit Butterschmalz bzw. Öl gut vorheizen und das grob gewürfelte Gemüse hineingeben und so lange anbraten, bis es dunkle Ränder bekommt."},{s:3,n:"Rinderbraten Soße zubereiten und reduzieren",d:"3 EL Tomatenmark, 3 EL Senf und 2 EL Johannisbeergelee einrühren und ein paar Minuten anrösten. 1,5 TL Thymian, 3 TL Majoran sowie Pfeffer aus der Mühle untermischen, mit Sojasauce angießen und unter ständigem Rühren andicken lassen. Nun das Malzbier in den Topf geben und aufkochen. 4 TL Gemüsebrühe einstreuen und umrühren. Wer auf das Brühepulver verzichten möchte, kann ebenso Gemüsefond hinzugießen. Die Reduktion dauert jedoch etwas länger."},{s:4,n:"Rindfleisch sowie Gewürze hinzufügen und schmoren lassen",d:"Das Fleisch roh in den Topf geben bis es ganz von der Flüssigkeit bedeckt ist. Ist dies noch nicht der Fall, dann einfach etwas heißes Wasser aufgießen. In ein Tee-Ei gibt man nun 10 Wacholderbeeren, 2 Lorbeerblätter und 4 cm gehackte Vanilleschote. Dies zusammen mit dem Glühweingewürz gibt man nun in den Topf. Das Fleisch darf nun bei reduzierter Hitze und geschlossenem Deckel sanft 2-3 Stunden schmoren. Danach herausnehmen, in Alufolie einwickeln und in den auf 60 Grad vorgeheizten Ofen geben."},{s:5,n:"Die Soße verfeinern und abschmecken",d:"Die Soße wird durch ein Sieb in einen anderen Topf passiert. Für einen noch intensiveren Geschmack habe ich 1/3 der passierten Gemüsemasse der Soße hinzugefügt und dies mit dem Pürierstab püriert. Sollte die Soße ggfs. in ihrer Konsistenz noch zu dünn sein, dann etwas Mehl in einer kleinen Schüssel mit kaltem Wasser verrühren, klumpenfrei und in die Soße rühren. 11 Minuten köcheln lassen, sodaß der Mehlgeschmack verkocht. Warum 11 Minuten? Meine Ma hat es mir gesagt, sie hat es von ihrem Vater, er hat es von seiner Mutter und so weiter und so fort :-) Die Soße kann zum Abschluss noch mit Salz, Pfeffer und Sojasauce abgeschmeckt werden. War bei mir jedoch nicht notwendig. Der Geschmack war schon jetzt einmalig."},{s:6,n:"Rinderbraten aufschneiden und servieren",d:"Das Fleisch aus dem Ofen nehmen und mit einem scharfen Messer in Scheiben schneiden. Dazu gab es bei uns Kartoffeln und in Butter geschwenktes Gemüse. Ich habe schon viele Rinderbraten Rezepte ausprobiert. Bisher sind sie mir nie gelungen. Dieser hier jedoch ist genau so geworden, wie ich ihn mir vorgestellt habe. Sehr zart, geschmacklich gehaltvoll, eine aromatische Soße dazu. Der perfekte Braten für die Weihnachtszeit um bei der Familie mal wieder Pluspunkte sammeln zu können:-)"}],p:"00:45",c:"1:40",tot:220,srv:"8",cats:["Fleisch"]},{id:2836,t:"Tomate Rucola Wrap Auf Einer Kaesecreme",i:[{n:"Wraps",u:"Stk",a:"8"},{n:"eingelegte getrocknete Tomaten",u:"Glas",a:"1"},{n:"Rucola",u:"Pck",a:"1"},{n:"Parmaschinken",u:"Pck",a:"2"},{n:"Pininenkerne",u:"g",a:"100"},{n:"Parmesankäse",u:"",a:""},{n:"Frischkäse",u:"Pck",a:"1"},{n:"Joghurt",u:"Becher",a:"1"},{n:"frisch gehackte Kräuter",u:"Hand",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Wraps vorheizen",d:"Leckere Tomate-Rucola Wraps auf einer Käsecreme zubereiten Wraps für etwa 10 Minuten in Alufolie umwickelt bei 150 Grad in den vorgeheizten Ofen legen"},{s:2,n:"Rucola putzen, Pinienkerne anrösten",d:"Währenddessen Rucola abwaschen und die dickeren Stiele entfernen. Die Pinienkerne kurz in einer Pfanne anrösten und in einer Schüssel zur Seite stellen."},{s:3,n:"Cremefüllung zubereiten",d:"Frischkäse mit 2 EL Joghurt, gehackten Kräutern, Salz und Pfeffer cremig rühren"},{s:4,n:"Warme Fladenbrote belegen",d:"Die nun angewärmten Fladenbrote herausnehmen. Die einzelnen Wraps mit der Käsecreme bestreichen und mit Rucola, Parmaschinken, angerösteten Pinienkernen, eingelegten Tomaten sowie frisch geriebenen Parmesankäse belegen."},{s:5,n:"Wraps einrollen",d:"Nun die Fladenbrote vorsichtig einrollen. Nicht zu fest, da sie leicht reißen können. Die Rollen werden jetzt mit etwa 10 cm langem Küchengarn fixiert. Von den Wraps etwa 1 cm von beiden Enden abschneiden und in der Mitte quer teilen"}],p:"00:10",c:"00:10",tot:20,srv:"4",cats:["Sandwiches & Snacks"]},{id:2913,t:"Thai Curry Mit Huhn Gemuese Und Erdnussbutter",i:[{n:"Reis",u:"EL",a:"6"},{n:"Hühnerbrust",u:"g",a:"500"},{n:"Ingwer",u:"cm",a:"2"},{n:"Bambussprossen (kl. Dose)",u:"Stk",a:"1"},{n:"Kokosmilch",u:"ml",a:"400"},{n:"Stängel Zwiebellauch",u:"Stängel",a:"2"},{n:"rote Spitzpaprika Schoten",u:"Stk",a:"3"},{n:"helle Sojasauce",u:"EL",a:"4"},{n:"Currypulver",u:"EL",a:"1"},{n:"Erdnussbutter",u:"EL",a:"1"},{n:"Erdnussöl",u:"EL",a:"4"},{n:"Zitronengraspaste",u:"Tl",a:"0.33"},{n:"Fischsauce",u:"EL",a:"0.5"}],st:[{s:1,n:"Hühnchenfleisch vorbereiten",d:"Hühnchenfleisch mit kaltem Wasser abwaschen, mit Küchenpapier trocken tupfen und in feine Streifen schneiden."},{s:2,n:"Fleisch marinieren",d:"Ingwer schälen und fein hacken. In eine Schüssel gibt man nun Hühnchen, Ingwer, 1-2 EL helle Sojasauce sowie 1 EL Erdnussöl. Vermengt dies gut miteinander und stellt die Schüssel abgedeckt für 30 Minuten in den Kühlschrank."},{s:2,n:"Fleisch marinieren",d:"Ingwer schälen und fein hacken. In eine Schüssel gibt man nun Hühnchen, Ingwer, 1-2 EL helle Sojasauce sowie 1 EL Erdnussöl. Vermengt dies gut miteinander und stellt die Schüssel abgedeckt für 30 Minuten in den Kühlschrank."},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/LeaiYuk7hMY\\ width=\\480\\ height=\\360\\]"},{s:3,n:"Das Video zum Rezept",d:"[su_youtube url=\\https://youtu.be/LeaiYuk7hMY\\ width=\\480\\ height=\\360\\]"},{s:4,n:"Gemüse putzen und schneiden",d:"Währenddessen das Paprika-Gemüse in schmale Streifen schneiden sowie Zwiebellauch in schmale Ringe schneiden.Bambussprossen in einem Sieb abtropfen. Einen kleinen Teil der Zwiebellauchringe für die Dekoration zur Seite legen."},{s:4,n:"Gemüse putzen und schneiden",d:"Währenddessen das Paprika-Gemüse in schmale Streifen schneiden sowie Zwiebellauch in schmale Ringe schneiden.Bambussprossen in einem Sieb abtropfen. Einen kleinen Teil der Zwiebellauchringe für die Dekoration zur Seite legen."},{s:5,n:"Erdnussbutter zubereiten für Thai Curry",d:"Erdnussbutter lässt sich ebenso schnell zubereiten: Mir ist ein ganzes Glas davon aus dem Handel einfach zu viel. Also werden ein paar Erdnüsse mit dem Stabmixer klein gehäckselt und mit Butter sowie einer Prise Salz vermengt. Endspurt zum originalen Thai-Curry mit Huhn"},{s:5,n:"Erdnussbutter zubereiten für Thai Curry",d:"Erdnussbutter lässt sich ebenso schnell zubereiten: Mir ist ein ganzes Glas davon aus dem Handel einfach zu viel. Also werden ein paar Erdnüsse mit dem Stabmixer klein gehäckselt und mit Butter sowie einer Prise Salz vermengt. Endspurt zum originalen Thai-Curry mit Huhn"},{s:6,n:"Reis kochen",d:"Einen Topf mit Wasser für Reis aufsetzen und bissfest kochen."},{s:6,n:"Reis kochen",d:"Einen Topf mit Wasser für Reis aufsetzen und bissfest kochen."},{s:7,n:"Hühnchenfleisch im Wok anbraten",d:"Den Wok mit Erdnussöl erhitzen und das marinierte Hühnchenfleisch scharf anbraten. Austretendes Fleischwasser in einem Glas auffangen. Sobald das Fleisch 5 Minuten angebraten ist, in einer Schüssel zur Seite stellen"},{s:7,n:"Hühnchenfleisch im Wok anbraten",d:"Den Wok mit Erdnussöl erhitzen und das marinierte Hühnchenfleisch scharf anbraten. Austretendes Fleischwasser in einem Glas auffangen. Sobald das Fleisch 5 Minuten angebraten ist, in einer Schüssel zur Seite stellen"},{s:8,n:"Gewürzzutaten für Thai Curry hinzufügen",d:"Im Wok 1 EL Currypulver mit 2 EL Erdnussöl kurz anrösten und mit der selbst angefertigten Erdnussbutter verrühren und schmelzen lassen. Alles zusammen mit dem aufgefangenen Fleischwasser sowie der Kokosmilch ablöschen, Gemüse hinzugeben und 15 Minuten leicht köcheln lassen."},{s:8,n:"Gewürzzutaten für Thai Curry hinzufügen",d:"Im Wok 1 EL Currypulver mit 2 EL Erdnussöl kurz anrösten und mit der selbst angefertigten Erdnussbutter verrühren und schmelzen lassen. Alles zusammen mit dem aufgefangenen Fleischwasser sowie der Kokosmilch ablöschen, Gemüse hinzugeben und 15 Minuten leicht köcheln lassen."},{s:9,n:"Mit restlichen Zutaten abschmecken",d:"Kurz vor dem Ende der Garzeit Fleisch wieder hinzufügen und mit Zitronengraspaste, heller Sojasauce, ca. 1/2 EL Fischsauce abgeschmecken. [su_slider source=\\media: 5720,5722,5724,5717,5719,5715,5714,5723,5718,5721,5716\\ limit=\\30\\ link=\\lightbox\\ width=\\200\\ height=\\200\\ autoplay=\\8000\\ speed=\\2000\\]"}],p:"00:30",c:"00:15",tot:45,srv:"4",cats:["Geflügel","Asiatisch"]},{id:2947,t:"Rote Minestrone",i:[{n:"Speck",u:"g",a:"100"},{n:"kleine Penne Nudeln",u:"g",a:"100"},{n:"frische grüne Bohnen",u:"g",a:"140"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"mittelgroße Zwiebel",u:"Stk",a:"1"},{n:"Staudensellerie",u:"Stangen",a:"3"},{n:"Tomaten",u:"g",a:"250"},{n:"Sonnenblumenöl",u:"EL",a:"2"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"Zucker (nach Bedarf)",u:"",a:""},{n:"Brühe",u:"ml",a:"700"},{n:"Oregano",u:"Stiele",a:"5"},{n:"Parmesan (hobeln)",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse, Speck und Co für die Minestrone kleinschneiden",d:"Die Bohnen abwaschen, putzen und halbieren. Den Speck, die Zwiebeln und den Knoblauch fein würfeln. Die Enden von drei Stangen Staudensellerie abschneiden, längs halbieren und in 5 mm kleine Stücke schneiden. Die Tomaten abwaschen, halbieren, den Stielansatz entfernen und die Tomaten in grobe Stücke schneiden. Wasser für die Brühe aufsetzen."},{s:2,n:"Gemüse anbraten, Brühe hinzugeben und köcheln lassen",d:"Öl in einem Topf erhitzen und den Schinkenspeck kross ausbraten.1/4 herausnehmen und zur Seite stellen. Die Zwiebeln sowie den Knoblauch etwa 2 Minuten anbraten, mit Tomatenmark und etwas Zucker einrühren und mitdünsten. Die vorbereitete Brühe hineingießen und mit den Tomaten, Bohnen, Nudeln sowie 2-3 Stengel Oregano auffüllen und etwa 10-15 Minuten bei mittlerer Hitze zugedeckt köcheln lassen."},{s:3,n:"Die rote Minestrone abschmecken und servieren",d:"um Schluss mit Salz und Pfeffer abschmecken. Alles zusammen portionsweise in eine Schüssel geben, mit klein gehacktem Oregano, geriebenen Parmesankäse und den Schinkenwürfeln bestreuen und servieren. Die frischen Zutaten lassen die Minestrone zu einer leckeren gehaltvollen Suppe werden. Je nach Region variieren die Zutaten und die Zubereitung."}],p:"00:15",c:"00:00",tot:40,srv:"4",cats:["Suppen & Eintöpfe"]},{id:3023,t:"Risotto Mit Tomaten, Oliven Und Basilikum   Herdzeit.De",i:[{n:"Risotto Reis",u:"g",a:"200"},{n:"Schalotten",u:"g",a:"100"},{n:"Mozzarella",u:"Pck",a:"1"},{n:"Parmesankäse",u:"g",a:"100"},{n:"Tomatensaft",u:"ml",a:"300"},{n:"passierte stückige Tomaten",u:"ml",a:"400"},{n:"Gemüsefond",u:"ml",a:"400"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"grüne Oliven",u:"g",a:"80"},{n:"Weißwein",u:"ml",a:"150"},{n:"kalte Butter",u:"g",a:"40"},{n:"Basilikumblätter",u:"",a:""},{n:"Salz/Pfeffer und Zucker",u:"",a:""}],st:[{s:1,n:"Tomaten Gemüse Fond warm halten",d:"Die Schalotten, den Knoblauch schälen und ebenso wie die Oliven klein würfeln. Den Tomatensaft sowie den Gemüsefond in einem Topf kurz aufkochen und bei niedriger Hitze warm halten. Ggfs. noch mit etwas Wasser und Brühe auffüllen. Es ist gut möglich, daß der Tomatensaft recht schnell andickt, sodaß man dies mit etwas Wasser verdünnen kann."},{s:2,n:"Risotto zubereiten",d:"Die Schalotten, die Oliven und den Knoblauch ca. 3 Minuten in einem hohen Topf glasig andünsten. Den Reis hinzugeben und nach etwa 1-2 Minuten mit 150 ml Wein ablöschen. Gut reduzieren, mit den stückigen Tomaten auffüllen und kurz mitdünsten."},{s:3,n:"Das Risotto immer wieder rühren und auffüllen",d:"Nun muß für etwa 15-20 Minuten mit einer Kelle immer soviel Tomaten-Gemüsefond aufgefüllt werden, daß der Reis knapp bedeckt ist. Reduzieren lassen und wiederrum mit dem Fond auffüllen. Man muß unbedingt dabei stehen bleiben und unter häufigem rühren ein Anbrennen vermeiden."},{s:4,n:"Mediteran abschmecken",d:"Nach der letzten Kelle mit Salz, Pfeffer und Zucker kräftig abschmecken. Den Topf vom Herd nehmen und die in Streifen geschnittenen Basilikumblätter sowie den geriebenen Parmesankäse und kalte Butterflocken darunter rühren. Kurz ziehen lassen und servieren. Risotto gibt es in unglaublich vielen Variationen. Mit frischen Zutaten und ein wenig Kreativität kann man hier seinen kulinarischen Ideen ein breites Spektrum bieten. Das Tomaten-Risotto glänzt durch die kräftige Note der Oliven und der aromatischen Tomaten. Wer mag, darf gern noch etwas Mozzarella Käse darüber streuen."}],p:"00:5",c:"00:20",tot:30,srv:"4",cats:["Vegetarisch"]},{id:3026,t:"Salat Mit Leberkaese",i:[{n:"Leberkäse",u:"g",a:"400"},{n:"mittelgroße Gewürzgurken",u:"Stk",a:"4"},{n:"rote Zwiebel",u:"Stk",a:"1"},{n:"Radieschen (abhängig von der Größe)",u:"Stk",a:"5"},{n:"Petersilie (zum bestreuen)",u:"",a:""},{n:"Senf",u:"TL",a:"1"},{n:"rote Schoten Spitzparika",u:"Stk",a:"2"},{n:"Senf",u:"TL",a:"1"},{n:"Weißweinessig",u:"EL",a:"3"},{n:"Sonnenblumenöl",u:"EL",a:"3"},{n:"Salz/Pfeffer und Zucker",u:"",a:""}],st:[{s:1,n:"Leberkäse und Gemüse in Streifen schneiden",d:"Den Leberkäse in 1/2 cm schmale Scheiben und ebenso wie die rote Zwiebel und den Spitzpaprika in schmale Streifen schneiden. Von den sauren Gurken die Enden entfernen und genau wie die geputzten Radieschen in Scheiben schneiden."},{s:1,n:"Leberkäse und Gemüse in Streifen schneiden",d:"Den Leberkäse in 1/2 cm schmale Scheiben und ebenso wie die rote Zwiebel und den Spitzpaprika in schmale Streifen schneiden. Von den sauren Gurken die Enden entfernen und genau wie die geputzten Radieschen in Scheiben schneiden."},{s:2,n:"Dressing für Leberkäse zubereiten",d:"Für die Vinaigrette werden, Öl, Weißweinessig, Gurkenwasser, Senf, Salz, Pfeffer und Zucker kräftig miteinander vermengt und zusammen mit dem vorbereiteten Gemüse in einer Schüssel unter gehoben. Im Kühlschrank für ein paar Minuten ziehen lassen. Vor dem Servieren mit kleingehacktem Petersilie bestreuen. Ein frischer Fleischsalat mit einer kräftig würzigen Vinaigrette eignet sich ideal als Beilage als auch für den kulinarischen Abschluss eines heißen Tages. Dazu darf gern ein Baguette gereicht werden."},{s:2,n:"Dressing für Leberkäse zubereiten",d:"Für die Vinaigrette werden, Öl, Weißweinessig, Gurkenwasser, Senf, Salz, Pfeffer und Zucker kräftig miteinander vermengt und zusammen mit dem vorbereiteten Gemüse in einer Schüssel unter gehoben. Im Kühlschrank für ein paar Minuten ziehen lassen. Vor dem Servieren mit kleingehacktem Petersilie bestreuen. Ein frischer Fleischsalat mit einer kräftig würzigen Vinaigrette eignet sich ideal als Beilage als auch für den kulinarischen Abschluss eines heißen Tages. Dazu darf gern ein Baguette gereicht werden."}],p:"00:15",c:"00:00",tot:20,srv:"4",cats:["Fleisch","Salate"]},{id:3071,t:"Paprikahaehnchen Mit Kraeuterbutter",i:[{n:"Hühnchen (ca. 1,3 kg)",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"3"},{n:"Küchengarn",u:"",a:""},{n:"Salz",u:"",a:""},{n:"Paprikapulver",u:"EL",a:"2"},{n:"Sonnenblumenöl",u:"EL",a:"6"},{n:"Paprikapulver",u:"EL",a:"2"},{n:"Currypulver",u:"TL",a:"1"},{n:"Cayennepfeffer",u:"TL",a:"0.5"},{n:"Küchengarn",u:"",a:""},{n:"gehackte Kräuter (Rosmarin, Thymian, Salbei, Petersilie)",u:"EL",a:"2"},{n:"Butter",u:"g",a:"125"}],st:[{s:1,n:"Kräuterbutter und Paprikamarinade zubereiten",d:"Den Ofen auf 200 Grad Umluft vorheizen. Die Hähnchen gründlich mit kaltem Wasser aus- und abwaschen und mit Küchenpapier trocken tupfen. 125 g Butter und 2 EL klein gehackte Kräuter sowie 1 TL Salz miteinander verkneten. In einer kleinen Schüssel 2 EL Paprikapulver, 1/2 TL Cayenne Pfeffer, 2 EL Salz, 1 TL Curry und 4-6 EL Sonnenblumenöl gut miteinander vermengen. 3 Knoblauchzehen schälen und in sehr feine Scheiben schneiden."},{s:2,n:"Kräuterbutter unter die Hähnchenhaut reiben",d:"Nun werden die Knoblauchscheiben sowie die Kräuterbutter vorsichtig unter die Hühnerhaut geschoben. Dabei empfiehlt es sich an der Halsöffnung vorsichtig mit dem Finger unter die Haut zu fahren und diese vom Körper zu lösen. Danach können die Knoblauchscheiben und die Kräuterbutter hineingegeben werden und ggfs. hineinmassiert werden."},{s:3,n:"Hähnchen fixieren und in den Ofen geben",d:"Nachdem dies erledigt ist, werden die Beine sowie die Flügel mit Küchengarn verbunden. Nun kann das ganze Huhn mit der Paprikamarinade eingerieben werden. Das so vorbereitete Huhn wird nun für etwa 90 Minuten in den Ofen gegeben. Nach etwa 45 Minuten einmal wenden und kurz vor Schluss nochmals die Temperatur erhöhen um eine schön krosse Haut zu bekommen. Bei uns gab es dazu noch gebackene Kartoffeln. Das Gericht ist schnell vorbereitet. Den Rest erledigt der Ofen. :-) Somit eignet sich dieses Rezept auch als kulinarische Bereicherung für die Familie im Alltag. Auch in einer Männerrunde bei Fußball und Bier darf dieses Huhn nicht fehlen."}],p:"00:20",c:"1:30",tot:110,srv:"4",cats:["Geflügel"]},{id:3074,t:"Honig Senf Kraeuter Marinade",i:[{n:"Hühnerbrustfilets",u:"Stk",a:"4"},{n:"gehackte Kräuter (Rosmarin, Majoran, Salbei, Thymian, Petersilie)",u:"EL",a:"2"},{n:"gehackte Kräuter von allem etwas",u:"EL",a:"2"},{n:"Senf",u:"TL",a:"1"},{n:"Honig",u:"TL",a:"2"},{n:"dunkler Balsamico",u:"EL",a:"15"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Hühnerbrustfilet vorbereiten",d:"Das Hühnerbrustfilet mit kaltem Wasser abwaschen und mit Küchenpapier trockentupfen."},{s:2,n:"Marinade zubereiten",d:"Für die Marinade 1 TL Senf, 2 TL Honig, 2 -3 EL gehackte Kräuter, 2-4 EL Sonnenblumenöl, 1,5 EL schwarzer Balsamico, Salz und Pfeffer miteinander vermengen."},{s:3,n:"Brustfilets 3-4 Stunden marinieren",d:"Brustfilets hinzugeben, vermischen und ca. 3-4 Stunden im Kühlschrank ziehen lassen. Es darf auch etwas länger sein."},{s:4,n:"Filets bei Zimmertemperatur ruhen lassen",d:"Etwa 2 Stunden vor dem Braten oder Grillen aus dem Kühlschrank nehmen, sodass euer Fleisch etwa Zimmertemperatur annimmt."}],p:"00:10",c:"00:00",tot:10,srv:"4",cats:["Grillen & Marinaden"]},{id:3091,t:"Bolognese Auflauf",i:[{n:"Penne",u:"g",a:"400"},{n:"Hackfleisch (gemischt)",u:"g",a:"500"},{n:"Mozzarella",u:"Pck",a:"2"},{n:"Sellerie",u:"Stangen",a:"2"},{n:"Möhren",u:"Stk",a:"2"},{n:"Sellerie",u:"Stangen",a:"2"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Tomatenmark",u:"El",a:"2"},{n:"Rotwein');",u:"ml",a:"200"},{n:"passierte stückige Tomaten",u:"ml",a:"800"},{n:"Butter",u:"TL",a:"2"},{n:"gehackte Kräuter (Majoran, Thymian, Rosmarin, Petersilie, Salbei, Orgegano)",u:"EL",a:""},{n:"Zucker",u:"EL",a:"1"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse für die Bolognese putzen und klein schneiden",d:"Die Selleriestangen sowie die Möhren putzen, die Zwiebel schälen und alles in kleine Würfel schneiden. Ein oder zwei Knoblauchzehen schälen und sehr fein hacken."},{s:2,n:"Bolognese zubereiten",d:"Einen Topf mit 2 EL Öl erhitzen und das Hackfleisch darin krümelig anbraten und schon etwas mit Majoran, Salz und Pfeffer würzen. Das klein geschnittene Gemüse hinzugeben und etwa 2-4 Minuten mit dünsten. 2 EL Tomatenmark in den Topf geben und etwa 2 Minuten mitrösten. Den Rotwein hinzugießen und gut einkochen lassen. Die passierten stückigen Tomaten in dem Topf auffüllen und ggfs. mit etwas Wasser verdünnen. Aufkochen lassen, Hitze reduzieren und mit 2 EL klein gehackten Kräutern sowie mit Salz und Pfeffer würzen. Deckel drauf und für etwa 20 Minuten schmoren."},{s:2,n:"Bolognese zubereiten",d:"Einen Topf mit 2 EL Öl erhitzen und das Hackfleisch darin krümelig anbraten und schon etwas mit Majoran, Salz und Pfeffer würzen. Das klein geschnittene Gemüse hinzugeben und etwa 2-4 Minuten mit dünsten. 2 EL Tomatenmark in den Topf geben und etwa 2 Minuten mitrösten. Den Rotwein hinzugießen und gut einkochen lassen. Die passierten stückigen Tomaten in dem Topf auffüllen und ggfs. mit etwas Wasser verdünnen. Aufkochen lassen, Hitze reduzieren und mit 2 EL klein gehackten Kräutern sowie mit Salz und Pfeffer würzen. Deckel drauf und für etwa 20 Minuten schmoren."},{s:3,n:"Nudeln kochen und Bolognese abschmecken",d:"Während dessen einen Topf mit Wasser erhitzen und die Nudeln bissfest kochen. 5 Minuten vor dem Ende der Garzeit der Bolognese den Ofen auf 200 Grad Umluft erhitzen. Die Bolognese ggfs. mit Salz, Pfeffer und etwas Zucker abschmecken. Ich gebe ganz gern noch 2 TL Butter hinzu. Sobald es schmeckt, die Nudeln hinzugeben und vorsichtig unterheben."},{s:3,n:"Nudeln kochen und Bolognese abschmecken",d:"Während dessen einen Topf mit Wasser erhitzen und die Nudeln bissfest kochen. 5 Minuten vor dem Ende der Garzeit der Bolognese den Ofen auf 200 Grad Umluft erhitzen. Die Bolognese ggfs. mit Salz, Pfeffer und etwas Zucker abschmecken. Ich gebe ganz gern noch 2 TL Butter hinzu. Sobald es schmeckt, die Nudeln hinzugeben und vorsichtig unterheben."},{s:4,n:"Zutaten in die Auflaufform geben",d:"Den Mozzarella Käse in kleine Würfel schneiden. Mit Salz und 1 EL gehackten Kräutern würzen. Die Bolognese sowie die Nudeln werden nun in eine Auflaufform gegeben und mit dem gewürztem Mozzarella Käse bestreut. Dies wird nun für ca. 25 Minuten in den Ofen gegeben. Die Käsekruste sollte schön knusprig sein. Bolognese in der Auflaufform, raffiniert und einfach umgesetzt bringt es Abwechslung in das beliebte Gericht."},{s:4,n:"Zutaten in die Auflaufform geben",d:"Den Mozzarella Käse in kleine Würfel schneiden. Mit Salz und 1 EL gehackten Kräutern würzen. Die Bolognese sowie die Nudeln werden nun in eine Auflaufform gegeben und mit dem gewürztem Mozzarella Käse bestreut. Dies wird nun für ca. 25 Minuten in den Ofen gegeben. Die Käsekruste sollte schön knusprig sein. Bolognese in der Auflaufform, raffiniert und einfach umgesetzt bringt es Abwechslung in das beliebte Gericht."}],p:"00:15",c:"00:50",tot:70,srv:"6",cats:["Pasta & Nudeln"]},{id:3096,t:"Puten Gemuese Gulasch",i:[{n:"Putenbrustfilet",u:"g",a:"500"},{n:"Möhren",u:"Stk",a:"4"},{n:"Zuckerschoten",u:"g",a:"200"},{n:"Zwiebellauch",u:"Stängel",a:"3"},{n:"Geflügelfond",u:"ml",a:"400"},{n:"Milch",u:"ml",a:"100"},{n:"Petersilie",u:"Stk",a:"4"},{n:"groben Senf",u:"EL",a:"2"},{n:"Butter",u:"EL",a:"3"},{n:"Mehl",u:"EL",a:"1"},{n:"Zucker",u:"Tl",a:"1"},{n:"Sahne",u:"Becher",a:"0.5"},{n:"Öl",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Putenfleisch und Gemüse vorbereiten",d:"Das Fleisch mit kaltem Wasser abspülen, mit Küchenpapier trocken tupfen und in mundgerechte Stücke schneiden. Einen Topf mit Wasser aufsetzen und den Reis bissfess kochen. Das Gemüse putzen, von den Lauchzwiebeln die Wurzeln sowie vom Grün die obersten 1 cm abschneiden und den Rest in grobe Ringe sowie die Möhren in dünne Scheiben schneiden. Von den Zuckerschoten ggfs. die Stiele entfernen."},{s:2,n:"Putenfleisch anbraten und Mehlschwitze zubereiten",d:"In einem Topf etwas Öl erhitzen und das Fleisch ca. 3 Minuten rundherum anbraten. Herausnehmen und in einer Schüssel zur Seite stellen. Im gleichen Topf Butter erhitzen, Mehl hinzugeben und mit einem Schneebesen einrühren, bis keine Klümpchen mehr vorhanden sind. Mit dem Geflügelfond und der Milch ablöschen und reduzieren bis eine leicht cremige Flüssigkeit entstanden ist. Nun darf das Fleisch, die Zuckerschoten sowie die in Scheiben geschnittenen Möhren hinzu gegeben und ca. 10 Minuten gegart werden."},{s:3,n:"Puten Gulasch verfeinern",d:"Währenddessen Petersilie abwaschen, kleinhacken und zusammen mit der Sahne, dem groben Senf und den Lauchzwiebeln in den Topf geben. Vorsichtig unterheben und weitere 3 Minuten köcheln lassen. Zum Schluss mit Salz, Pfeffer und ggfs etwas Zucker abschmecken. Durch den groben Senf kann die Soße einen leicht säuerlichen Geschmack erhalten. Dies kann mit dem Zucker ertwas abgemildert werden. Letztendlich darf der Puten-Gemüse Gulasch angerichtet werden. Reis beifügen und die restliche Petersilie darüber streuen. Ein sehr leichtes Gericht mit wenig Kalorien schnell und einfach zubereitet. Die Sahne darf gern weg gelassen werden. Wer mag darf stattdessen etwas Butter in der Soße schmelzen lassen."}],p:"00:15",c:"00:15",tot:30,srv:"4",cats:["Geflügel","Fleisch"]},{id:3099,t:"Rippchen Mit Bluetenhonig",i:[{n:"Schälrippen",u:"kg",a:"12"},{n:"Blütenhonig",u:"EL",a:"4"},{n:"Blütenhonig",u:"EL",a:"4"},{n:"Worchestersauce",u:"EL",a:"2"},{n:"Sojasauce",u:"EL",a:"25"},{n:"Tomatenketchup",u:"EL",a:"1"},{n:"gemahlener Ingwer",u:"TL",a:"1"},{n:"Senfpulver",u:"TL",a:"1"},{n:"Paprikapulver",u:"EL",a:"1"},{n:"Kräuteressig",u:"EL",a:"2"},{n:"Rotwein",u:"EL",a:"2"},{n:"Tabasco Sauce (nach Bedarf)",u:"",a:""},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen, zerdrückt",u:"Stk",a:"5"},{n:"Öl",u:"EL",a:"2"}],st:[{s:1,n:"Rippchen vorbereiten",d:"Den Backofen auf 200 Grad Umluft vorheizen. Die Rippchen mit kaltem Wasser abwaschen und trocken tupfen. Eine Zwiebel schälen und in dünne Spalten schneiden. 5 Knoblauchzehen schälen und leicht andrücken."},{s:2,n:"Blütenhonig Marinade vorbereiten",d:"In einem Topf 2 EL Öl erhitzen und die Zwiebeln sowie die Knoblauchzehen darin anschwitzen bis sie weich sind. 4 EL Blütenhonig, 2,5 EL dunkle Sojasauce, 2 EL Worchestersauce, 1 EL Tomatenketchup, 1 TL gemahlener Ingwer, 1 TL Senfpulver, 1 TL Paprikapulver, 2 EL Kräuteressig, 2 EL Rotwein und nach Bedarf Tabascosauce und Salz hinzufügen. Aufkochen und bei stark reduzierter Hitze 3 Minuten köcheln lassen."},{s:3,n:"Rippchen mit der Blütenhonig Marinade bestreichen",d:"Während dessen die Rippchen in einen Bräter geben, von beiden Seiten mit Salz würzen und später die im Topf reduzierte Soße darüber verteilen. Den Bräter mit Alufoile abdecken und für etwa 45 Minuten in den Ofen geben. Danach die Folie abnehmen und weitere 15 Minuten bei 250 Grad auf dem Rost von beiden Seiten knusprig backen."},{s:4,n:"Aus dem Bratensud einen Dip zubereiten",d:"Die gesammelte Flüssigkeit aus dem Bräter in einen kleinen Topf geben, ggfs festgebackene Flüssikeit vorsichtig mit etwas Wasser und einem Holzlöffel lösen und ebenso in den Topf geben. 2 EL Butter hinein und etwa 5 Minuten einkochen bis die Soße eine sämige Konsistenz angenommen hat. Die Soße eignet sich insbesondere zum dippen für die Rippchen. Kräftig und sehr aromatisch im Geschmack Bei uns gab es gestern die Rippchen zum Fussballspiel. In der Halbzeitpause zubereitet, während des Spiels im Ofen gebacken. Herausgekommen sind sehr zarte Rippchen mit einer wunderbar aromatisierten Marinade. Vermutlich kann man die so zubereiteten Rippchen auch auf den Grill packen. Doch das dürft Ihr gern ausprobieren und hier gern davon berichten."}],p:"00:10",c:"1:00",tot:75,srv:"4",cats:["Grillen & Marinaden"]},{id:3103,t:"Rezept 3103",i:[{n:"Babypenne (Nudeln)",u:"g",a:"300"},{n:"große Zwiebel",u:"Stk",a:"1"},{n:"Rinderhack",u:"g",a:"500"},{n:"große Zwiebel",u:"Stk",a:"1"},{n:"Knoblauchzehen",u:"Stk",a:"2"},{n:"Kreuzkümmel",u:"TL",a:"0.5"},{n:"Zimtpulver",u:"TL",a:"1"},{n:"Tomatenmark",u:"EL",a:"1"},{n:"gehackte Minze",u:"EL",a:"1"},{n:"Rinderfond",u:"ml",a:"400"},{n:"Öl",u:"EL",a:"2"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Öl",u:"EL",a:"2"},{n:"Joghurt",u:"g",a:"150"},{n:"Mozzarella",u:"Pck",a:"2"},{n:"Milch",u:"ml",a:"200"},{n:"Mehl",u:"EL",a:"1"},{n:"Butter",u:"EL",a:"2"}],st:[{s:1,n:"Nudeln kochen und Gemüse und Kräuter schneiden",d:"Wasser aufsetzen, zum kochen bringen und die Nudeln bissfest kochen. Danach die Nudeln in ein Sieb geben und mit kaltem Wasser abspülen. Die Zwiebel schälen und in kleine Würfel schneiden. Den Knoblauch schälen und leicht andrücken. Minzblätter abzupfen und kleinhacken."},{s:2,n:"Rinderhack anbraten und dick einkochen",d:"Öl in einem Topf erhitzen und die Zwiebeln sowie den Knoblauch anschwitzen, das Rinderhack hinzugeben und krümelig anbraten. Nun das Tomatenmark, den Kreuzkümmel, das Zimtpulver, die Minze, Salz und Pfeffer hinzugeben. Verrühren, kurz anrösten und mit dem Rinderfond ablöschen. Alles zusammen bei reduzierter Hitze ca. 10-15 Minuten köcheln. Den Ofen auf 190 Grad Umluft vorheizen."},{s:3,n:"Mehlschwitze für Johgurt Käse Soße ansetzen",d:"Während dessen, Butter anschwitzen, Mehl hinzugeben, mit dem Schneebesen gut verrühren bis keine Klümpchen mehr vorhanden sind. Vom Herd nehmen und die Milch sowie den Joghurt einrühren. Den Mozzarellakäse in kleine Würfel schneiden und zu der Milchsauce in den Topf geben. Mit Salz und Pfeffer abschmecken."},{s:4,n:"Nudeln, Hackfleisch und Soße zusammenfügen",d:"Die Nudeln und die Milchsauce mit dem geschmolzenem Käse in einen Topf geben und vorsichtig unterheben. Eine Hälfte der Nudelmischung in eine Auflaufform verteilen. Die Fleischsauce darüber verteilen und mit der übrigen Nudelmischung abschließen. Den restlichen Mozzarella in Würfel schneiden, mit Kräutern und Salz würzen und über die Nudeln streuen. Die Lasagne für etwa 30-40 Minuten in den Ofen geben."}],p:"00:10",c:"00:50",tot:65,srv:"4",cats:["Sonstiges"]},{id:3106,t:"Bunte Bohnensuppe",i:[{n:"junge Brechbohnen (gefrostet)",u:"g",a:"600"},{n:"Kartoffeln (festkochend)",u:"g",a:"300"},{n:"Möhren",u:"g",a:"250"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Bohnenkraut",u:"Bd",a:"1"},{n:"Brühe",u:"Liter",a:"1"},{n:"Thymian",u:"Zweige",a:"3"},{n:"Öl",u:"EL",a:"2"},{n:"Parmesankäse",u:"",a:""},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Gemüse kleinschneiden",d:"Die Möhren und die Kartoffeln schälen und mit kaltem Wasser abwaschen. Die Möhren in Scheiben schneiden, die Kartoffeln würfeln. Die Zwiebel schälen und in kleine Würfel schneiden."},{s:2,n:"Gemüse anschwitzen und mit Wasser auffüllen",d:"Einen großen Topf mit Öl erhitzen, die Zwiebelwürfel anschwitzen, Kartoffeln hinzufügen und ca. 5 Minuten dünsten, danach die Möhren und später die Bohnen hinzufügen und jeweils weitere 2-3 Minuten dünsten. Mit Salz und Pfeffer würzen. Das Bohnenkraut entweder als Bündel in den Topf geben oder in ein Teei stopfen und in den Topf legen. Mit 1 Liter Brühe ablöschen, kurz aufkochen und bei reduzierter Hitze ca. 10 Minuten köcheln lassen."},{s:2,n:"Gemüse anschwitzen und mit Wasser auffüllen",d:"Einen großen Topf mit Öl erhitzen, die Zwiebelwürfel anschwitzen, Kartoffeln hinzufügen und ca. 5 Minuten dünsten, danach die Möhren und später die Bohnen hinzufügen und jeweils weitere 2-3 Minuten dünsten. Mit Salz und Pfeffer würzen. Das Bohnenkraut entweder als Bündel in den Topf geben oder in ein Teei stopfen und in den Topf legen. Mit 1 Liter Brühe ablöschen, kurz aufkochen und bei reduzierter Hitze ca. 10 Minuten köcheln lassen."},{s:3,n:"mit Thymian abschmecken",d:"Während dessen den Thymian abwaschen, trocken schütteln, klein hacken, in den Topf geben und vorsichtig unterheben. Zum Schluss nochmals mit Salz und Pfeffer abschmecken. Die Bohnensuppe in einen Teller geben und Parmesankäse darüber hobeln. Eine würzige Bohnensuppe mit Möhren als Geschmacks- und Farbtupfer. Wer mag, kann noch Wiener in Stücke schneiden und der Suppen beifügen."},{s:3,n:"mit Thymian abschmecken",d:"Während dessen den Thymian abwaschen, trocken schütteln, klein hacken, in den Topf geben und vorsichtig unterheben. Zum Schluss nochmals mit Salz und Pfeffer abschmecken. Die Bohnensuppe in einen Teller geben und Parmesankäse darüber hobeln. Eine würzige Bohnensuppe mit Möhren als Geschmacks- und Farbtupfer. Wer mag, kann noch Wiener in Stücke schneiden und der Suppen beifügen."}],p:"00:15",c:"00:30",tot:50,srv:"4",cats:["Suppen & Eintöpfe"]},{id:3115,t:"GefüLlte Pilze Mit Hackfleisch   Herdzeit.De",i:[{n:"große braune Champignons",u:"Stk",a:"4"},{n:"Salz/Pfeffer",u:"",a:""},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Schweinehackfleisch",u:"g",a:"150"},{n:"Petersilie",u:"Stängel",a:"3"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Parmesankäse",u:"",a:""},{n:"Ei",u:"Stk",a:"1"},{n:"Zitrone",u:"Stk",a:"0.5"},{n:"eingelegte getrocknete Tomaten",u:"Stk",a:"3"}],st:[{s:1,n:"Pilze vorbereiten, Gemüse und Kräuter klein schneiden",d:"Die großen Pilze mit Küchenpapier abreiben. Den Stiel vorsichtig herausdrehen und in kleine Würfel schneiden. Den Ofen auf 180 Grad Umluft vorheizen. Die eingelegten getrockneten Tomaten, sowie den Knoblauch sehr fein hacken. Petersilieblätter abzupfen und ebenso klein hacken."},{s:2,n:"Hackfleischfüllung zubereiten",d:"In eine Schüssel werden nun das Hackfleisch, die Petersilie, ein Ei, geraspelter Parmesankäse, die Tomaten und fein abgeriebene Zitronenschale zusammen mit Salz und Pfeffer miteinander verknetet. Die Zitrone sollte vor dem Abreiben gründlich abgewaschen werden. Dies eignet sich jedoch nur für unbehandelte Zitronen."},{s:3,n:"Pilze befüllen und im Ofen backen",d:"Die Pilze werden nun in eine Auflaufform gegeben, mit Salz, Pfeffer und ein paar Tropfen des Zitronensafts gewürzt. Danach die Hackfleischmasse vorsichtig in die Pilze gegeben. Nochmals etwas Parmesankäse darüber reiben und für ca. 30 Minuten im Ofen backen lassen. Die fertig gebackenen Pilze ansehnlich auf einem Teller servieren und schmecken lassen. Eine herzhafte Variante der gefüllten Pilze."}],p:"00:10",c:"00:30",tot:45,srv:"2",cats:["Fleisch","Vegetarisch"]},{id:3118,t:"Gefuellte Pilze Mit Tomate Mozzarella",i:[{n:"große braune Champignons",u:"Stk",a:"4"},{n:"kleine Kirschtomaten",u:"Stk",a:"8"},{n:"Mozzarellakäse",u:"Stk",a:"0.5"},{n:"Basilikumblätter",u:"Stk",a:"8"},{n:"heller Balsamico Essig",u:"Tl",a:"3"},{n:"Salz/Pfeffer",u:"",a:""}],st:[{s:1,n:"Champignons putzen",d:"Die Pilze mit Küchenpapier abreiben und die Stiele vorsichtig herausdrehen. Den Ofen auf 180 Grad Umluft vorheizen."},{s:2,n:"Gemüse und Mozzarella würfeln",d:"Die Tomaten abwaschen, grüne Stiele entfernen und in kleine Würfel schneiden. Mozzarella abtropfen lassen und sehr klein schneiden. Die Basillikumblätter abzupfen, abwaschen und trocken tupfen. Davon eine Hälfte klein hacken"},{s:3,n:"Füllung würzen",d:"Tomaten, Mozzarella, kleingehackte Basilikumblätter zusammen mit einem Teelöffel hellem Balsamico Essig, Salz und Pfeffer in einer Schüssel vermengen."},{s:4,n:"Pilze befüllen und ab in den Ofen",d:"Pilze in eine Auflaufform geben. Mit Salz, Pfeffer und ein paar Tropfen Balsamico Essig würzen. Die Tomate-Mozzarella Mischung in die Pilze geben, leicht auftürmen und für ca. 20 Minuten in den Ofen geben, bis der Käse geschmolzen ist."},{s:5,n:"Servieren",d:"Danach auf einem Teller drapieren und mit ein paar Scheiben Baguette und einem Glas Weißwein genießen."}],p:"00:10",c:"00:20",tot:30,srv:"2",cats:["Vegetarisch"]},{id:3136,t:"Lasagne",i:[{n:"Lasagneblätter (fertig, ungekocht)",u:"",a:""},{n:"Bratwurst",u:"Stk",a:"1"},{n:"Hackfleisch gemischt",u:"g",a:"200"},{n:"Schinken im Stück",u:"g",a:"60"},{n:"Dosentomaten",u:"g",a:"600"},{n:"Staudensellerie",u:"Stange",a:"0.75"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Möhre",u:"Stk",a:"1"},{n:"Rotwein",u:"Glas",a:"1"},{n:"Knoblauchzehe",u:"Stk",a:"1"},{n:"Nelke",u:"Stk",a:"1"},{n:"Oregano",u:"EL",a:"1"},{n:"Basilikum",u:"EL",a:"1"},{n:"Lorbeerblatt",u:"Stk",a:"1"},{n:"Mozzarellakäse",u:"Pck",a:"1"},{n:"Parmesankäse",u:"",a:""},{n:"Öl, Salz und Pfeffer",u:"",a:""},{n:"Nelke",u:"Stk",a:"1"},{n:"Zwiebel",u:"Stk",a:"1"},{n:"Speck",u:"g",a:"50"},{n:"Butter",u:"g",a:"100"},{n:"Milch",u:"l",a:"0.75"},{n:"Mehl",u:"g",a:"75"},{n:"Muskat",u:"",a:""}],st:[{s:1,n:"Gemüse und Bratwurst klein schneiden",d:"Das Gemüse (Möhren, Staudensellerie, Zwiebeln und Knoblauch) putzen und in sehr kleine Würfel schneiden. Vom Schinken evtl. die harte Haut entfernen. Den Rest ebenso sehr fein würfeln. Eine Bratwurst klein hacken."},{s:2,n:"Bratwurst und Hackfleisch anbraten",d:"Einen großen Topf mit etwas Öl erhitzen, die Bratwurstwürfel kurz anbraten. Danach den Schinken hinzugeben und weitere 2 Minuten später das Gemüse unter Rühren anschwitzen. Das Hackfleisch hinzufügen, bevor alles angebräunt ist und gleichmäßig anbraten"},{s:2,n:"Bratwurst und Hackfleisch anbraten",d:"Einen großen Topf mit etwas Öl erhitzen, die Bratwurstwürfel kurz anbraten. Danach den Schinken hinzugeben und weitere 2 Minuten später das Gemüse unter Rühren anschwitzen. Das Hackfleisch hinzufügen, bevor alles angebräunt ist und gleichmäßig anbraten"},{s:3,n:"Hackfleischmischung zur Soße verarbeiten",d:"Mit Rotwein ablöschen, einkochen und die Dosentomaten hinzufügen. Mit Salz, Pfeffer, 1 Nelke, 1 EL Oregano, Basilikum, Lorbeerblat und etwas Zimt (nach Geschmack) würzen. Etwas heißes Wasser dazu geben und bei niedriger Flamme ca. 1 Stunde köcheln lassen. Zum Schluss nochmals abschmecken und ggfs. nachwürzen. Die Sauce darf ruhig noch etwas \\feucht\\ sein, bringt sie doch so einen saftigen Geschmack in die Lasagne. Während dessen wird die Bechamelsauce nach diesem Rezept zubereitet."},{s:3,n:"Hackfleischmischung zur Soße verarbeiten",d:"Mit Rotwein ablöschen, einkochen und die Dosentomaten hinzufügen. Mit Salz, Pfeffer, 1 Nelke, 1 EL Oregano, Basilikum, Lorbeerblat und 